                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#PriceSpecification"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#SpecialOffer"/>
                </owl:unionOf>
