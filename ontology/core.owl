        </rdfs:range>
        <rdfs:comment xml:lang="es">Clasificación de las vías de una ruta, organizada o no, en función del tipo de itinerario y el entorno en el que se emplaza.</rdfs:comment>
        <rdfs:comment xml:lang="en">Classification of the paths used along a route, whether organized or not, based on the type of itinerary and the environment in which they are located.</rdfs:comment>
        <rdfs:label xml:lang="es">tipo de camino</rdfs:label>
        <rdfs:label xml:lang="en">trail type</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#transportInfrastructureContains -->

