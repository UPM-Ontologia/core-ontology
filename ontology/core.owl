    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TraditionalMarket">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AgrotourismFacility"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">An area made up of individual stalls that offer products of various kinds with a predominance of fresh products: meat, fruits, vegetables, fish, etc.</rdfs:comment>
        <rdfs:comment xml:lang="es">Recinto formado por puestos individuales que ofrecen productos de diversa índole con predominancia de los productos frescos: carne, frutas, verduras, pescado, etc.</rdfs:comment>
        <rdfs:label xml:lang="es">Mercado tradicional</rdfs:label>
        <rdfs:label xml:lang="en">Traditional market</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Trail -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Trail">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="en">Road, path or path that is characterized by being very small and narrow and that is generally found in rural areas</rdfs:comment>
        <rdfs:comment xml:lang="es">Vía, senda o camino que se caracteriza por ser muy pequeña y angosta y que por lo general se encuentran en las zonas rurales.</rdfs:comment>
        <rdfs:label xml:lang="es">Sendero</rdfs:label>
        <rdfs:label xml:lang="en">Trail</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TrainStation -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TrainStation">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#transportInfrastructureContains"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Instalación ferroviaria con vías a la que pueden llegar y desde la que se pueden expedir trenes.</rdfs:comment>
        <rdfs:comment xml:lang="en">Railway facility with tracks that can be reached and from which trains can be dispatched.</rdfs:comment>
        <rdfs:label xml:lang="es">Estación de tren</rdfs:label>
        <rdfs:label xml:lang="en">Train station</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Place"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalTransportInfrastructureService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#additionalClassification"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Instalaciones físicas que permiten el movimiento de personas de un lugar a otro. Proporcionan las vías, conexiones y recursos necesarios para el transporte terrestre, aéreo, marítimo y ferroviario, facilitando la movilidad tanto a nivel local como global.</rdfs:comment>
        <rdfs:comment xml:lang="en">Physical facilities that allow the movement of people from one place to another. They provide the roads, connections and resources necessary for land, air, sea and rail transportation, facilitating mobility both locally and globally.</rdfs:comment>
        <rdfs:label xml:lang="es">Infraestructura de transporte</rdfs:label>
        <rdfs:label xml:lang="en">Transport infrastructure</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TransportService -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TransportService">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offeredBy"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#PassengerTransportCompany"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Passenger transport service between a predefined origin and destination, carried out using a specific means of transport and following a set route.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicio de desplazamiento de pasajeros entre un origen y un destino previamente definidos, realizado mediante un medio de transporte concreto y conforme a un recorrido establecido.</rdfs:comment>
        <rdfs:label xml:lang="es">Servicio de transporte</rdfs:label>
        <rdfs:label xml:lang="en">Transport service</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TravelAgency -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TravelAgency">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismIntermediary"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalTravelAgencyService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A private retailer that provides travel and tourism related services to the public on behalf of suppliers such as activities, airlines, car rentals, cruise lines, hotels, railways, travel insurance, and package tours.</rdfs:comment>
        <rdfs:comment xml:lang="es">Minorista privado que ofrece al público servicios relacionados con los viajes y el turismo en nombre de proveedores tales como actividades, aerolíneas, alquiler de coches, líneas de cruceros, hoteles, ferrocarriles, seguros de viaje y paquetes turísticos.</rdfs:comment>
        <rdfs:label xml:lang="es">Agencia de viajes</rdfs:label>
        <rdfs:label xml:lang="en">Travel agency</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#UndergroundWineCellar -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#UndergroundWineCellar">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AgrotourismFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalWineTourismFacilityService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A cellar, cave or underground winery with high humidity and a constant temperature throughout the year, used for maturing and ageing wines</rdfs:comment>
        <rdfs:comment xml:lang="es">Cava, cueva o bodega subterránea con mucha humedad ambiente y temperatura constante todo el año que se utiliza para criar y envejecer vinos</rdfs:comment>
        <rdfs:label xml:lang="es">Calado</rdfs:label>
        <rdfs:label xml:lang="en">Underground wine cellar</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#UrbanViewPoint -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#UrbanViewPoint">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">An urban viewpoint from which the city can be enjoyed from a unique perspective, whether from the top of a building or a hillside.</rdfs:comment>
        <rdfs:comment xml:lang="es">Lugar para disfrutar de las vistas de una ciudad desde una perspectiva única, desde la cima de un edificio o de una colina.</rdfs:comment>
        <rdfs:label xml:lang="es">Mirador urbano</rdfs:label>
        <rdfs:label xml:lang="en">Urban viewpoint</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VATRefund -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VATRefund">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FinancialService"/>
        <rdfs:comment xml:lang="en">Companies specialized in managing the return of Value Added Tax (VAT) to tourists or foreign visitors.</rdfs:comment>
        <rdfs:comment xml:lang="es">Compañías especializadas en la gestión de la devolución del Impuesto al Valor Agregado (IVA) a los turistas o visitantes extranjeros.</rdfs:comment>
        <rdfs:label xml:lang="es">Devolución de IVA</rdfs:label>
        <rdfs:label xml:lang="en">VAT refund</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VacationRental -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VacationRental">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
        <rdfs:comment xml:lang="en">Complete properties (flats, chalets, townhouses...) that are regularly rented for tourist, vacation or leisure purposes.</rdfs:comment>
        <rdfs:comment xml:lang="es">Inmuebles completos (pisos, chalets, adosados…) que se alquilan de forma habitual con fines turísticos, vacacionales o de ocio.</rdfs:comment>
        <rdfs:label xml:lang="en">Vacation rental</rdfs:label>
        <rdfs:label xml:lang="es">Vivienda de uso turístico</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Valley -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Valley">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#naturalResourceContains"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Llanura entre montes o alturas</rdfs:comment>
        <rdfs:comment xml:lang="en">Plain between mountains or heights</rdfs:comment>
        <rdfs:label xml:lang="es">Valle</rdfs:label>
        <rdfs:label xml:lang="en">Valley</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VehicleExperience -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VehicleExperience">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPriceClass"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#vehicleExperienceType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Servicio turístico que ofrece el uso temporal de un vehículo durante un periodo concreto, generalmente vinculado a una actividad recreativa o de ocio.</rdfs:comment>
        <rdfs:comment xml:lang="en">Tourism service that provides the temporary use of a vehicle for a specific period, generally linked to a recreational or leisure activity.</rdfs:comment>
        <rdfs:label xml:lang="es">Experiencia en vehículo</rdfs:label>
        <rdfs:label xml:lang="en">Vehicle experience</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VehicleRentalAgency -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VehicleRentalAgency">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalTourismOrRelatedFacilityService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalVehicleRentalAgencyService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#vehicleType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Facility offering temporary vehicle hire, allowing free and autonomous use for travel.</rdfs:comment>
        <rdfs:comment xml:lang="es">Instalación que ofrece el alquiler temporal de vehículos, permitiendo su uso libre y autónomo para desplazarse.</rdfs:comment>
        <rdfs:label xml:lang="es">Agencia de alquiler de vehículos</rdfs:label>
        <rdfs:label xml:lang="en">Vehicle rental agency</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VehicleRentalCompany -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VehicleRentalCompany">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PassengerTransportCompany"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalVehicleRentalAgencyService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#vehicleType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Commercial entity dedicated to providing short-term vehicle rental services to travelers who need a temporary means of transportation.</rdfs:comment>
        <rdfs:comment xml:lang="es">Entidad comercial que se dedica a proporcionar servicios de alquiler de vehículos a corto plazo a viajeros que necesitan un medio de transporte temporal.</rdfs:comment>
        <rdfs:label xml:lang="es">Empresa de alquiler de vehículos</rdfs:label>
        <rdfs:label xml:lang="en">Vehicle rental company</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VehicleWorkshop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VehicleWorkshop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MiscellaneousBusiness"/>
        <rdfs:comment xml:lang="es">Establecimiento donde se reparan las averías de los automóviles.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment where automobile breakdowns are repaired.</rdfs:comment>
        <rdfs:label xml:lang="es">Taller mecánico</rdfs:label>
        <rdfs:label xml:lang="en">Vehicle workshop</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VendingMachine -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VendingMachine">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#GroceriesService"/>
        <rdfs:comment xml:lang="en">Machine that provides snacks, drinks, candy and other products to consumers</rdfs:comment>
        <rdfs:comment xml:lang="es">Máquina que proporciona aperitivos, bebidas, golosinas y otros productos a los consumidores.</rdfs:comment>
        <rdfs:label xml:lang="es">Máquina expendedora</rdfs:label>
        <rdfs:label xml:lang="en">Vending machine</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VernacularArchitecture -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VernacularArchitecture">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="es">Construcciones tradicionales que reflejan las tradiciones y estilos arquitectónicos locales (masías, molinos, almazaras, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">Traditional buildings that reflect local architectural traditions and styles (such as farmhouses, mills, olive presses, etc.).</rdfs:comment>
        <rdfs:label xml:lang="es">Arquitectura vernácula</rdfs:label>
        <rdfs:label xml:lang="en">Vernacular architecture</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VeterinaryCare -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VeterinaryCare">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MedicalBusiness"/>
        <rdfs:comment xml:lang="es">Establecimiento con personal cualificado, registrado o autorizado por el organismo veterinario estatutario pertinente para ejercer la medicina/ciencia veterinaria en un país.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment with qualified personnel, registered or authorised by the relevant statutory veterinary body to practise veterinary medicine/science in a country.</rdfs:comment>
        <rdfs:label xml:lang="es">Atención veterinaria</rdfs:label>
        <rdfs:label xml:lang="en">Veterinary care</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Vineyard -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Vineyard">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AgrotourismFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalWineTourismFacilityService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Land intended for vine cultivation for grape production.</rdfs:comment>
        <rdfs:comment xml:lang="es">Terreno destinado al cultivo de la vid para la producción de uva.</rdfs:comment>
        <rdfs:label xml:lang="en">Vineyard</rdfs:label>
        <rdfs:label xml:lang="es">Viñedo</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VineyardHouse -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VineyardHouse">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#VernacularArchitecture"/>
        <rdfs:comment xml:lang="es">Construcción tradicional situada entre viñedos que, siguiendo un modelo arquitectónico funcional, sirve para llevar a cabo las labores de la viña, el soleo y pisado de la uva, ocupando el lagar, el espacio principal de la casa</rdfs:comment>
        <rdfs:comment xml:lang="en">Traditional building located among vineyards which, following a functional architectural model, is used to carry out vineyard work, the sun-drying and treading of the grapes. The winepress, the main space of the house, occupies the central area.</rdfs:comment>
        <rdfs:label xml:lang="es">Casa de viña</rdfs:label>
        <rdfs:label xml:lang="en">Vineyard house</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VineyardShelter -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VineyardShelter">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#VernacularArchitecture"/>
        <rdfs:comment xml:lang="es">Pequeña edificación construida tradicionalmente en piedra y destinada al refugio del propio agricultor, al almacenamiento de sus herramientas y como puesto de vigilancia de las cosechas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Small building traditionally constructed in stone and used as a shelter for the farmer, for storing his tools and as a lookout post for the crops.</rdfs:comment>
        <rdfs:label xml:lang="es">Chozo</rdfs:label>
        <rdfs:label xml:lang="es">Guardaviña</rdfs:label>
        <rdfs:label xml:lang="en">Vineyard shelter</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Volcano -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Volcano">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="es">Abertura en la tierra, y más comúnmente en una montaña, por donde salen de tiempo en tiempo humo, llamas y materias encendidas o derretidas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Opening in the earth, and more commonly in a mountain, through which smoke, flames, and burning or melted matter emerge from time to time.</rdfs:comment>
        <rdfs:label xml:lang="en">Volcano</rdfs:label>
        <rdfs:label xml:lang="es">Volcán</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Wall -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Wall">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">A tall and robust structure, generally topped with a parapet, that surrounds a fortification, stronghold, or other site for defensive purposes.</rdfs:comment>
        <rdfs:comment xml:lang="es">Construcción alta y robusta, generalmente coronada por un parapeto, que rodea una fortificación, plaza fuerte u otro lugar para su defensa.</rdfs:comment>
        <rdfs:label xml:lang="es">Muralla</rdfs:label>
        <rdfs:label xml:lang="en">Wall</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Waterfall -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Waterfall">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="es">Caída desde cierta altura del agua de un río u otra corriente por el brusco desnivel del cauce.</rdfs:comment>
        <rdfs:comment xml:lang="en">Fall from a certain height of the water of a river or other stream due to the sudden drop in level of the channel.</rdfs:comment>
        <rdfs:label xml:lang="es">Cascada</rdfs:label>
        <rdfs:label xml:lang="en">Waterfall</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#WellnessSpa -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#WellnessSpa">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HealthAndWellnessFacility"/>
        <rdfs:comment xml:lang="es">Establecimiento dedicado a la prestación de tratamientos de spa o paquetes de tratamientos de bienestar en un espacio apartado con un ambiente relajante, para la promoción de la salud y el bienestar.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment dedicated to the provision of wellness spa treatments or treatment packages within a secluded space with a relaxing ambience, for the promotion of health and well-being.</rdfs:comment>
        <rdfs:label xml:lang="es">Spa</rdfs:label>
        <rdfs:label xml:lang="en">Wellness spa</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#WineBar -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#WineBar">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
        <rdfs:comment xml:lang="es">Establecimiento especializado en la venta y degustación de vinos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment specialized in the sale and tasting of wines.</rdfs:comment>
        <rdfs:label xml:lang="es">Bar de vinos</rdfs:label>
        <rdfs:label xml:lang="en">Wine bar</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#WinePress -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#WinePress">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#VernacularArchitecture"/>
        <rdfs:comment xml:lang="en">A vat where grapes were once trodden</rdfs:comment>
        <rdfs:comment xml:lang="es">Depósito donde antiguamente se pisaba la uva</rdfs:comment>
        <rdfs:label xml:lang="es">Lagar</rdfs:label>
        <rdfs:label xml:lang="en">Wine press</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#WineShop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#WineShop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AgrotourismFacility"/>
        <rdfs:comment xml:lang="es">Lugar donde se exponen, guardan, venden e incluso se catan o degustan distintas clases de vinos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place where different types of wines are exhibited, stored, sold and even tasted or tasted.</rdfs:comment>
        <rdfs:label xml:lang="es">Enoteca</rdfs:label>
        <rdfs:label xml:lang="es">Vinoteca</rdfs:label>
        <rdfs:label xml:lang="en">Wine shop</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Winery -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Winery">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AgrotourismFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalWineTourismFacilityService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A complex of facilities dedicated to the production, ageing, and marketing of wine. In many cases, wineries feature complementary facilities for tourism activities, such as tasting rooms, retail shops, and event venues.</rdfs:comment>
        <rdfs:comment xml:lang="es">Conjunto de instalaciones donde se elabora, cría y comercializa el vino. En ocasiones, las bodegas cuentan con instalaciones complementarias destinadas a la actividad turística (espacios de degustación, tienda, espacios para la realización de eventos, etc.)</rdfs:comment>
        <rdfs:label xml:lang="es">Bodega</rdfs:label>
        <rdfs:label xml:lang="en">Winery</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#WinterSportsResort -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#WinterSportsResort">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="en">A tourist center dedicated to skiing and other snow and mountain sports, comprising a coordinated system of mechanical ski lifts, slopes, and complementary facilities.</rdfs:comment>
        <rdfs:comment xml:lang="es">Centro turístico dedicado a la práctica del esquí y demás deportes de nieve y montaña, que forma un conjunto coordinado de medios de remonte mecánicos, pistas e instalaciones complementarias.</rdfs:comment>
        <rdfs:label xml:lang="es">Estación de deportes de invierno</rdfs:label>
        <rdfs:label xml:lang="en">Winter sports resort</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#YatchingHarbour -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#YatchingHarbour">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Instalación de amarre que ofrece refugio contra las inclemencias meteorológicas y proporciona un embarcadero y las instalaciones terrestres y acuáticas adecuadas para las embarcaciones y sus tripulaciones.</rdfs:comment>
        <rdfs:comment xml:lang="en">Mooring facility giving shelter against bad weather conditions and providing a landing stage and the appropriate land and water based facilities for craft and their crew</rdfs:comment>
        <rdfs:label xml:lang="es">Puerto deportivo</rdfs:label>
        <rdfs:label xml:lang="en">Yachting harbour</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#YogaCentre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#YogaCentre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HealthAndWellnessFacility"/>
        <rdfs:comment xml:lang="en">A dedicated space for the practice and teaching of physical, mental, and spiritual disciplines aimed at holistic wellness and personal balance.</rdfs:comment>
        <rdfs:comment xml:lang="es">Espacio dedicado a la práctica y enseñanza de disciplinas físicas, mentales y espirituales orientadas al bienestar integral y el equilibrio personal.</rdfs:comment>
        <rdfs:label xml:lang="es">Centro de yoga</rdfs:label>
        <rdfs:label xml:lang="en">Yoga centre</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Zoo -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Zoo">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="en">A facility dedicated to the conservation, care, and occasionally the breeding of diverse animal species for public exhibition and scientific study.</rdfs:comment>
        <rdfs:comment xml:lang="es">Lugar en que se conservan, cuidan y en ocasiones se crían diversas especies animales para que sean contempladas por el público y para su estudio.</rdfs:comment>
        <rdfs:label xml:lang="en">Zoo</rdfs:label>
        <rdfs:label xml:lang="es">Zoológico</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://id.loc.gov/vocabulary/iso639-2 -->

    <owl:NamedIndividual rdf:about="https://id.loc.gov/vocabulary/iso639-2">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="es">Idioma en el que el evento o servicio turístico ofrecido puede presentarse, comunicarse o utilizarse, ya sea de forma oral, escrita o interactiva.</rdfs:comment>
        <rdfs:comment xml:lang="en">Language in which the event or tourism service offered can be presented, communicated, or used, whether orally, in written form, or interactively.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/iso639-2.nt"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/AccommodationRateType -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/AccommodationRateType">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">Rates applicable specifically to accommodation establishments and lodging services.</rdfs:comment>
        <rdfs:comment xml:lang="es">Tarifas aplicables específicamente a establecimientos alojativos y servicios de hospedaje.</rdfs:comment>
        <rdfs:label xml:lang="en">Accommodation rate type</rdfs:label>
        <rdfs:label xml:lang="es">Tipo de tarifa de alojamiento</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-AccommodationRateType.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/AccommodationRatingSystem -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/AccommodationRatingSystem">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">Grading or classification scheme system providing an assessment of the facilities, services or both provided by tourist accommodation. Typically within five categories, often indicated by one to five symbols.</rdfs:comment>
        <rdfs:comment xml:lang="es">Sistema de clasificación o categorización que evalúa las instalaciones, los servicios o ambos aspectos de los alojamientos turísticos. Normalmente se divide en cinco categorías, que suelen indicarse con uno a cinco símbolos.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-AccommodationRatingSystem.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/AccommodationUnitCategory -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/AccommodationUnitCategory">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="es">Tipo de unidad de alojamiento que se ofrece a los huéspedes y en la que se les proporcionan, como mínimo, camas y servicios de higiene.</rdfs:comment>
        <rdfs:comment xml:lang="en">Type of accommodation unit offered to guests, in which they are provided with, at least, sleeping and sanitary facilities.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-AccommodationUnitCategory.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/AdditionalAccommodationService -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/AdditionalAccommodationService">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">Complementary or additional services that an accommodation establishment may offer alongside its main service or activity in order to enhance or improve the user experience.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicios complementarios o adicionales que puede ofrecer un establecimiento alojativo junto a su servicio o actividad principal para ampliar o mejorar la experiencia del usuario.</rdfs:comment>
        <rdfs:label xml:lang="en">Additional accommodation service</rdfs:label>
        <rdfs:label xml:lang="es">Servicio adicional del alojamiento</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-AdditionalAccommodationService.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/AdditionalDMCService -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/AdditionalDMCService">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">Complementary or additional services that a destination management company may offer alongside its main service or activity in order to enhance or improve the user experience.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicios complementarios o adicionales que puede ofrecer un operador receptivo junto a su servicio o actividad principal para ampliar o mejorar la experiencia del usuario.</rdfs:comment>
        <rdfs:label xml:lang="en">Additional DMC service</rdfs:label>
        <rdfs:label xml:lang="es">Servicio adicional del operador receptivo</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-AdditionalDMCService.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/AdditionalEducationalFacilityService -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/AdditionalEducationalFacilityService">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">Complementary or additional services that an educational facility may offer alongside its main service or activity in order to enhance or improve the user experience.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicios complementarios o adicionales que puede ofrecer una instalación educativa junto a su servicio o actividad principal para ampliar o mejorar la experiencia del usuario.</rdfs:comment>
        <rdfs:label xml:lang="en">Additional educational facility service</rdfs:label>
        <rdfs:label xml:lang="es">Servicio adicional de la instalación educativa</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-AdditionalEducationalFacilityService.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/AdditionalEventAttendanceFacilityService -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/AdditionalEventAttendanceFacilityService">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">Complementary or additional services that an event attendance facility may offer alongside its main service or activity in order to enhance or improve the user experience.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicios complementarios o adicionales que puede ofrecer una instalación para eventos junto a su servicio o actividad principal para ampliar o mejorar la experiencia del usuario.</rdfs:comment>
        <rdfs:label xml:lang="en">Additional event attendance facility service</rdfs:label>
        <rdfs:label xml:lang="es">Servicio adicional de la instalación para eventos</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-AdditionalEventAttendanceFacilityService.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/AdditionalFoodEstablishmentService -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/AdditionalFoodEstablishmentService">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">Complementary or additional services that a food establishment may offer alongside its main service or activity in order to enhance or improve the user experience.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicios complementarios o adicionales que puede ofrecer un establecimiento de restauración junto a su servicio o actividad principal para ampliar o mejorar la experiencia del usuario.</rdfs:comment>
        <rdfs:label xml:lang="en">Additional food establishment service</rdfs:label>
        <rdfs:label xml:lang="es">Servicio adicional del establecimiento de restauración</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-AdditionalFoodEstablishmentService.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/AdditionalHistoricalOrCulturalResourceService -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/AdditionalHistoricalOrCulturalResourceService">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">Complementary or additional services that a historical or cultural resource may offer alongside its main service or activity in order to enhance or improve the user experience.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicios complementarios o adicionales que puede ofrecer un recurso histórico o cultural junto a su servicio o actividad principal para ampliar o mejorar la experiencia del usuario.</rdfs:comment>
        <rdfs:label xml:lang="es">Additional historical or cultural resource service</rdfs:label>
        <rdfs:label xml:lang="en">Servicio adicional del recurso histórico o cultural</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-AdditionalHistoricalOrCulturalResourceService.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/AdditionalLeisureAndCultureFacilityService -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/AdditionalLeisureAndCultureFacilityService">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">Complementary or additional services that a leisure and culture facility may offer alongside its main service or activity in order to enhance or improve the user experience.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicios complementarios o adicionales que puede ofrecer una instalación de cultura y ocio junto a su servicio o actividad principal para ampliar o mejorar la experiencia del usuario.</rdfs:comment>
        <rdfs:label xml:lang="en">Additional leisure and culture facility service</rdfs:label>
        <rdfs:label xml:lang="es">Servicio adicional de instalación de ocio y cultura</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-AdditionalLeisureAndCultureFacilityService.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/AdditionalPartyAndEntertainmentFacilityService -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/AdditionalPartyAndEntertainmentFacilityService">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">Complementary or additional services that a party and entertainment facility may offer alongside its main service or activity in order to enhance or improve the user experience.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicios complementarios o adicionales que puede ofrecer una instalación para fiestas y entretenimiento junto a su servicio o actividad principal para ampliar o mejorar la experiencia del usuario.</rdfs:comment>
        <rdfs:label xml:lang="en">Additional party and entertainment facility service</rdfs:label>
        <rdfs:label xml:lang="es">Servicio adicional de la instalación para fiestas y entretenimiento</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-AdditionalPartyAndEntertainmentFacilityService.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/AdditionalPetAccommodationService -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/AdditionalPetAccommodationService">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">Complementary or additional services that an accommodation establishment may offer alongside its main service or activity in order to enhance or improve the experience of a tourist with pets.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicios complementarios o adicionales que puede ofrecer un establecimiento alojativo junto a su servicio o actividad principal para ampliar o mejorar la experiencia del turista con mascotas.</rdfs:comment>
        <rdfs:label xml:lang="en">Additional pet accommodation service</rdfs:label>
