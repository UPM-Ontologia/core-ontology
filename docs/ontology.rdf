        <rdfs:label xml:lang="es">Servicio turístico</rdfs:label>
        <rdfs:label xml:lang="en">Tourism Service</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Tourist -->


    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Tourist">
