            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#numberOfPetsAllowedPerService"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#passportOrAnimalHealthCertificatedRequired"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#petAdmissionFee"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#petPermanenceInTravelContainerRequired"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#petWeightLimitation"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Criteria for permitting or restricting pets from entering certain places.</rdfs:comment>
        <rdfs:comment xml:lang="es">Criterio de permisión o restricción para el ingreso de mascotas a ciertos lugares.</rdfs:comment>
        <rdfs:label xml:lang="en">Pet admission policy</rdfs:label>
        <rdfs:label xml:lang="es">Política de admisión de mascotas</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PetDayCare -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PetDayCare">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MiscellaneousBusiness"/>
        <rdfs:comment xml:lang="en">A place where owners can leave their pets when they are away.</rdfs:comment>
        <rdfs:comment xml:lang="es">Lugar donde los dueños puedan dejar a sus mascotas cuando están fuera.</rdfs:comment>
        <rdfs:label xml:lang="es">Guardería de mascotas</rdfs:label>
        <rdfs:label xml:lang="en">Pet day care</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PetGroomingSalon -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PetGroomingSalon">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MiscellaneousBusiness"/>
        <rdfs:comment xml:lang="en">Commercial establishment where pets can be bathed, brushed, trimmed, or groomed.</rdfs:comment>
        <rdfs:comment xml:lang="es">Establecimiento comercial en el que se puede bañar, cepillar, recortar o peinar a una mascota.</rdfs:comment>
        <rdfs:label xml:lang="es">Peluquería de mascotas</rdfs:label>
        <rdfs:label xml:lang="en">Pet grooming salon</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PetShipper -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PetShipper">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MiscellaneousBusiness"/>
        <rdfs:comment xml:lang="en">An organisation dedicated to the professional transport of animals, guaranteeing their care during transit.</rdfs:comment>
        <rdfs:comment xml:lang="es">Entidad que se dedica al transporte profesional de animales, garantizando su cuidado durante el desplazamiento.</rdfs:comment>
        <rdfs:label xml:lang="en">Pet shipper</rdfs:label>
        <rdfs:label xml:lang="es">Transportista de mascotas</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PetShop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PetShop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashionBusiness"/>
        <rdfs:comment xml:lang="es">Comercio al por menor dedicado a la venta de productos para mascotas como alimentos, juguetes, golosinas, cepillos y accesorios para mascotas en general.</rdfs:comment>
        <rdfs:comment xml:lang="en">Retail business dedicated to the sale of pet products such as food, toys, treats, brushes, and general pet accessories.</rdfs:comment>
        <rdfs:label xml:lang="en">Pet shop</rdfs:label>
        <rdfs:label xml:lang="es">Tienda para mascotas</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PetTransportPolicy -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PetTransportPolicy">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#travelContainerType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#brachycephalicPetsAllowed"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#minimumBookingTime"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#numberOfPetsAllowedPerTravelContainer"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#petsInHeatAllowed"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#travelContainerSize"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Criteria for permitting or restricting passenger transport companies from transporting pets.</rdfs:comment>
        <rdfs:comment xml:lang="es">Criterio de permisión o restricción de las empresas de transporte de viajeros para el traslado con mascotas.</rdfs:comment>
        <rdfs:label xml:lang="en">Pet transport policy</rdfs:label>
        <rdfs:label xml:lang="es">Política de transporte con mascotas</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Pharmacy -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Pharmacy">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MedicalBusiness"/>
        <rdfs:comment xml:lang="en">A healthcare establishment where medicines are prepared, stored, and dispensed, while also offering health products and professional medical advice.</rdfs:comment>
        <rdfs:comment xml:lang="es">Establecimiento sanitario donde se preparan, conservan y dispensan medicamentos, además de ofrecer productos de parafarmacia y asesoramiento profesional sobre salud.</rdfs:comment>
        <rdfs:label xml:lang="es">Farmacia</rdfs:label>
        <rdfs:label xml:lang="en">Pharmacy</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Place -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Place">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalInformation"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#AdditionalInformation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasContactPoint"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#ContactPoint"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasOpeningHours"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#OpeningHours"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#nearTo"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Place"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#relatedTo"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasLocation"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#keyword"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#name"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es"> Cualquier punto de interés.</rdfs:comment>
        <rdfs:comment xml:lang="en">Any point of interest.</rdfs:comment>
        <rdfs:label xml:lang="es">Lugar</rdfs:label>
        <rdfs:label xml:lang="en">Place</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Planetarium -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Planetarium">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="es">Estructura acondicionada para la proyección de espectáculos relacionados con la astronomía.</rdfs:comment>
        <rdfs:comment xml:lang="en">Structure equipped for the projection of shows related to astronomy.</rdfs:comment>
        <rdfs:label xml:lang="es">Planetario</rdfs:label>
        <rdfs:label xml:lang="en">Planetarium</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Playground -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Playground">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:comment xml:lang="es">Espacio recreativo enfocado a los niños, que cuenta con juegos infantiles y que suele estar en espacios abiertos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Recreational space focused on children, which has children&apos;s games and is usually in open spaces.</rdfs:comment>
        <rdfs:label xml:lang="es">Parque infantil</rdfs:label>
        <rdfs:label xml:lang="en">Playground</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Playroom -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Playroom">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="es">Centro de recreo donde se guardan juegos y juguetes para su uso y préstamo</rdfs:comment>
        <rdfs:comment xml:lang="en">Recreation center where games and toys are stored for use and loan</rdfs:comment>
        <rdfs:label xml:lang="es">Ludoteca</rdfs:label>
        <rdfs:label xml:lang="en">Playroom</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PoliceStation -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PoliceStation">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:comment xml:lang="en">Building where police activities are centralized of a neighborhood or district under the command of a commissioner</rdfs:comment>
        <rdfs:comment xml:lang="es">Edificio donde se centralizan las actividades policiales de un barrio o distrito bajo el mando de un comisario.</rdfs:comment>
        <rdfs:label xml:lang="es">Comisaría de policía</rdfs:label>
        <rdfs:label xml:lang="en">Police station</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PortPassengerTerminal -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PortPassengerTerminal">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#transportInfrastructureContains"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Unidad establecida en un puerto o fuera de él, formada por obras, instalaciones y superficies, incluida su zona de agua, que permite la realización íntegra de la operación portuaria de tránsito de pasajeros, incluyendo el embarque y el desembarque de pasajeros y equipajes del buque al puerto.</rdfs:comment>
        <rdfs:comment xml:lang="en">Unit established in a port or outside it, made up of works, facilities and surfaces, including its water area, that allows the full implementation of the port operation of passenger transit, including the boarding and disembarkation of passengers and luggage from the ship to the port.</rdfs:comment>
        <rdfs:label xml:lang="en">Port passenger terminal</rdfs:label>
        <rdfs:label xml:lang="es">Terminal portuaria de pasajeros</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PostOffice -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PostOffice">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:comment xml:lang="es">Establecimiento encargado de enviar, recibir, ordenar, manejar, transmitir y entregar el correo. En algunas de ellas se ofrecen servicios como formularios, giros de dinero, cambio de monedas y servicios bancarios, entre otros.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment responsible for sending, receiving, sorting, handling, transmitting and delivering mail. Some of them offer services such as forms, money transfers, currency exchange and banking services, among others</rdfs:comment>
        <rdfs:label xml:lang="es">Oficina de correos</rdfs:label>
        <rdfs:label xml:lang="en">Post office</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PriceSpecification -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PriceSpecification">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#priceSchedule"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Schedule"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#eligibleQuantity"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#isAccessibleForFree"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#maxPrice"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#minPrice"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#petDeposit"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#petFee"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#price"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#priceCurrency"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#taxesAndFeesIncluded"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Coste total del producto o servicio que puede incluir impuestos, cargos o reducciones en las tarifas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Total cost of the product or service that may include taxes, charges, or rate reductions.</rdfs:comment>
        <rdfs:label xml:lang="es">Especificación del precio</rdfs:label>
        <rdfs:label xml:lang="en">Price specification</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PrimaryCare -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PrimaryCare">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:comment xml:lang="en">Building where the population is served at a first level of health care</rdfs:comment>
        <rdfs:comment xml:lang="es">Edificio donde se atiende a la población en un primer nivel asistencial sanitario</rdfs:comment>
        <rdfs:label xml:lang="es">Centro de atención primaria</rdfs:label>
        <rdfs:label xml:lang="en">Primary care</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PrivateHireCompany -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PrivateHireCompany">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PassengerTransportCompany"/>
        <rdfs:comment xml:lang="en">Company that provides passenger transportation services using private vehicles and professional drivers.</rdfs:comment>
        <rdfs:comment xml:lang="es">Empresa que proporciona servicios de transporte de pasajeros utilizando vehículos privados y conductores profesionales.</rdfs:comment>
        <rdfs:label xml:lang="es">Empresa VTC</rdfs:label>
        <rdfs:label xml:lang="en">Private hire company</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PrivateHospital -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PrivateHospital">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MedicalBusiness"/>
        <rdfs:comment xml:lang="es">Establecimiento destinado al diagnóstico y tratamiento de enfermos, cuya financiación corre a cargo de los propios pacientes, de las aseguradoras o de embajadas extranjeras.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment intended for the diagnosis and treatment of patients, whose financing is provided by the patients themselves, by insurance companies or by foreign embassies.</rdfs:comment>
        <rdfs:label xml:lang="es">Hospital privado</rdfs:label>
        <rdfs:label xml:lang="en">Private hospital</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Promotion -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Promotion">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PriceSpecification"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasDescription"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Description"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#name"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#finalPrice"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#discount"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Advertising campaign carried out on a specific product or service for a limited time through an attractive offer.</rdfs:comment>
        <rdfs:comment xml:lang="es">Campaña publicitaria que se hace de un determinado producto o servicio durante un tiempo limitado mediante una oferta atractiva.</rdfs:comment>
        <rdfs:label xml:lang="es">Promoción</rdfs:label>
        <rdfs:label xml:lang="en">Promotion</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Pub -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Pub">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PartyAndEntertainmentFacility"/>
        <rdfs:comment xml:lang="es">Establecimiento donde se sirven y consumen bebidas alcohólicas. Se diferencia de un bar por la decoración, el horario de apertura y el tipo de bebidas y comida que se sirve.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment where alcoholic beverages are served and consumed. It is differentiated from a bar based on the decoration, opening times and type of beverages and food served.</rdfs:comment>
        <rdfs:label xml:lang="en">Pub</rdfs:label>
        <rdfs:label xml:lang="es">Pub</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PublicHospital -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicHospital">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:comment xml:lang="es">Establecimiento financiado con fondos estatales destinado al diagnóstico y tratamiento de enfermos, donde a menudo se practican la investigación y la docencia.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment financed by state funds for the diagnosis and treatment of patients, where research and teaching are often practiced</rdfs:comment>
        <rdfs:label xml:lang="es">Hospital público</rdfs:label>
        <rdfs:label xml:lang="en">Public hospital</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PublicRestroom -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicRestroom">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#adaptedPublicRestroom"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Habitación o edificación pequeña con uno o más inodoros para uso del público en general.</rdfs:comment>
        <rdfs:comment xml:lang="en">Room or small building with one or more toilets for use by the general public</rdfs:comment>
        <rdfs:label xml:lang="es">Baño público</rdfs:label>
        <rdfs:label xml:lang="en">Public restroom</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PublicService -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicService">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Place"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAcknowledgement"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Acknowledgement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#additionalClassification"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A publicly accessible physical or institutional entity serving a civic function that supports community life and governance.</rdfs:comment>
        <rdfs:comment xml:lang="es">Entidad física o institucional de acceso público que desempeña una función cívica y apoya la vida comunitaria y la gobernanza.</rdfs:comment>
        <rdfs:label xml:lang="en">Public service</rdfs:label>
        <rdfs:label xml:lang="es">Servicio público</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PublicTransportStop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicTransportStop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#stationType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#publicTransportStopCode"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#publicTransportStopZone"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A specific and marked location on an established route where vehicles (such as buses, trams, or trains) stop regularly to allow passengers to board or get off.</rdfs:comment>
        <rdfs:comment xml:lang="es">Lugar específico y señalizado en una ruta establecida donde los vehículos (como autobuses, tranvías o trenes) se detienen regularmente para permitir que los pasajeros suban o bajen.</rdfs:comment>
        <rdfs:label xml:lang="es">Parada de transporte público</rdfs:label>
        <rdfs:label xml:lang="en">Public transport stop</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Quarter -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Quarter">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#historicalOrCulturalResourceContains"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A group of streets in a city that offer tourist attractions of interest, usually related to a specific theme</rdfs:comment>
        <rdfs:comment xml:lang="es">Conjunto de calles de una ciudad que alberga oferta turística de interés, habitualmente relacionada con un tema</rdfs:comment>
        <rdfs:label xml:lang="es">Barrio</rdfs:label>
        <rdfs:label xml:lang="en">Quarter</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Racetrack -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Racetrack">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Lugar destinado a carreras de caballos</rdfs:comment>
        <rdfs:comment xml:lang="en">Place for horse racing</rdfs:comment>
        <rdfs:label xml:lang="es">Hipódromo</rdfs:label>
        <rdfs:label xml:lang="en">Race track</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Reservoir -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Reservoir">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="en">Accumulation of water produced by a construction in the bed of a river or stream that partially or totally closes its channel</rdfs:comment>
        <rdfs:comment xml:lang="es">Acumulación de agua producida por una construcción en el lecho de un río o arroyo que cierra parcial o totalmente su cauce.</rdfs:comment>
        <rdfs:label xml:lang="es">Embalse</rdfs:label>
        <rdfs:label xml:lang="en">Reservoir</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Residence -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Residence">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
        <rdfs:comment xml:lang="en">Accommodation establishment offering extended stays, in many cases on a semi-permanent or temporary basis, with services similar to those of a household.</rdfs:comment>
        <rdfs:comment xml:lang="es">Establecimiento alojativo que ofrece estancias prolongadas, en muchos casos con carácter semi-permanente o temporal, y con servicios similares a los de un hogar.</rdfs:comment>
        <rdfs:label xml:lang="en">Residence</rdfs:label>
        <rdfs:label xml:lang="es">Residencia</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Resort -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Resort">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#resortContains"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Lugar habilitado para el desarrollo de la actividad turística en el que se ofrece una gama amplia de servicios e instalaciones relacionadas con la hostelería, especialmente dedicadas al descanso y esparcimiento.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place enabled for the development of tourist activity in which a wide range of services and facilities related to hospitality are offered, especially dedicated to rest and recreation.</rdfs:comment>
        <rdfs:label xml:lang="es">Complejo turístico</rdfs:label>
        <rdfs:label xml:lang="en">Resort</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Restaurant -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Restaurant">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se preparan alimentos y bebidas en una cocina y se sirven a los clientes.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment where food and beverages are prepared in a kitchen and served to customers.</rdfs:comment>
        <rdfs:label xml:lang="en">Restaurant</rdfs:label>
        <rdfs:label xml:lang="es">Restaurante</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#RestaurantCompany -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#RestaurantCompany">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrganisation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasTourismOrRelatedFacility"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offers"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#FoodAndBeverageService"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Company that offers restaurant services</rdfs:comment>
        <rdfs:comment xml:lang="es">Empresa que se encarga de ofrecer servicios de restauración</rdfs:comment>
        <rdfs:label xml:lang="es">Empresa de restauración</rdfs:label>
        <rdfs:label xml:lang="en">Restaurant company</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#RetailAndFashionBusiness -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#RetailAndFashionBusiness">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LocalBusiness"/>
        <rdfs:comment xml:lang="es">Espacios físicos que ofrecen un lugar accesible y conveniente para que los consumidores adquieran diversos productos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Physical spaces that offer an accessible and convenient place for consumers to purchase various products.</rdfs:comment>
        <rdfs:label xml:lang="es">Negocio de comercio y moda</rdfs:label>
        <rdfs:label xml:lang="en">Retail and fashion business</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#River -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#River">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasRiverService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Continuous and more or less large current of water that flows into another, a lake or the sea</rdfs:comment>
        <rdfs:comment xml:lang="es">Corriente de agua continua y más o menos caudalosa que va a desembocar en otra, en un lago o en el mar.</rdfs:comment>
        <rdfs:label xml:lang="en">River</rdfs:label>
        <rdfs:label xml:lang="es">Río</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Route -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Route">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Place"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalRouteService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalTourismResourceService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasRulesAndTips"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#RulesAndTips"/>
