    <!-- https://ontologia.segittur.es/turismo/def/core#validity -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#validity">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#WeatherForecast"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">validez</rdfs:label>
        <rdfs:label xml:lang="en">validity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#video -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#video">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Multimedia"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">video</rdfs:label>
        <rdfs:label xml:lang="es">vídeo</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#visitduration -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#visitduration">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Tour"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TouristOrRelatedFacility"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">duración de la visita</rdfs:label>
        <rdfs:label xml:lang="en">visit duration</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#voltage -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#voltage">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#EVChargingStation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">voltage</rdfs:label>
        <rdfs:label xml:lang="es">voltaje</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#weatherType -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#weatherType">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#WeatherForecast"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">tipo de clima</rdfs:label>
        <rdfs:label xml:lang="en">weather type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#windDirection -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#windDirection">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#WeatherForecast"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">dirección del viento</rdfs:label>
        <rdfs:label xml:lang="en">wind direction</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#windSpeed -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#windSpeed">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#WeatherForecast"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">velocidad del viento</rdfs:label>
        <rdfs:label xml:lang="en">wind speed</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#zone -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#zone">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicTransportStop"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">zona</rdfs:label>
        <rdfs:label xml:lang="en">zone</rdfs:label>
    </owl:DatatypeProperty>
    


