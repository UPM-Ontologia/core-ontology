    "@value" : "Construcciones tradicionales que reflejan las tradiciones y estilos arquitectónicos locales (masías, molinos, almazaras, etc.)"
  }, {
    "@language" : "en",
    "@value" : "Traditional buildings that reflect local architectural traditions and styles (such as farmhouses, mills, olive presses, etc.)."
  } ],
