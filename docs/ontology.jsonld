  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Establecimiento encargado de enviar, recibir, ordenar, manejar, transmitir y entregar el correo. En algunas de ellas se ofrecen servicios como formularios, giros de dinero, cambio de monedas y servicios bancarios, entre otros."
  }, {
    "@language" : "en",
    "@value" : "Establishment responsible for sending, receiving, sorting, handling, transmitting and delivering mail. Some of them offer services such as forms, money transfers, currency exchange and banking services, among others"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Oficina de correos"
  }, {
    "@language" : "en",
    "@value" : "Post office"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
