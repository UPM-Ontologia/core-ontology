            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#routeNavigationOrientation"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#severityOfTheEnvironment"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#terrainConditions"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A path or direction that contains a series of places that must be passed through or stopped at to reach a destination.</rdfs:comment>
        <rdfs:comment xml:lang="es">Camino o dirección que contiene una serie de lugares por los que se debe pasar o detenerse para llegar a un destino.</rdfs:comment>
        <rdfs:label xml:lang="en">Route</rdfs:label>
        <rdfs:label xml:lang="es">Ruta</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Rule -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Rule">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RulesAndTips"/>
        <rdfs:comment xml:lang="es">Principio que se impone para dirigir la conducta, la correcta realización de una acción o el correcto desarrollo de una actividad.</rdfs:comment>
        <rdfs:comment xml:lang="en">Principle that is imposed to direct behavior, the correct performance of an action or the correct development of an activity.</rdfs:comment>
        <rdfs:label xml:lang="es">Regla</rdfs:label>
        <rdfs:label xml:lang="en">Rule</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#RulesAndTips -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#RulesAndTips">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#adversityType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasDescription"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Description"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#name"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#validFrom"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#validThrough"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A set of principles, standards and recommendations established by a tourism destination with the aim of ensuring a safe, respectful and satisfying experience for tourists, the local community and the environment.</rdfs:comment>
        <rdfs:comment xml:lang="es">Conjunto de principios, normas y recomendaciones que establece un destino turístico con el objetivo de garantizar una experiencia segura, respetuosa y satisfactoria tanto para los turistas como para la comunidad local y el entorno.</rdfs:comment>
        <rdfs:label xml:lang="es">Reglas y consejos</rdfs:label>
        <rdfs:label xml:lang="en">Rules and tips</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#RunningTrack -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#RunningTrack">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="en">Area in which the athletics discipline races are held.</rdfs:comment>
        <rdfs:comment xml:lang="es">Zona en la que se realizan las carreras de la disciplina de atletismo.</rdfs:comment>
        <rdfs:label xml:lang="es">Pista de atletismo</rdfs:label>
        <rdfs:label xml:lang="en">Running track</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#RuralHouse -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#RuralHouse">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
        <rdfs:comment xml:lang="es">Tipo de establecimiento extrahotelero ubicado en un inmueble situado en suelo rústico y de ámbito rural que dispone de una unidad alojativa y que cuenta con el equipamiento y las instalaciones necesarias para la conservación, manipulado y consumo de alimentos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Type of non-hotel establishment located in a property located on rustic land and in a rural area that has an accommodation unit and that has the equipment and facilities necessary for the conservation, handling and consumption of food.</rdfs:comment>
        <rdfs:label xml:lang="es">Agroturismo</rdfs:label>
        <rdfs:label xml:lang="es">Casa rural</rdfs:label>
        <rdfs:label xml:lang="en">Rural house</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Salina -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Salina">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="es">Lugar donde se deja evaporar agua salada para dejar solo la sal, secarla y recogerla luego para su utilización, consumo o venta.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place where salt water is allowed to evaporate to leave only the salt, dry it and then collect it for use, consumption or sale</rdfs:comment>
        <rdfs:label xml:lang="en">Salina</rdfs:label>
        <rdfs:label xml:lang="es">Salina</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Sanctuary -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Sanctuary">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">A place of worship where the image or relic of a highly venerated saint is revered.</rdfs:comment>
        <rdfs:comment xml:lang="es">Templo en que se venera la imagen o reliquia de un santo de especial devoción.</rdfs:comment>
        <rdfs:label xml:lang="es">Ermita</rdfs:label>
        <rdfs:label xml:lang="en">Sanctuary</rdfs:label>
        <rdfs:label xml:lang="es">Santuario</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Schedule -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Schedule">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#byDay"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#byMonth"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasDescription"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Description"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#byMonthDay"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#byMonthWeek"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Planificación temporal que define cuándo un servicio, evento u oferta se repite o se produce en intervalos específicos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Time-based plan that defines when a service, event, or offer occurs repeatedly or at specific intervals.</rdfs:comment>
        <rdfs:label xml:lang="es">Programación</rdfs:label>
        <rdfs:label xml:lang="en">Schedule</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ShootingRange -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ShootingRange">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="en">Areas designated for shooting practice that meet the required characteristics and safety standards.</rdfs:comment>
        <rdfs:comment xml:lang="es">Espacios habilitados para la práctica del tiro que reúnan las características y medidas de seguridad pertinentes.</rdfs:comment>
        <rdfs:label xml:lang="es">Campo de tiro</rdfs:label>
        <rdfs:label xml:lang="en">Shooting range</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ShoppingMall -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ShoppingMall">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashionBusiness"/>
        <rdfs:comment xml:lang="en">A complex comprising establishments dedicated to commercial, leisure, and food and beverage activities.</rdfs:comment>
        <rdfs:comment xml:lang="es">Complejo formado por establecimientos dedicados a actividades comerciales, de ocio y restauración.</rdfs:comment>
        <rdfs:label xml:lang="es">Centro comercial</rdfs:label>
        <rdfs:label xml:lang="en">Shopping mall</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#SingularTree -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#SingularTree">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="en">Tree that stands out among others due to its size, shape, age, rarity, biological origin, state of conservation, beauty or for being part of myths or traditions.</rdfs:comment>
        <rdfs:comment xml:lang="es">Árbol que destaca entre los demás por su tamaño, forma, edad, rareza, origen biológico, estado de conservación, belleza o por formar parte de mitos o tradiciones.</rdfs:comment>
        <rdfs:label xml:lang="en">Singular tree</rdfs:label>
        <rdfs:label xml:lang="es">Árbol singular</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#SkatePark -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#SkatePark">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Instalación deportiva diseñada específicamente para la práctica del monopatinaje.</rdfs:comment>
        <rdfs:comment xml:lang="en">Sports facility designed specifically for skateboarding.</rdfs:comment>
        <rdfs:label xml:lang="es">Parque de patinaje</rdfs:label>
        <rdfs:label xml:lang="en">Skatepark</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#SkatingRink -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#SkatingRink">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Superficie acondicionada y diseñada para la práctica del patinaje sobre ruedas o sobre hielo, dependiendo del tipo de pista.</rdfs:comment>
        <rdfs:comment xml:lang="en">Surface conditioned and designed for the practice of roller or ice skating, depending on the type of rink.</rdfs:comment>
        <rdfs:label xml:lang="es">Pista de patinaje</rdfs:label>
        <rdfs:label xml:lang="en">Skating rink</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#SocialMediaProfile -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#SocialMediaProfile">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#socialMediaPlatform"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#url"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Cuentas individuales o de empresas creadas en plataformas digitales diseñadas para la interacción social. Permiten a las personas y organizaciones compartir información, publicar contenido, interactuar con otros usuarios y construir una presencia en línea.</rdfs:comment>
        <rdfs:comment xml:lang="en">Individual or company accounts created on digital platforms designed for social interaction. They allow people and organizations to share information, publish content, interact with other users and build an online presence.</rdfs:comment>
        <rdfs:label xml:lang="es">Perfil en redes sociales</rdfs:label>
        <rdfs:label xml:lang="en">Social media profile</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Souvenir -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Souvenir">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashionBusiness"/>
        <rdfs:comment xml:lang="es">Establecimiento que vende objetos representativos de un lugar específico, destinados a que los turistas los compren como recuerdo de su viaje o para regalar.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment that sells items representing a specific location, intended for tourists to buy as memory of their trip or as gifts.</rdfs:comment>
        <rdfs:label xml:lang="en">Souvenirs</rdfs:label>
        <rdfs:label xml:lang="es">Tienda de souvenirs</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#SpecialOffer -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#SpecialOffer">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPriceSpecification"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#PriceSpecification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#relatedTourismOrRelatedFacility"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#touristType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#travelUnit"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offerSchedule"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#Schedule"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offeredBy"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismDestination"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrganisation"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Offer of products that vary from the regular offer of tourism service providers, including, but not limited to, plans, temporary price reductions, and free gifts or extra quantities.</rdfs:comment>
        <rdfs:comment xml:lang="es">Propuesta de productos que difieren de la oferta habitual de los proveedores de servicios turísticos, incluyendo, entre otros, planes, reducciones temporales de precios y obsequios o cantidades adicionales.</rdfs:comment>
        <rdfs:label xml:lang="es">Propuesta especial</rdfs:label>
        <rdfs:label xml:lang="en">Special offer</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#SportFacility -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#SportFacility">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalSportFacilityService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalTourismOrRelatedFacilityService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Espacios diseñados y equipados específicamente para brindar servicios y oportunidades relacionadas con actividades deportivas y recreativas para turistas, visitantes y residentes.</rdfs:comment>
        <rdfs:comment xml:lang="en">Spaces designed and equipped specifically to provide services and opportunities related to sports and recreational activities for tourists, visitors and residents.</rdfs:comment>
        <rdfs:label xml:lang="es">Instalación deportiva</rdfs:label>
        <rdfs:label xml:lang="en">Sport facility</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#SportingGoodsStore -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#SportingGoodsStore">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashionBusiness"/>
        <rdfs:comment xml:lang="en">Commercial establishment dedicated to the sale of sports-related goods, equipment, and materials, intended for the practice of sports, recreational activities, or active leisure.</rdfs:comment>
        <rdfs:comment xml:lang="es">Establecimiento comercial dedicado a la venta de artículos, equipamiento y material deportivo, destinados a la práctica de actividades deportivas, recreativas o de ocio activo.</rdfs:comment>
        <rdfs:label xml:lang="en">Sporting goods store</rdfs:label>
        <rdfs:label xml:lang="es">Tienda de equipamiento deportivo</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#SportsCentre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#SportsCentre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#sportsCentrePremises"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Lugar que dispone de diferentes instalaciones e infraestructuras para la práctica de disciplinas deportivas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place that has different facilities and infrastructure for practicing sports disciplines.</rdfs:comment>
        <rdfs:label xml:lang="es">Centro deportivo</rdfs:label>
        <rdfs:label xml:lang="es">Polideportivo</rdfs:label>
        <rdfs:label xml:lang="en">Sports centre</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Spring -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Spring">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="es">Corriente de agua que mana del suelo o de entre las rocas de forma natural.</rdfs:comment>
        <rdfs:comment xml:lang="en">Current of water that flows from the ground or between rocks naturally</rdfs:comment>
        <rdfs:label xml:lang="es">Manantial</rdfs:label>
        <rdfs:label xml:lang="en">Spring</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Square -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Square">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#historicalOrCulturalResourceContains"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A broad and open space within a town or city, into which several streets typically converge. It may also serve as a place where goods are sold, neighbors gather socially, and public fairs, markets, and festivities are held.</rdfs:comment>
        <rdfs:comment xml:lang="es">Lugar ancho y espacioso dentro de una población, al que suelen afluir varias calles. En ocasiones, en este lugar se venden artículos diversos, se tiene el trato común con los vecinos, y se celebran las ferias, los mercados y las fiestas públicas.</rdfs:comment>
        <rdfs:label xml:lang="es">Plaza</rdfs:label>
        <rdfs:label xml:lang="en">Square</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Stadium -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Stadium">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="en">Large venue with stands for spectators, intended for sports competitions.</rdfs:comment>
        <rdfs:comment xml:lang="es">Recinto de grandes dimensiones con graderías para los espectadores, destinado a competiciones deportivas.</rdfs:comment>
        <rdfs:label xml:lang="es">Estadio</rdfs:label>
        <rdfs:label xml:lang="en">Stadium</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Supermarket -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Supermarket">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#GroceriesService"/>
        <rdfs:comment xml:lang="es">Establecimiento comercial de venta al por menor en el que se expenden todo género de artículos alimenticios, bebidas, productos de limpieza, etc., y en el que el cliente se sirve y paga a la salida</rdfs:comment>
        <rdfs:comment xml:lang="en">Retail commercial establishment in which all types of food items, beverages, cleaning products, etc. are sold, and in which the customer is served and pays upon departure</rdfs:comment>
        <rdfs:label xml:lang="en">Supermarket</rdfs:label>
        <rdfs:label xml:lang="es">Supermercado</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Swamp -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Swamp">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="en">Sunken land with a more or less muddy bottom and abundant vegetation, where the water stagnates naturally</rdfs:comment>
        <rdfs:comment xml:lang="es">Terreno hundido de fondo más o menos cenagoso y abundante vegetación, donde las aguas se estancan de forma natural.</rdfs:comment>
        <rdfs:label xml:lang="es">Pantano</rdfs:label>
        <rdfs:label xml:lang="en">Swamp</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#SwimmingPool -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#SwimmingPool">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Construcción que contiene gran cantidad de agua y que se destina al baño, a la natación o a otros ejercicios y deportes acuáticos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Construction that contains a large amount of water and is intended for bathing, swimming or other water exercises and sports.</rdfs:comment>
        <rdfs:label xml:lang="es">Piscina</rdfs:label>
        <rdfs:label xml:lang="en">Swimming pool</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Synagogue -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Synagogue">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">A building dedicated to the gathering and worship practices of the Jewish faith.</rdfs:comment>
        <rdfs:comment xml:lang="es">Edificio dedicado a la congregación y culto de la religión judía.</rdfs:comment>
        <rdfs:label xml:lang="es">Sinagoga</rdfs:label>
        <rdfs:label xml:lang="en">Synagogue</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TailorShop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TailorShop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashionBusiness"/>
        <rdfs:comment xml:lang="en">A tailor&apos;s shop and workshop</rdfs:comment>
        <rdfs:comment xml:lang="es">Tienda y taller de sastre</rdfs:comment>
        <rdfs:label xml:lang="es">Sastrería</rdfs:label>
        <rdfs:label xml:lang="en">Tailorshop</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TakeAwayEstablishment -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TakeAwayEstablishment">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
        <rdfs:comment xml:lang="es">Establecimiento donde se preparan y venden alimentos listos para ser llevados y consumidos fuera del lugar de venta.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment where food is prepared and sold ready to be taken and consumed outside the place of sale.</rdfs:comment>
        <rdfs:label xml:lang="es">Casa de comidas para llevar</rdfs:label>
        <rdfs:label xml:lang="en">Take away establishment</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Tavern -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Tavern">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
        <rdfs:comment xml:lang="en">A popular public establishment where drinks are served and sold, as well as meals or appetizers.</rdfs:comment>
        <rdfs:comment xml:lang="es">Establecimiento público de carácter popular donde se sirven y expenden bebidas, además de ofrecer comidas o aperitivos.</rdfs:comment>
        <rdfs:label xml:lang="es">Taberna</rdfs:label>
        <rdfs:label xml:lang="en">Tavern</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TaxiStand -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TaxiStand">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:comment xml:lang="es">Lugar en que se detienen los taxis a la espera de pasajeros.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place where taxis stop waiting for passengers.</rdfs:comment>
        <rdfs:label xml:lang="es">Parada de taxis</rdfs:label>
        <rdfs:label xml:lang="en">Taxi stand</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TeaRoom -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TeaRoom">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
        <rdfs:comment xml:lang="en">An establishment specialized in the retail and service of teas and infusions of diverse origins.</rdfs:comment>
        <rdfs:comment xml:lang="es">Establecimiento especializado en la venta y servicio de tés e infusiones de distinta procedencia.</rdfs:comment>
        <rdfs:label xml:lang="en">Tea room</rdfs:label>
        <rdfs:label xml:lang="es">Tetería</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TelephoneShop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TelephoneShop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashionBusiness"/>
        <rdfs:comment xml:lang="es">Establecimiento de venta al por menor de artículos de telefonía, teléfonos móviles y accesorios.</rdfs:comment>
        <rdfs:comment xml:lang="en">Retail establishment of telephone items, mobile phones and accessories.</rdfs:comment>
        <rdfs:label xml:lang="en">Telephone shop</rdfs:label>
        <rdfs:label xml:lang="es">Tienda de telefonía</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TemporaryTouristInformationPoint -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TemporaryTouristInformationPoint">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#availableLanguage"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Espacio ubicado en lugares de máxima afluencia donde se ofrece información de interés al visitante.</rdfs:comment>
        <rdfs:comment xml:lang="en">Space located in places of maximum influx where information of interest to the visitor is offered</rdfs:comment>
        <rdfs:label xml:lang="es">Punto de información turística temporal</rdfs:label>
        <rdfs:label xml:lang="en">Temporary tourist information point</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TennisCourt -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TennisCourt">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="en">A rectangular surface adapted for tennis, divided by a central net and featuring various types of court surfaces depending on the style of play.</rdfs:comment>
        <rdfs:comment xml:lang="es">Superficie rectangular adaptada para la práctica del tenis, dividida por una red intermedia y acondicionada con diferentes tipos de pavimento según la modalidad de juego.</rdfs:comment>
        <rdfs:label xml:lang="es">Pista de tenis</rdfs:label>
        <rdfs:label xml:lang="en">Tennis court</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Terroir -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Terroir">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AgrotourismFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalWineTourismFacilityService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Areas of land where an indeterminate number of vineyards are located which, due to their location and microclimatic conditions, geological composition or terrain, share similar conditions and therefore produce grapes with distinctive characteristics that give rise to very unique wines, generally known as vinos de pago</rdfs:comment>
        <rdfs:comment xml:lang="es">Extensiones de terreno en las que se localizan un número indeterminado de viñas que -por razón de su situación y condiciones micro-climáticas, por su composición geológica o por su orografía- comparten condiciones similares y producen por ello uvas con características diferenciadas que dan lugar a unos vinos muy singulares, generalmente conocidos como vinos de pago</rdfs:comment>
        <rdfs:label xml:lang="es">Pago</rdfs:label>
        <rdfs:label xml:lang="en">Terroir</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Thalasso -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Thalasso">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HealthAndWellnessFacility"/>
        <rdfs:comment xml:lang="es">Instalación especializada en el uso terapéutico del agua de mar y del entorno marino con fines de bienestar y salud.</rdfs:comment>
        <rdfs:comment xml:lang="en">TA facility specialized in the therapeutic use of seawater and the marine environment for wellbeing and health purposes.</rdfs:comment>
        <rdfs:label xml:lang="es">Talaso</rdfs:label>
        <rdfs:label xml:lang="en">Thalasso</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Theater -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Theater">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="en">Building or site intended for the representation of dramatic works or other public spectacles typical of the scene.</rdfs:comment>
        <rdfs:comment xml:lang="es">Edificio o sitio destinado a la representación de obras dramáticas o a otros espectáculos públicos propios de la escena.</rdfs:comment>
        <rdfs:label xml:lang="es">Teatro</rdfs:label>
        <rdfs:label xml:lang="en">Theater</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TicketOrEntrance -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TicketOrEntrance">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offeredBy"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#ComplementaryActivitiesCompany"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">PServicio turístico que consiste en la emisión o venta de un ticket o entrada que otorga derecho de acceso, uso o participación en una actividad de una instalación turística o vinculada bajo unas condiciones y periodo determinados.</rdfs:comment>
        <rdfs:comment xml:lang="en">Tourism service consisting of the issuance or sale of a ticket or entrance that grants the right of access, use, or participation in an activity at a tourism or related facility under specific conditions and within a defined period.</rdfs:comment>
        <rdfs:label xml:lang="es">Ticket o entrada</rdfs:label>
        <rdfs:label xml:lang="en">Ticket or entrance</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TimeSlot -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TimeSlot">
        <rdfs:comment xml:lang="es">Intervalo temporal que define un periodo continuo de apertura, delimitado por una hora de inicio y una hora de finalización, y utilizado para describir tramos horarios dentro de un día concreto. </rdfs:comment>
        <rdfs:comment xml:lang="en">Time interval that defines a continuous period of opening, delimited by a start time and an end time, and used to describe time ranges within a specific day.</rdfs:comment>
        <rdfs:label xml:lang="es">Franja horaria</rdfs:label>
        <rdfs:label xml:lang="en">Time slot</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TobaccoShop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TobaccoShop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashionBusiness"/>
        <rdfs:comment xml:lang="es">Negocio donde se venden principalmente sellos y tabaco, además de ofrecer servicios de recarga de tarjetas prepago de telefonía y de transportes urbanos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Store where stamps and tobacco are mainly sold, in addition to offering recharge services for prepaid telephone and urban transport cards.</rdfs:comment>
        <rdfs:label xml:lang="es">Estanco</rdfs:label>
        <rdfs:label xml:lang="en">Tobacco shop</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Tour -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Tour">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalTourService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offeredBy"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#ComplementaryActivitiesCompany"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourGuide"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPriceClass"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#itinerary"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#Itinerary"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#meetingPoint"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#Place"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#dramatisedTour"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#includes"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#isAllinclusive"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#notIncluded"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Experiencia turística que incluye el recorrido por algún lugar o recinto de interés, que se hace generalmente en grupo y con la ayuda de un guía que conduce y proporciona información acerca de lo que se muestra.</rdfs:comment>
        <rdfs:comment xml:lang="en">Tourist experience that includes a tour of a place or area of ​​interest, which is generally done in a group and with the help of a guide who drives and provides information about what is shown.</rdfs:comment>
        <rdfs:label xml:lang="en">Tour</rdfs:label>
        <rdfs:label xml:lang="es">Visita guiada</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TourGuide -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TourGuide">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrganisation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offers"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Tour"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#tourSpecialty"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#registrationNumber"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Person with extensive knowledge of the destination, capable of expressing himself in two or more languages, whose responsibility is to serve, inform and assist tourists on the tours they take.</rdfs:comment>
        <rdfs:comment xml:lang="es">Persona con amplio conocimiento del destino, capaz de expresarse en dos o más idiomas, cuya responsabilidad es atender, informar y asistir a los turistas en los tours que realizan.</rdfs:comment>
        <rdfs:label xml:lang="es">Guía turístico</rdfs:label>
        <rdfs:label xml:lang="en">Tour guide</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TourismDestination -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismDestination">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Place"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#destinationType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAcknowledgement"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Acknowledgement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasRulesAndTips"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#RulesAndTips"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasSocialMediaProfile"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#SocialMediaProfile"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#nearTo"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Route"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offeredBy"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#DestinationExperience"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offers"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#DestinationExperience"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Event"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Tour"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#relatedTourismDestination"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismDestination"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#touristType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Espacio físico con o sin límites administrativos y/o analíticos en el que un visitante puede pasar la noche, que consiste en una agrupación o coubicación de productos y servicios, así como de actividades y experiencias a lo largo de la cadena de valor del turismo, y que constituye una unidad básica de análisis del turismo. Incorpora a diversas partes interesadas y puede conectarse en red para formar destinos más grandes. También es intangible, con su imagen e identidad, que pueden influir en su competitividad en el mercado.</rdfs:comment>
        <rdfs:comment xml:lang="en">Physical space with or without administrative and/or analytical boundaries in which a visitor can spend an overnight, consisting of a clustering or co-location of products and services and of activities and experiences along the tourism value chain and a basic unit of analysis of tourism. It incorporates various stakeholders and can network to form larger destinations. It is also intangible with its image and identity, which can influence its market competitiveness</rdfs:comment>
        <rdfs:label xml:lang="es">Destino turístico</rdfs:label>
        <rdfs:label xml:lang="en">Tourism destination</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TourismEntity -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismEntity">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasSocialMediaProfile"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#SocialMediaProfile"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#relatedTourismDestination"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismDestination"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasDescription"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#Description"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalInformation"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#AdditionalInformation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasMultimedia"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#Multimedia"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#name"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Concepto general que agrupa los elementos públicos y privados con capacidad de intervenir en el ciclo de viaje del turista.</rdfs:comment>
        <rdfs:comment>General concept that groups public and private elements capable of intervening in the tourist&apos;s travel cycle.</rdfs:comment>
        <rdfs:label xml:lang="es">Entidad turística</rdfs:label>
        <rdfs:label xml:lang="en">Tourism entity</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TourismIntermediary -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismIntermediary">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrganisation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasTourismOrRelatedFacility"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offers"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#HolidayPackage"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#touristType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#travelUnit"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Agente de distribución que participa en la venta y/o corretaje de productos y servicios relacionados con viajes y turismo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Distribution agent that participates in the sale and/or brokerage of products and services related to travel and tourism.</rdfs:comment>
        <rdfs:label xml:lang="es">Intermediario turístico</rdfs:label>
        <rdfs:label xml:lang="en">Tourism intermediary</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Place"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAcknowledgement"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Acknowledgement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
