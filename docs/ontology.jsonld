  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Caída desde cierta altura del agua de un río u otra corriente por el brusco desnivel del cauce."
  }, {
    "@language" : "en",
    "@value" : "Fall from a certain height of the water of a river or other stream due to the sudden drop in level of the channel."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Cascada"
  }, {
    "@language" : "en",
    "@value" : "Waterfall"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#NaturalResource"
  } ],
  "https://ontologia.segittur.es/turismo/def/annot#visibleResource" : [ {
