    "@language" : "es",
    "@value" : "cierre temporal"
  }, {
    "@language" : "en",
    "@value" : "temporary closure"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#boolean"
  } ],
  "https://ontologia.segittur.es/turismo/def/annot#presentationOrderCategory" : [ {
    "@value" : "other"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#terrainConditions",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Aspectos encontrados en la ruta en relación con el terreno y sus condiciones, tales como tipos de terreno, tramos con obstáculos, tramos con piedras sueltas."
  }, {
    "@language" : "en",
    "@value" : "Aspects found on the route in relation to the ground and its conditions, such as types of terrain, sections with obstacles, sections with loose stones."
  }, {
    "@language" : "en",
    "@value" : "Levels of grading of the technical and physical demands of routes, where 1 indicates least difficulty and 5 greatest difficulty."
  }, {
    "@language" : "es",
    "@value" : "Niveles de graduación de las exigencias técnicas y físicas de rutas, en los que 1 indica menor dificultad y 5 mayor dificultad."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#Route"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "condiciones del terreno"
  }, {
    "@language" : "en",
    "@value" : "terrainConditions"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#int"
  } ],
  "https://ontologia.segittur.es/turismo/def/annot#presentationOrderCategory" : [ {
    "@value" : "other"
  } ],
  "https://ontologia.segittur.es/turismo/def/annot#tooltip" : [ {
    "@language" : "es",
    "@value" : "Asigna un valor entero del 1 al 5 para valorar la dificultad relativa a las condiciones del terreno de la ruta, siendo 1 muy bajo y 5 muy alto"
  }, {
    "@language" : "en",
    "@value" : "Assigns an integer value from 1 to 5 to assess the difficulty related to the terrain conditions of the route, where 1 is very low and 5 is very high"
  } ]
}, {
