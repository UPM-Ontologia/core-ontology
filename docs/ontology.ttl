                      rdfs:domain :PublicTransportStop ;
                      rdfs:range :TransportRoute ;
                      rdfs:label "public transport route"@en ,
                                 "ruta de transporte público"@es .


###  https://ontologia.segittur.es/turismo/def/core#registration
:registration rdf:type owl:ObjectProperty ;
              rdfs:domain :Accommodation ;
              rdfs:range :AccommodationRegistration ;
              rdfs:label "registration"@en ,
                         "registro"@es .


###  https://ontologia.segittur.es/turismo/def/core#relatedTo
:relatedTo rdf:type owl:ObjectProperty ;
           rdfs:domain [ rdf:type owl:Class ;
                         owl:unionOf ( :Organisation
                                       :TourismResource
                                       :TourismService
                                     )
                       ] ;
           rdfs:range [ rdf:type owl:Class ;
                        owl:unionOf ( :Organisation
                                      :TourismResource
                                      :TourismService
                                    )
                      ] ;
           rdfs:label "relacionado con"@es ,
                      "related to"@en .


###  https://ontologia.segittur.es/turismo/def/core#reservationType
:reservationType rdf:type owl:ObjectProperty ;
                 rdfs:domain :ParkingFacility ;
                 rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                     owl:hasValue <https://ontologia.segittur.es/turismo/kos/ReservationType>
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
                 rdfs:label "reservation type"@en ,
                            "tipo de reserva"@es .


###  https://ontologia.segittur.es/turismo/def/core#roomType
:roomType rdf:type owl:ObjectProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :Room ;
          rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                              owl:hasValue <https://ontologia.segittur.es/turismo/kos/RoomType>
                                            ]
                                          ) ;
                       rdf:type owl:Class
                     ] ;
          rdfs:label "room type"@en ,
                     "tipo de habitación"@es .


###  https://ontologia.segittur.es/turismo/def/core#saturationLevel
:saturationLevel rdf:type owl:ObjectProperty ;
                 rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                     owl:hasValue <https://ontologia.segittur.es/turismo/kos/SaturationLevel>
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
                 rdfs:label "nivel de saturación"@es ,
                            "saturation level"@en .


###  https://ontologia.segittur.es/turismo/def/core#seaConditions
:seaConditions rdf:type owl:ObjectProperty ;
               rdfs:domain :Beach ;
               rdfs:range :SeaConditions ;
