@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix estur-core: <https://ontologia.segittur.es/turismo/def/core#> .
@prefix estur-kos: <https://ontologia.segittur.es/turismo/kos/> .

@prefix estur-cabintype: <https://ontologia.segittur.es/turismo/kos/cabintype/> .

#################################################################
#
#    Concept Scheme
#
#################################################################

estur-kos:CabinType a skos:ConceptScheme ; 
    dct:issued "2024-10-29"^^xsd:date ;
    dct:modified "2024-10-29"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the SEGITTUR tourism ontology."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por la ontología de turismo de SEGITTUR."@es ;
    rdfs:label "Cabin Type"@en ;
    rdfs:label "Tipo de cabina"@es ;
    dct:title "Concept scheme grouping cabin types"@en ;
    dct:title "Esquema de conceptos agrupando tipos de cabinas"@es .

#################################################################
#
#    Concepts
#
#################################################################

estur-cabintype:SingleCabin a skos:Concept;
  skos:inScheme estur-kos:CabinType;
  skos:note "Value generated from the original SEGITTUR ontology"@en;
  skos:note "Valor generado a partir de la ontología de SEGITTUR original"@es;
  skos:prefLabel "Single cabin"@en ;
  skos:prefLabel "Cabina sencilla"@es .

estur-cabintype:DoubleCabin a skos:Concept;
  skos:inScheme estur-kos:CabinType;
  skos:note "Value generated from the original SEGITTUR ontology"@en;
  skos:note "Valor generado a partir de la ontología de SEGITTUR original"@es;
  skos:prefLabel "Double cabin"@en ;
  skos:prefLabel "Cabina doble"@es .

estur-cabintype:TripleCabin a skos:Concept;
  skos:inScheme estur-kos:CabinType;
  skos:note "Value generated from the original SEGITTUR ontology"@en;
  skos:note "Valor generado a partir de la ontología de SEGITTUR original"@es;
  skos:prefLabel "Triple cabin"@en ;
  skos:prefLabel "Cabina triple"@es .

estur-cabintype:QuadrupleCabin a skos:Concept;
  skos:inScheme estur-kos:CabinType;
  skos:note "Value generated from the original SEGITTUR ontology"@en;
  skos:note "Valor generado a partir de la ontología de SEGITTUR original"@es;
  skos:prefLabel "Quadruple cabin"@en ;
  skos:prefLabel "Cabina cuádruple"@es .

