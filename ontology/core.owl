     -->

    


    <!-- http://www.opengis.net/ont/geosparql#Feature -->

    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Feature"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->

    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
    


    <!-- http://www.w3.org/2008/05/skos#ConceptScheme -->

    <owl:Class rdf:about="http://www.w3.org/2008/05/skos#ConceptScheme">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ATM -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ATM">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FinancialService"/>
        <rdfs:comment xml:lang="en">Machine computer-connected to a bank that allows certain banking operations to be carried out using a card or magnetic book that has a personal password assigned to it.</rdfs:comment>
        <rdfs:comment xml:lang="es">Máquina conectada informáticamente con un banco que permite efectuar ciertas operaciones bancarias mediante una tarjeta o libreta magnética que tienen asignada una clave personal.</rdfs:comment>
        <rdfs:label xml:lang="en">ATM</rdfs:label>
        <rdfs:label xml:lang="es">cajero automático</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#AccesoriesAndComplements -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#AccesoriesAndComplements">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashion"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se venden objetos que complementan la indumentaria de una persona, como bolsos, calzado, paraguas, corbatas, sombreros, gafas, guantes, etc.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment in which objects that complement a person&apos;s clothing are sold, such as bags, footwear, umbrellas, ties, hats, glasses, gloves, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">accesories and complements</rdfs:label>
        <rdfs:label xml:lang="es">tienda de accesorios y complementos</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Accommodation -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Accommodation">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#accommodationCapacity"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasBookingInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPaymentInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPriceClass"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPriceInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasTransactionInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#registration"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Lugar donde una persona o un grupo de personas se hospeda, se aposenta o acampa.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place where a person or a group of people stays, stays or camps.</rdfs:comment>
        <rdfs:label xml:lang="en">Accommodation</rdfs:label>
        <rdfs:label xml:lang="es">Alojamiento</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#AccommodationCapacity -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#AccommodationCapacity">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#numberOfBeds"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#numberOfRooms"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Cantidad máxima de personas que pueden ser alojadas en un alojamiento.</rdfs:comment>
        <rdfs:comment xml:lang="en">Maximum number of people that can be accommodated in an accommodation.</rdfs:comment>
        <rdfs:label xml:lang="en">accommodation capacity</rdfs:label>
        <rdfs:label xml:lang="es">capacidad alojativa</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Acknowledgement -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Acknowledgement">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#recognizedBy"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#url"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Achievements or distinctions awarded to people, companies or products for meeting certain standards or specific criteria. These recognitions may include certifications, ratings, awards, or other types of honors that recognize quality, outstanding performance, compliance, or excellence in a particular field.</rdfs:comment>
        <rdfs:comment xml:lang="es">Logros o distinciones otorgadas a personas, empresas o productos por cumplir con ciertos estándares o criterios específicos. Estos reconocimientos pueden¡ incluir certificaciones, puntuaciones, premios u otros tipos de distinciones que reconocen la calidad, el rendimiento destacado, el cumplimiento de normas o la excelencia en un determinado campo.</rdfs:comment>
        <rdfs:label xml:lang="en">Acknowledgement</rdfs:label>
        <rdfs:label xml:lang="es">Reconocimiento</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Activity -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Activity">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#multiadventureActivityType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="es">Actividad</rdfs:label>
        <rdfs:label xml:lang="en">Activity</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#AdditionalInformation -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#AdditionalInformation">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#conditions"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#curiosities"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#frequentlyAskedQuestions"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#remarks"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Additional details, data or explanations that complement or expand the main information provided. It is extra information that can provide clarification, context, or specific details on a given topic.</rdfs:comment>
        <rdfs:comment xml:lang="es">Detalles, datos o explicaciones adicionales que complementan o amplían la información principal proporcionada. Es información extra que puede proporcionar aclaraciones, contexto o detalles específicos sobre un tema determinado.</rdfs:comment>
        <rdfs:label xml:lang="en">additional information</rdfs:label>
        <rdfs:label xml:lang="es">información adicional</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Advice -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Advice">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RulesAndTips"/>
        <rdfs:comment xml:lang="en">Communication to the user of advice and good practices.</rdfs:comment>
        <rdfs:comment xml:lang="es">Comunicación al usuario de consejos y buenas prácticas.</rdfs:comment>
        <rdfs:label xml:lang="en">Advice</rdfs:label>
        <rdfs:label xml:lang="es">Recomendación</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#AgrotourismFacility -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#AgrotourismFacility">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TouristOrRelatedFacility"/>
        <rdfs:comment xml:lang="en">Facility focused on promoting agricultural, livestock, and active tourism activities in rural settings.</rdfs:comment>
        <rdfs:comment xml:lang="es">Instalación enfocada a la promoción de actividades agrícolas, ganaderas y de turismo activo en entornos rurales.</rdfs:comment>
        <rdfs:label xml:lang="en">Agrotourism Facility</rdfs:label>
        <rdfs:label xml:lang="es">Instalación agroturística</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Airline -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Airline">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PassengerTransportCompany"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#airplane"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Airplane"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalAirlineService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Air transportation organization or company</rdfs:comment>
        <rdfs:comment xml:lang="es">Organización o compañía de transporte aéreo</rdfs:comment>
        <rdfs:label xml:lang="es">aerolínea</rdfs:label>
        <rdfs:label xml:lang="en">airline</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Airplane -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Airplane">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MeansOfTransport"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalAirplaneService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Means of air transportation used to cover long distances.</rdfs:comment>
        <rdfs:comment xml:lang="es">Medio de transporte aéreo utilizado para cubrir distancias largas.</rdfs:comment>
        <rdfs:label xml:lang="en">airplane</rdfs:label>
        <rdfs:label xml:lang="es">avión</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Airport -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Airport">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalAirportService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Area intended for the landing and takeoff of airplanes equipped with facilities for air traffic control and passenger services.</rdfs:comment>
        <rdfs:comment xml:lang="es">Área destinada al aterrizaje y despegue de aviones dotada de instalaciones para el control del tráfico aéreo y de servicios a los pasajeros.</rdfs:comment>
        <rdfs:label xml:lang="es">aeropuerto</rdfs:label>
        <rdfs:label xml:lang="en">airport</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Alcazar -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Alcazar">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Castillo fortificado situado en un lugar estratégico, especialmente cuando está amurallado.</rdfs:comment>
        <rdfs:label xml:lang="en">alcazar</rdfs:label>
        <rdfs:label xml:lang="es">alcázar</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Amphitheatre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Amphitheatre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Construcción oval o circular provista de un graderío alrededor de una zona arenosa central, en la que en la esantigua Roma se celebraban espectáculos públicos.</rdfs:comment>
        <rdfs:label xml:lang="en">amphitheater</rdfs:label>
        <rdfs:label xml:lang="es">anfiteatro</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#AmusementPark -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#AmusementPark">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="en">A venue that hosts a wide variety of attractions and events for fun and entertainment.</rdfs:comment>
        <rdfs:comment xml:lang="es">Recinto que acoge una gran variedad de atracciones y acontecimientos destinados a la diversión y al entretenimiento.</rdfs:comment>
        <rdfs:label xml:lang="en">amusement park</rdfs:label>
        <rdfs:label xml:lang="es">parque de atracciones</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ApartHotel -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ApartHotel">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Accommodation"/>
        <rdfs:comment xml:lang="es">Establecimiento que facilita el servicio de alojamiento para clientes en estudios o unidades de servicio, dentro de las cuales se dispone de instalaciones adecuadas para la conservación, elaboración y consumo de alimentos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment that provides accommodation service for clients in studios or service units, within which adequate facilities are available for the conservation, preparation and consumption of food.</rdfs:comment>
        <rdfs:label xml:lang="es">apartahotel</rdfs:label>
        <rdfs:label xml:lang="en">aparthotel</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Aquarium -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Aquarium">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalAquariumService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Enclosure intended for the exhibition of live aquatic animals.</rdfs:comment>
        <rdfs:comment xml:lang="es">Recinto destinado a la exhibición de animales acuáticos vivos.</rdfs:comment>
        <rdfs:label xml:lang="es">acuario</rdfs:label>
        <rdfs:label xml:lang="en">aquarium</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Aqueduct -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Aqueduct">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Construcción en forma de puente soportado por una o más filas de arcos sobre la cual se conduce agua de un lado a otro de una fuerte depresión de terreno.</rdfs:comment>
        <rdfs:label xml:lang="es">acueducto</rdfs:label>
        <rdfs:label xml:lang="en">aqueduct</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Arcade -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Arcade">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="es">Lugar donde se encuentran un conjunto de máquinas o juegos, en los que a cambio de una determinada cantidad de dinero se obtiene un tiempo de juego.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place where a set of machines or games are found, in which in exchange for a certain amount of money you get playing time.</rdfs:comment>
        <rdfs:label xml:lang="en">arcade</rdfs:label>
        <rdfs:label xml:lang="es">salón recreativo</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Arch -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Arch">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Elemento constructivo de directriz en forma curvada o poligonal.</rdfs:comment>
        <rdfs:label xml:lang="en">arch</rdfs:label>
        <rdfs:label xml:lang="es">arco</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ArcheologicalSite -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ArcheologicalSite">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Lugar donde se hallan restos arqueológicos.</rdfs:comment>
        <rdfs:label xml:lang="es">archaelogical site</rdfs:label>
        <rdfs:label xml:lang="es">yacimiento arqueológico</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ArtGallery -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ArtGallery">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalArtGalleryService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Establecimiento para exposición y venta de obras de arte.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment for exhibition and sale of works of art.</rdfs:comment>
        <rdfs:label xml:lang="en">art gallery</rdfs:label>
        <rdfs:label xml:lang="es">galería de arte</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Auditorium -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Auditorium">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#EventAttendanceFacility"/>
        <rdfs:comment xml:lang="en">Room for concerts, recitals, conferences, colloquiums, public readings, etc.</rdfs:comment>
        <rdfs:comment xml:lang="es">Sala destinada a conciertos, recitales, conferencias, coloquios, lecturas públicas, etc.</rdfs:comment>
        <rdfs:label xml:lang="es">auditorio</rdfs:label>
        <rdfs:label xml:lang="en">auditorium</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BakeryAndPastry -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BakeryAndPastry">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Groceries"/>
        <rdfs:comment xml:lang="es">Establecimiento donde se hacen y/o se venden panes, pasteles, pastas u otros dulces.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment where breads, cakes, pastas or other sweets are made and/or sold.</rdfs:comment>
        <rdfs:label xml:lang="en">bakery and pastry</rdfs:label>
        <rdfs:label xml:lang="es">panadería y pastelería</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BankOffice -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BankOffice">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FinancialService"/>
        <rdfs:comment xml:lang="es">Lugar donde una institución financiera ofrece asistencia personal y automatizada a los clientes.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place where a financial institution offers personal and automated assistance to customers</rdfs:comment>
        <rdfs:label xml:lang="en">bank office</rdfs:label>
        <rdfs:label xml:lang="es">oficina bancaria</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Bar -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Bar">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantService"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se despachan bebidas que suelen tomarse de pie ante el mostrador.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment in which drinks are served that are usually drunk standing at the counter.</rdfs:comment>
        <rdfs:label xml:lang="en">bar</rdfs:label>
        <rdfs:label xml:lang="es">bar</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Basilica -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Basilica">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Iglesia notable por su antigüedad o magnificencia o por los cultos que en ella se celebran.</rdfs:comment>
        <rdfs:label xml:lang="en">basilica</rdfs:label>
        <rdfs:label xml:lang="es">basílica</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BasketballCourt -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BasketballCourt">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="en">Flat surface, indoor or outdoor, with a hoop at each end suspended about three meters high for practicing this sport.</rdfs:comment>
        <rdfs:comment xml:lang="es">Superficie plana, interior o exterior, con un aro en cada extremo suspendido a unos tres metros de altura para la práctica de este deporte.</rdfs:comment>
        <rdfs:label xml:lang="en">basketball court</rdfs:label>
        <rdfs:label xml:lang="es">cancha de baloncesto</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Bazaar -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Bazaar">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashion"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se venden gran diversidad de productos, como ropa, relojes, juguetes, artículos para la casa y objetos de regalo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment where a wide variety of products are sold, such as clothing, watches, toys, household items and gift items.</rdfs:comment>
        <rdfs:label xml:lang="en">bazaar</rdfs:label>
        <rdfs:label xml:lang="es">bazar</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Beach -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Beach">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#beachType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalBeachService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Bank of the sea or a large river, formed by sandbanks on an almost flat surface</rdfs:comment>
        <rdfs:comment xml:lang="es">Ribera del mar o de un río grande, formada de arenales en superficie casi plana.</rdfs:comment>
        <rdfs:label xml:lang="en">beach</rdfs:label>
        <rdfs:label xml:lang="es">playa</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BeachBar -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BeachBar">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantService"/>
        <rdfs:comment xml:lang="es">Pequeño establecimiento a pie de playa, que ofrece comidas y bebidas y que posee una terraza o área de mesas al aire libre.</rdfs:comment>
        <rdfs:comment xml:lang="en">Small establishment on the beach, which offers food and drinks and has a terrace or outdoor table area.</rdfs:comment>
        <rdfs:label xml:lang="en">beach bar</rdfs:label>
        <rdfs:label xml:lang="es">chiringuito</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BeachClub -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BeachClub">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PartyAndEntertainmentFacility"/>
        <rdfs:comment xml:lang="en">Leisure and entertainment venue in coastal areas with facilities and services similar to those of a hotel, but without the lodging option.</rdfs:comment>
        <rdfs:comment xml:lang="es">Lugar de ocio y entretenimiento en las zonas costeras con instalaciones y servicios semejantes a los de un hotel, pero sin la opción de hospedaje.</rdfs:comment>
        <rdfs:label xml:lang="en">beach club</rdfs:label>
        <rdfs:label xml:lang="es">club de playa</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BeautyCentre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BeautyCentre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HealthAndWellnessFacility"/>
        <rdfs:comment xml:lang="es">Establecimiento orientado a la belleza y cuidado del cuerpo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment aimed at beauty and body care.</rdfs:comment>
        <rdfs:label xml:lang="en">beauty centre</rdfs:label>
        <rdfs:label xml:lang="es">centro de belleza</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BellTower -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BellTower">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Torre elevada, exenta, adosada o integrada en un edificio, donde se colocan las campanas.</rdfs:comment>
        <rdfs:label xml:lang="en">bell tower</rdfs:label>
        <rdfs:label xml:lang="es">campanario</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BicycleSharingSystem -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BicycleSharingSystem">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasTransactionInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Service that makes a series of bicycles available to users to be used temporarily as a means of transportation.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicio que pone a disposición de los usuarios una serie de bicicletas para que sean utilizadas temporalmente como medio de transporte.</rdfs:comment>
        <rdfs:label xml:lang="en">bicycle sharing system</rdfs:label>
        <rdfs:label xml:lang="es">sistema de bicicletas compartidas</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BikeLane -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BikeLane">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:comment xml:lang="en">Cycle route that runs adjacent to the road in one or two directions.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vía ciclista que discurre adosada a la calzada en uno o en doble sentido.</rdfs:comment>
        <rdfs:label xml:lang="en">bike lane</rdfs:label>
        <rdfs:label xml:lang="es">carril bici</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Bingo -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Bingo">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PartyAndEntertainmentFacility"/>
        <rdfs:label xml:lang="en">bingo</rdfs:label>
        <rdfs:label xml:lang="es">bingo</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BookShop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BookShop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashion"/>
        <rdfs:comment xml:lang="en">Shop where books are sold</rdfs:comment>
        <rdfs:comment xml:lang="es">Tienda donde se venden libros.</rdfs:comment>
        <rdfs:label xml:lang="en">bookshop</rdfs:label>
        <rdfs:label xml:lang="es">librería</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BookingChannel -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BookingChannel">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#ContactPoint"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#onSite"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#app"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Means or platforms used by guests to make a reservation</rdfs:comment>
        <rdfs:comment xml:lang="es">Medios o plataformas utilizados por los huéspedes para realizar una reserva.</rdfs:comment>
        <rdfs:label xml:lang="en">booking channel</rdfs:label>
        <rdfs:label xml:lang="es">canal de reserva</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BookingInformation -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BookingInformation">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#bookingChannel"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#cancellationFee"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#modificationFee"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#prepayment"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Includes specifications related to the accommodation reservation.</rdfs:comment>
        <rdfs:comment xml:lang="es">Incluye las especificaciones relacionadas con la reserva del alojamiento.</rdfs:comment>
        <rdfs:label xml:lang="en">booking information</rdfs:label>
        <rdfs:label xml:lang="es">información de la reserva</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BowlingAlley -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BowlingAlley">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Lugar destinado al juego de bolos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place for bowling.</rdfs:comment>
        <rdfs:label xml:lang="es">bolera</rdfs:label>
        <rdfs:label xml:lang="en">bowling alley</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Brewery -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Brewery">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantService"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se sirve cerveza como especialidad.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment in which beer is served as specialty.</rdfs:comment>
        <rdfs:label xml:lang="en">brewery</rdfs:label>
        <rdfs:label xml:lang="es">cervecería</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Bridge -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Bridge">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Construcción de piedra, ladrillo, madera, hierro, hormigón, etc., que se construye y forma sobre los ríos, fosos y otros sitios, para comunicar dos lados.</rdfs:comment>
        <rdfs:label xml:lang="en">bridge</rdfs:label>
        <rdfs:label xml:lang="es">puente</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BullRing -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BullRing">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#EventAttendanceFacility"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Construcción generalmente circular y con graderías, destinada a la lidia de toros, aunque también puede ser utilizada para otros tipos de eventos.</rdfs:comment>
        <rdfs:label xml:lang="en">Bullring</rdfs:label>
        <rdfs:label xml:lang="es">Plaza de toros</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Bus -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Bus">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MeansOfTransport"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalBusService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Land vehicle for group travel.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vehículo terrestre para viajes en grupo.</rdfs:comment>
        <rdfs:label xml:lang="es">autocar</rdfs:label>
        <rdfs:label xml:lang="en">bus</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BusOperator -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BusOperator">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PassengerTransportCompany"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#bus"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Bus"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalBusOperatorService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Company specialized in providing passenger transport services using coaches on pre-established routes.</rdfs:comment>
        <rdfs:comment xml:lang="es">Empresa especializada en la prestación de servicios de transporte de pasajeros utilizando autocares en rutas preestablecidas.</rdfs:comment>
        <rdfs:label xml:lang="en">bus operator</rdfs:label>
        <rdfs:label xml:lang="es">operador de autocares</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BusStation -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BusStation">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalBusStationService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Facility for the arrival and departure of buses.</rdfs:comment>
        <rdfs:comment xml:lang="es">Instalación destinada a la llegada y salida de autobuses.</rdfs:comment>
        <rdfs:label xml:lang="en">bus station</rdfs:label>
        <rdfs:label xml:lang="es">estación de autobuses</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Cabin-Deprecated -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Cabin-Deprecated">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasDescription"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Description"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#maximumCapacity"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#numberOfCabins"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A cabin or private accommodation space on board the ship where passengers stay during the voyage.</rdfs:comment>
        <rdfs:comment xml:lang="es">Cabina o espacio de alojamiento privado a bordo del barco donde los pasajeros se alojan durante la travesía.</rdfs:comment>
        <rdfs:label xml:lang="en">cabin - deprecated</rdfs:label>
        <rdfs:label xml:lang="es">camarote - deprecado</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CafeOrCoffeShop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CafeOrCoffeShop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantService"/>
        <rdfs:comment xml:lang="en">Coffee and other beverage outlet, where snacks and meals are sometimes served</rdfs:comment>
        <rdfs:comment xml:lang="es">Despacho de café y otras bebidas, donde a veces se sirven aperitivos y comidas</rdfs:comment>
        <rdfs:label xml:lang="en">cafe or coffee shop</rdfs:label>
        <rdfs:label xml:lang="es">cafetería</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CallShop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CallShop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MiscellaneousService"/>
        <rdfs:comment xml:lang="es">Local que ofrece a sus clientes servicios de telefonía y conexión a internet principalmente.</rdfs:comment>
        <rdfs:comment xml:lang="en">Local that offers its clients telephone services and internet connection mainly.</rdfs:comment>
        <rdfs:label xml:lang="en">call shop</rdfs:label>
        <rdfs:label xml:lang="es">locutorio</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Camping -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Camping">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Accommodation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#stars"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Tipo de establecimiento situado al aire libre que posee las instalaciones necesarias para atender la demanda y las necesidades alojativas y servicios para albergar a turistas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Type of establishment located outdoors that has the necessary facilities to meet the demand and accommodation needs and services to accommodate tourists.</rdfs:comment>
        <rdfs:label xml:lang="en">camping</rdfs:label>
        <rdfs:label xml:lang="es">camping</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Campsite -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Campsite">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#EducationalFacility"/>
        <rdfs:comment xml:lang="es">Instalación eventual, en terreno abierto, donde se practican actividades de convivencia al aire libre, orientada a fines educativos y de formación.</rdfs:comment>
        <rdfs:comment xml:lang="en">Possible installation, in open terrain, where outdoor coexistence activities are practiced, aimed at educational and training purposes.</rdfs:comment>
        <rdfs:label xml:lang="es">Campamento</rdfs:label>
        <rdfs:label xml:lang="en">campsite</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Canal -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Canal">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="en">Artificial channel through which water is conducted to discharge it or for other uses</rdfs:comment>
        <rdfs:comment xml:lang="es">Cauce artificial por donde se conduce el agua para darle salida o para otros usos</rdfs:comment>
        <rdfs:label xml:lang="en">canal</rdfs:label>
        <rdfs:label xml:lang="es">canal</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CancellationFee -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CancellationFee">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#free"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#freeCancellationValidity"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#nonRefundable"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Amount of money that a service provider can charge the customer when the customer cancels a previously confirmed reservation.</rdfs:comment>
        <rdfs:comment xml:lang="es">Cantidad de dinero que un proveedor de servicios puede cobrar al cliente cuando éste cancela una reserva previamente confirmada.</rdfs:comment>
        <rdfs:label xml:lang="en">cancellation fee</rdfs:label>
        <rdfs:label xml:lang="es">cargo de cancelación</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CaravanArea -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CaravanArea">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:comment xml:lang="es">Espacio específicamente designado para el estacionamiento y pernocta de autocaravanas y campers, que ofrece servicios adaptados a este tipo de vehículos</rdfs:comment>
        <rdfs:comment xml:lang="en">Space specifically designated for parking and overnight stays for motorhomes and campers, which offers services adapted to this type of vehicle.</rdfs:comment>
        <rdfs:label xml:lang="en">Caravan area</rdfs:label>
        <rdfs:label xml:lang="es">Área de autocaravanas</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Carpool -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Carpool">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PassengerTransportCompany"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalCarpoolService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#vehicleType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#brand"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#lugaggeCapacity"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#modelName"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#passengerCapacity"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#driverAge"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#driverSince"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#smokingAllowed"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Practice that consists of sharing a car with other people both for periodic trips and for specific trips.</rdfs:comment>
        <rdfs:comment xml:lang="es">Práctica que consiste en compartir un automóvil con otras personas tanto para viajes periódicos como para trayectos puntuales.</rdfs:comment>
        <rdfs:label xml:lang="en">carpool</rdfs:label>
        <rdfs:label xml:lang="es">coche compartido</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Casino -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Casino">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PartyAndEntertainmentFacility"/>
        <rdfs:label xml:lang="en">casino</rdfs:label>
        <rdfs:label xml:lang="es">casino</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Castle -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Castle">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Edificio o conjunto de edificios rodeados de murallas, fosos y otras obras de fortificación, construido generalmente en un lugar elevado y estratégicamente situado para la guerra.</rdfs:comment>
        <rdfs:label xml:lang="es">castillo</rdfs:label>
        <rdfs:label xml:lang="en">castle</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Catacomb -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Catacomb">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Galerías subterráneas que algunas civilizaciones mediterráneas antiguas construyeron y utilizaron como lugar de enterramiento.</rdfs:comment>
        <rdfs:label xml:lang="en">catacomb</rdfs:label>
        <rdfs:label xml:lang="es">catacumba</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CateringService -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CateringService">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantService"/>
        <rdfs:comment xml:lang="en">Food and beverage services for events, whether large or small, formal or informal.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicio de provisión de alimentos y bebidas para eventos, ya sean grandes o pequeños, formales o informales.</rdfs:comment>
        <rdfs:label xml:lang="en">Catering Service</rdfs:label>
        <rdfs:label xml:lang="es">Servicio de catering</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Cathedral -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Cathedral">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Iglesia principal en que el obispo, con su cabildo, tiene su sede o cátedra.</rdfs:comment>
        <rdfs:label xml:lang="es">catedral</rdfs:label>
        <rdfs:label xml:lang="en">cathedral</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Cave -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Cave">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="es">Cavidad natural del terreno causada por algún tipo de erosión de corrientes de agua, hielo o lava.</rdfs:comment>
        <rdfs:comment xml:lang="en">Natural cavity in the ground caused by some type of erosion from water currents, ice or lava.</rdfs:comment>
        <rdfs:label xml:lang="en">cave</rdfs:label>
        <rdfs:label xml:lang="es">cueva o caverna</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Cemetery -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Cemetery">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Terreno, generalmente cercado, destinado a enterrar cadáveres.</rdfs:comment>
        <rdfs:label xml:lang="es">Cementerio</rdfs:label>
        <rdfs:label xml:lang="en">Cemetery</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Certification -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Certification">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Acknowledgement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#universalAccessibility"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Certificados que indican el cumplimiento de normas, requisitos, características o exigencias</rdfs:comment>
        <rdfs:comment xml:lang="en">Certificates that indicate compliance with standards, requirements, characteristics or demands</rdfs:comment>
        <rdfs:label xml:lang="es">Certificación</rdfs:label>
        <rdfs:label xml:lang="en">Certification</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Chapel -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Chapel">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Edificio contiguo a una iglesia o parte integrante de ella, con altar y advocación particular.</rdfs:comment>
        <rdfs:label xml:lang="es">capilla</rdfs:label>
        <rdfs:label xml:lang="en">chapel</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ChillOut -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ChillOut">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PartyAndEntertainmentFacility"/>
        <rdfs:comment xml:lang="en">A place where drinks are served and calm and relaxing electronic music is listened to.</rdfs:comment>
        <rdfs:comment xml:lang="es">Local en el que se despachan bebidas y se escucha música electrónica tranquila y relajante.</rdfs:comment>
        <rdfs:label xml:lang="en">chill out</rdfs:label>
        <rdfs:label xml:lang="es">chill out</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ChocolateShop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ChocolateShop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantService"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se sirve chocolate a la taza, bebidas y productos de pastelería.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment that serves hot chocolate, drinks and pastries.</rdfs:comment>
        <rdfs:label xml:lang="en">chocolate shop</rdfs:label>
        <rdfs:label xml:lang="es">chocolatería</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Church -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Church">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Templo cristiano. También se pueden utilizar otros términos como parroquia</rdfs:comment>
        <rdfs:label xml:lang="en">church</rdfs:label>
        <rdfs:label xml:lang="es">iglesia</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ChurroShop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ChurroShop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantService"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se elaboran y se comercializan churros y porras, de forma artesanal, así como chocolate a la taza.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment where artisanal churros and porras are made and sold, as well as hot chocolate.</rdfs:comment>
        <rdfs:label xml:lang="es">churrería</rdfs:label>
        <rdfs:label xml:lang="en">churro shop</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CiderBar -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CiderBar">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantService"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se vende y se consume sidra como especialidad.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment in which cider is sold and consumed as a specialty.</rdfs:comment>
        <rdfs:label xml:lang="en">cider bar</rdfs:label>
        <rdfs:label xml:lang="es">sidrería</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CivilProtection -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CivilProtection">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:comment xml:lang="en">Public service that protects people and property, guaranteeing an adequate response to different types of emergencies and catastrophes</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicio público que protege a las personas y bienes garantizando una respuesta adecuada ante los distintos tipos de emergencias y catástrofes.</rdfs:comment>
        <rdfs:label xml:lang="en">civil protection</rdfs:label>
        <rdfs:label xml:lang="es">protección civil</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ClimbingWall -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ClimbingWall">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Instalación deportiva consistente en una pared rocosa para el entrenamiento de la escalada.</rdfs:comment>
        <rdfs:comment xml:lang="en">Sports facility consisting of a rock wall for climbing training.</rdfs:comment>
        <rdfs:label xml:lang="en">climbing wall</rdfs:label>
        <rdfs:label xml:lang="es">pared de escalada</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Cloister -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Cloister">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Galería que cerca el patio principal de una iglesia o convento.</rdfs:comment>
        <rdfs:label xml:lang="es">Claustro</rdfs:label>
        <rdfs:label xml:lang="en">Cloister</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Clothing -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Clothing">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashion"/>
        <rdfs:comment xml:lang="en">Store where the latest news in clothing is sold.</rdfs:comment>
        <rdfs:comment xml:lang="es">Tienda en la que se venden las últimas novedades en ropa.</rdfs:comment>
        <rdfs:label xml:lang="en">clothing</rdfs:label>
        <rdfs:label xml:lang="es">tienda de moda</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CocktailBar -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CocktailBar">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantService"/>
        <rdfs:comment xml:lang="es">Establecimiento especializado en la preparación y en el servicio de cócteles -bebida, generalmente alcohólica, que resulta de una mezcla de otras con varios ingredientes más-.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment specialized in the preparation and serving of cocktails - a drink, generally alcoholic, that results from a mixture of others with several other ingredients.</rdfs:comment>
        <rdfs:label xml:lang="en">cocktail bar</rdfs:label>
        <rdfs:label xml:lang="es">coctelería</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CongressCentre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CongressCentre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#EventAttendanceFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalCongressCentreService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Espacio preparado para la acogida y celebración de congresos, convenciones, ferias, incentivos y cualquier otro acontecimiento similar.</rdfs:comment>
        <rdfs:comment xml:lang="en">Space prepared for hosting and holding conferences, conventions, fairs, incentives and any other similar event.</rdfs:comment>
        <rdfs:label xml:lang="en">congress centre</rdfs:label>
        <rdfs:label xml:lang="es">palacio de congresos y exposiciones</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ContactPoint -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ContactPoint">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#email"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#telephone"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#url"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Data necessary to establish communication with a person or entity. This information allows other individuals or companies to directly and effectively contact the person or entity in question.</rdfs:comment>
        <rdfs:comment xml:lang="es">Datos necesarios para establecer comunicación con una persona o entidad. Esta información permite a otros individuos o empresas ponerse en contacto de manera directa y efectiva con la persona o entidad en cuestión.</rdfs:comment>
        <rdfs:label xml:lang="en">contact point</rdfs:label>
        <rdfs:label xml:lang="es">punto de contacto</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Convent -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Convent">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Casa en que viven religiosos o religiosas bajo las reglas de su instituto.</rdfs:comment>
        <rdfs:label xml:lang="en">convent</rdfs:label>
        <rdfs:label xml:lang="es">convento</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Cove -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Cove">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="es">Tramo de bahía de forma redondeada, de dimensiones más pequeñas a las de la playa y donde sus aguas son más tranquilas</rdfs:comment>
        <rdfs:label xml:lang="es">Cala</rdfs:label>
        <rdfs:label xml:lang="en">Cove</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CruiseLine -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CruiseLine">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PassengerTransportCompany"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#cruiseShip"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#CruiseShip"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Empresa naviera o conjunto de empresas navieras, del mismo grupo empresarial, dedicados a ofrecer servicios de viajes en crucero, operando una flota de buques de pasajeros tipo crucero turístico diseñados para el entretenimiento y transporte de pasajeros en viajes de placer.</rdfs:comment>
        <rdfs:comment xml:lang="en">Shipping company or group of shipping companies, from the same business group, dedicated to offering cruise travel services, operating a fleet of tourist cruise type passenger ships designed for the entertainment and transportation of passengers on pleasure trips.</rdfs:comment>
        <rdfs:label xml:lang="es">compañía de cruceros</rdfs:label>
        <rdfs:label xml:lang="en">cruise line</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CruiseShip -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CruiseShip">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MeansOfTransport"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalCruiseShipService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersCabin"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Cabin-Deprecated"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#capacity"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Barco de pasajeros que realiza viajes con fines vacacionales o turísticos a cualquier parte del mundo haciendo escala en destinos intermedios, que proporciona a sus pasajeros todos los servicios propios de un hotel, como alojamiento, manutención, servicio médico, actividades de entretenimiento, etc.</rdfs:comment>
        <rdfs:comment xml:lang="en">Passenger ship that makes trips for vacation or tourism purposes to any part of the world, stopping at intermediate destinations, which provides its passengers with all the services of a hotel, such as accommodation, food, medical service, entertainment activities, etc.</rdfs:comment>
        <rdfs:label xml:lang="es">crucero</rdfs:label>
        <rdfs:label xml:lang="en">cruise ship</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CultureCentre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CultureCentre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalCultureCentreService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Recinto en los que se organizan actividades de carácter cultural: conferencias, exposiciones, tertulias, etc.</rdfs:comment>
        <rdfs:comment xml:lang="en">Venue where cultural activities are organized: conferences, exhibitions, gatherings, etc.</rdfs:comment>
        <rdfs:label xml:lang="es">centro cultural</rdfs:label>
        <rdfs:label xml:lang="en">culture centre</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#DayOfTheWeek -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#DayOfTheWeek">
        <rdfs:label xml:lang="en">day of the week</rdfs:label>
        <rdfs:label xml:lang="es">día de la semana</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#DeliveryPoint -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#DeliveryPoint">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#ParcelAndCourier"/>
        <rdfs:comment xml:lang="en">Designated location where customers can pick up or receive their packages and shipments.</rdfs:comment>
        <rdfs:comment xml:lang="es">Ubicación designada donde los clientes pueden recoger o recibir sus paquetes y envíos.</rdfs:comment>
        <rdfs:label xml:lang="en">delivery point</rdfs:label>
        <rdfs:label xml:lang="es">punto de entrega</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Description -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Description">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#keyword"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#shortDescription"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#longDescription"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Proporciona información concisa y resumida sobre un elemento específico, como un producto, servicio o entidad. Este bloque suele contener detalles clave y destacados que describen las características principales, funciones, beneficios o aspectos destacados del elemento en cuestión.</rdfs:comment>
        <rdfs:comment xml:lang="en">Provides concise, summarized information about a specific item, such as a product, service, or entity. This block usually contains key details and highlights that describe the main features, functions, benefits or highlights of the item in question.</rdfs:comment>
        <rdfs:label xml:lang="es">descripción</rdfs:label>
        <rdfs:label xml:lang="en">description</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Desert -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Desert">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="en">Sandy or rocky territory, which due to the almost total lack of rain lacks or has very little vegetation</rdfs:comment>
        <rdfs:comment xml:lang="es">Territorio arenoso o pedregoso, que por la falta casi total de lluvias carece de vegetación o la tiene muy escasa.</rdfs:comment>
        <rdfs:label xml:lang="en">desert</rdfs:label>
        <rdfs:label xml:lang="es">desierto</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#DestinationExperience -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#DestinationExperience">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#timeOfTheYear"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#duration"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#endsAt"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#startsAt"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Price-free experiences that the destination proposes so that the tourist integrates into the way of life of its inhabitants, their culture and their authenticity, to motivate the completion of the trip or so that they take away a memory that survives after it and can be transmitted to others. It allows establishing an emotional relationship between the tourist and the inhabitants of the destination.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vivencias libres de precio que el destino propone para que el turista se integre en la forma de vivir de sus habitantes, su cultura y su autenticidad, para motivar la realización del viaje o bien para que se lleve un recuerdo que perviva después del mismo y pueda ser transmitido a los demás. Permite establecer una relación emocional entre el turista y los habitantes del destino.</rdfs:comment>
        <rdfs:label xml:lang="en">destination experience</rdfs:label>
        <rdfs:label xml:lang="es">experiencia en destino</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#DestinationManagementCompany -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#DestinationManagementCompany">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TouristIntermediary"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalDMCService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Company specialized in the organization and management of tourist services for foreign visitors in a specific destination.</rdfs:comment>
        <rdfs:comment xml:lang="es">Empresa especializada en la organización y gestión de servicios turísticos para visitantes extranjeros en un destino específico.</rdfs:comment>
        <rdfs:label xml:lang="en">destination management company</rdfs:label>
        <rdfs:label xml:lang="es">operador receptivo</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#DryCleaningOrLaundry -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#DryCleaningOrLaundry">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MiscellaneousService"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se tiñen, se planchan o se limpian en seco o mediante otro procedimiento tejidos y prendas de vestir.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment in which fabrics and clothing are dyed, ironed, dry cleaned or otherwise cleaned.</rdfs:comment>
        <rdfs:label xml:lang="en">dry cleaning or laundry</rdfs:label>
        <rdfs:label xml:lang="es">tintorería o lavandería</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EVChargingStation -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EVChargingStation">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#allowedVehicleType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasTransactionInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#amperage"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#capacity"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#voltage"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Lugar que provee electricidad para la recarga rápida de las baterías de los vehículos eléctricos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place that provides electricity for the rapid recharging of electric vehicle batteries.</rdfs:comment>
        <rdfs:label xml:lang="en">electric vehicle charging station</rdfs:label>
        <rdfs:label xml:lang="es">estación de carga eléctrica</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EducationalCentre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EducationalCentre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#EducationalFacility"/>
        <rdfs:comment xml:lang="es">Establecimiento destinado a la enseñanza.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment intended for teaching.</rdfs:comment>
        <rdfs:label xml:lang="es">centro educativo</rdfs:label>
        <rdfs:label xml:lang="en">educational centre</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EducationalFacility -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EducationalFacility">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TouristOrRelatedFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalEducationalService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Espacios dedicados al aprendizaje y desarrollo de habilidades donde los participantes, generalmente niños o jóvenes, participan en actividades educativas, recreativas y sociales fuera del entorno escolar tradicional y con un enfoque generalmente temático.</rdfs:comment>
        <rdfs:comment xml:lang="en">Spaces dedicated to learning and skill development where participants, generally children or young people, participate in educational, recreational and social activities outside the traditional school environment and with a generally thematic focus.</rdfs:comment>
        <rdfs:label xml:lang="en">educational facility</rdfs:label>
        <rdfs:label xml:lang="es">instalación educativa</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EmbassyAndConsulate -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EmbassyAndConsulate">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasBookingChannel"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#BookingChannel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#countryOfRepresentation"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Representación de la administración pública de un país en otro.</rdfs:comment>
        <rdfs:comment xml:lang="en">Representation of the public administration of a country in another</rdfs:comment>
        <rdfs:label xml:lang="es">embajada y consulado</rdfs:label>
        <rdfs:label xml:lang="en">embassy and consulate</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EmergencyService112 -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EmergencyService112">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:comment xml:lang="en">Single emergency telephone number for the entire European Union where you can communicate any emergency, whether in the field of aid and rescue, health, traffic and security.</rdfs:comment>
        <rdfs:comment xml:lang="es">Teléfono único de emergencias para toda la Unión Europea donde se puede comunicar cualquier emergencia, ya sea del ámbito de auxilio y rescate, sanitario, de tráfico y seguridad.</rdfs:comment>
        <rdfs:label xml:lang="en">emergency service 112</rdfs:label>
        <rdfs:label xml:lang="es">servicio de emergencia 112</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EngineCircuit -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EngineCircuit">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:label xml:lang="es">circuito del motor</rdfs:label>
        <rdfs:label xml:lang="en">engine circuit</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Enoteca -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Enoteca">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AgrotourismFacility"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Groceries"/>
        <rdfs:comment xml:lang="es">Lugar donde se exponen, guardan, venden e incluso se catan o degustan distintas clases de vinos. En algunos lugares también se puede utilizar el término tabanco</rdfs:comment>
        <rdfs:comment xml:lang="en">Place where different types of wines are exhibited, stored, sold and even tasted or tasted</rdfs:comment>
        <rdfs:label xml:lang="es">Enoteca</rdfs:label>
        <rdfs:label xml:lang="en">enoteca</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EquestrianClub -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EquestrianClub">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="en">Facilities that house horses for recreational, sporting or tourist purposes, including sports stables, rental stables and other establishments for equestrian practice.</rdfs:comment>
        <rdfs:comment xml:lang="es">Instalaciones que albergan caballos con fines recreativos deportivos o turísticos incluyendo las cuadras deportivas, las cuadras en alquiler y otros establecimientos para la práctica ecuestre.</rdfs:comment>
        <rdfs:label xml:lang="es">club hípico</rdfs:label>
        <rdfs:label xml:lang="en">equestrian club</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EscapeRoom -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EscapeRoom">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="en">Game that is based on solving a series of tests and finding objects with the objective of escaping from a room.</rdfs:comment>
        <rdfs:comment xml:lang="es">Juego que se basa en resolver una serie de pruebas y encontrar objetos con el objetivo de escapar de una habitación.</rdfs:comment>
        <rdfs:label xml:lang="en">escape room</rdfs:label>
        <rdfs:label xml:lang="es">escape room</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Event -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Event">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#eventSession"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#EventSession"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalEventService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#eventType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasBookingInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasTransactionInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offeredBy"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#EventOrganisationCompany"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#performer"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#availableLanguage"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#availabilityEnds"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#availabilityStarts"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#maximumAttendeeCapacity"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#outdoorEvent"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A planned or scheduled event that has a specific purpose and brings together a group of people to participate in activities, celebrations, or shared experiences.</rdfs:comment>
        <rdfs:comment xml:lang="es">Acontecimiento planificado o programado que tiene un propósito específico y reúne a un grupo de personas para participar en actividades, celebraciones o experiencias compartidas.</rdfs:comment>
        <rdfs:label xml:lang="en">event</rdfs:label>
        <rdfs:label xml:lang="es">evento</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EventAttendanceFacility -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EventAttendanceFacility">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TouristOrRelatedFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalEventAttendanceService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Espacios diseñados y equipados para albergar la celebración de diversas actividades y acontecimientos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Spaces designed and equipped to host various activities and events.</rdfs:comment>
        <rdfs:label xml:lang="en">event attendance facility</rdfs:label>
        <rdfs:label xml:lang="es">instalación para eventos</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EventOrganisationCompany -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EventOrganisationCompany">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrganisation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasLocation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasMultimedia"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasOpeningHours"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasSocialMediaProfile"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasTemporaryClosure"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Company that is mainly responsible for the design, planning, coordination, as well as the production and execution of an event.</rdfs:comment>
        <rdfs:comment xml:lang="es">Empresa que se encarga principalmente del diseño, la planificación, la coordinación, así como la producción y ejecución de un evento.</rdfs:comment>
        <rdfs:label xml:lang="es">Empresa de organización de eventos</rdfs:label>
        <rdfs:label xml:lang="en">Event Organisation Company</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EventSession -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EventSession">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#endsAt"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#sessionDate"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#startsAt"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Período de tiempo específico dentro del programa o agenda del evento en el cual se lleva a cabo una actividad o conjunto de actividades relacionadas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Specific period of time within the event program or agenda in which an activity or set of related activities is carried out.</rdfs:comment>
        <rdfs:label xml:lang="en">event session</rdfs:label>
        <rdfs:label xml:lang="es">sesión de un evento</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ExchangeBureau -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ExchangeBureau">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FinancialService"/>
        <rdfs:comment xml:lang="es">Organización o centro que permite a los clientes cambiar una divisa por otra.</rdfs:comment>
        <rdfs:comment xml:lang="en">Organization or facility that allows customers to exchange one currency for another</rdfs:comment>
        <rdfs:label xml:lang="es">casa de cambio</rdfs:label>
        <rdfs:label xml:lang="en">exchange bureau</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Excursionist -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Excursionist">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PersonRole"/>
        <rdfs:comment xml:lang="en">Person who travels but does not spend the night in a main destination other than their usual environment, for any main purpose other than to be employed by an entity resident in the country or place visited.</rdfs:comment>
        <rdfs:comment xml:lang="es">Persona que viaja pero no pernocta en un destino principal distinto al de su entorno habitual, con cualquier finalidad principal que no sea la de ser empleado por una entidad residente en el país o lugar visitado.</rdfs:comment>
        <rdfs:label xml:lang="en">excursionist</rdfs:label>
        <rdfs:label xml:lang="es">excursionista</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ExhibitionHall -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ExhibitionHall">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="es">Espacio de fomento, promoción y difusión de las artes plásticas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Space for the promotion, promotion and dissemination of the plastic arts.</rdfs:comment>
        <rdfs:label xml:lang="en">exhibition hall</rdfs:label>
        <rdfs:label xml:lang="es">sala de exposiciones</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#FarmSchool -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#FarmSchool">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#EducationalFacility"/>
        <rdfs:comment xml:lang="en">Educational and learning space where activities related to nature, the rural world and respect for the environment are carried out.</rdfs:comment>
        <rdfs:comment xml:lang="es">Espacio educativo y de aprendizaje donde se realizan actividades relacionadas con la naturaleza, el mundo rural y el respeto al medio ambiente.</rdfs:comment>
        <rdfs:label xml:lang="en">farm school</rdfs:label>
        <rdfs:label xml:lang="es">granja escuela</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Ferry -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Ferry">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MeansOfTransport"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalFerryService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#maximumVehicleHeightAccepted"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#maximumVehicleLengthtAccepted"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Barco que enlaza dos puntos llevando pasajeros y a veces vehículos en horarios programados. Forman parte del transporte público en algunas ciudades situadas en la costa, con bahías, grandes lagos o ríos, permitiendo el tránsito directo entre dos puntos y su coste es mucho menor a la construcción de puentes y túneles. En algunas regiones la palabra transbordador se usa para el buque que une distancias cortas (dos orillas de un río, por ejemplo), mientras que ferry se denomina a un buque que cubre mayores recorridos y es también de mayores dimensiones.</rdfs:comment>
        <rdfs:comment xml:lang="en">Boat that connects two points carrying passengers and sometimes vehicles at scheduled times. They are part of public transport in some cities located on the coast, with bays, large lakes or rivers, allowing direct transit between two points and their cost is much lower than the construction of bridges and tunnels. In some regions the word ferry is used for a ship that connects short distances (two banks of a river, for example), while a ferry is a ship that covers longer distances and is also larger.</rdfs:comment>
        <rdfs:label xml:lang="en">ferry</rdfs:label>
        <rdfs:label xml:lang="es">transbordador ferry</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#FerryOperator -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#FerryOperator">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PassengerTransportCompany"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#ferry"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Ferry"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalFerryOperatorService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Company dedicated to operating maritime transportation services for passengers and vehicles through ferries and specific maritime routes.</rdfs:comment>
        <rdfs:comment xml:lang="es">Compañía que se dedica a operar servicios de transporte marítimo de pasajeros y vehículos a través de ferrys y rutas marítimas específicas.</rdfs:comment>
        <rdfs:label xml:lang="en">ferry operator</rdfs:label>
        <rdfs:label xml:lang="es">operador de ferrys</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#FinancialService -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#FinancialService">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LocalBusiness"/>
        <rdfs:comment xml:lang="es">Actividad o función relacionada con la gestión, el manejo o la intermediación de dinero y recursos financieros.</rdfs:comment>
        <rdfs:comment xml:lang="en">Activity or function related to the management, handling or intermediation of money and financial resources.</rdfs:comment>
        <rdfs:label xml:lang="en">financial service</rdfs:label>
        <rdfs:label xml:lang="es">servicio financiero</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#FireService -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#FireService">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:comment xml:lang="en">Competent body for the prevention, preparation and attention of fires and other emergencies</rdfs:comment>
        <rdfs:comment xml:lang="es">Órgano competente para la prevención, preparación y atención de incendios y otras emergencias</rdfs:comment>
        <rdfs:label xml:lang="es">cuerpo de bomberos</rdfs:label>
        <rdfs:label xml:lang="en">fire service</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#FootballField -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#FootballField">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="en">Area where a soccer match takes place.</rdfs:comment>
        <rdfs:comment xml:lang="es">Área donde se desarrolla un partido de fútbol.</rdfs:comment>
        <rdfs:label xml:lang="es">campo de fútbol</rdfs:label>
        <rdfs:label xml:lang="en">football field</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Forest -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Forest">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="es">Ecosistema donde la vegetación predominante la constituyen los árboles y arbustos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Ecosystem where the predominant vegetation is trees and shrubs.</rdfs:comment>
        <rdfs:label xml:lang="es">bosque</rdfs:label>
        <rdfs:label xml:lang="en">forest</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Garden -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Garden">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Terreno donde se cultivan especies vegetales, con posible añadidura de otros elementos como fuentes, esculturas o zonas de ocio. También pueden referirse a parques urbanos.</rdfs:comment>
        <rdfs:label xml:lang="en">garden</rdfs:label>
        <rdfs:label xml:lang="es">jardín</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#GasStation -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#GasStation">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:comment xml:lang="es">Establecimiento o puesto de venta en el que se vende y suministra a vehículos automóviles gasolina u otros combustibles.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment or sales stand in which gasoline or other fuels are sold and supplied to automobile vehicles.</rdfs:comment>
        <rdfs:label xml:lang="en">gas station</rdfs:label>
        <rdfs:label xml:lang="es">gasolinera</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#GastronomicMarket -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#GastronomicMarket">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantService"/>
        <rdfs:comment xml:lang="es">Lugar donde se reúnen diferentes puestos de comida y bebida en un espacio común donde consumir productos y elaboraciones de carácter gourmet.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place where different food and drink stalls meet in a common space where you can consume gourmet products and preparations.</rdfs:comment>
        <rdfs:label xml:lang="en">gastronomic market</rdfs:label>
        <rdfs:label xml:lang="es">mercado gastronómico</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Gastronomy_-_deprecated -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Gastronomy_-_deprecated">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Referido a la cocina, los productos y platos típicos de una región como experiencia cultural de un destino.</rdfs:comment>
        <rdfs:label xml:lang="en">gastronomy -deprecated</rdfs:label>
        <rdfs:label xml:lang="es">gastronomía - deprecado</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#GeneralStore -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#GeneralStore">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Groceries"/>
        <rdfs:comment xml:lang="es">Establecimiento o tienda comercial que vende diversos productos alimenticios.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment or commercial store that sells various food products.</rdfs:comment>
        <rdfs:label xml:lang="en">general store</rdfs:label>
        <rdfs:label xml:lang="es">tienda de ultramarinos</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Geyser -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Geyser">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="es">Fuente termal intermitente, en forma de surtidor.</rdfs:comment>
        <rdfs:comment xml:lang="en">Intermittent hot spring, in the form of a jet</rdfs:comment>
        <rdfs:label xml:lang="en">geyser</rdfs:label>
        <rdfs:label xml:lang="es">géiser</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Glamping -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Glamping">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Accommodation"/>
        <rdfs:comment xml:lang="en">Camping type that combines the experience of outdoor camping with the comforts and luxuries of the best hotels.</rdfs:comment>
        <rdfs:comment xml:lang="es">Modalidad de acampada que combina la experiencia de acampar al aire libre con las comodidades y lujos propios de los mejores hoteles.</rdfs:comment>
        <rdfs:label xml:lang="en">glamping</rdfs:label>
        <rdfs:label xml:lang="es">glamping</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#GlobalDistributionSystem -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#GlobalDistributionSystem">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TouristIntermediary"/>
        <rdfs:comment xml:lang="en">Global reservation computer system that acts as a conduit between travel reservists and suppliers.</rdfs:comment>
        <rdfs:comment xml:lang="es">Sistema informático de reservas mundial que actúa como conducto entre los reservistas de viajes y los proveedores.</rdfs:comment>
        <rdfs:label xml:lang="en">global distribution system</rdfs:label>
        <rdfs:label xml:lang="es">sistema de distribución global</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#GolfCourse -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#GolfCourse">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="en">Large outdoor natural grass area where golf is practiced.</rdfs:comment>
        <rdfs:comment xml:lang="es">Área amplia de hierba natural al aire libre donde se practica el golf.</rdfs:comment>
        <rdfs:label xml:lang="es">campo de golf</rdfs:label>
        <rdfs:label xml:lang="en">golf course</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Groceries -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Groceries">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LocalBusiness"/>
        <rdfs:comment xml:lang="es">Espacios físicos que proporcionan a los consumidores un lugar accesible y conveniente donde se ofrecen productos alimenticios para su compra y consumo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Physical spaces that provide consumers with an accessible and convenient place where food products are offered for purchase and consumption.</rdfs:comment>
        <rdfs:label xml:lang="es">alimentación</rdfs:label>
        <rdfs:label xml:lang="en">groceries</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#GuestHouse -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#GuestHouse">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Accommodation"/>
        <rdfs:comment xml:lang="es">Casa donde se reciben huéspedes mediante precio convenido.</rdfs:comment>
        <rdfs:comment xml:lang="en">House where guests are received at an agreed price.</rdfs:comment>
        <rdfs:label xml:lang="en">guest house</rdfs:label>
        <rdfs:label xml:lang="es">pensión</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Gym -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Gym">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalGymService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Local dotado de las instalaciones y los aparatos adecuados para hacer gimnasia y practicar ciertos deportes.</rdfs:comment>
        <rdfs:comment xml:lang="en">Local equipped with the appropriate facilities and equipment to do gymnastics and practice certain sports.</rdfs:comment>
        <rdfs:label xml:lang="es">gimnasio</rdfs:label>
        <rdfs:label xml:lang="en">gym</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Hairdressing -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Hairdressing">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MiscellaneousService"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se peina, se corta, se arregla y se cuida el cabello.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment where hair is combed, cut, groomed and cared for.</rdfs:comment>
        <rdfs:label xml:lang="en">hairdressing</rdfs:label>
        <rdfs:label xml:lang="es">peluquería</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Hammam -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Hammam">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:label xml:lang="es">Baños árabes</rdfs:label>
        <rdfs:label xml:lang="en">Hammam</rdfs:label>
        <rdfs:label xml:lang="es">Los baños árabes, también conocidos como hammam, son espacios públicos de baño que combinan la limpieza del cuerpo con la relajación y el bienestar</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#HandicraftAndLocalProduct -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#HandicraftAndLocalProduct">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Productos artesanales y creaciones hechas a mano por artesanos locales (tejidos, cerámica, joyería, productos de cuero, talla de madera, etc.)</rdfs:comment>
        <rdfs:label xml:lang="es">artesanía y producto local</rdfs:label>
        <rdfs:label xml:lang="en">handicraft and local product</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Handicrafts -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Handicrafts">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashion"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalHandiCraftService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Store dedicated to the sale of handmade products by artisans.</rdfs:comment>
        <rdfs:comment xml:lang="es">Tienda que se dedica a la venta de productos hechos a mano por artesanos.</rdfs:comment>
        <rdfs:label xml:lang="en">handicrafts</rdfs:label>
        <rdfs:label xml:lang="es">tienda de artesanías</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#HealthAndWellnessFacility -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#HealthAndWellnessFacility">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TouristOrRelatedFacility"/>
        <rdfs:label xml:lang="en">health and wellness facility</rdfs:label>
        <rdfs:label xml:lang="es">instalación de salud y bienestar</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#HealthResort -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#HealthResort">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HealthAndWellnessFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalHealthResortService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Establecimiento dotado de instalaciones apropiadas para tomar baños medicinales y curativos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment equipped with appropriate facilities to take medicinal and curative baths.</rdfs:comment>
        <rdfs:label xml:lang="es">balneario</rdfs:label>
        <rdfs:label xml:lang="en">health resort</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismResource"/>
        <rdfs:comment xml:lang="es">Lugares, sitios y estructuras que tienen un valor significativo para los turistas desde el punto de vista histórico, arqueológico, arquitectónico o cultural.</rdfs:comment>
        <rdfs:comment xml:lang="en">Places, sites and structures that have significant value to tourists from a historical, archaeological, architectural or cultural point of view</rdfs:comment>
        <rdfs:label xml:lang="en">historical and/or cultural resource</rdfs:label>
        <rdfs:label xml:lang="es">recurso histórico y/o cultural</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#HolidayPackage -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#HolidayPackage">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#allinclusivePackage"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#duration"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#itinerary"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#maximumAttendeeCapacity"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#slogan"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#subcategory"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Experience that is marketed only through travel agencies that contains two or more tourist services (accommodation, maintenance or transportation) for which the client pays a price.</rdfs:comment>
        <rdfs:comment xml:lang="es">Experiencia que se comercializa únicamente por medio de las agencias de viajes que contiene dos o más servicios de carácter turístico (alojamiento, manutención o transporte) por el que el cliente abona un precio.</rdfs:comment>
        <rdfs:label xml:lang="en">holiday package</rdfs:label>
        <rdfs:label xml:lang="es">paquete turístico</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Horchateria -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Horchateria">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantService"/>
        <rdfs:comment xml:lang="es">Establecimiento donde se vende o se sirve horchata.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment where horchata is sold or served.</rdfs:comment>
        <rdfs:label xml:lang="en">horchateria</rdfs:label>
        <rdfs:label xml:lang="es">horchatería</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Hostal -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Hostal">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Accommodation"/>
        <rdfs:comment xml:lang="es">Establecimiento hotelero de categoría inferior a un hotel.</rdfs:comment>
        <rdfs:comment xml:lang="en">Hotel establishment of a category lower than a hotel.</rdfs:comment>
        <rdfs:label xml:lang="en">hostal</rdfs:label>
        <rdfs:label xml:lang="es">hostal</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Hostel -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Hostel">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Accommodation"/>
        <rdfs:comment xml:lang="es">Establecimiento hotelero para estancias cortas, generalmente situado en un lugar de paso o estratégico.</rdfs:comment>
        <rdfs:comment xml:lang="en">Hotel establishment for short stays, generally located in a transit or strategic location.</rdfs:comment>
        <rdfs:label xml:lang="es">Albergue</rdfs:label>
        <rdfs:label xml:lang="en">hostel</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Hotel -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Hotel">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Accommodation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#stars"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Establecimiento, reconocido o registrado como hotel según la legislación aplicable, con recepción, servicios e instalaciones adicionales que ofrece alojamiento y, en la mayoría de los casos, servicios de comidas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment, recognized or registered as a hotel under applicable legislation, with reception, additional services and facilities offering accommodation and, in most cases, food services.</rdfs:comment>
        <rdfs:label xml:lang="en">hotel</rdfs:label>
        <rdfs:label xml:lang="es">hotel</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#IceCreamShop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#IceCreamShop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantService"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se comercializan y se sirven helados.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment in which ice cream is sold and served.</rdfs:comment>
        <rdfs:label xml:lang="es">heladería</rdfs:label>
        <rdfs:label xml:lang="en">ice cream shop</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Inn -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Inn">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantService"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se preparan y sirven comidas y que está decorado de forma tradicional y rústica. También se puede utilizar el término venta</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment in which meals are prepared and served and which is decorated in a traditional and rustic way.</rdfs:comment>
        <rdfs:label xml:lang="en">inn</rdfs:label>
        <rdfs:label xml:lang="es">mesón</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#InterpretationCentre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#InterpretationCentre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#EducationalFacility"/>
        <rdfs:comment xml:lang="es">Espacio que revela el significado y la relación del patrimonio con el visitante que llega hasta el sitio turístico que lo contiene.</rdfs:comment>
        <rdfs:comment xml:lang="en">Space that reveals the meaning and relationship of heritage with the visitor who arrives at the tourist site that contains it.</rdfs:comment>
        <rdfs:label xml:lang="es">centro de interpretación</rdfs:label>
        <rdfs:label xml:lang="en">interpretation centre</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#JewelryAndWatches -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#JewelryAndWatches">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashion"/>
        <rdfs:comment xml:lang="es">Establecimiento donde se venden joyas y relojes</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment where jewelry and watches are sold</rdfs:comment>
        <rdfs:label xml:lang="en">jewelry and watches</rdfs:label>
        <rdfs:label xml:lang="es">joyería y relojería</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Karaoke -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Karaoke">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PartyAndEntertainmentFacility"/>
        <rdfs:comment xml:lang="es">Local público con instalaciones para karaoke, equipo que se usa para interpretar canciones sobre un fondo musical grabado, mientras se sigue la letra que aparece en una pantalla.</rdfs:comment>
        <rdfs:comment xml:lang="en">Public venue with karaoke facilities, equipment used to perform songs over a recorded musical background, while following the lyrics that appear on a screen.</rdfs:comment>
        <rdfs:label xml:lang="en">karaoke</rdfs:label>
        <rdfs:label xml:lang="es">karaoke</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#KartsCircuit -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#KartsCircuit">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Espacio provisto de una o varias pistas preparadas para disputar carreras con estos vehículos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Space provided with one or more tracks prepared to compete in races with these vehicles.</rdfs:comment>
        <rdfs:label xml:lang="es">circuito de karts</rdfs:label>
        <rdfs:label xml:lang="en">karts circuit</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Kiosk -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Kiosk">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashion"/>
        <rdfs:comment xml:lang="es">Local comercial de pequeño tamaño destinado a la venta de periódicos, revistas, golosinas y otros artículos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Small commercial premises for the sale of newspapers, magazines, candy and other items.</rdfs:comment>
        <rdfs:label xml:lang="en">kiosk</rdfs:label>
        <rdfs:label xml:lang="es">quiosco</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Label -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Label">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Acknowledgement"/>
        <rdfs:comment xml:lang="es">Aquellos reconocimientos que el propio establecimiento se otorga, o que son obtenidos a través de una membresía.</rdfs:comment>
        <rdfs:comment xml:lang="en">Those recognitions that the establishment itself grants, or that are obtained through a membership.</rdfs:comment>
        <rdfs:label xml:lang="es">Distintivo</rdfs:label>
        <rdfs:label xml:lang="en">Label</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Lake -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Lake">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalLakeService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Gran masa permanente de agua depositada en depresiones del terreno.</rdfs:comment>
        <rdfs:comment xml:lang="en">Large permanent mass of water deposited in depressions in the ground.</rdfs:comment>
        <rdfs:label xml:lang="es">lago</rdfs:label>
        <rdfs:label xml:lang="en">lake</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Landform -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Landform">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:label xml:lang="es">accidente geográfico</rdfs:label>
        <rdfs:label xml:lang="en">landform</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TouristOrRelatedFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalLeisureAndCultureService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Espacios destinados a actividades recreativas, artísticas y culturales que ofrecen oportunidades para el entretenimiento, la diversión y la apreciación de diversas formas de expresión artística y cultural.</rdfs:comment>
        <rdfs:comment xml:lang="en">Spaces for recreational, artistic and cultural activities that offer opportunities for entertainment, fun and appreciation of various forms of artistic and cultural expression.</rdfs:comment>
        <rdfs:label xml:lang="es">instalación de cultura y ocio</rdfs:label>
        <rdfs:label xml:lang="en">leisure and culture facility</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#LenghtOfStay -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#LenghtOfStay">
        <rdfs:label xml:lang="es">duración de la visita</rdfs:label>
        <rdfs:label xml:lang="en">lenght of stay</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Library -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Library">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="es">Lugar cuya finalidad consiste en la adquisición, conservación, estudio y exposición de libros y documentos</rdfs:comment>
        <rdfs:label xml:lang="es">Biblioteca</rdfs:label>
        <rdfs:label xml:lang="en">Library</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#LocalBusiness -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#LocalBusiness">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismResource"/>
        <rdfs:comment xml:lang="en">Company or commercial establishment that operates in a specific physical location that provides products or services.</rdfs:comment>
        <rdfs:comment xml:lang="es">Empresa o establecimiento comercial que opera en una ubicación física específica que proporciona productos o servicios.</rdfs:comment>
        <rdfs:label xml:lang="en">local business</rdfs:label>
        <rdfs:label xml:lang="es">negocio local</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Location -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Location">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#autonomousCommunity"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#locality"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#postalCode"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#province"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#streetAddress"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#country"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#county"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Proporciona información sobre la ubicación física de un negocio, establecimiento u organización.</rdfs:comment>
        <rdfs:comment xml:lang="en">Provides information about the physical location of a business, establishment or organization.</rdfs:comment>
        <rdfs:label xml:lang="es">localización</rdfs:label>
        <rdfs:label xml:lang="en">location</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Lodge -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Lodge">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Accommodation"/>
        <rdfs:comment xml:lang="es">Establecimiento hotelero formado por varias unidades independientes alojativas (bungalows, cabañas, villas) edificadas en entornos naturales y construidos con materiales propios del lugar, normalmente madera, cuyo fin es acercar al cliente a la naturaleza.</rdfs:comment>
        <rdfs:comment xml:lang="en">Hotel establishment made up of several independent accommodation units (bungalows, cabins, villas) built in natural environments and built with local materials, usually wood, whose purpose is to bring the client closer to nature.</rdfs:comment>
        <rdfs:label xml:lang="en">Lodge</rdfs:label>
        <rdfs:label xml:lang="es">Lodge</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#LuggageStore -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#LuggageStore">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MiscellaneousService"/>
        <rdfs:comment xml:lang="es">Lugares reservados para guardar el equipaje de forma segura y para espacios de tiempo cortos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Reserved places to store luggage safely and for short periods of time.</rdfs:comment>
        <rdfs:label xml:lang="es">consigna de equipaje</rdfs:label>
        <rdfs:label xml:lang="en">lugagge store</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#MassageCentre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#MassageCentre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HealthAndWellnessFacility"/>
        <rdfs:comment xml:lang="en">Business that provides relaxation, health and body well-being services through therapeutic and anti-stress massages.</rdfs:comment>
        <rdfs:comment xml:lang="es">Negocio que brinda los servicios de relax, salud y bienestar corporal por medio de masajes terapéuticos y anti estrés.</rdfs:comment>
        <rdfs:label xml:lang="es">centro de masajes</rdfs:label>
        <rdfs:label xml:lang="en">massage centre</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#MeansOfTransport -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#MeansOfTransport">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasContactPoint"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasDescription"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasMultimedia"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPaymentInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#availableLanguage"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">means of transport</rdfs:label>
        <rdfs:label xml:lang="es">medio de transporte</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#MedicalService -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#MedicalService">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LocalBusiness"/>
        <rdfs:comment xml:lang="es">Atención y cuidado de la salud proporcionados por profesionales de la salud para mantener, promover y restablecer la salud de las personas, prevenir enfermedades y lesiones, y brindar diagnóstico, tratamiento y seguimiento médico.</rdfs:comment>
        <rdfs:comment xml:lang="en">Health care and care provided by health professionals to maintain, promote and restore people&apos;s health, prevent illness and injury, and provide diagnosis, treatment and medical follow-up.</rdfs:comment>
        <rdfs:label xml:lang="en">medical service</rdfs:label>
        <rdfs:label xml:lang="es">servicio médico</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Menu -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Menu">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#menuOptions"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#availableLanguage"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersWineMenu"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Document that presents the food and beverage options available in a food and beverage establishment.</rdfs:comment>
        <rdfs:comment xml:lang="es">Documento que presenta las opciones de alimentos y bebidas disponibles en un establecimiento de comida y bebida.</rdfs:comment>
        <rdfs:label xml:lang="es">carta</rdfs:label>
        <rdfs:label xml:lang="en">menu</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#MetasearchEngine -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#MetasearchEngine">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TouristIntermediary"/>
        <rdfs:comment xml:lang="es">Herramienta en línea que permite a los usuarios buscar y comparar múltiples opciones de viaje en un solo lugar.</rdfs:comment>
        <rdfs:comment xml:lang="en">Online tool that allows users to search and compare multiple travel options in one place.</rdfs:comment>
        <rdfs:label xml:lang="es">metabuscador</rdfs:label>
        <rdfs:label xml:lang="en">metasearch engine</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Micromobility -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Micromobility">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PassengerTransportCompany"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalMicromobilityService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#areaServed"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#app"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#standardPrice"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#topSpeedLimit"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Modalidad de transporte a través de vehículos muy ligeros como patinetes eléctricos, monopatines eléctricos, bicicletas compartidas y bicicletas con asistencia.</rdfs:comment>
        <rdfs:comment xml:lang="en">Mode of transportation through very light vehicles such as electric scooters, electric skateboards, shared bicycles and bicycles with assistance.</rdfs:comment>
        <rdfs:label xml:lang="en">micromobility</rdfs:label>
        <rdfs:label xml:lang="es">micromovilidad</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Minaret -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Minaret">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Torre de las mezquitas desde cuya altura convoca el almuédano a los musulmanes en las horas de oración.</rdfs:comment>
        <rdfs:label xml:lang="en">minaret</rdfs:label>
        <rdfs:label xml:lang="es">minarete</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#MiscellaneousService -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#MiscellaneousService">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LocalBusiness"/>
        <rdfs:comment xml:lang="es">Espacios físicos donde se ofrecen una variedad de servicios para satisfacer las necesidades de los clientes.</rdfs:comment>
        <rdfs:comment xml:lang="en">Physical spaces where a variety of services are offered to satisfy customer needs.</rdfs:comment>
        <rdfs:label xml:lang="en">miscallaneous service</rdfs:label>
        <rdfs:label xml:lang="es">servicios varios</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ModificationFee -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ModificationFee">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#free"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#freeCancellationValidity"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#penalty"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Amount of money that a service provider can charge the client when the client modifies a previously confirmed reservation.</rdfs:comment>
        <rdfs:comment xml:lang="es">Cantidad de dinero que un proveedor de servicios puede cobrar al cliente cuando éste modifica una reserva previamente confirmada.</rdfs:comment>
        <rdfs:label xml:lang="es">cargo por modificación</rdfs:label>
        <rdfs:label xml:lang="en">modification fee</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Monastery -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Monastery">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Casa, ordinariamente fuera de poblado, donde viven monjes en comunidad.</rdfs:comment>
        <rdfs:label xml:lang="es">monasterio</rdfs:label>
        <rdfs:label xml:lang="en">monastery</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Monument -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Monument">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Construcción arquitectónica o escultórica, generalmente de grandes dimensiones, que se erige en recuerdo de una persona o hecho memorable.</rdfs:comment>
        <rdfs:label xml:lang="en">monument</rdfs:label>
        <rdfs:label xml:lang="es">monumento</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Mosque -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Mosque">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Templo musulmán.</rdfs:comment>
        <rdfs:label xml:lang="es">mezquita</rdfs:label>
        <rdfs:label xml:lang="en">mosque</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Motel -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Motel">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Accommodation"/>
        <rdfs:comment xml:lang="en">Modest type of tourist accommodation characterized by being located close to roads and offering accommodation and parking for short-term stays.</rdfs:comment>
        <rdfs:comment xml:lang="es">Tipo de alojamiento turístico modesto que se caracteriza por estar situado próximo a carreteras y ofrecer alojamiento y aparcamiento para estancias de corta duración.</rdfs:comment>
        <rdfs:label xml:lang="en">Motel</rdfs:label>
        <rdfs:label xml:lang="es">Motel</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Mountain -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Mountain">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="es">Gran elevación natural del terreno.</rdfs:comment>
        <rdfs:comment xml:lang="en">Great natural elevation of the land</rdfs:comment>
        <rdfs:label xml:lang="es">montaña</rdfs:label>
        <rdfs:label xml:lang="en">mountain</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#MountainShelter -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#MountainShelter">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Accommodation"/>
        <rdfs:label xml:lang="en">mountain shelter</rdfs:label>
        <rdfs:label xml:lang="es">refugio de montaña</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#MovieTheater -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#MovieTheater">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalMovieTheatreService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Establecimiento destinado a la proyección de películas cinematográficas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment intended for the projection of cinematographic films.</rdfs:comment>
        <rdfs:label xml:lang="es">cine</rdfs:label>
        <rdfs:label xml:lang="en">movie theater</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#MultiAdventureCentre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#MultiAdventureCentre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersActivity"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Activity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Center oriented towards sports or practices that involve, in addition to physical activity, intense recreational activity in the natural environment.</rdfs:comment>
        <rdfs:comment xml:lang="es">Centro orientado a los deportes o prácticas que conllevan, además de una actividad física, una intensa actividad recreativa en el medio natural.</rdfs:comment>
        <rdfs:label xml:lang="es">centro de actividades multiaventura</rdfs:label>
        <rdfs:label xml:lang="en">multiadventure centre</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Multimedia -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Multimedia">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#secondaryImage"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#video"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#mainImage"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#logo"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Contenido visual o interactivo utilizados para captar la atención del usuario, transmitir información de manera más visual y atractiva, y proporcionar una experiencia interactiva.</rdfs:comment>
        <rdfs:comment xml:lang="en">Visual or interactive content used to capture the user&apos;s attention, convey information in a more visual and attractive way, and provide an interactive experience.</rdfs:comment>
        <rdfs:label xml:lang="en">multimedia</rdfs:label>
        <rdfs:label xml:lang="es">multimedia</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Museum -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Museum">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#museumType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalMuseumService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Institución sin ánimo de lucro permanente cuya finalidad consiste en la adquisición, conservación, estudio y exposición al público de objetos de interés cultural.</rdfs:comment>
        <rdfs:comment xml:lang="en">Permanent non-profit institution whose purpose is the acquisition, conservation, study and exhibition to the public of objects of cultural interest.</rdfs:comment>
        <rdfs:label xml:lang="es">museo</rdfs:label>
        <rdfs:label xml:lang="en">museum</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#MusicVenue -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#MusicVenue">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#EventAttendanceFacility"/>
        <rdfs:comment xml:lang="es">Local dedicado a interpretaciones de música en vivo</rdfs:comment>
        <rdfs:comment xml:lang="en">Venue dedicated to live music performances</rdfs:comment>
        <rdfs:label xml:lang="en">music venue</rdfs:label>
        <rdfs:label xml:lang="es">sala de conciertos</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#NaturalPark -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalPark">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="es">Espacio natural legalmente protegido que, por su belleza o por la singularidad de su fauna y flora, posee valor ecológico y cultural.</rdfs:comment>
        <rdfs:comment xml:lang="en">Legally protected natural space that, due to its beauty or the uniqueness of its fauna and flora, has ecological and cultural value</rdfs:comment>
        <rdfs:label xml:lang="en">natural park</rdfs:label>
        <rdfs:label xml:lang="es">parque natural</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#NaturalResource -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalResource">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismResource"/>
        <rdfs:comment xml:lang="es">Lugar, paisaje o fenómeno de la naturaleza que posee un valor especial y atractivo para los turistas. Son apreciados por su belleza escénica, biodiversidad, características geológicas únicas o experiencias al aire libre que ofrecen a los visitantes.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place, landscape or natural phenomenon that has a special and attractive value for tourists. They are appreciated for their scenic beauty, biodiversity, unique geological features or outdoor experiences they offer to visitors.</rdfs:comment>
        <rdfs:label xml:lang="en">natural resource</rdfs:label>
        <rdfs:label xml:lang="es">recurso natural</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#NaturalViewPoint -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalViewPoint">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="es">Lugar o punto elevado desde el cual puede contemplarse con facilidad un paisaje.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place or elevated point from which a landscape can be easily seen</rdfs:comment>
        <rdfs:label xml:lang="es">mirador natural</rdfs:label>
        <rdfs:label xml:lang="en">natural viewpoint</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#NightClub -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#NightClub">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PartyAndEntertainmentFacility"/>
        <rdfs:comment xml:lang="es">Local público donde sirven bebidas y se baila al son de música grabada.</rdfs:comment>
        <rdfs:comment xml:lang="en">Public place where they serve drinks and dance to recorded music.</rdfs:comment>
        <rdfs:label xml:lang="es">discoteca</rdfs:label>
        <rdfs:label xml:lang="en">night club</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#OilPress -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#OilPress">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AgrotourismFacility"/>
        <rdfs:comment xml:lang="es">Molino de aceite</rdfs:comment>
        <rdfs:comment xml:lang="en">Oil press</rdfs:comment>
        <rdfs:label xml:lang="es">Almazara</rdfs:label>
        <rdfs:label xml:lang="en">Oil Press</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#OnlineTravelAgency -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#OnlineTravelAgency">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TouristIntermediary"/>
        <rdfs:comment xml:lang="en">Company that provides organization, planning, development and sale services of products or services of a tourist nature and purposes between suppliers and end customers, exclusively in the digital environment.</rdfs:comment>
        <rdfs:comment xml:lang="es">Empresa que presta servicios de organización, planificación, desarrollo y venta de productos o servicios de naturaleza y fines turísticos entre proveedores y clientes finales, exclusivamente en el entorno digital.</rdfs:comment>
        <rdfs:label xml:lang="es">agencia de viajes online</rdfs:label>
        <rdfs:label xml:lang="en">online travel agency</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#OpeningHours -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#OpeningHours">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#dayOfTheWeek"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#DayOfTheWeek"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasDescription"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Description"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#closesAt"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#open24Hours"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#opensAt"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#temporaryClosure"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#validFrom"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#validTo"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Period of time during which a business, establishment or service is available to serve customers or carry out commercial activities.</rdfs:comment>
        <rdfs:comment xml:lang="es">Período de tiempo durante el cual un negocio, establecimiento o servicio está disponible para atender a clientes o realizar actividades comerciales.</rdfs:comment>
        <rdfs:label xml:lang="es">Horario de apertura</rdfs:label>
        <rdfs:label xml:lang="en">Opening Hours</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#OrnamentalFountain -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#OrnamentalFountain">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:label xml:lang="es">Estructura, típicamente de agua, diseñada para embellecer un espacio, tanto interior como exterior, a través de su forma, diseño y efectos visuales y/o auditivos</rdfs:label>
        <rdfs:label xml:lang="es">Fuente ornamental</rdfs:label>
        <rdfs:label xml:lang="en">Ornamental Fountain</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PaddelCourt -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PaddelCourt">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Cancha rectangular cerrada para la práctica de este deporte.</rdfs:comment>
        <rdfs:comment xml:lang="en">Closed rectangular court for the practice of this sport.</rdfs:comment>
        <rdfs:label xml:lang="en">paddel court</rdfs:label>
        <rdfs:label xml:lang="es">pista de pádel</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Palace -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Palace">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Mansión grande y lujosa destinada a ser residencia de reyes, de aristócratas o de personajes importantes.</rdfs:comment>
        <rdfs:label xml:lang="en">palace</rdfs:label>
        <rdfs:label xml:lang="es">palacio</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Parador -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Parador">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Accommodation"/>
        <rdfs:label xml:lang="en">parador</rdfs:label>
        <rdfs:label xml:lang="es">parador</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ParcelAndCourier -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ParcelAndCourier">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MiscellaneousService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#deliveryPoint"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#DeliveryPoint"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalParcelAndCourierService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#maximumSize"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#maximumWeight"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Mail and package delivery service carried out by a company.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicio de reparto de correspondencia y de paquetes realizado por una empresa.</rdfs:comment>
        <rdfs:label xml:lang="es">paquetería y mensajería</rdfs:label>
        <rdfs:label xml:lang="en">parcel and courier</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ParkingFacility -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ParkingFacility">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#allowedVehicleType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalParkingFacilityService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#parkingType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#parkingType"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#capacity"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#isIndoorParking"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#maximumParkingDuration"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Lugar o recinto destinado a aparcar vehículos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place or area intended for parking vehicles.</rdfs:comment>
        <rdfs:label xml:lang="es">aparcamiento</rdfs:label>
        <rdfs:label xml:lang="en">parking</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PartyAndEntertainmentFacility -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PartyAndEntertainmentFacility">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TouristOrRelatedFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalPartyAndEntertaimentService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Espacios destinados a la diversión, celebración y entretenimiento de las personas, diseñados para ofrecer experiencias sociales y recreativas a través de música, baile, bebidas, espectáculos en vivo y actividades temáticas o lúdicas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Spaces intended for fun, celebration and entertainment of people, designed to offer social and recreational experiences through music, dance, drinks, live shows and thematic or recreational activities.</rdfs:comment>
        <rdfs:label xml:lang="es">instalación para fiestas y entretenimiento</rdfs:label>
        <rdfs:label xml:lang="en">party and entertainment facility</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PassengerTerminal -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PassengerTerminal">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:label xml:lang="en">passenger terminal</rdfs:label>
        <rdfs:label xml:lang="es">terminal portuaria de pasajeros</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PassengerTransportCompany -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PassengerTransportCompany">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrganisation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasTransactionInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Transportation dedicated to the movement of people and their luggage in vehicles built and conditioned for this purpose.</rdfs:comment>
        <rdfs:comment xml:lang="es">Transporte dedicado al desplazamiento de las personas y sus equipajes en vehículos construidos y acondicionados para tal fin.</rdfs:comment>
        <rdfs:label xml:lang="es">compañía de transporte de pasajeros</rdfs:label>
        <rdfs:label xml:lang="en">passenger transport company</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PaymentInformation -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PaymentInformation">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#paymentMethod"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#PaymentMethod"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#currency"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Datos relevantes sobre el pago que el turista requiere conocer para proceder con la adquisición de un producto o servicio.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relevant payment data that the tourist needs to know to proceed with the acquisition of a product or service.</rdfs:comment>
        <rdfs:label xml:lang="es">información de pago</rdfs:label>
        <rdfs:label xml:lang="en">payment information</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PaymentMethod -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PaymentMethod">
        <rdfs:comment xml:lang="es">Diferentes formas en que los clientes pueden realizar transacciones de compra y pagar por bienes o servicios.</rdfs:comment>
        <rdfs:comment xml:lang="en">Different ways in which customers can carry out purchase transactions and pay for goods or services.</rdfs:comment>
        <rdfs:label xml:lang="es">método de pago</rdfs:label>
        <rdfs:label xml:lang="en">payment method</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Perfumery -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Perfumery">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashion"/>
        <rdfs:comment xml:lang="en">Store where perfumes are sold.</rdfs:comment>
        <rdfs:comment xml:lang="es">Tienda donde se venden perfumes.</rdfs:comment>
        <rdfs:label xml:lang="en">perfumery</rdfs:label>
        <rdfs:label xml:lang="es">perfumería</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Person -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Person">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPersonRole"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#PersonRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#originLocation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#age"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">person</rdfs:label>
        <rdfs:label xml:lang="es">persona</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PersonRole -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PersonRole">
        <rdfs:label xml:lang="en">person role</rdfs:label>
        <rdfs:label xml:lang="es">rol de una persona</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Pharmacy -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Pharmacy">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MedicalService"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se preparan y venden medicamentos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment in which medicines are prepared and sold.</rdfs:comment>
        <rdfs:label xml:lang="es">farmacia</rdfs:label>
        <rdfs:label xml:lang="en">pharmacy</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Planetarium -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Planetarium">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalPlanetariumService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Estructura acondicionada para la proyección de espectáculos relacionados con la astronomía.</rdfs:comment>
        <rdfs:comment xml:lang="en">Structure equipped for the projection of shows related to astronomy.</rdfs:comment>
        <rdfs:label xml:lang="es">planetario</rdfs:label>
        <rdfs:label xml:lang="en">planetarium</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Playground -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Playground">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="es">Espacio recreativo enfocado a los niños, que cuenta con juegos infantiles y que suele estar en espacios abiertos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Recreational space focused on children, which has children&apos;s games and is usually in open spaces.</rdfs:comment>
        <rdfs:label xml:lang="es">parque infantil</rdfs:label>
        <rdfs:label xml:lang="en">playground</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PointOfSale -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PointOfSale">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LocalBusiness"/>
        <rdfs:comment xml:lang="en">Physical location established by suppliers with a primarily online presence that offers the convenience of purchasing products or services immediately.</rdfs:comment>
        <rdfs:comment xml:lang="es">Ubicación física establecida por proveedores con presencia principalmente en línea que ofrece la conveniencia de adquirir productos o servicios de forma inmediata.</rdfs:comment>
        <rdfs:label xml:lang="en">point of sale</rdfs:label>
        <rdfs:label xml:lang="es">punto de venta</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PoliceStation -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PoliceStation">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:comment xml:lang="en">Building where police activities are centralized of a neighborhood or district under the command of a commissioner</rdfs:comment>
        <rdfs:comment xml:lang="es">Edificio donde se centralizan las actividades policiales de un barrio o distrito bajo el mando de un comisario.</rdfs:comment>
        <rdfs:label xml:lang="es">comisaría de policía</rdfs:label>
        <rdfs:label xml:lang="en">police station</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PortPassengerTerminal -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PortPassengerTerminal">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:comment xml:lang="es">Unidad establecida en un puerto o fuera de él, formada por obras, instalaciones y superficies, incluida su zona de agua, que permite la realización íntegra de la operación portuaria de tránsito de pasajeros, incluyendo el embarque y el desembarque de pasajeros y equipajes del buque al puerto.</rdfs:comment>
        <rdfs:comment xml:lang="en">Unit established in a port or outside it, made up of works, facilities and surfaces, including its water area, that allows the full implementation of the port operation of passenger transit, including the boarding and disembarkation of passengers and luggage from the ship to the port.</rdfs:comment>
        <rdfs:label xml:lang="en">port passenger terminal</rdfs:label>
        <rdfs:label xml:lang="es">terminal portuaria de pasajeros</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PostOffice -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PostOffice">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasTransactionInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#maximumSize"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#maximumWeight"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Establecimiento encargado de enviar, recibir, ordenar, manejar, transmitir y entregar el correo. En algunas de ellas se ofrecen servicios como formularios, giros de dinero, cambio de monedas y servicios bancarios, entre otros.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment responsible for sending, receiving, sorting, handling, transmitting and delivering mail. Some of them offer services such as forms, money transfers, currency exchange and banking services, among others</rdfs:comment>
        <rdfs:label xml:lang="es">oficina de correos</rdfs:label>
        <rdfs:label xml:lang="en">post office</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PriceSpecification -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PriceSpecification">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#discount"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#currency"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#isAccesibleForFree"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#maxPrice"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#minPrice"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#price"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#taxesAndFessIncluded"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Coste total del producto o servicio que puede incluir impuestos, cargos o reducciones en las tarifas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Total cost of the product or service that may include taxes, charges, or rate reductions.</rdfs:comment>
        <rdfs:label xml:lang="es">Especificación del precio</rdfs:label>
        <rdfs:label xml:lang="en">price specification</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PrimaryCare -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PrimaryCare">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:comment xml:lang="en">Building where the population is served at a first level of health care</rdfs:comment>
        <rdfs:comment xml:lang="es">Edificio donde se atiende a la población en un primer nivel asistencial sanitario</rdfs:comment>
        <rdfs:label xml:lang="es">centro de atención primaria</rdfs:label>
        <rdfs:label xml:lang="en">primary care</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PrivateHireCompany -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PrivateHireCompany">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PassengerTransportCompany"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersTransport"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportService"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Company that provides passenger transportation services using private vehicles and professional drivers.</rdfs:comment>
        <rdfs:comment xml:lang="es">Empresa que proporciona servicios de transporte de pasajeros utilizando vehículos privados y conductores profesionales.</rdfs:comment>
        <rdfs:label xml:lang="es">empresa VTC</rdfs:label>
        <rdfs:label xml:lang="en">private hire company</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PrivateHospital -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PrivateHospital">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MedicalService"/>
        <rdfs:comment xml:lang="es">Establecimiento destinado al diagnóstico y tratamiento de enfermos, cuya financiación corre a cargo de los propios pacientes, de las aseguradoras o de embajadas extranjeras.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment intended for the diagnosis and treatment of patients, whose financing is provided by the patients themselves, by insurance companies or by foreign embassies.</rdfs:comment>
        <rdfs:label xml:lang="es">hospital privado</rdfs:label>
        <rdfs:label xml:lang="en">private hospital</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Pub -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Pub">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantService"/>
        <rdfs:comment xml:lang="es">Local público, de diseño cuidado, donde se sirven bebidas y se escucha música.</rdfs:comment>
        <rdfs:comment xml:lang="en">Public place, with a careful design, where drinks are served and music is listened to.</rdfs:comment>
        <rdfs:label xml:lang="en">pub</rdfs:label>
        <rdfs:label xml:lang="es">pub</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PublicHospital -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicHospital">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:comment xml:lang="es">Establecimiento financiado con fondos estatales destinado al diagnóstico y tratamiento de enfermos, donde a menudo se practican la investigación y la docencia.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment financed by state funds for the diagnosis and treatment of patients, where research and teaching are often practiced</rdfs:comment>
        <rdfs:label xml:lang="es">hospital público</rdfs:label>
        <rdfs:label xml:lang="en">public hospital</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PublicRestroom -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicRestroom">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:comment xml:lang="es">Habitación o edificación pequeña con uno o más inodoros para uso del público en general.</rdfs:comment>
        <rdfs:comment xml:lang="en">Room or small building with one or more toilets for use by the general public</rdfs:comment>
        <rdfs:label xml:lang="es">baño público</rdfs:label>
        <rdfs:label xml:lang="en">public restroom</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PublicService -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicService">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:comment xml:lang="en">Actividad o función proporcionada por la administración local con el propósito de satisfacer las necesidades básicas de la sociedad y promover el bienestar común.</rdfs:comment>
        <rdfs:comment xml:lang="en">Activity or function provided by the local administration with the purpose of satisfying the basic needs of society and promoting the common well-being.</rdfs:comment>
        <rdfs:label xml:lang="en">public service</rdfs:label>
        <rdfs:label xml:lang="es">servicio público</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#PublicTransportStop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicTransportStop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#stationType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#zone"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">En los tranvías, autobuses, metro, etc. sitio donde habitualmente hacen parada los vehículos.</rdfs:comment>
        <rdfs:comment xml:lang="en">On trams, buses, subways, etc. place where vehicles usually stop.</rdfs:comment>
        <rdfs:label xml:lang="es">parada de transporte público</rdfs:label>
        <rdfs:label xml:lang="en">public transport stop</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Racetrack -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Racetrack">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Lugar destinado a carreras de caballos</rdfs:comment>
        <rdfs:comment xml:lang="en">Place for horse racing</rdfs:comment>
        <rdfs:label xml:lang="es">hipódromo</rdfs:label>
        <rdfs:label xml:lang="en">race track</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#RailwayCompany -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#RailwayCompany">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PassengerTransportCompany"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalRailwayCompanyService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Entidades, titulares de una licencia de empresa ferroviaria, cuya actividad principal consiste en prestar servicios de transporte de viajeros o de mercancías por ferrocarril.</rdfs:comment>
        <rdfs:comment xml:lang="en">Entities, holders of a railway company license, whose main activity consists of providing passenger or freight transport services by rail.</rdfs:comment>
        <rdfs:label xml:lang="es">empresa ferroviaria</rdfs:label>
        <rdfs:label xml:lang="en">railway company</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Rating -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Rating">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Acknowledgement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#ratingUnit"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#ratingValue"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Evaluación numérica o calificación asignada a algo, como productos, servicios, empresas o individuos. Representan una medida cuantitativa o cualitativa de
calidad, rendimiento o satisfacción. A partir de está puntuación, se podrán ordenar las instancias de cada entidad para recomendar en función del perfil del turista.</rdfs:comment>
        <rdfs:comment xml:lang="en">Numerical evaluation or rating assigned to something, such as products, services, companies, or individuals. They represent a quantitative or qualitative measure of
quality, performance or satisfaction. Based on this score, the instances of each entity can be ordered to recommend based on the tourist profile.</rdfs:comment>
        <rdfs:label xml:lang="es">Puntuación</rdfs:label>
        <rdfs:label xml:lang="en">Rating</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Registration -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Registration">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#checkInHours"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#checkOutHours"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#online"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#onsite"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Complete process that encompasses the check-in and check-out actions of a client.</rdfs:comment>
        <rdfs:comment xml:lang="es">Proceso completo que engloba las acciones de check-in (registro de entrada) y check-out (registro de salida) de un cliente.</rdfs:comment>
        <rdfs:label xml:lang="en">registration</rdfs:label>
        <rdfs:label xml:lang="es">registro</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Reservoir -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Reservoir">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="en">Accumulation of water produced by a construction in the bed of a river or stream that partially or totally closes its channel</rdfs:comment>
        <rdfs:comment xml:lang="es">Acumulación de agua producida por una construcción en el lecho de un río o arroyo que cierra parcial o totalmente su cauce.</rdfs:comment>
        <rdfs:label xml:lang="es">embalse</rdfs:label>
        <rdfs:label xml:lang="en">reservoir</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Residence -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Residence">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Accommodation"/>
        <rdfs:comment xml:lang="es">Establecimiento público donde se alojan viajeros o huéspedes estables.</rdfs:comment>
        <rdfs:comment xml:lang="en">Public establishment where travelers or stable guests stay.</rdfs:comment>
        <rdfs:label xml:lang="en">Residence</rdfs:label>
        <rdfs:label xml:lang="es">Residencia</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Resident -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Resident">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PersonRole"/>
        <rdfs:comment xml:lang="en">Person whose center of predominant economic interest is located in its economic territory.</rdfs:comment>
        <rdfs:comment xml:lang="es">Persona cuyo centro de interés económico predominante está ubicado en su territorio económico.</rdfs:comment>
        <rdfs:label xml:lang="en">resident</rdfs:label>
        <rdfs:label xml:lang="es">residente</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Resort -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Resort">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Accommodation"/>
        <rdfs:comment xml:lang="es">Lugar habilitado para el desarrollo de la actividad turística en el que se ofrece una gama amplia de servicios e instalaciones relacionadas con la hostelería, especialmente dedicadas al descanso y esparcimiento.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place enabled for the development of tourist activity in which a wide range of services and facilities related to hospitality are offered, especially dedicated to rest and recreation.</rdfs:comment>
        <rdfs:label xml:lang="es">Complejo turístico</rdfs:label>
        <rdfs:label xml:lang="en">Resort</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Restaurant -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Restaurant">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantService"/>
        <rdfs:comment xml:lang="es">Establecimiento público donde se sirven comidas y bebidas, mediante precio, para ser consumidas en el mismo local</rdfs:comment>
        <rdfs:comment xml:lang="en">Public establishment where food and drinks are served, for a price, to be consumed in the same premises</rdfs:comment>
        <rdfs:label xml:lang="en">restaurant</rdfs:label>
        <rdfs:label xml:lang="es">restaurante</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#RestaurantService -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#RestaurantService">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#cuisineType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasBookingInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPriceInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offeredBy"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersMenu"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Businesses dedicated to the production of foods and beverages prepared for consumption.</rdfs:comment>
        <rdfs:comment xml:lang="es">Negocios dedicados a la elaboración de comidas y bebidas preparadas para su consumo.</rdfs:comment>
        <rdfs:label xml:lang="en">Restaurant service</rdfs:label>
        <rdfs:label xml:lang="es">Servicio de restauración</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#RetailAndFashion -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#RetailAndFashion">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LocalBusiness"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalRetailAndFashionService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Espacios físicos que ofrecen un lugar accesible y conveniente para que los consumidores adquieran diversos productos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Physical spaces that offer an accessible and convenient place for consumers to purchase various products.</rdfs:comment>
        <rdfs:label xml:lang="es">comercio y moda</rdfs:label>
        <rdfs:label xml:lang="en">retail and fashion</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#River -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#River">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalRiverService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Continuous and more or less large current of water that flows into another, a lake or the sea</rdfs:comment>
        <rdfs:comment xml:lang="es">Corriente de agua continua y más o menos caudalosa que va a desembocar en otra, en un lago o en el mar.</rdfs:comment>
        <rdfs:label xml:lang="en">river</rdfs:label>
        <rdfs:label xml:lang="es">río</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Room -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Room">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalRoomService"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#numberOfRooms"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="es">habitación</rdfs:label>
        <rdfs:label xml:lang="en">room</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Rule -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Rule">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RulesAndTips"/>
        <rdfs:comment xml:lang="es">Principio que se impone para dirigir la conducta, la correcta realización de una acción o el correcto desarrollo de una actividad.</rdfs:comment>
        <rdfs:comment xml:lang="en">Principle that is imposed to direct behavior, the correct performance of an action or the correct development of an activity.</rdfs:comment>
        <rdfs:label xml:lang="es">Regla</rdfs:label>
        <rdfs:label xml:lang="en">Rule</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#RulesAndTips -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#RulesAndTips">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#adversity"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#validFrom"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#validTo"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Conjunto de principios, normas y recomendaciones que establece un destino turístico con el objetivo de garantizar una experiencia segura, respetuosa y satisfactoria tanto para los turistas como para la comunidad local y el entorno.</rdfs:comment>
        <rdfs:comment xml:lang="en">Set of principles, standards and recommendations established by a tourist destination with the aim of guaranteeing a safe, respectful and satisfactory experience for both tourists and the local community and the environment.</rdfs:comment>
        <rdfs:label xml:lang="es">Reglas y consejos</rdfs:label>
        <rdfs:label xml:lang="en">Rules and Tips</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#RunningTrack -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#RunningTrack">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="en">Area in which the athletics discipline races are held.</rdfs:comment>
        <rdfs:comment xml:lang="es">Zona en la que se realizan las carreras de la disciplina de atletismo.</rdfs:comment>
        <rdfs:label xml:lang="es">pista de atletismo</rdfs:label>
        <rdfs:label xml:lang="en">running track</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#RuralHouse -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#RuralHouse">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Accommodation"/>
        <rdfs:comment xml:lang="es">Tipo de establecimiento extrahotelero ubicado en un inmueble situado en suelo rústico y de ámbito rural que dispone de una unidad alojativa y que cuenta con el equipamiento y las instalaciones necesarias para la conservación, manipulado y consumo de alimentos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Type of non-hotel establishment located in a property located on rustic land and in a rural area that has an accommodation unit and that has the equipment and facilities necessary for the conservation, handling and consumption of food.</rdfs:comment>
        <rdfs:label xml:lang="es">casa rural</rdfs:label>
        <rdfs:label xml:lang="en">rural house</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Salina -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Salina">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="es">Lugar donde se deja evaporar agua salada para dejar solo la sal, secarla y recogerla luego para su utilización, consumo o venta.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place where salt water is allowed to evaporate to leave only the salt, dry it and then collect it for use, consumption or sale</rdfs:comment>
        <rdfs:label xml:lang="en">salina</rdfs:label>
        <rdfs:label xml:lang="es">salina</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Sanctuary -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Sanctuary">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Templo en que se venera la imagen o reliquia de un santo de especial devoción. También puede utilizarse el término ermita.</rdfs:comment>
        <rdfs:label xml:lang="en">sanctuary</rdfs:label>
        <rdfs:label xml:lang="es">santuario</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ShootingRange -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ShootingRange">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Espacios habilitados para la práctica del tiro que reúnan las características y medidas de seguridad pertinentes.</rdfs:comment>
        <rdfs:label xml:lang="es">campo de tiro</rdfs:label>
        <rdfs:label xml:lang="en">shooting range</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ShoppingMall -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ShoppingMall">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashion"/>
        <rdfs:comment xml:lang="es">Complejo formado por establecimientos dedicados a actividades comerciales y de ocio.</rdfs:comment>
        <rdfs:comment xml:lang="en">Complex made up of establishments dedicated to commercial and leisure activities.</rdfs:comment>
        <rdfs:label xml:lang="es">centro comercial</rdfs:label>
        <rdfs:label xml:lang="en">shopping mall</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#SingularExperience -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#SingularExperience">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#DestinationExperience"/>
        <rdfs:comment xml:lang="en">Destination experience with link to a particular business with a differential value, which may or may not involve the transaction of a product or service. Also called microexperiences.</rdfs:comment>
        <rdfs:comment xml:lang="es">Experiencia en destino con vínculo a un negocio particular con un valor diferencial, que puede llevar consigo o no la transacción de un producto o servicio. También llamadas microexperiencias.</rdfs:comment>
        <rdfs:label xml:lang="es">expeiencia particular</rdfs:label>
        <rdfs:label xml:lang="en">singular experience</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#SkatePark -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#SkatePark">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Instalación deportiva diseñada específicamente para la práctica del monopatinaje.</rdfs:comment>
        <rdfs:comment xml:lang="en">Sports facility designed specifically for skateboarding.</rdfs:comment>
        <rdfs:label xml:lang="en">skatepark</rdfs:label>
        <rdfs:label xml:lang="es">skatepark</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#SkatingRink -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#SkatingRink">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Superficie acondicionada y diseñada para la práctica del patinaje sobre ruedas o sobre hielo, dependiendo del tipo de pista.</rdfs:comment>
        <rdfs:comment xml:lang="en">Surface conditioned and designed for the practice of roller or ice skating, depending on the type of rink.</rdfs:comment>
        <rdfs:label xml:lang="es">pista de patinaje</rdfs:label>
        <rdfs:label xml:lang="en">skating rink</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#SocialMediaProfile -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#SocialMediaProfile">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#socialMediaPlatform"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#socialMediaUser"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Cuentas individuales o de empresas creadas en plataformas digitales diseñadas para la interacción social. Permiten a las personas y organizaciones compartir información, publicar contenido, interactuar con otros usuarios y construir una presencia en línea.</rdfs:comment>
        <rdfs:comment xml:lang="en">Individual or company accounts created on digital platforms designed for social interaction. They allow people and organizations to share information, publish content, interact with other users and build an online presence.</rdfs:comment>
        <rdfs:label xml:lang="es">perfil en redes sociales</rdfs:label>
        <rdfs:label xml:lang="en">social media profile</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Souvenir -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Souvenir">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashion"/>
        <rdfs:comment xml:lang="en">Store that sells objects that serve as souvenirs of the visit to a certain place.</rdfs:comment>
        <rdfs:comment xml:lang="es">Tienda que vende objetos que sirven como recuerdo de la visita a un lugar determinado.</rdfs:comment>
        <rdfs:label xml:lang="en">souvenirs</rdfs:label>
        <rdfs:label xml:lang="es">tienda de souvenirs</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Spa -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Spa">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HealthAndWellnessFacility"/>
        <rdfs:comment xml:lang="es">Establecimiento que ofrece tratamientos, terapias o sistemas de relajación, utilizando como base principal el agua, generalmente corriente, no medicinal.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment that offers treatments, therapies or relaxation systems, using water as its main base, generally running water, not medicinal.</rdfs:comment>
        <rdfs:label xml:lang="en">spa</rdfs:label>
        <rdfs:label xml:lang="es">spa</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#SportFacility -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#SportFacility">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TouristOrRelatedFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalSportService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Espacios diseñados y equipados específicamente para brindar servicios y oportunidades relacionadas con actividades deportivas y recreativas para turistas, visitantes y residentes.</rdfs:comment>
        <rdfs:comment xml:lang="en">Spaces designed and equipped specifically to provide services and opportunities related to sports and recreational activities for tourists, visitors and residents.</rdfs:comment>
        <rdfs:label xml:lang="es">instalación deportiva</rdfs:label>
        <rdfs:label xml:lang="en">sport facility</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#SportsCentre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#SportsCentre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Lugar que dispone de diferentes instalaciones e infraestructuras para la práctica de disciplinas deportivas. También se puede denominar centro deportivo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place that has different facilities and infrastructure for practicing sports disciplines.</rdfs:comment>
        <rdfs:label xml:lang="es">polideportivo</rdfs:label>
        <rdfs:label xml:lang="en">sports centre</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Spring -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Spring">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="es">Corriente de agua que mana del suelo o de entre las rocas de forma natural.</rdfs:comment>
        <rdfs:comment xml:lang="en">Current of water that flows from the ground or between rocks naturally</rdfs:comment>
        <rdfs:label xml:lang="es">manantial</rdfs:label>
        <rdfs:label xml:lang="en">spring</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Square -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Square">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Lugar ancho y espacioso dentro de una población, al que suelen afluir varias calles. En ocasiones, en este lugar se venden artículos diversos, se tiene el trato común con los vecinos, y se celebran las ferias, los mercados y las fiestas públicas.</rdfs:comment>
        <rdfs:label xml:lang="es">Plaza</rdfs:label>
        <rdfs:label xml:lang="en">Square</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Stadium -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Stadium">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalStadiumService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Large venue with stands for spectators, intended for sports competitions.</rdfs:comment>
        <rdfs:comment xml:lang="es">Recinto de grandes dimensiones con graderías para los espectadores, destinado a competiciones deportivas.</rdfs:comment>
        <rdfs:label xml:lang="es">estadio</rdfs:label>
        <rdfs:label xml:lang="en">stadium</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Supermarket -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Supermarket">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Groceries"/>
        <rdfs:comment xml:lang="es">Establecimiento comercial de venta al por menor en el que se expenden todo género de artículos alimenticios, bebidas, productos de limpieza, etc., y en el que el cliente se sirve y paga a la salida</rdfs:comment>
        <rdfs:comment xml:lang="en">Retail commercial establishment in which all types of food items, beverages, cleaning products, etc. are sold, and in which the customer is served and pays upon departure</rdfs:comment>
        <rdfs:label xml:lang="en">supermarket</rdfs:label>
        <rdfs:label xml:lang="es">supermercado</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Swamp -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Swamp">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="en">Sunken land with a more or less muddy bottom and abundant vegetation, where the water stagnates naturally</rdfs:comment>
        <rdfs:comment xml:lang="es">Terreno hundido de fondo más o menos cenagoso y abundante vegetación, donde las aguas se estancan de forma natural.</rdfs:comment>
        <rdfs:label xml:lang="es">pantano</rdfs:label>
        <rdfs:label xml:lang="en">swamp</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#SwimmingPool -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#SwimmingPool">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalSwimmingPoolService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Construcción que contiene gran cantidad de agua y que se destina al baño, a la natación o a otros ejercicios y deportes acuáticos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Construction that contains a large amount of water and is intended for bathing, swimming or other water exercises and sports.</rdfs:comment>
        <rdfs:label xml:lang="es">piscina</rdfs:label>
        <rdfs:label xml:lang="en">swimming pool</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Synagogue -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Synagogue">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Edificio dedicado a la congregación y culto de la religión judía.</rdfs:comment>
        <rdfs:label xml:lang="es">sinagoga</rdfs:label>
        <rdfs:label xml:lang="en">synagogue</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Tailoring -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Tailoring">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashion"/>
        <rdfs:comment xml:lang="en">A tailor&apos;s shop and workshop</rdfs:comment>
        <rdfs:comment xml:lang="es">Tienda y taller de sastre</rdfs:comment>
        <rdfs:label xml:lang="es">Sastrería</rdfs:label>
        <rdfs:label xml:lang="en">Tailoring</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TakeAway -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TakeAway">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantService"/>
        <rdfs:comment xml:lang="es">Establecimiento donde se preparan y venden alimentos listos para ser llevados y consumidos fuera del lugar de venta.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment where food is prepared and sold ready to be taken and consumed outside the place of sale.</rdfs:comment>
        <rdfs:label xml:lang="es">casa de comidas para llevar</rdfs:label>
        <rdfs:label xml:lang="en">take away</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Tavern -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Tavern">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantService"/>
        <rdfs:comment xml:lang="es">Establecimiento público, de carácter popular, donde se sirven y expenden bebidas y, a veces, se sirven comidas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Public establishment, of a popular nature, where drinks are served and sold and, sometimes, meals are served.</rdfs:comment>
        <rdfs:label xml:lang="es">taberna</rdfs:label>
        <rdfs:label xml:lang="en">tavern</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TaxiStand -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TaxiStand">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:comment xml:lang="es">Lugar en que se detienen los taxis a la espera de pasajeros.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place where taxis stop waiting for passengers.</rdfs:comment>
        <rdfs:label xml:lang="es">parada de taxis</rdfs:label>
        <rdfs:label xml:lang="en">taxi stand</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TeaRoom -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TeaRoom">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantService"/>
        <rdfs:comment xml:lang="es">Establecimiento especializado en la venta y servicio de tés e infusiones de todo el mundo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment specialized in the sale and service of teas and infusions from around the world.</rdfs:comment>
        <rdfs:label xml:lang="en">tea room</rdfs:label>
        <rdfs:label xml:lang="es">tetería</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TelephoneShop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TelephoneShop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashion"/>
        <rdfs:comment xml:lang="es">Establecimiento de venta al por menor de artículos de telefonía, teléfonos móviles y accesorios.</rdfs:comment>
        <rdfs:comment xml:lang="en">Retail establishment of telephone items, mobile phones and accessories.</rdfs:comment>
        <rdfs:label xml:lang="en">telephone shop</rdfs:label>
        <rdfs:label xml:lang="es">tienda de telefonía</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TennisCourt -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TennisCourt">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Campo de juego donde se juega al tenis.</rdfs:comment>
        <rdfs:comment xml:lang="en">Playing field where tennis is played.</rdfs:comment>
        <rdfs:label xml:lang="es">pista de tenis</rdfs:label>
        <rdfs:label xml:lang="en">tennnis court</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Theater -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Theater">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalTheaterService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Building or site intended for the representation of dramatic works or other public spectacles typical of the scene.</rdfs:comment>
        <rdfs:comment xml:lang="es">Edificio o sitio destinado a la representación de obras dramáticas o a otros espectáculos públicos propios de la escena.</rdfs:comment>
        <rdfs:label xml:lang="es">teatro</rdfs:label>
        <rdfs:label xml:lang="en">theater</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TobaccoShop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TobaccoShop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashion"/>
        <rdfs:comment xml:lang="en">Site or store where stamps and tobacco are mainly sold, in addition to offering recharge services for prepaid telephone and urban transport cards.</rdfs:comment>
        <rdfs:comment xml:lang="es">Sitio o tienda donde se venden principalmente sellos y tabaco, además de ofrecer servicios de recarga de tarjetas prepago de telefonía y de transportes urbanos.</rdfs:comment>
        <rdfs:label xml:lang="es">estanco</rdfs:label>
        <rdfs:label xml:lang="en">tobacco shop</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Tour -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Tour">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#meetingPoint"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#allinclusivePackage"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#dramatisedTour"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#duration"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#itinerary"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#locationName"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#maximumAttendeeCapacity"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#refPointOfInterest"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#slogan"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#subcategory"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#timeOfTheDay"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Experiencia turística que incluye el recorrido por algún lugar o recinto de interés, que se hace generalmente en grupo y con la ayuda de un guía que conduce y proporciona información acerca de lo que se muestra.</rdfs:comment>
        <rdfs:comment xml:lang="en">Tourist experience that includes a tour of a place or area of ​​interest, which is generally done in a group and with the help of a guide who drives and provides information about what is shown.</rdfs:comment>
        <rdfs:label xml:lang="en">tour</rdfs:label>
        <rdfs:label xml:lang="es">visita guiada</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TourGuide -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TourGuide">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrganisation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#registrationNumber"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Person with extensive knowledge of the destination, capable of expressing himself in two or more languages, whose responsibility is to serve, inform and assist tourists on the tours they take.</rdfs:comment>
        <rdfs:comment xml:lang="es">Persona con amplio conocimiento del destino, capaz de expresarse en dos o más idiomas, cuya responsabilidad es atender, informar y asistir a los turistas en los tours que realizan.</rdfs:comment>
        <rdfs:label xml:lang="es">guía turístico</rdfs:label>
        <rdfs:label xml:lang="en">tour guide</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TourOperator -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TourOperator">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TouristIntermediary"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersHolidayPackage"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#HolidayPackage"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Operador que ofrece productos o servicios turísticos, generalmente contratados por él e integrados por más de uno de los siguientes servicios: transporte, alojamiento, traslados, excursiones, etc. Puede ser operador mayorista, si trabaja exclusivamente con agencias de viajes, o mayorista y minorista, en caso de que su oferta vaya también destinada al cliente final.</rdfs:comment>
        <rdfs:comment xml:lang="en">Operator that offers tourist products or services, generally contracted by it and consisting of more than one of the following services: transportation, accommodation, transfers, excursions, etc. You can be a wholesale operator, if you work exclusively with travel agencies, or a wholesaler and retailer, if your offer is also intended for the end customer.</rdfs:comment>
        <rdfs:label xml:lang="en">tour operator</rdfs:label>
        <rdfs:label xml:lang="es">turoperador</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TourismEntity -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismEntity">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalInformation"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#AdditionalInformation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasDescription"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#Description"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasMultimedia"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#Multimedia"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasSocialMediaProfile"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#SocialMediaProfile"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Concepto general que agrupa los servicios turísticos, recursos turísticos, destinos turísticos y organizaciones turísticas</rdfs:comment>
        <rdfs:comment>General concept that groups Tourism Resources, Tourism Services, Tourist Destinations and Tourism Organisation</rdfs:comment>
        <rdfs:label xml:lang="es">Entidad turística</rdfs:label>
        <rdfs:label xml:lang="en">Tourism Entity</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TourismOrganisation -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrganisation">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasContactPoint"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#ContactPoint"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasLocation"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasOpeningHours"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#OpeningHours"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="es">Organización turística</rdfs:label>
        <rdfs:label xml:lang="en">Tourism Organisation</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TourismResource -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismResource">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#bookingChannel"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#BookingChannel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasContactPoint"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#ContactPoint"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasLocation"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasOpeningHours"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#OpeningHours"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasTransactionInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#capacity"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#managementEntity"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#publicAccess"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#visitduration"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Lugar, sitio o elemento que tiene un valor significativo y atractivo para los turistas y es capaz de motivar su desplazamiento. Suelen ser destacados por su belleza escénica, importancia histórica, singularidad cultural o valor recreativo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place, site or element that has a significant and attractive value for tourists and is capable of motivating their movement. They are often noted for their scenic beauty, historical importance, cultural uniqueness, or recreational value.</rdfs:comment>
        <rdfs:label xml:lang="es">Recurso turístico</rdfs:label>
        <rdfs:label xml:lang="en">Tourism Resource</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TourismService -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismService">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasContactPoint"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#ContactPoint"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasLocation"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasOpeningHours"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#OpeningHours"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Clase que agrupa de manera general los servicios relevantes para el sector turístico, donde se aplicarán las propiedades comunes a todos estos servicios.</rdfs:comment>
        <rdfs:comment xml:lang="en">Class that groups in a general manner all services that are relevant for the tourism sector, so as to group all common properties to all these services.</rdfs:comment>
        <rdfs:label xml:lang="es">Servicio turístico</rdfs:label>
        <rdfs:label xml:lang="en">Tourism Service</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Tourist -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Tourist">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PersonRole"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#lenghtOfStay"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#travelUnit"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#averageDailyExpenditure"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#bringsBagagge"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hiresTourPackage"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#preferredTravelSeason"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#travelFrequency"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Person who travels, spends the night and purchases a product or service at least once, in a destination other than their usual environment, for a duration of less than one year, with any main purpose other than being employed by an entity resident in the country or place visited</rdfs:comment>
        <rdfs:comment xml:lang="es">Persona que viaja, pernocta y ejerce la acción de compra de un producto o servicio como mínimo una vez, en un destino distinto al de su entorno habitual, por una duración inferior a un año, con cualquier finalidad principal que no sea la de ser empleado por una entidad residente en el país o lugar visitado</rdfs:comment>
        <rdfs:label xml:lang="en">tourist</rdfs:label>
        <rdfs:label xml:lang="es">turista</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TouristAttractionSite -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TouristAttractionSite">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Espacio delimitado en el que se reúnen diferentes atractivos que no son exclusivamente turísticos, pero que en razón de sus condiciones y singularidad suscitan interés para la actividad turística. Por ejemplo, puede incluir el casco antiguo de una población</rdfs:comment>
        <rdfs:label xml:lang="es">conjunto de interés artístico</rdfs:label>
        <rdfs:label xml:lang="en">tourist attraction site</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TouristDestination -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TouristDestination">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasRulesAndTips"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#managementEntity"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#population"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#slogan"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Espacio físico, con o sin una delimitación de carácter administrativo o analítico, en el que un visitante puede pernoctar.</rdfs:comment>
        <rdfs:comment xml:lang="en">Physical space, with or without an administrative or analytical delimitation, in which a visitor can spend the night.</rdfs:comment>
        <rdfs:label xml:lang="es">destino turístico</rdfs:label>
        <rdfs:label xml:lang="en">tourist destination</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TouristDestinationService -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TouristDestinationService">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:label xml:lang="es">servicio de destino turístico</rdfs:label>
        <rdfs:label xml:lang="en">tourist destination service</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TouristInformationOffice -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TouristInformationOffice">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#availableLanguage"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Organización encargada de proveer información a los turistas potenciales y turistas que visitan un determinado lugar.</rdfs:comment>
        <rdfs:comment xml:lang="en">Organization in charge of providing information to potential tourists and tourists who visit a certain place</rdfs:comment>
        <rdfs:label xml:lang="es">oficina de turismo</rdfs:label>
        <rdfs:label xml:lang="en">tourist information office</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TouristInformationPoint -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TouristInformationPoint">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#availableLanguage"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Espacio ubicado en lugares de máxima afluencia donde se ofrece información de interés al visitante.</rdfs:comment>
        <rdfs:comment xml:lang="en">Space located in places of maximum influx where information of interest to the visitor is offered</rdfs:comment>
        <rdfs:label xml:lang="es">puesto de información turística</rdfs:label>
        <rdfs:label xml:lang="en">tourist information point</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TouristIntermediary -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TouristIntermediary">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrganisation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersHolidayPackage"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#HolidayPackage"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offeredBy"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Agente de distribución que participa en la venta y/o corretaje de productos y servicios relacionados con viajes y turismo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Distribution agent that participates in the sale and/or brokerage of products and services related to travel and tourism.</rdfs:comment>
        <rdfs:label xml:lang="es">intermediario turístico</rdfs:label>
        <rdfs:label xml:lang="en">tourist intermediary</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TouristOrRelatedFacility -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TouristOrRelatedFacility">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasTransactionInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offeredBy"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Infraestructuras y servicios que están diseñados tanto para satisfacer las necesidades de los turistas como para brindar beneficios a los residentes locales.</rdfs:comment>
        <rdfs:comment xml:lang="en">Infrastructure and services that are designed to both meet the needs of tourists and provide benefits to local residents.</rdfs:comment>
        <rdfs:label xml:lang="es">instalación turística o vinculada</rdfs:label>
        <rdfs:label xml:lang="en">tourist or related facility</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Tower -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Tower">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Construcción fortificada, más alta que ancha, utilizada para defender una ciudad o plaza.</rdfs:comment>
        <rdfs:label xml:lang="es">Torre</rdfs:label>
        <rdfs:label xml:lang="en">Tower</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TownHall -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TownHall">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">El edificio del ayuntamiento, también conocido como casa consistorial, es el edificio de una población adonde concurren los concejales de su ayuntamiento a celebrar sus juntas.</rdfs:comment>
        <rdfs:label xml:lang="es">Ayuntamiento</rdfs:label>
        <rdfs:label xml:lang="en">Town Hall</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ToyLibrary -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ToyLibrary">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="es">Centro de recreo donde se guardan juegos y juguetes para su uso y préstamo</rdfs:comment>
        <rdfs:comment xml:lang="en">Recreation center where games and toys are stored for use and loan</rdfs:comment>
        <rdfs:label xml:lang="es">Ludoteca</rdfs:label>
        <rdfs:label xml:lang="es">Toy Library</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ToyStore -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ToyStore">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashion"/>
        <rdfs:comment xml:lang="en">Store where toys are sold.</rdfs:comment>
        <rdfs:comment xml:lang="es">Tienda donde se venden juguetes.</rdfs:comment>
        <rdfs:label xml:lang="es">juguetería</rdfs:label>
        <rdfs:label xml:lang="en">toy store</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TraditionalMarket -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TraditionalMarket">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AgrotourismFacility"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Groceries"/>
        <rdfs:comment xml:lang="en">An area made up of individual stalls that offer products of various kinds with a predominance of fresh products: meat, fruits, vegetables, fish, etc.</rdfs:comment>
        <rdfs:comment xml:lang="es">Recinto formado por puestos individuales que ofrecen productos de diversa índole con predominancia de los productos frescos: carne, frutas, verduras, pescado, etc.</rdfs:comment>
        <rdfs:label xml:lang="es">mercado tradicional</rdfs:label>
        <rdfs:label xml:lang="en">traditional market</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Trail -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Trail">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="en">Road, path or path that is characterized by being very small and narrow and that is generally found in rural areas</rdfs:comment>
        <rdfs:comment xml:lang="es">Vía, senda o camino que se caracteriza por ser muy pequeña y angosta y que por lo general se encuentran en las zonas rurales.</rdfs:comment>
        <rdfs:label xml:lang="es">sendero</rdfs:label>
        <rdfs:label xml:lang="en">trail</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TrailMTB -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TrailMTB">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="es">Caminos disponibles para ir en bicicleta por la montaña o el campo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Paths available for cycling in the mountains or countryside</rdfs:comment>
        <rdfs:label xml:lang="es">sendero BTT</rdfs:label>
        <rdfs:label xml:lang="en">trail for mountain bike</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Train -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Train">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MeansOfTransport"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalTrainService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Means of rail transport that connects cities and regions.</rdfs:comment>
        <rdfs:comment xml:lang="es">Medio de transporte ferroviario que conecta ciudades y regiones.</rdfs:comment>
        <rdfs:label xml:lang="en">train</rdfs:label>
        <rdfs:label xml:lang="es">tren</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TrainStation -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TrainStation">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalTrainStationService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Instalación ferroviaria con vías a la que pueden llegar y desde la que se pueden expedir trenes.</rdfs:comment>
        <rdfs:comment xml:lang="en">Railway facility with tracks that can be reached and from which trains can be dispatched.</rdfs:comment>
        <rdfs:label xml:lang="es">estación de ferrocarril</rdfs:label>
        <rdfs:label xml:lang="en">train station</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Tram -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Tram">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MeansOfTransport"/>
        <rdfs:label xml:lang="en">tram</rdfs:label>
        <rdfs:label xml:lang="es">tranvía</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TransactionInformation -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TransactionInformation">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasBookingInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPaymentInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPriceInformation"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Conjunto de datos y detalles que engloban la información relevante sobre la reserva, el pago y el precio de un servicio.</rdfs:comment>
        <rdfs:comment xml:lang="en">Set of data and details that encompass relevant information about the reservation, payment and price of a service.</rdfs:comment>
        <rdfs:label xml:lang="es">información de transacción</rdfs:label>
        <rdfs:label xml:lang="en">transaction information</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TouristOrRelatedFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#transportInfrastructureAuthority"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Instalaciones físicas que permiten el movimiento de personas de un lugar a otro. Proporcionan las vías, conexiones y recursos necesarios para el transporte terrestre, aéreo, marítimo y ferroviario, facilitando la movilidad tanto a nivel local como global.</rdfs:comment>
        <rdfs:comment xml:lang="en">Physical facilities that allow the movement of people from one place to another. They provide the roads, connections and resources necessary for land, air, sea and rail transportation, facilitating mobility both locally and globally.</rdfs:comment>
        <rdfs:label xml:lang="es">infraestructura de transporte</rdfs:label>
        <rdfs:label xml:lang="en">transport infrastructure</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TransportService -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TransportService">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#vehicleType"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#capacity"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#brand"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#carNumberPlate"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#cargoVolume"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#driverName"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#modelName"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#smokingAllowed"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="es">servicio de transporte</rdfs:label>
        <rdfs:label xml:lang="en">transport service</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TravelAgency -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TravelAgency">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TouristIntermediary"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalTravelAgencyService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Company that provides organization, planning, development and sale services of products or services of a tourist nature and purposes between suppliers and end customers.</rdfs:comment>
        <rdfs:comment xml:lang="es">Empresa que presta servicios de organización, planificación, desarrollo y venta de productos o servicios de naturaleza y fines turísticos entre proveedores y clientes finales.</rdfs:comment>
        <rdfs:label xml:lang="es">agencia de viajes</rdfs:label>
        <rdfs:label xml:lang="en">travel agency</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Tree -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Tree">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="en">Tree that stands out among others due to its size, shape, age, rarity, biological origin, state of conservation, beauty or for being part of myths or traditions.</rdfs:comment>
        <rdfs:comment xml:lang="es">Árbol que destaca entre los demás por su tamaño, forma, edad, rareza, origen biológico, estado de conservación, belleza o por formar parte de mitos o tradiciones.</rdfs:comment>
        <rdfs:label xml:lang="en">tree</rdfs:label>
        <rdfs:label xml:lang="es">árbol singular</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Trip -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Trip">
        <rdfs:label xml:lang="en">trip</rdfs:label>
        <rdfs:label xml:lang="es">viaje</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#UrbanViewPoint -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#UrbanViewPoint">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Lugar para disfrutar de las vistas de una ciudad desde una perspectiva única, desde la cima de un edificio o de una colina.</rdfs:comment>
        <rdfs:label xml:lang="es">mirador urbano</rdfs:label>
        <rdfs:label xml:lang="en">urban viewpoint</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VATRefund -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VATRefund">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FinancialService"/>
        <rdfs:comment xml:lang="en">Companies specialized in managing the return of Value Added Tax (VAT) to tourists or foreign visitors.</rdfs:comment>
        <rdfs:comment xml:lang="es">Compañías especializadas en la gestión de la devolución del Impuesto al Valor Agregado (IVA) a los turistas o visitantes extranjeros.</rdfs:comment>
        <rdfs:label xml:lang="en">VAT refund</rdfs:label>
        <rdfs:label xml:lang="es">devolución de IVA</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VacationRental -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VacationRental">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Accommodation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#keys"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Complete properties (flats, chalets, townhouses...) that are regularly rented for tourist, vacation or leisure purposes.</rdfs:comment>
        <rdfs:comment xml:lang="es">Inmuebles completos (pisos, chalets, adosados…) que se alquilan de forma habitual con fines turísticos, vacacionales o de ocio.</rdfs:comment>
        <rdfs:label xml:lang="en">Vacation rental</rdfs:label>
        <rdfs:label xml:lang="es">Vivienda de uso turístico</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Valley -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Valley">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="es">Llanura entre montes o alturas</rdfs:comment>
        <rdfs:comment xml:lang="en">Plain between mountains or heights</rdfs:comment>
        <rdfs:label xml:lang="es">valle</rdfs:label>
        <rdfs:label xml:lang="en">valley</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Vehicle -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Vehicle">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasDescription"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#Description"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalInformation"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#AdditionalInformation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#vehicleType"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#brand"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#carNumberPlate"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#mileage"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#modelName"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#numberOfDoors"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#engine"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#fullTank"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#passengerCapacity"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Means of transportation that is available to be rented by clients.</rdfs:comment>
        <rdfs:comment xml:lang="es">Medio de transporte que está disponible para ser alquilado por los clientes.</rdfs:comment>
        <rdfs:label xml:lang="en">vehicle</rdfs:label>
        <rdfs:label xml:lang="es">vehículo</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VehicleExperience -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VehicleExperience">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalVehicleExperienceService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#pointOfSale"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#PointOfSale"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#vehicleExperienceType"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#itinerary"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#maximumDuration"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Pequeñas excursiones en tren, bus o barco para conocer los principales monumentos y atracciones de una ciudad.</rdfs:comment>
        <rdfs:comment xml:lang="en">Small excursions by train, bus or boat to see the main monuments and attractions of a city.</rdfs:comment>
        <rdfs:label xml:lang="es">experiencia en vehículo</rdfs:label>
        <rdfs:label xml:lang="en">vehicle experience</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VehicleRentalCompany -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VehicleRentalCompany">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PassengerTransportCompany"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalVehicleRentalCompanyService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#vehicle"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Vehicle"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Commercial entity dedicated to providing short-term vehicle rental services to travelers who need a temporary means of transportation.</rdfs:comment>
        <rdfs:comment xml:lang="es">Entidad comercial que se dedica a proporcionar servicios de alquiler de vehículos a corto plazo a viajeros que necesitan un medio de transporte temporal.</rdfs:comment>
        <rdfs:label xml:lang="es">empresa de alquiler de vehículos</rdfs:label>
        <rdfs:label xml:lang="en">vehicle rental company</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VehicleRentalService -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VehicleRentalService">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:label xml:lang="es">servicio de alquiler de vehículos</rdfs:label>
        <rdfs:label xml:lang="en">vehicle rental service</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VehicleWorkshop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VehicleWorkshop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MiscellaneousService"/>
        <rdfs:comment xml:lang="es">Establecimiento donde se reparan las averías de los automóviles.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment where automobile breakdowns are repaired.</rdfs:comment>
        <rdfs:label xml:lang="es">taller mecánico</rdfs:label>
        <rdfs:label xml:lang="en">vehicle workshop</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VendingMachine -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VendingMachine">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Groceries"/>
        <rdfs:comment xml:lang="en">Machine that provides snacks, drinks, candy and other products to consumers</rdfs:comment>
        <rdfs:comment xml:lang="es">Máquina que proporciona aperitivos, bebidas, golosinas y otros productos a los consumidores.</rdfs:comment>
        <rdfs:label xml:lang="es">máquina expendedora</rdfs:label>
        <rdfs:label xml:lang="en">vending machine</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VernacularArchitecture -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VernacularArchitecture">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Construcciones tradicionales que reflejan las tradiciones y estilos arquitectónicos locales (masías, molinos, almazaras, etc.)</rdfs:comment>
        <rdfs:label xml:lang="es">arquitectura vernácula</rdfs:label>
        <rdfs:label xml:lang="en">vernacular architecture</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Vineyard -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Vineyard">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AgrotourismFacility"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="en">Land planted with vineyards belonging to a winery, area, region, country, designation of origin, etc. A characteristic element of the wine landscape of La Rioja and Rioja Alavesa, currently in disuse, it became popular at the end of the 19th century, although its origin dates back centuries.</rdfs:comment>
        <rdfs:comment xml:lang="es">Tierra plantada de viñas perteneciente a una bodega, zona, región, país, denominación de origen, etc. Elemento característico del paisaje vitivinícola de La  Rioja y la Rioja Alavesa actualmente en desuso, se popularizó a finales del siglo XIX, aunque su origen se remonta a siglos atrás.</rdfs:comment>
        <rdfs:label xml:lang="en">vineyard</rdfs:label>
        <rdfs:label xml:lang="es">viñedo</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#VineyardShelter -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#VineyardShelter">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">También conocido como chozo, se trata de una pequeña edificación de piedra de una sola planta, normalmente de forma circular y coronada con una falsa cúpula, levantada por el propio agricultor de la vid como refugio ante las inclemencias del tiempo o durante los momentos de descanso, y como almacén de herramientas de labor. También utilizada como puesto de vigilancia para proteger las cosechas. Elemento característico del paisaje vitivinícola de La Rioja y la Rioja Alavesa actualmente en desuso, se popularizó a finales del siglo XIX, aunque su origen se remonta a siglos atrás.</rdfs:comment>
        <rdfs:label xml:lang="es">guardaviña</rdfs:label>
        <rdfs:label xml:lang="en">vineyard shelter</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Volcano -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Volcano">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="es">Abertura en la tierra, y más comúnmente en una montaña, por donde salen de tiempo en tiempo humo, llamas y materias encendidas o derretidas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Opening in the earth, and more commonly in a mountain, through which smoke, flames, and burning or melted matter emerge from time to time.</rdfs:comment>
        <rdfs:label xml:lang="en">volcano</rdfs:label>
        <rdfs:label xml:lang="es">volcán</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Wall -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Wall">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"/>
        <rdfs:comment xml:lang="es">Construcción alta y robusta, generalmente coronada por un parapeto, que rodea una fortificación, plaza fuerte u otro lugar para su defensa.</rdfs:comment>
        <rdfs:label xml:lang="es">muralla</rdfs:label>
        <rdfs:label xml:lang="en">wall</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Waterfall -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Waterfall">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="es">Caída desde cierta altura del agua de un río u otra corriente por el brusco desnivel del cauce.</rdfs:comment>
        <rdfs:comment xml:lang="en">Fall from a certain height of the water of a river or other stream due to the sudden drop in level of the channel.</rdfs:comment>
        <rdfs:label xml:lang="es">cascada</rdfs:label>
        <rdfs:label xml:lang="en">waterfall</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#WeatherForecast -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#WeatherForecast">
        <rdfs:label xml:lang="es">predicción meteorológica</rdfs:label>
        <rdfs:label xml:lang="en">weather forecast</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#WineBar -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#WineBar">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantService"/>
        <rdfs:comment xml:lang="es">Establecimiento especializado en la venta y degustación de vinos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment specialized in the sale and tasting of wines.</rdfs:comment>
        <rdfs:label xml:lang="es">bar de vinos</rdfs:label>
        <rdfs:label xml:lang="en">wine bar</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Winery -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Winery">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AgrotourismFacility"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalWineryService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Lugar donde se cría y almacena el vino.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place where wine is raised and stored.</rdfs:comment>
        <rdfs:label xml:lang="es">bodega</rdfs:label>
        <rdfs:label xml:lang="en">winery</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#WinterSportsResort -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#WinterSportsResort">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Centro turístico básicamente dedicado a la práctica del esquí y demás deportes de nieve y montaña, que forma un conjunto coordinado de medios de remonte mecánicos, pistas e instalaciones complementarias.</rdfs:comment>
        <rdfs:comment xml:lang="en">Tourist center basically dedicated to the practice of skiing and other snow and mountain sports, which forms a coordinated set of mechanical lifts, slopes and complementary facilities.</rdfs:comment>
        <rdfs:label xml:lang="es">estación de deportes de invierno</rdfs:label>
        <rdfs:label xml:lang="en">winter sports resort</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#YatchingPort -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#YatchingPort">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Instalación ubicada en una zona costera o junto a un cuerpo de agua, que se utiliza para el amarre y resguardo de embarcaciones de recreo y deportivas, como yates, veleros, lanchas y otros tipos de barcos privados.</rdfs:comment>
        <rdfs:comment xml:lang="en">Installation located in a coastal area or next to a body of water, which is used for mooring and sheltering recreational and sports vessels, such as yachts, sailboats, motorboats and other types of private boats.</rdfs:comment>
        <rdfs:label xml:lang="es">puerto deportivo</rdfs:label>
        <rdfs:label xml:lang="en">yachting port</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#YogaCentre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#YogaCentre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HealthAndWellnessFacility"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se practica yoga</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment where yoga is practiced</rdfs:comment>
        <rdfs:label xml:lang="es">Centro de yoga</rdfs:label>
        <rdfs:label xml:lang="en">Yoga Centre</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Zoo -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Zoo">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersAdditionalZooService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Lugar en que se conservan, cuidan y a veces se crían diversas especies animales para que sean contempladas por el público y para su estudio.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place where various animal species are conserved, cared for and sometimes raised so that they can be seen by the public and for study.</rdfs:comment>
        <rdfs:label xml:lang="en">zoo</rdfs:label>
        <rdfs:label xml:lang="es">zoológico</rdfs:label>
    </owl:Class>
    


