  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Indica si un lugar está abierto o cerrado debido a una suspensión temporal de sus operaciones durante un período específico y por razones como mantenimiento, renovación, reestructuración, falta de personal, emergencias, situaciones extraordinarias o vacaciones."
  }, {
    "@language" : "en",
    "@value" : "Indicates whether a place is open or not due to a temporary suspension of their operations for a specific period and for reasons such as maintenance, renovation, restructuring, staff shortages, emergencies, extraordinary situations, or holidays"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#OpeningHours"
  } ],
