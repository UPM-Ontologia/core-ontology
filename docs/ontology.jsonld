}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#Acknowledgement",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Achievements or distinctions awarded to people, companies or products for meeting certain standards or specific criteria. These recognitions may include certifications, awards, or other types of honors that recognize quality, performance, compliance, or excellence in a particular field."
  }, {
    "@language" : "es",
    "@value" : "Logros o distinciones otorgadas a personas, empresas o productos por cumplir con ciertos estándares o criterios específicos. Estos reconocimientos pueden incluir certificaciones, premios u otros tipos de distinciones que reconocen la calidad, el rendimiento, el cumplimiento de normas o la excelencia en un determinado campo."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Acknowledgement"
  }, {
    "@language" : "es",
    "@value" : "Reconocimiento"
  } ],
