                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Place"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
        <rdfs:comment xml:lang="es">Proporciona información sobre la ubicación física de un lugar.</rdfs:comment>
        <rdfs:comment xml:lang="en">Provides information about the physical location of a place.</rdfs:comment>
        <rdfs:label xml:lang="en">has location</rdfs:label>
        <rdfs:label xml:lang="es">tiene localización</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>location</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#hasMultimedia -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#hasMultimedia">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismEntity"/>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#Multimedia"/>
        <rdfs:comment xml:lang="en">A digital file containing audio, video, or image content.</rdfs:comment>
        <rdfs:comment xml:lang="es">Archivo digital que contiene audio, vídeo o imágenes.</rdfs:comment>
        <rdfs:label xml:lang="en">has multimedia</rdfs:label>
        <rdfs:label xml:lang="es">tiene multimedia</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>multimedia</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#hasOpeningHours -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#hasOpeningHours">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Place"/>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#OpeningHours"/>
        <rdfs:comment xml:lang="es">El horario de apertura de un lugar determinado.</rdfs:comment>
        <rdfs:comment xml:lang="en">The opening hours of a certain place.</rdfs:comment>
        <rdfs:label xml:lang="en">has opening hours</rdfs:label>
        <rdfs:label xml:lang="es">tiene horario de apertura</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">4</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>generalInfo</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#hasPriceClass -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#hasPriceClass">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AdventureActivity"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AgrotourismExperience"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Tour"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#VehicleExperience"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/PriceClass"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">A range of prices at which products or services are offered, allowing them to be classified into different segments within a given market or industry.</rdfs:comment>
        <rdfs:comment xml:lang="es">Rango de precios en el que se ofrecen productos o servicios que permiten clasificarlos en diferentes segmentos dentro de un determinado mercado o industria.</rdfs:comment>
        <rdfs:label xml:lang="es">gama de precios</rdfs:label>
        <rdfs:label xml:lang="en">has price class</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#hasPriceSpecification -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#hasPriceSpecification">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#BicycleSharingSystem"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Event"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#ParkingFacility"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#SpecialOffer"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#PriceSpecification"/>
        <rdfs:comment xml:lang="en">A structured definition of the cost associated with a tourism offering, including amount, currency, validity period, and applicable taxes or fees.</rdfs:comment>
        <rdfs:comment xml:lang="es">Definición estructurada del coste asociado a una prestación turística, incluyendo el importe, la divisa, la validez y los impuestos o tasas aplicables.</rdfs:comment>
        <rdfs:label xml:lang="en">has price specification</rdfs:label>
        <rdfs:label xml:lang="es">tiene especificación del precio</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">5</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>contact</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#hasRiverService -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#hasRiverService">
        <rdfs:subPropertyOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalService"/>
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#River"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/RiverService"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Complementary or additional services that may be offered at a river alongside its main service or activity in order to enhance or improve the user experience.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicios complementarios o adicionales que pueden ofrecerse en un río junto a su servicio o actividad principal para ampliar o mejorar la experiencia del usuario.</rdfs:comment>
        <rdfs:label xml:lang="en">has river service</rdfs:label>
        <rdfs:label xml:lang="es">tiene servicios de río</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#hasRulesAndTips -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#hasRulesAndTips">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Route"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismDestination"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#RulesAndTips"/>
        <rdfs:comment xml:lang="en">A set of principles, standards and recommendations established by a tourism destination with the aim of ensuring a safe, respectful and satisfying experience for tourists, the local community and the environment.</rdfs:comment>
        <rdfs:comment xml:lang="es">Conjunto de principios, normas y recomendaciones que establece un destino turístico con el objetivo de garantizar una experiencia segura, respetuosa y satisfactoria tanto para los turistas como para la comunidad local y el entorno.</rdfs:comment>
        <rdfs:label xml:lang="en">has rules and tips</rdfs:label>
        <rdfs:label xml:lang="es">tiene reglas y consejos</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#hasSocialMediaProfile -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#hasSocialMediaProfile">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Event"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismDestination"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrganisation"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismResource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#SocialMediaProfile"/>
        <rdfs:comment xml:lang="es">Cuentas individuales o de empresas creadas en plataformas digitales diseñadas para la interacción social. Permiten a las personas y organizaciones compartir información, publicar contenido, interactuar con otros usuarios y construir una presencia en línea.</rdfs:comment>
        <rdfs:comment xml:lang="en">Individual or company accounts created on digital platforms designed for social interaction. They allow individuals and organisations to share information, publish content, interact with other users and build an online presence.</rdfs:comment>
        <rdfs:label xml:lang="en">has social media profile</rdfs:label>
        <rdfs:label xml:lang="es">tiene perfil de redes sociales</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">3</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>contact</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#hasSubEvent -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#hasSubEvent">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Event"/>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#Event"/>
        <rdfs:comment xml:lang="es">Relación que indica que uno o varios eventos forman parte de este evento.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship indicating that one or more events are part of this event.</rdfs:comment>
        <rdfs:label xml:lang="en">has subevent</rdfs:label>
        <rdfs:label xml:lang="es">tiene subevento</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">10</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>acknowledgement</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="en">Points out events that are part of this event.</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="es">Señala eventos que forman parte de este evento</estur-annot:tooltip>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#hasSuperEvent -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#hasSuperEvent">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Event"/>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#Event"/>
        <rdfs:comment xml:lang="es">Relación que indica que un evento forma parte de un evento de mayor nivel o evento principal.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship that indicates that the event is part of a higher-level or main event.</rdfs:comment>
        <rdfs:label xml:lang="en">has super event</rdfs:label>
        <rdfs:label xml:lang="es">tiene superevento</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">11</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>acknowledgement</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Especifica el evento del que forma parte este subevento</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Specifies the event of which this sub-event is part</estur-annot:tooltip>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#hasTag -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#hasTag">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Event"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Route"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#SpecialOffer"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismDestination"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismIntermediary"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/Tag"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Conjunto de etiquetas utilizadas para clasificar y describir de forma sintética características, temáticas, atributos o enfoques experienciales asociados a un elemento.</rdfs:comment>
        <rdfs:comment xml:lang="en">Set of tags used to classify and describe, in a transversal manner, characteristics, themes, attributes or experiential approaches associated with an item.</rdfs:comment>
        <rdfs:label xml:lang="en">has tag</rdfs:label>
        <rdfs:label xml:lang="es">tiene etiqueta</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#hasTimeSlot -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#hasTimeSlot">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#OpeningHours"/>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#TimeSlot"/>
        <rdfs:comment xml:lang="es">Intervalo temporal que define un periodo continuo de apertura, delimitado por una hora de inicio y una hora de finalización, y utilizado para describir tramos horarios dentro de un día concreto.</rdfs:comment>
        <rdfs:comment xml:lang="en">Time interval that defines a continuous period of opening, delimited by a start time and an end time, and used to describe time ranges within a specific day.</rdfs:comment>
        <rdfs:label xml:lang="en">has time slot</rdfs:label>
        <rdfs:label xml:lang="es">tiene franja horaria</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#hasTourismOrRelatedFacility -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#hasTourismOrRelatedFacility">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AccommodationCompany"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#ComplementaryActivitiesCompany"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#EventOrganisationCompany"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#PassengerTransportCompany"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#RestaurantCompany"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismIntermediary"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
        <rdfs:comment xml:lang="es">Asocia una organización con una instalación turística o vinculada.</rdfs:comment>
        <rdfs:comment xml:lang="en">Associates an organisation with a tourism or related facility.</rdfs:comment>
        <rdfs:label xml:lang="en">has tourism or related facility</rdfs:label>
        <rdfs:label xml:lang="es">tiene recurso o instalación asociada</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">5</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>acknowledgement</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#historicalOrCulturalResourceContains -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#historicalOrCulturalResourceContains">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#OldTown"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Quarter"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Square"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Indica instalaciones turísticas o vinculadas, y recursos históricos o culturales que un recurso histórico o cultural puede contener.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates tourism or related facilities, and historical or cultural resources that a historical or cultural resource may contain.</rdfs:comment>
        <rdfs:label xml:lang="en">historical or cultural resource contains</rdfs:label>
        <rdfs:label xml:lang="es">recurso histórico o cultural contiene</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Indica instalaciones turísticas o vinculadas, y recursos históricos o culturales que un recurso histórico o cultural puede contener.</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Indicates tourist or related facilities, and historical or cultural resources that a historical or cultural resource may contain</estur-annot:tooltip>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#itinerary -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#itinerary">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AdventureActivity"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AgrotourismExperience"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#DestinationExperience"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#HolidayPackage"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Route"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Tour"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TransportService"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#Itinerary"/>
        <rdfs:comment xml:lang="en">A collection of points of interest associated with a route or tourism service.</rdfs:comment>
        <rdfs:comment xml:lang="es">Colección de puntos de interés de referencia asociados a la realización de una ruta o servicio turístico.</rdfs:comment>
        <rdfs:label xml:lang="es">itinerario</rdfs:label>
        <rdfs:label xml:lang="en">itinerary</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#labelType -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#labelType">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Label"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/LabelType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">List of tourism labels of reference for events, destinations, tourism resources, public services and tourism organisations, including their facilities and services.</rdfs:comment>
        <rdfs:comment xml:lang="es">Listado de distintivos turísticos de referencia para eventos, destinos, recursos turísticos, servicios públicos y empresas turísticas, incluyendo sus instalaciones y servicios.</rdfs:comment>
        <rdfs:label xml:lang="en">label type</rdfs:label>
        <rdfs:label xml:lang="es">tipo de distintivo</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">9</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>acknowledgement</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#locomotionMode -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#locomotionMode">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Route"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Trail"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/LocomotionMode"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Forma específica en que se realiza el desplazamiento durante una ruta o actividad organizada, definida por el medio o método de transporte utilizado.</rdfs:comment>
        <rdfs:comment xml:lang="en">Specific way in which movement is carried out during a route or organized activity, defined by the means or method of transportation used.</rdfs:comment>
        <rdfs:label xml:lang="en">locomotion mode</rdfs:label>
        <rdfs:label xml:lang="es">modalidad de locomoción</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#meetingPoint -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#meetingPoint">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AdventureActivity"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Tour"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#Place"/>
        <rdfs:comment xml:lang="en">A geographically defined place where people receiving a tourism service gather to start, coordinate, or carry out an activity.</rdfs:comment>
        <rdfs:comment xml:lang="es">Lugar geográficamente definido donde las personas que reciben un servicio turístico se reúnen para iniciar, coordinar o desarrollar una actividad</rdfs:comment>
        <rdfs:label xml:lang="en">meeting point</rdfs:label>
        <rdfs:label xml:lang="es">punto de encuentro</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#menuOptions -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#menuOptions">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#FoodAndBeverageService"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/MenuOptions"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Alternativas o elecciones que están disponibles en un establecimiento de restauración en relación a los tipos de alimentos que se ofrecen. Estas opciones pueden adaptarse a las preferencias y necesidades dietéticas de los comensales, incluyendo alergias alimentarias, restricciones dietéticas, preferencias vegetarianas o veganas, entre otros.</rdfs:comment>
        <rdfs:comment xml:lang="en">Options or choices available in a food establishment regarding the types of food offered. These options may be adapted to diners’ preferences and dietary needs, including food allergies, dietary restrictions, vegetarian or vegan preferences, among others.</rdfs:comment>
        <rdfs:label xml:lang="en">menu options</rdfs:label>
        <rdfs:label xml:lang="es">opciones de la carta</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#museumType -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#museumType">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Museum"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/MuseumType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Categories or classifications used to differentiate museums according to their theme, focus, or collections. Each museum type focuses on a specific field of art, history, science, or other areas of interest.</rdfs:comment>
        <rdfs:comment xml:lang="es">Categorías o clasificaciones que se utilizan para diferenciar los museos según su temática, enfoque o colecciones. Cada tipo de museo se centra en un ámbito específico del arte, la historia, la ciencia u otros campos de interés.</rdfs:comment>
        <rdfs:label xml:lang="en">museum type</rdfs:label>
        <rdfs:label xml:lang="es">tipo de museo</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#naturalResourceContains -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#naturalResourceContains">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Beach"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Desert"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Forest"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Mountain"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalPark"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Valley"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Indica instalaciones turísticas o vinculadas, recursos naturales, y servicios públicos que un recurso natural puede contener.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates tourism or related facilities, natural resources, and public services that a natural resource may contain.</rdfs:comment>
        <rdfs:label xml:lang="en">natural resource contains</rdfs:label>
        <rdfs:label xml:lang="es">recurso natural contiene</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Indica instalaciones turísticas o vinculadas, recursos naturales, y servicios públicos que un recurso natural puede contener</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Indicates tourist or related facilities, natural resources, and public services that a natural resource may contain</estur-annot:tooltip>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#nearTo -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#nearTo">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Event"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Place"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#Place"/>
        <rdfs:comment xml:lang="en">Indicates relevant places that a particular place may be close to and whose proximity may be useful or interesting to tourists.</rdfs:comment>
        <rdfs:comment xml:lang="es">Señala lugares relevantes a los que un determinado lugar puede estar próximo y cuya proximidad puede ser útil o interesante para el turista.</rdfs:comment>
        <rdfs:label xml:lang="es">cerca de</rdfs:label>
        <rdfs:label xml:lang="en">near to</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="en">Points out relevant places to which a given place may be close, and whose proximity may be useful or interesting for tourists</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="es">Señala lugares relevantes a los que un determinado lugar puede estar próximo y cuya proximidad puede ser útil o interesante para el turista.</estur-annot:tooltip>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#offerSchedule -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#offerSchedule">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#SpecialOffer"/>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#Schedule"/>
        <rdfs:comment xml:lang="es">Asocia una oferta a una programación.</rdfs:comment>
        <rdfs:comment xml:lang="en">Association of an offer with a schedule.</rdfs:comment>
        <rdfs:label xml:lang="en">offer schedule</rdfs:label>
        <rdfs:label xml:lang="es">programación de la oferta</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">7</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>contact</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#offeredBy -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#offeredBy">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Event"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#SpecialOffer"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismDestination"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrganisation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Asocia un servicio turístico, un evento, una propuesta especial y una instalación turística o vinculada con una organización turística o un destino turístico.</rdfs:comment>
        <rdfs:comment xml:lang="en">Associates a tourism service, event, special offer, and tourism or related facility with a tourism organisation or tourism destination.</rdfs:comment>
        <rdfs:label xml:lang="en">offered by</rdfs:label>
        <rdfs:label xml:lang="es">ofrecido por</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">4</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>acknowledgement</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#offers -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#offers">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismDestination"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrganisation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Event"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#SpecialOffer"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Asociación de una organización o destino turístico con los eventos, propuestas especiales y/o servicios turísticos que estos ponen a disposición de los turistas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Association of a tourism organisation or destination with the events, special offers and tourism services that they provide to tourists. </rdfs:comment>
        <rdfs:label xml:lang="en">offers</rdfs:label>
        <rdfs:label xml:lang="es">ofrece</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#offersGastronomicResource -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#offersGastronomicResource">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#FoodAndBeverageService"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#GastronomicResource"/>
        <rdfs:comment xml:lang="es">Asociación de un establecimiento de restauración y/o un servicio de comidas y bebidas con un recurso gastronómico.</rdfs:comment>
        <rdfs:comment xml:lang="en">Association of a food establishment and a food and beverage service with a gastronomic resource.</rdfs:comment>
        <rdfs:label xml:lang="en">offers gastronomic resource</rdfs:label>
        <rdfs:label xml:lang="es">ofrece recurso gastronómico</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#onSite -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#onSite">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#BookingChannel"/>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#Place"/>
        <rdfs:comment xml:lang="en">A booking channel through which reservations are made in person at a specific place.</rdfs:comment>
        <rdfs:comment xml:lang="es">Canal de reserva que se realiza de manera presencial en un lugar determinado.</rdfs:comment>
        <rdfs:label xml:lang="en">on site</rdfs:label>
        <rdfs:label xml:lang="es">presencial</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#paymentMethod -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#paymentMethod">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Route"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TransportService"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/PaymentMethod"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Method used by the customer to pay for the service.</rdfs:comment>
        <rdfs:comment xml:lang="es">Método utilizado por el cliente para pagar el servicio.</rdfs:comment>
        <rdfs:label xml:lang="es">método de pago</rdfs:label>
        <rdfs:label xml:lang="en">payment method</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">2</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>contact</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#petAdmissionPolicy -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#petAdmissionPolicy">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#AdditionalInformation"/>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
        <rdfs:comment xml:lang="en">Criteria for permitting or restricting pets from entering certain places.</rdfs:comment>
        <rdfs:comment xml:lang="es">Criterio de permisión o restricción para el ingreso de mascotas a ciertos lugares.</rdfs:comment>
        <rdfs:label xml:lang="en">pet admission policy</rdfs:label>
        <rdfs:label xml:lang="es">política de admisión de mascotas</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


