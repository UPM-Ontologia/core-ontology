  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Negocio donde se venden principalmente sellos y tabaco, además de ofrecer servicios de recarga de tarjetas prepago de telefonía y de transportes urbanos."
  }, {
    "@language" : "en",
    "@value" : "Store where stamps and tobacco are mainly sold, in addition to offering recharge services for prepaid telephone and urban transport cards."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Estanco"
  }, {
    "@language" : "en",
    "@value" : "Tobacco shop"
  } ],
