                          owl:onProperty :hasPersonRole ;
                          owl:allValuesFrom :PersonRole
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :educationLevel ;
                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
