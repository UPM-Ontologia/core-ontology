  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Amount of physical exertion required to complete the route, taking into account extension and unevenness (uphill and downhill), based on an average participant."
  }, {
    "@language" : "es",
    "@value" : "Cantidad de esfuerzo físico necesario para completar la ruta, teniendo en cuenta la extensión y las irregularidades (subidas y bajadas), basado en un participante medio."
  }, {
    "@language" : "en",
    "@value" : "Levels of grading of the technical and physical demands of routes, where 1 indicates least difficulty and 5 greatest difficulty."
  }, {
    "@language" : "es",
    "@value" : "Niveles de graduación de las exigencias técnicas y físicas de rutas, en los que 1 indica menor dificultad y 5 mayor dificultad."
