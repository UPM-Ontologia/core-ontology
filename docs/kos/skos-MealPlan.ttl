@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix estur-core: <https://ontologia.segittur.es/turismo/def/core#> .
@prefix estur-kos: <https://ontologia.segittur.es/turismo/kos/> .

@prefix estur-mealplan: <https://ontologia.segittur.es/turismo/kos/mealplan/> .

#################################################################
#
#    Concept Scheme
#
#################################################################

estur-kos:MealPlan a skos:ConceptScheme ; 
    dct:issued "2024-10-29"^^xsd:date ;
    dct:modified "2024-10-29"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the SEGITTUR tourism ontology."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por la ontología de turismo de SEGITTUR."@es ;
    rdfs:label "Meal plan"@en ;
    rdfs:label "Plan de comidas"@es ;
    dct:title "Concept scheme grouping meal plans"@en ;
    dct:title "Esquema de conceptos agrupando planes de comidas"@es .

#################################################################
#
#    Concepts
#
#################################################################

estur-mealplan:AccommodationOnly a skos:Concept;
  skos:inScheme estur-kos:MealPlan;
  skos:note "Value generated from the original SEGITTUR ontology"@en;
  skos:note "Valor generado a partir de la ontología de SEGITTUR original"@es;
  skos:prefLabel "Accommodation only"@en ;
  skos:prefLabel "Sólo alojamiento"@es .

estur-mealplan:AllInclusive a skos:Concept;
  skos:inScheme estur-kos:MealPlan;
  skos:note "Value generated from the original SEGITTUR ontology"@en;
  skos:note "Valor generado a partir de la ontología de SEGITTUR original"@es;
  skos:prefLabel "All inclusive"@en ;
  skos:prefLabel "Todo incluido"@es .

estur-mealplan:Breakfast a skos:Concept;
  skos:inScheme estur-kos:MealPlan;
  skos:note "Value generated from the original SEGITTUR ontology"@en;
  skos:note "Valor generado a partir de la ontología de SEGITTUR original"@es;
  skos:prefLabel "Breakfast"@en ;
  skos:prefLabel "Desayuno"@es .

estur-mealplan:FullBoard a skos:Concept;
  skos:inScheme estur-kos:MealPlan;
  skos:note "Value generated from the original SEGITTUR ontology"@en;
  skos:note "Valor generado a partir de la ontología de SEGITTUR original"@es;
  skos:prefLabel "Full board"@en ;
  skos:prefLabel "Pensión completa"@es .

estur-mealplan:HalfBoard a skos:Concept;
  skos:inScheme estur-kos:MealPlan;
  skos:note "Value generated from the original SEGITTUR ontology"@en;
  skos:note "Valor generado a partir de la ontología de SEGITTUR original"@es;
  skos:prefLabel "Half board"@en ;
  skos:prefLabel "Media pensión"@es .
