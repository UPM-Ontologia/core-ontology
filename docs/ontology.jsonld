  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Proveedor de, al menos, camas y servicios de higiene"
  }, {
    "@language" : "en",
    "@value" : "Provider of at least sleeping and sanitary facilities"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Accommodation company"
