@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix estur-core: <https://ontologia.segittur.es/turismo/def/core#> .
@prefix estur-kos: <https://ontologia.segittur.es/turismo/kos/> .

@prefix estur-timeoftheyear: <https://ontologia.segittur.es/turismo/kos/timeoftheyear/> .

#################################################################
#
#    Concept Scheme
#
#################################################################

estur-kos:TimeOfTheYear a skos:ConceptScheme ; 
    dct:issued "2026-03-06"^^xsd:date ;
    dct:modified "2026-03-06"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the SEGITTUR tourism ontology."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por la ontología de turismo de SEGITTUR."@es ;
    rdfs:label "Time of the year"@en ;
    rdfs:label "Temporada del año"@es ;
    dct:title "Concept scheme grouping times of the year"@en ;
    dct:title "Esquema de conceptos agrupando temporadas del año"@es .

#################################################################
#
#    Concepts
#
#################################################################

estur-timeoftheyear:Spring a skos:Concept;
  skos:inScheme estur-kos:TimeOfTheYear;
  skos:prefLabel "Spring"@en ;
  skos:prefLabel "Primavera"@es .

estur-timeoftheyear:Summer a skos:Concept;
  skos:inScheme estur-kos:TimeOfTheYear;
  skos:prefLabel "Summer"@en ;
  skos:prefLabel "Verano"@es .

estur-timeoftheyear:Fall a skos:Concept;
  skos:inScheme estur-kos:TimeOfTheYear;
  skos:prefLabel "Fall"@en ;
  skos:prefLabel "Otoño"@es .

estur-timeoftheyear:Winter a skos:Concept;
  skos:inScheme estur-kos:TimeOfTheYear;
  skos:prefLabel "Winter"@en ;
  skos:prefLabel "Invierno"@es .

estur-timeoftheyear:Christmas a skos:Concept;
  skos:inScheme estur-kos:TimeOfTheYear;
  skos:prefLabel "Christmas"@en ;
  skos:prefLabel "Navidad"@es .

estur-timeoftheyear:Easter a skos:Concept;
  skos:inScheme estur-kos:TimeOfTheYear;
  skos:prefLabel "Easter"@en ;
  skos:prefLabel "Semana Santa"@es .
