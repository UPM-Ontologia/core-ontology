  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A broad and open space within a town or city, into which several streets typically converge. It may also serve as a place where goods are sold, neighbors gather socially, and public fairs, markets, and festivities are held."
  }, {
    "@language" : "es",
    "@value" : "Lugar ancho y espacioso dentro de una población, al que suelen afluir varias calles. En ocasiones, en este lugar se venden artículos diversos, se tiene el trato común con los vecinos, y se celebran las ferias, los mercados y las fiestas públicas."
  } ],
