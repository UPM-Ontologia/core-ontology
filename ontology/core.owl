    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme"/>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#accommodationCapacity -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#accommodationCapacity">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Accommodation"/>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#AccommodationCapacity"/>
        <rdfs:label xml:lang="es">capacidad alojativa</rdfs:label>
        <rdfs:label xml:lang="en">capacity of the accommodation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#adversity -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#adversity">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#RulesAndTips"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/AdversityType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:label xml:lang="es">adversidad</rdfs:label>
        <rdfs:label xml:lang="en">adversity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#airplane -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#airplane">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Airline"/>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#Airplane"/>
        <rdfs:label xml:lang="en">Airplane</rdfs:label>
        <rdfs:label xml:lang="es">avión</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#allowedVehicleType -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#allowedVehicleType">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#EVChargingStation"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#ParkingFacility"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/VehicleType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:label xml:lang="en">allowed vehicle type</rdfs:label>
        <rdfs:label xml:lang="es">tipo de vehículo permitido</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#areaServed -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#areaServed">
        <rdfs:domain>
