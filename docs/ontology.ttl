                           ] ;
                rdfs:label "education level"@en ,
                           "nivel educativo"@es .


###  https://ontologia.segittur.es/turismo/def/core#event
:event rdf:type owl:ObjectProperty ;
       rdfs:domain :EventOrganisationCompany ;
       rdfs:range :Event ;
       rdfs:label "event"@en ,
                  "evento"@es .


###  https://ontologia.segittur.es/turismo/def/core#eventSession
:eventSession rdf:type owl:ObjectProperty ;
              rdfs:domain :Event ;
              rdfs:range :EventSession ;
              rdfs:label "event session"@en ,
                         "sesión del evento"@es .


###  https://ontologia.segittur.es/turismo/def/core#eventType
:eventType rdf:type owl:ObjectProperty ;
