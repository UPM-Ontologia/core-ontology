    "@language" : "es",
    "@value" : "esfuerzo físico"
  }, {
    "@language" : "en",
    "@value" : "physical effort"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#int"
  } ],
  "https://ontologia.segittur.es/turismo/def/annot#presentationOrderCategory" : [ {
    "@value" : "other"
  } ],
  "https://ontologia.segittur.es/turismo/def/annot#tooltip" : [ {
    "@language" : "es",
    "@value" : "Asigna un valor entero del 1 al 5 para valorar el esfuerzo físico de la ruta, siendo 1 muy bajo y 5 muy alto"
  }, {
    "@language" : "en",
    "@value" : "Assigns an integer value from 1 to 5 to assess the physical effort required by the route, where 1 is very low and 5 is very high"
  } ]
