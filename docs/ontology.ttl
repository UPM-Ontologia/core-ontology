:hasBookingChannel rdf:type owl:ObjectProperty ;
                   rdfs:domain [ rdf:type owl:Class ;
                                 owl:unionOf ( :Organisation
                                               :TourismResource
                                               :TourismService
                                             )
                               ] ;
                   rdfs:range :BookingChannel ;
                   rdfs:label "has booking channel"@en ,
                              "tiene canal de reservas"@es .


