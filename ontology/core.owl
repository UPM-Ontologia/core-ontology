        <rdfs:comment xml:lang="es">Construcción fortificada, más alta que ancha, utilizada para defender una ciudad o plaza.</rdfs:comment>
        <rdfs:label xml:lang="es">Torre</rdfs:label>
        <rdfs:label xml:lang="en">Tower</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#TownHall -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#TownHall">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">Governing and administrative body of a municipality. It is the public institution closest to the citizen, responsible for managing local services and the development of the city or town.</rdfs:comment>
        <rdfs:comment xml:lang="es">Órgano de gobierno y administración de un municipio. Es la institución pública más cercana al ciudadano, encargada de gestionar los servicios locales y el desarrollo de la ciudad o pueblo.</rdfs:comment>
        <rdfs:label xml:lang="es">Ayuntamiento</rdfs:label>
        <rdfs:label xml:lang="en">Town Hall</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


