  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Sandy or rocky territory, which due to the almost total lack of rain lacks or has very little vegetation"
  }, {
    "@language" : "es",
    "@value" : "Territorio arenoso o pedregoso, que por la falta casi total de lluvias carece de vegetación o la tiene muy escasa."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Desert"
  }, {
    "@language" : "es",
    "@value" : "Desierto"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#NaturalResource"
  }, {
