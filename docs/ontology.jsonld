  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Establecimiento con personal cualificado, registrado o autorizado por el organismo veterinario estatutario pertinente para ejercer la medicina/ciencia veterinaria en un país."
  }, {
    "@language" : "en",
    "@value" : "Establishment with qualified personnel, registered or authorised by the relevant statutory veterinary body to practise veterinary medicine/science in a country."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Atención veterinaria"
