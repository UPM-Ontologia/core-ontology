###  https://ontologia.segittur.es/turismo/def/core#CancellationFee
:CancellationFee rdf:type owl:Class ;
                 rdfs:subClassOf owl:Thing ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :free ;
                                   owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :freeCancellationValidity ;
                                   owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :nonRefundable ;
                                   owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                 ] ;
                 rdfs:label "Cargo de cancelación"@es ,
                            "cancellation fee"@en .


###  https://ontologia.segittur.es/turismo/def/core#Carpool
:Carpool rdf:type owl:Class ;
         rdfs:subClassOf :PassengerTransportCompany ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :lugaggeCapacity ;
                           owl:cardinality "1"^^xsd:nonNegativeInteger
