    <!-- https://ontologia.segittur.es/turismo/kos/LabelType -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/LabelType">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">List of tourism labels of reference for events, destinations, tourism resources, public services and tourism organisations, including their facilities and services.</rdfs:comment>
        <rdfs:comment xml:lang="es">Listado de distintivos turísticos de referencia para eventos, destinos, recursos turísticos, servicios públicos y empresas turísticas, incluyendo sus instalaciones y servicios.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-LabelType.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/LakeService -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/LakeService">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">Complementary or additional services that may be offered at a lake alongside its main service or activity in order to enhance or improve the user experience.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicios complementarios o adicionales que pueden ofrecerse en un lago junto a su servicio o actividad principal para ampliar o mejorar la experiencia del usuario.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-LakeService.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/LocomotionMode -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/LocomotionMode">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="es">Formas particulares de emprender una ruta o cualquier tipo de actividad organizada.</rdfs:comment>
        <rdfs:comment xml:lang="en">Specific modes used to undertake a route or any type of organized activity.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-LocomotionMode.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/MenuOptions -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/MenuOptions">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="es">Alternativas o elecciones que están disponibles en un establecimiento de restauración en relación a los tipos de alimentos que se ofrecen. Estas opciones pueden adaptarse a las preferencias y necesidades dietéticas de los comensales, incluyendo alergias alimentarias, restricciones dietéticas, preferencias vegetarianas o veganas, entre otros.</rdfs:comment>
        <rdfs:comment xml:lang="en">Options or choices available in a food establishment regarding the types of food offered. These options may be adapted to diners’ preferences and dietary needs, including food allergies, dietary restrictions, vegetarian or vegan preferences, among others.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-MenuOptions.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/MonthOfTheYear -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/MonthOfTheYear">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">One of the twelve named periods (January through December) that constitute a standard yearly cycle, used to define recurring schedules.</rdfs:comment>
        <rdfs:comment xml:lang="es">Uno de los doce periodos nombrados (de enero a diciembre) que constituyen un ciclo anual estándar, utilizado para definir programaciones recurrentes.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-MonthOfTheYear.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/MuseumType -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/MuseumType">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">Categories or classifications used to differentiate museums according to their theme, focus, or collections. Each museum type focuses on a specific field of art, history, science, or other areas of interest.</rdfs:comment>
        <rdfs:comment xml:lang="es">Categorías o clasificaciones que se utilizan para diferenciar los museos según su temática, enfoque o colecciones. Cada tipo de museo se centra en un ámbito específico del arte, la historia, la ciencia u otros campos de interés.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-MuseumType.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/PaymentMethod -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/PaymentMethod">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">Method used by the customer to pay for the service.</rdfs:comment>
        <rdfs:comment xml:lang="es">Método utilizado por el cliente para pagar el servicio.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-PaymentMethod.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/PriceClass -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/PriceClass">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">A range of prices at which products or services are offered, allowing them to be classified into different segments within a given market or industry.</rdfs:comment>
        <rdfs:comment xml:lang="es">Rango de precios en el que se ofrecen productos o servicios que permiten clasificarlos en diferentes segmentos dentro de un determinado mercado o industria.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-PriceClass.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/RiverService -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/RiverService">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">Complementary or additional services that may be offered at a river alongside its main service or activity in order to enhance or improve the user experience.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicios complementarios o adicionales que pueden ofrecerse en un río junto a su servicio o actividad principal para ampliar o mejorar la experiencia del usuario.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-RiverService.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/SocialMediaPlatform -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/SocialMediaPlatform">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">A selection of leading digital platforms designed for social interaction.</rdfs:comment>
        <rdfs:comment xml:lang="es">Selección de plataformas digitales de referencia diseñadas para la interacción social.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-SocialMediaPlatform.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/Species -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/Species">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">Biological species of pets whose entry is permitted.</rdfs:comment>
        <rdfs:comment xml:lang="es">Especies biológicas de mascotas cuyo ingreso es permitido.</rdfs:comment>
        <rdfs:label xml:lang="es">Especie</rdfs:label>
        <rdfs:label xml:lang="en">Species</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-Species.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/SportsCentrePremise -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/SportsCentrePremise">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="es">Espacios, equipamientos y estructuras físicas que están disponibles para la práctica de diferentes actividades deportivas y recreativas en un polideportivo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Spaces, equipment and physical structures that are available for practising different sports and recreational activities in a sports centre.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-SportsCentrePremise.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/StationType -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/StationType">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="es">En el contexto del transporte público, el tipo de estación se refiere al medio de transporte público que opera en dicha estación.</rdfs:comment>
        <rdfs:comment xml:lang="en">In the context of public transport, the station type refers to the mode of public transport operating at that station.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-StationType.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/Tag -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/Tag">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="es">Conjunto de etiquetas utilizadas para clasificar y describir de forma transversal características, temáticas, atributos o enfoques experienciales asociados a un elemento.</rdfs:comment>
        <rdfs:comment xml:lang="en">Set of tags used to classify and describe, in a transversal manner, characteristics, themes, attributes or experiential approaches associated with an item.</rdfs:comment>
        <rdfs:label xml:lang="es">Etiqueta</rdfs:label>
        <rdfs:label xml:lang="en">Tag</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-Tag.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/TargetAudience -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/TargetAudience">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">A specific group of people targeted by a price or special offer, based on their age.</rdfs:comment>
        <rdfs:comment xml:lang="es">Grupo específico de personas al que va dirigido un precio o una propuesta especial, según la edad.</rdfs:comment>
        <rdfs:label xml:lang="es">Público objetivo</rdfs:label>
        <rdfs:label xml:lang="en">Target audience</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-TargetAudience.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/TimeOfTheYear -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/TimeOfTheYear">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">A seasonal period during which a destination experience, agrotourism experience, or route is recommended, or during which it has greater relevance, intensity, or appeal.</rdfs:comment>
        <rdfs:comment xml:lang="es">Periodo estacional en el que se recomienda realizar la experiencia en destino, experiencia agroturística o ruta, o en el que esta tiene mayor relevancia, intensidad o atractivo.</rdfs:comment>
        <rdfs:label xml:lang="es">Temporada del año</rdfs:label>
        <rdfs:label xml:lang="en">Time of the year</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-TimeOfTheYear.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/TourSpecialty -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/TourSpecialty">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="es">Enfoque particular o características únicas que distinguen al servicio de visita guiada.</rdfs:comment>
        <rdfs:comment xml:lang="en">Particular focus or unique features that distinguish the tour service.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-TourSpecialty.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/TouristType -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/TouristType">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="es">Clasificación para eventos, propuestas especiales, destinos y organizaciones turísticas, instalaciones turísticas o vinculadas, recursos y servicios turísticos en función de sus turistas objetivo con relación a sus motivaciones principales de viaje.</rdfs:comment>
        <rdfs:comment xml:lang="en">Classification for events, special offers, destinations and tourism organisations, tourism or related facilities, tourism resources and services based on their target tourists in relation to their main travel motivations.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-TouristType.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/TrailType -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/TrailType">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="es">Clasificación de las vías de una ruta, organizada o no, en función del tipo de itinerario y el entorno en el que se emplaza.</rdfs:comment>
        <rdfs:comment xml:lang="en">Classification of the paths used along a route, whether organized or not, based on the type of itinerary and the environment in which they are located.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-TrailType.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/TravelContainerType -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/TravelContainerType">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="es">Tipos de habitáculos portátiles utilizados para transportar o albergar a mascotas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Types of portable enclosures used to transport or house pets.</rdfs:comment>
        <rdfs:label xml:lang="es">Tipo de contenedor de viaje</rdfs:label>
        <rdfs:label xml:lang="en">Travel container type</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-TravelContainerType.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/TravelUnit -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/TravelUnit">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="es">Clasificación de eventos, propuestas especiales, destinos y organizaciones turísticas, instalaciones turísticas o relacionadas, recursos y servicios turísticos en función de sus turistas objetivo con relación a la composición del grupo con el que viajan y comparten los gastos asociados.</rdfs:comment>
        <rdfs:comment xml:lang="en">Classification for events, special offers, tourism destinations and organisations, tourism or related facilities, tourism resources and services based on their target tourists in relation to the composition of the party with whom they travel and share the associated expenses.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-TravelUnit.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/VehicleExperienceType -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/VehicleExperienceType">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">A list of vehicle types through which specific experiences can be carried out.</rdfs:comment>
        <rdfs:comment xml:lang="es">Listado de vehículos con los cuales se pueden realizar determinadas experiencias.</rdfs:comment>
        <rdfs:label xml:lang="es">Tipo de experiencia en vehículo</rdfs:label>
        <rdfs:label xml:lang="en">Vehicle experience type</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-VehicleExperienceType.ttl"/>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/kos/VehicleType -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/kos/VehicleType">
        <rdf:type rdf:resource="http://www.w3.org/2008/05/skos#ConceptScheme"/>
        <rdfs:comment xml:lang="en">Categories or classifications of vehicles based on their design, size, purpose, and characteristics.</rdfs:comment>
        <rdfs:comment xml:lang="es">Categorías o clasificaciones de vehículos según su diseño, tamaño, propósito y características.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://ontologia.segittur.es/turismo/def/core/kos/skos-VehicleType.ttl"/>
    </owl:NamedIndividual>
</rdf:RDF>



