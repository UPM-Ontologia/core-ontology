        <rdfs:label xml:lang="en">activity type</rdfs:label>
        <rdfs:label xml:lang="es">tipo de actividad</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#adversity -->


