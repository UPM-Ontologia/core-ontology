  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#ConventionCentre",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A facility designed for hosting conventions, congresses, conferences, professional meetings, and other corporate or institutional events, equipped with versatile spaces such as modular rooms, auditoriums, and support areas, as well as the technical infrastructure and services required for the organisation and management of large-scale events."
  }, {
    "@language" : "es",
    "@value" : "Instalación destinada a la celebración de congresos, convenciones, conferencias, reuniones profesionales y otros eventos de carácter corporativo o institucional, dotada de espacios versátiles como salas modulares, auditorios y áreas de apoyo, así como de infraestructuras técnicas y servicios necesarios para la organización y gestión de eventos a gran escala."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Centro de convenciones"
  }, {
    "@language" : "en",
    "@value" : "Convention centre"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#EventAttendanceFacility"
  } ],
  "https://ontologia.segittur.es/turismo/def/annot#visibleResource" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#Cove",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A small, rounded inlet forming part of a bay, smaller than a beach and characterized by calmer waters."
  }, {
    "@language" : "es",
    "@value" : "Tramo de bahía de forma redondeada, de dimensiones más pequeñas a las de la playa y donde sus aguas son más tranquilas"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Cala"
  }, {
    "@language" : "en",
    "@value" : "Cove"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#NaturalResource"
