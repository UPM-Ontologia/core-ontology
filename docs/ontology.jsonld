  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Land intended for vine cultivation for grape production."
  }, {
    "@language" : "es",
    "@value" : "Terreno destinado al cultivo de la vid para la producción de uva."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Vineyard"
  }, {
    "@language" : "es",
    "@value" : "Viñedo"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
