  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A vat where grapes were once trodden"
  }, {
    "@language" : "es",
    "@value" : "Depósito donde antiguamente se pisaba la uva"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Lagar"
  }, {
    "@language" : "en",
    "@value" : "Wine press"
