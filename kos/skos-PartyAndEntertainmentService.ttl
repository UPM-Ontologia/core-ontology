@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix estur-core: <https://ontologia.segittur.es/turismo/def/core#> .
@prefix estur-kos: <https://ontologia.segittur.es/turismo/kos/> .

@prefix estur-partyandentertainmentservice: <https://ontologia.segittur.es/turismo/kos/partyandentertainmentservice/> .

#################################################################
#
#    Concept Scheme
#
#################################################################

estur-kos:PartyAndEntertainmentService a skos:ConceptScheme ; 
    dct:issued "2024-05-24"^^xsd:date ;
    dct:modified "2025-12-15"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the SEGITTUR tourism ontology."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por la ontología de turismo de SEGITTUR."@es ;
    rdfs:label "Party And Entertainment Service"@en ;
    rdfs:label "Servicio de fiesta y entretenimiento"@es ;
    dct:title "Concept scheme grouping party and entertainment services"@en ;
    dct:title "Esquema de conceptos agrupando servicios de fiesta y entretenimiento"@es .

#################################################################
#
#    Concepts
#
#################################################################
estur-partyandentertainmentservice:CloackRoom a skos:Concept;
  skos:inScheme estur-kos:PartyAndEntertainmentService;
  skos:prefLabel "Cloack Room"@en ;
  skos:prefLabel "Guardarropa"@es .

estur-partyandentertainmentservice:OutdoorTables a skos:Concept;
  skos:inScheme estur-kos:PartyAndEntertainmentService;
  skos:prefLabel "Outdoor Tables"@en ;
  skos:prefLabel "Mesas exteriores"@es .

estur-partyandentertainmentservice:Venue a skos:Concept;
  skos:inScheme estur-kos:PartyAndEntertainmentService;
  skos:prefLabel "Venue"@en ;
  skos:prefLabel "Lugar de celebración"@es .

estur-partyandentertainmentservice:VIPRoom a skos:Concept;
  skos:inScheme estur-kos:PartyAndEntertainmentService;
  skos:prefLabel "VIP Room"@en ;
  skos:prefLabel "Sala VIP"@es .



