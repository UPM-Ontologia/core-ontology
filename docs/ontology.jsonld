}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#accommodationRateType",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Rates applicable specifically to accommodation establishments and lodging services."
