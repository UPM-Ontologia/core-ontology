                      ] ;
           rdfs:label "cabin type"@en ,
                      "tipo de cabina"@es .


###  https://ontologia.segittur.es/turismo/def/core#campingSpecialty
:campingSpecialty rdf:type owl:ObjectProperty ;
                  rdfs:domain :Camping ;
                  rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                      owl:hasValue <https://ontologia.segittur.es/turismo/kos/CampingSpecialty>
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ;
                  rdfs:label "camping specialty"@en ,
                             "especialidad del camping"@es .


###  https://ontologia.segittur.es/turismo/def/core#cancellationFee
:cancellationFee rdf:type owl:ObjectProperty ;
                 rdfs:domain :BookingInformation ;
                 rdfs:range :CancellationFee ;
                 rdfs:label "cancellation fee"@en ,
                            "comisión de cancelación"@es .


###  https://ontologia.segittur.es/turismo/def/core#civicBuildingType
:civicBuildingType rdf:type owl:ObjectProperty ;
                   rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                       owl:hasValue <https://ontologia.segittur.es/turismo/kos/CivicBuildingType>
                                                     ]
                                                   ) ;
                                rdf:type owl:Class
                              ] ;
                   rdfs:label "civic building type"@en ,
                              "tipo de edificio"@es .


###  https://ontologia.segittur.es/turismo/def/core#containedIn
:containedIn rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :relatedTo ;
             rdfs:label "contained in"@en ,
                        "contenido en"@es .


###  https://ontologia.segittur.es/turismo/def/core#cruiseShip
:cruiseShip rdf:type owl:ObjectProperty ;
            rdfs:domain :CruiseLine ;
            rdfs:range :CruiseShip ;
            rdfs:label "barco de crucero"@es ,
                       "cruise ship"@en .


###  https://ontologia.segittur.es/turismo/def/core#cuisineType
:cuisineType rdf:type owl:ObjectProperty ;
             rdfs:domain :RestaurantService ;
             rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                 owl:hasValue <https://ontologia.segittur.es/turismo/kos/CuisineType>
                                               ]
                                             ) ;
                          rdf:type owl:Class
                        ] ;
             rdfs:label "cuisine type"@en ,
                        "tipo de cocina"@es .


###  https://ontologia.segittur.es/turismo/def/core#dayOfTheWeek
:dayOfTheWeek rdf:type owl:ObjectProperty ;
              rdfs:domain [ rdf:type owl:Class ;
                            owl:unionOf ( :OpeningHours
                                          :TransportRoute
                                        )
                          ] ;
              rdfs:range :DayOfTheWeek ;
              rdfs:label "day of the week"@en ,
                         "día de la semana"@es .


###  https://ontologia.segittur.es/turismo/def/core#deliveryPoint
:deliveryPoint rdf:type owl:ObjectProperty ;
               rdfs:domain [ rdf:type owl:Class ;
                             owl:unionOf ( :ParcelAndCourier
                                           :PostOffice
                                         )
                           ] ;
               rdfs:range :DeliveryPoint ;
               rdfs:label "delivery point"@es ,
                          "punto de entrega"@es .


###  https://ontologia.segittur.es/turismo/def/core#destinationType
:destinationType rdf:type owl:ObjectProperty ;
                 rdfs:domain :TouristDestination ;
                 rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                     owl:hasValue <https://ontologia.segittur.es/turismo/kos/DestinationType>
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
                 rdfs:label "destination type"@en ,
                            "tipo de destino"@es .


###  https://ontologia.segittur.es/turismo/def/core#educationLevel
:educationLevel rdf:type owl:ObjectProperty ;
                rdfs:domain :Person ;
                rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                    owl:hasValue <https://ontologia.segittur.es/turismo/kos/EducationLevel>
                                                  ]
                                                ) ;
