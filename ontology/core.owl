                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">List of relevant national and international tourism certifications for events, destinations, tourism resources, public services, and tourism organisations, including their facilities and services.</rdfs:comment>
        <rdfs:comment xml:lang="es">Listado de certificaciones turísticas de referencia en el ámbito nacional e internacional para eventos, destinos, recursos turísticos, servicios públicos y empresas turísticas, incluyendo sus instalaciones y servicios.</rdfs:comment>
        <rdfs:label xml:lang="en">certification type</rdfs:label>
        <rdfs:label xml:lang="es">tipo de certificación</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#compulsoryZoosanitaryProduct -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#compulsoryZoosanitaryProduct">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/CompulsoryZoosanitaryProduct"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Substances, active ingredients, formulations or preparations intended for the diagnosis, prevention, treatment, alleviation or cure of diseases or ailments in animals, and whose administration is required for admission.</rdfs:comment>
        <rdfs:comment xml:lang="es">Sustancias, ingredientes activos, formulaciones o preparados destinados al diagnóstico, prevención, tratamiento, alivio o cura de las enfermedades o dolencias de los animales, y cuya administración es requerida para su admisión.</rdfs:comment>
        <rdfs:label xml:lang="en">compulsory zoosanitary product</rdfs:label>
        <rdfs:label xml:lang="es">producto zoosanitario obligatorio</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#dayOfTheWeek -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#dayOfTheWeek">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#OpeningHours"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/DayOfTheWeek"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">One of the seven named periods (Monday through Sunday) that constitute a standard weekly cycle, used to define recurring time slots.</rdfs:comment>
        <rdfs:comment xml:lang="es">Uno de los siete periodos nombrados (de lunes a domingo) que constituyen un ciclo semanal estándar, utilizado para definir franjas horarias recurrentes.</rdfs:comment>
        <rdfs:label xml:lang="en">day of the week</rdfs:label>
        <rdfs:label xml:lang="es">día de la semana</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#destinationType -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#destinationType">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismDestination"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/DestinationType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Categorisation of the space according to its main characteristics and attractions.</rdfs:comment>
        <rdfs:comment xml:lang="es">Categorización del espacio en función de sus características y atractivos principales.</rdfs:comment>
        <rdfs:label xml:lang="en">destination type</rdfs:label>
        <rdfs:label xml:lang="es">tipo de destino</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#eventSchedule -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#eventSchedule">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Event"/>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#Schedule"/>
        <rdfs:comment xml:lang="es">Asociación de un evento con una programación.</rdfs:comment>
        <rdfs:comment xml:lang="en">Association of an event with a schedule.</rdfs:comment>
        <rdfs:label xml:lang="en">event schedule</rdfs:label>
        <rdfs:label xml:lang="es">programación del evento</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">9</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>contact</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#eventType -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#eventType">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Event"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/EventType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Clasificación utilizada para agrupar jerárquicamente los diferentes tipos de eventos que se llevan a cabo en función de su naturaleza o temática.</rdfs:comment>
        <rdfs:comment xml:lang="en">Classification used to hierarchically group the different types of events that take place according to their nature or theme.</rdfs:comment>
        <rdfs:label xml:lang="en">event type</rdfs:label>
        <rdfs:label xml:lang="es">tipo de evento</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#frequentlyAskedQuestion -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#frequentlyAskedQuestion">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#AdditionalInformation"/>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#FrequentlyAskedQuestion"/>
        <rdfs:comment xml:lang="en">A collection of questions and answers that address the most common doubts users have about a particular topic, product, service, or organisation.</rdfs:comment>
        <rdfs:comment xml:lang="es">Recopilación de preguntas y respuestas que abordan las dudas más comunes que tienen los usuarios sobre un tema, producto, servicio o empresa en particular.</rdfs:comment>
        <rdfs:label xml:lang="en">frequently asked question</rdfs:label>
        <rdfs:label xml:lang="es">pregunta frecuente</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#handicraftsType -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#handicraftsType">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Handicrafts"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/HandicraftsType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Categorisation of handicraft shops according to the type of product they offer</rdfs:comment>
        <rdfs:comment xml:lang="es">Categorización de las tiendas de artesanías en función del tipo de producto que ofrece.</rdfs:comment>
        <rdfs:label xml:lang="en">handicrafts yype</rdfs:label>
        <rdfs:label xml:lang="es">tipo de artesanía</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#hasAcknowledgement -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#hasAcknowledgement">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Event"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismDestination"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrganisation"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismResource"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TouristInformationOffice"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#Acknowledgement"/>
        <rdfs:comment xml:lang="en">Achievements or distinctions awarded to people, companies or products for meeting certain standards or specific criteria. These recognitions may include certifications, awards, or other types of honors that recognize quality, performance, compliance, or excellence in a particular field.</rdfs:comment>
        <rdfs:comment xml:lang="es">Logros o distinciones otorgadas a personas, empresas o productos por cumplir con ciertos estándares o criterios específicos. Estos reconocimientos pueden incluir certificaciones, premios u otros tipos de distinciones que reconocen la calidad, el rendimiento, el cumplimiento de normas o la excelencia en un determinado campo.</rdfs:comment>
        <rdfs:label xml:lang="en">has acknowledgement</rdfs:label>
        <rdfs:label xml:lang="es">tiene reconocimiento</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">8</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>acknowledgement</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#hasAdditionalAccommodationService -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#hasAdditionalAccommodationService">
        <rdfs:subPropertyOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalService"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#LodgingService"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
