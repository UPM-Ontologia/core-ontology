#################################################################
#
#    Concept Scheme
#
#################################################################

estur-kos:TouristDestinationService a skos:ConceptScheme ; 
    dct:issued "2024-05-24"^^xsd:date ;
    dct:modified "2025-12-15"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the SEGITTUR tourism ontology."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por la ontología de turismo de SEGITTUR."@es ;
    rdfs:label "Tourist destination service"@en ;
    rdfs:label "Servicio de un destino turístico"@es ;
    dct:title "Concept scheme grouping tourist destination services"@en ;
    dct:title "Esquema de conceptos agrupando servicios de un destino turístico"@es .

#################################################################
#
#    Concepts
#
#################################################################

estur-touristdestinationservice:DestinationApp a skos:Concept;
  skos:inScheme estur-kos:TouristDestinationService;
  skos:note "Value generated from the original SEGITTUR ontology"@en;
  skos:note "Valor generado a partir de la ontología de SEGITTUR original"@es;
  skos:prefLabel "Destination app"@en ;
  skos:prefLabel "App de destino"@es .

