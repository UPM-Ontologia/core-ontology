@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix estur-core: <https://ontologia.segittur.es/turismo/def/core#> .
@prefix estur-kos: <https://ontologia.segittur.es/turismo/kos/> .

@prefix estur-accesstype: <https://ontologia.segittur.es/turismo/kos/accesstype/> .

#################################################################
#
#    Concept Scheme
#
#################################################################

estur-kos:AccessType a skos:ConceptScheme ; 
    dct:issued "2024-10-29"^^xsd:date ;
    dct:modified "2024-10-29"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the SEGITTUR tourism ontology."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por la ontología de turismo de SEGITTUR."@es ;
    rdfs:label "Access Type"@en ;
    rdfs:label "Tipo de acceso"@es ;
    dct:title "Concept scheme grouping access types"@en ;
    dct:title "Esquema de conceptos agrupando tipos de acceso"@es .

#################################################################
#
#    Concepts
#
#################################################################

estur-accesstype:BoatAccess a skos:Concept;
  skos:inScheme estur-kos:AccessType;
  skos:note "Value generated from the original SEGITTUR ontology"@en;
  skos:note "Valor generado a partir de la ontología de SEGITTUR original"@es;
  skos:prefLabel "Boat Access"@en ;
  skos:prefLabel "Bote/barco"@es .

estur-accesstype:OnFoot a skos:Concept;
  skos:inScheme estur-kos:AccessType;
  skos:note "Value generated from the original SEGITTUR ontology"@en;
  skos:note "Valor generado a partir de la ontología de SEGITTUR original"@es;
  skos:prefLabel "On foot"@en ;
  skos:prefLabel "A pie"@es .

estur-accesstype:PrivateVehicle a skos:Concept;
  skos:inScheme estur-kos:AccessType;
  skos:note "Value generated from the original SEGITTUR ontology"@en;
  skos:note "Valor generado a partir de la ontología de SEGITTUR original"@es;
  skos:prefLabel "Private vehicle"@en ;
  skos:prefLabel "Vehículo privado"@es .

estur-accesstype:PublicTransport a skos:Concept;
  skos:inScheme estur-kos:AccessType;
  skos:note "Value generated from the original SEGITTUR ontology"@en;
  skos:note "Valor generado a partir de la ontología de SEGITTUR original"@es;
  skos:prefLabel "Public Transport"@en ;
  skos:prefLabel "Transporte público"@es .

