  }, {
    "@language" : "es",
    "@value" : "Experiencias resultantes de la prestación de servicios turísticos en explotaciones del sector primario compatibles con la producción principal y capaces de atraer visitantes a los que transmitirles sensaciones satisfactorias."
  } ],
