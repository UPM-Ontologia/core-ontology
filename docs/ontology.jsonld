    "@language" : "es",
    "@value" : "Recinto en los que se organizan actividades de carácter cultural: conferencias, exposiciones, tertulias, etc."
  }, {
    "@language" : "en",
    "@value" : "Venue where cultural activities are organized: conferences, exhibitions, gatherings, etc."
  } ],
