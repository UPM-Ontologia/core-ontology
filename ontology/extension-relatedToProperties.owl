     xmlns:geosparql="http://www.opengis.net/ont/geosparql#">
    <owl:Ontology rdf:about="https://ontologia.segittur.es/turismo/def/extended-relatedTo#">
        <owl:versionIRI rdf:resource="https://ontologia.segittur.es/turismo/def/extended-relatedTo/0.0.1"/>
        <owl:imports rdf:resource="https://ontologia.segittur.es/turismo/def/core/1.1.0"/>
        <dc:rights>Creative Commons Attribution Non-Commercial No-Derivatives 4.0 International (CC BY-NC-ND 4.0)</dc:rights>
        <dct:description xml:lang="es">Este módulo extiende la propiedad estur:relatedTo de la ontología principal (core) de la Red de Ontologías del Sector Turístico al servicio de la futura Plataforma Inteligente de Destino (PID) promovida por SEGITTUR.</dct:description>
        <dct:description xml:lang="en">This module extends the object property estur:relatedTo from the main ontology (core) of the Network of Tourism Sector Ontologies at the service of the future Intelligent Destination Platform (IDP) promoted by SEGITTUR.</dct:description>
        <dct:hasFormat rdf:resource="https://ontologia.segittur.es/turismo/def/extended-relatedTo.owl"/>
        <dct:issued xml:lang="es">2024-11-13</dct:issued>
        <dct:license rdf:resource="https://creativecommons.org/licenses/by-nc-nd/4.0/"/>
        <dct:license>CC BY-NC-ND</dct:license>
        <dct:title xml:lang="en">Extended ontology for the relatedTo property of the tourism ontology by SEGITTUR</dct:title>
        <dct:title xml:lang="es">Extensión de la ontología principal de turismo de SEGITTUR, para la propiedad relatedTo</dct:title>
        <vann:preferredNamespacePrefix>estur-relatedto</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri rdf:resource="https://ontologia.segittur.es/turismo/def/extended-relatedTo#"/>
        <owl:versionInfo>0.0.1</owl:versionInfo>
        <owl:versionInfo xml:lang="es">0.0.1</owl:versionInfo>

    </owl:Ontology>
    


