  "@id" : "https://ontologia.segittur.es/turismo/def/core#MassageCentre",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Business that provides relaxation, health and body well-being services through therapeutic and anti-stress massages."
  }, {
    "@language" : "es",
    "@value" : "Negocio que brinda los servicios de relax, salud y bienestar corporal por medio de masajes terapéuticos y anti estrés."
  } ],
