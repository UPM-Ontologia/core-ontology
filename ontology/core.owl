        <rdfs:label xml:lang="es">NFC</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#bankCard -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/def/core#bankCard">
        <rdf:type rdf:resource="https://ontologia.segittur.es/turismo/def/core#PaymentMethod"/>
        <rdfs:label xml:lang="en">bank card</rdfs:label>
        <rdfs:label xml:lang="es">tarjeta bancaria</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#bankTransfer -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/def/core#bankTransfer">
        <rdf:type rdf:resource="https://ontologia.segittur.es/turismo/def/core#PaymentMethod"/>
        <rdfs:label xml:lang="en">bank transfer</rdfs:label>
        <rdfs:label xml:lang="es">transferencia bancaria</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#bizum -->

    <owl:NamedIndividual rdf:about="https://ontologia.segittur.es/turismo/def/core#bizum">
        <rdf:type rdf:resource="https://ontologia.segittur.es/turismo/def/core#PaymentMethod"/>
        <rdfs:label xml:lang="en">bizum</rdfs:label>
