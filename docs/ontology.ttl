###  http://www.w3.org/2004/02/skos/core#Concept
<http://www.w3.org/2004/02/skos/core#Concept> rdf:type owl:Class .


###  http://www.w3.org/2008/05/skos#ConceptScheme
<http://www.w3.org/2008/05/skos#ConceptScheme> rdf:type owl:Class ;
                                               rdfs:subClassOf owl:Thing .


###  https://ontologia.segittur.es/turismo/def/core#ATM
:ATM rdf:type owl:Class ;
     rdfs:subClassOf :FinancialService ;
     rdfs:label "ATM"@en ,
                "cajero automático"@es .


###  https://ontologia.segittur.es/turismo/def/core#AccesoriesAndComplements
:AccesoriesAndComplements rdf:type owl:Class ;
                          rdfs:subClassOf :RetailAndFashion ;
                          rdfs:label "accesories and complements"@en ,
                                     "tienda de accesorios y complementos"@es .


###  https://ontologia.segittur.es/turismo/def/core#Accommodation
:Accommodation rdf:type owl:Class ;
               rdfs:subClassOf :TourismService ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :accommodationCapacity ;
                                 owl:maxCardinality "1"^^xsd:nonNegativeInteger
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasBookingInformation ;
                                 owl:maxCardinality "1"^^xsd:nonNegativeInteger
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasPaymentInformation ;
                                 owl:maxCardinality "1"^^xsd:nonNegativeInteger
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasPriceClass ;
                                 owl:maxCardinality "1"^^xsd:nonNegativeInteger
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasPriceInformation ;
                                 owl:maxCardinality "1"^^xsd:nonNegativeInteger
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasTransactionInformation ;
                                 owl:maxCardinality "1"^^xsd:nonNegativeInteger
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :registration ;
                                 owl:maxCardinality "1"^^xsd:nonNegativeInteger
                               ] ;
               rdfs:label "Accommodation"@en ,
                          "Alojamientos"@es .


###  https://ontologia.segittur.es/turismo/def/core#AccommodationCapacity
:AccommodationCapacity rdf:type owl:Class ;
                       rdfs:subClassOf owl:Thing ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :maximumCapacity ;
                                         owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :numberOfRooms ;
                                         owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                       ] ;
                       rdfs:label "accommodation capacity"@en ,
                                  "capacidad del alojamiento"@es .


###  https://ontologia.segittur.es/turismo/def/core#AccommodationRegistration
:AccommodationRegistration rdf:type owl:Class ;
                           rdfs:subClassOf owl:Thing ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty :checkInHours ;
                                             owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty :checkOutHours ;
                                             owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty :online ;
                                             owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty :onsite ;
                                             owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                           ] ;
                           rdfs:label "accommodation registration"@en ,
                                      "registro en el alojamiento"@es .


