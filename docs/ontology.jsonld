}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#PortPassengerTerminal",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Unidad establecida en un puerto o fuera de él, formada por obras, instalaciones y superficies, incluida su zona de agua, que permite la realización íntegra de la operación portuaria de tránsito de pasajeros, incluyendo el embarque y el desembarque de pasajeros y equipajes del buque al puerto."
  }, {
    "@language" : "en",
    "@value" : "Unit established in a port or outside it, made up of works, facilities and surfaces, including its water area, that allows the full implementation of the port operation of passenger transit, including the boarding and disembarkation of passengers and luggage from the ship to the port."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Port passenger terminal"
  }, {
    "@language" : "es",
    "@value" : "Terminal portuaria de pasajeros"
  } ],
