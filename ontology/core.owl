                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Enfoque particular o características únicas que distinguen al servicio de visita guiada.</rdfs:comment>
        <rdfs:comment xml:lang="en">Particular focus or unique features that distinguish the tour service.</rdfs:comment>
        <rdfs:label xml:lang="es">especialidad de la visita guiada</rdfs:label>
        <rdfs:label xml:lang="en">tour specialty</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#touristType -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#touristType">
        <rdfs:domain>
            <owl:Class>
