###  https://ontologia.segittur.es/turismo/def/core#TourismResource
:TourismResource rdf:type owl:Class ;
                 rdfs:subClassOf [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasContactInfo ;
                                   owl:allValuesFrom :ContactInfo
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasLocation ;
                                   owl:allValuesFrom :Location
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasOpeningHours ;
                                   owl:allValuesFrom :OpeningHours
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasTemporaryClosure ;
                                   owl:allValuesFrom :TemporaryClosure
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasAdditionalInformation ;
                                   owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                   owl:onClass :AdditionalInformation
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasDescription ;
                                   owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                   owl:onClass :Description
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasMultimedia ;
                                   owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                   owl:onClass :Multimedia
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasSocialMediaProfile ;
                                   owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                   owl:onClass :SocialMediaProfile
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasTransactionInformation ;
                                   owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :capacity ;
                                   owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :managementEntity ;
                                   owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :publicAccess ;
                                   owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :visitduration ;
                                   owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                 ] ;
                 rdfs:comment "Clase que agrupa de manera general los recursos relevantes para el sector turístico, donde se aplicarán las propiedades comunes a todos estos recursos."@es ,
                              "Class that groups in a general manner all resources that are relevant for the tourism sector, so as to group all common properties to all these resources."@en ;
                 rdfs:label "Recurso turístico"@es ,
                            "Tourism Resource"@en .


###  https://ontologia.segittur.es/turismo/def/core#TourismService
:TourismService rdf:type owl:Class ;
                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                  owl:onProperty :hasContactInfo ;
                                  owl:allValuesFrom :ContactInfo
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :hasLocation ;
                                  owl:allValuesFrom :Location
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :hasTemporaryClosure ;
                                  owl:allValuesFrom :TemporaryClosure
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :hasAdditionalInformation ;
                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass :AdditionalInformation
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :hasDescription ;
                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass :Description
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :hasMultimedia ;
                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass :Multimedia
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :hasOpeningHours ;
                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass :OpeningHours
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :hasSocialMediaProfile ;
                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass :SocialMediaProfile
                                ] ;
                rdfs:comment "Clase que agrupa de manera general los servicios relevantes para el sector turístico, donde se aplicarán las propiedades comunes a todos estos servicios."@es ,
                             "Class that groups in a general manner all services that are relevant for the tourism sector, so as to group all common properties to all these services."@en ;
                rdfs:label "Servicio turístico"@es ,
                           "Tourism Service"@en .


