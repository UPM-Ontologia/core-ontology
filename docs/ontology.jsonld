    "@language" : "en",
    "@value" : "A cellar, cave or underground winery with high humidity and a constant temperature throughout the year, used for maturing and ageing wines"
  }, {
    "@language" : "es",
    "@value" : "Cava, cueva o bodega subterránea con mucha humedad ambiente y temperatura constante todo el año que se utiliza para criar y envejecer vinos"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Calado"
