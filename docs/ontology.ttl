                      ] ;
           rdfs:label "ferry type"@en ,
                      "tipo de ferry"@es .


###  https://ontologia.segittur.es/turismo/def/core#gardenCategory
:gardenCategory rdf:type owl:ObjectProperty ;
                rdfs:domain :Garden ;
                rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                    owl:hasValue <https://ontologia.segittur.es/turismo/kos/GardenCategory>
                                                  ]
                                                ) ;
