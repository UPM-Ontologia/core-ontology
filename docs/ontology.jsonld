}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#TennisCourt",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A rectangular surface adapted for tennis, divided by a central net and featuring various types of court surfaces depending on the style of play."
  }, {
    "@language" : "es",
    "@value" : "Superficie rectangular adaptada para la práctica del tenis, dividida por una red intermedia y acondicionada con diferentes tipos de pavimento según la modalidad de juego."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Pista de tenis"
  }, {
    "@language" : "en",
