    "@value" : "true"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#TimeSlot",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Intervalo temporal que define un periodo continuo de apertura, delimitado por una hora de inicio y una hora de finalización, y utilizado para describir tramos horarios dentro de un día concreto. "
  }, {
    "@language" : "en",
    "@value" : "Time interval that defines a continuous period of opening, delimited by a start time and an end time, and used to describe time ranges within a specific day."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Franja horaria"
  }, {
    "@language" : "en",
    "@value" : "Time slot"
  } ],
