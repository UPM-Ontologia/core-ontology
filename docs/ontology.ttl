###  https://ontologia.segittur.es/turismo/def/core#Train
:Train rdf:type owl:Class ;
       rdfs:subClassOf :MeansOfTransport ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasContactInfo ;
                         owl:cardinality "1"^^xsd:nonNegativeInteger
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasDescription ;
                         owl:cardinality "1"^^xsd:nonNegativeInteger
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasAdditionalInformation ;
                         owl:maxCardinality "1"^^xsd:nonNegativeInteger
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasMultimedia ;
                         owl:maxCardinality "1"^^xsd:nonNegativeInteger
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasPaymentInformation ;
                         owl:maxCardinality "1"^^xsd:nonNegativeInteger
                       ] ;
       rdfs:label "train"@en ,
                  "tren"@es .


###  https://ontologia.segittur.es/turismo/def/core#TrainStation
