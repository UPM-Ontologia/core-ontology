    "@language" : "en",
    "@value" : "Passenger transport service between a predefined origin and destination, carried out using a specific means of transport and following a set route."
  }, {
    "@language" : "es",
    "@value" : "Servicio de desplazamiento de pasajeros entre un origen y un destino previamente definidos, realizado mediante un medio de transporte concreto y conforme a un recorrido establecido."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Servicio de transporte"
  }, {
    "@language" : "en",
