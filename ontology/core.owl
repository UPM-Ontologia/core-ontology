    <!-- https://ontologia.segittur.es/turismo/def/core#accessType -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#accessType">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismResource"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
