    "@value" : "true"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#DailyOpeningHours",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Horario de apertura correspondiente a un día concreto de la semana, definido mediante uno o varios intervalos horarios con horas de apertura y cierre."
  }, {
    "@language" : "en",
    "@value" : "Opening hours corresponding to a specific day of the week, defined by one or more time intervals with opening and closing times."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Daily opening hours"
  }, {
    "@language" : "es",
