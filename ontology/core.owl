                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">A specific group of people targeted by a price or special offer, based on their age.</rdfs:comment>
        <rdfs:comment xml:lang="es">Grupo específico de personas al que va dirigido un precio o una propuesta especial, según la edad.</rdfs:comment>
        <rdfs:label xml:lang="es">público objetivo</rdfs:label>
        <rdfs:label xml:lang="en">target audience</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Especifica el grupo objetivo para el que es adecuado la propuesta especial o el precio. Por ejemplo, niños, adultos, personas mayores, parejas, visitantes de un país concreto, etc</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Specifies the target group for which the special offer or price is suitable. For example, children, adults, seniors, couples, visitors from a specific country, etc</estur-annot:tooltip>
    </owl:ObjectProperty>
    


