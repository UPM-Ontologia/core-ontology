}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/AccommodationRatingSystem",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Grading or classification scheme system providing an assessment of the facilities, services or both provided by tourist accommodation. Typically within five categories, often indicated by one to five symbols."
  }, {
    "@language" : "es",
    "@value" : "Sistema de clasificación o categorización que evalúa las instalaciones, los servicios o ambos aspectos de los alojamientos turísticos. Normalmente se divide en cinco categorías, que suelen indicarse con uno a cinco símbolos."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-AccommodationRatingSystem.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/AccommodationUnitCategory",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Tipo de unidad de alojamiento que se ofrece a los huéspedes y en la que se les proporcionan, como mínimo, camas y servicios de higiene."
  }, {
    "@language" : "en",
    "@value" : "Type of accommodation unit offered to guests, in which they are provided with, at least, sleeping and sanitary facilities."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-AccommodationUnitCategory.ttl"
  } ]
