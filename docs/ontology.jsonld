  "@id" : "https://ontologia.segittur.es/turismo/def/core#Minaret",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A tower of a mosque from which the muezzin calls Muslims to prayer."
  }, {
    "@language" : "es",
    "@value" : "Torre de las mezquitas desde cuya altura convoca el almuédano a los musulmanes en las horas de oración."
