@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix estur-core: <https://ontologia.segittur.es/turismo/def/core#> .
@prefix estur-kos: <https://ontologia.segittur.es/turismo/kos/> .

@prefix estur-ferryservice: <https://ontologia.segittur.es/turismo/kos/ferryservice/> .

#################################################################
#
#    Concept Scheme
#
#################################################################

estur-kos:FerryService a skos:ConceptScheme ; 
    dct:issued "2024-05-24"^^xsd:date ;
    dct:modified "2024-05-24"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the SEGITTUR tourism ontology."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por la ontología de turismo de SEGITTUR."@es ;
    rdfs:label "Ferry Service"@en ;
    rdfs:label "Tipo de servicio de un ferry"@es ;
    dct:title "Concept scheme grouping ferry service types"@en ;
    dct:title "Esquema de conceptos agrupando tipos de servicio de un ferry"@es .

#################################################################
#
#    Concepts
#
#################################################################

estur-ferryservice:Bar a skos:Concept;
  skos:inScheme estur-kos:FerryServiceType;
  skos:note "Value generated from the original SEGITTUR ontology"@en;
  skos:note "Valor generado a partir de la ontología de SEGITTUR original"@es;
  skos:prefLabel "Bar"@en ;
  skos:prefLabel "Bar"@es .

estur-ferryservice:PassengerVehicleTransport a skos:Concept;
  skos:inScheme estur-kos:FerryServiceType;
  skos:note "Value generated from the original SEGITTUR ontology"@en;
  skos:note "Valor generado a partir de la ontología de SEGITTUR original"@es;
  skos:prefLabel "Passenger Vehicle Transport"@en ;
  skos:prefLabel "Transporte de vehículos de pasajeros"@es .

estur-ferryservice:Wifi a skos:Concept;
  skos:inScheme estur-kos:FerryServiceType;
  skos:note "Value generated from the original SEGITTUR ontology"@en;
  skos:note "Valor generado a partir de la ontología de SEGITTUR original"@es;
  skos:prefLabel "Wifi"@en ;
  skos:prefLabel "Wifi"@es .

