    <!-- https://ontologia.segittur.es/turismo/def/core#accessTip -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#accessTip">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#AdditionalInformation"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="es">Información específica sobre cómo llegar a una dirección física asociada a una entidad turística.</rdfs:comment>
        <rdfs:comment xml:lang="en">Specific information on how to reach a physical address associated with a tourism entity.</rdfs:comment>
        <rdfs:label xml:lang="en">access tip</rdfs:label>
        <rdfs:label xml:lang="es">consejo para acceder</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#adaptedPublicRestroom -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#adaptedPublicRestroom">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicRestroom"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si el baño público está adaptado a personas con discapacidad.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether the public restroom is adapted for people with disabilities.</rdfs:comment>
        <rdfs:label xml:lang="en">adapted public restroom</rdfs:label>
        <rdfs:label xml:lang="es">baño público adaptado</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#additionalClassification -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#additionalClassification">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrganisation"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Supplementary values to represent specific internal or proprietary classifications that are not formally included in the model.</rdfs:comment>
        <rdfs:comment xml:lang="es">Valores complementarios para representar clasificaciones internas o propias específicas que no están incluidas formalmente en el modelo.</rdfs:comment>
        <rdfs:label xml:lang="en">additional classification</rdfs:label>
        <rdfs:label xml:lang="es">clasificación adicional</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Facilita valores complementarios para representar clasificaciones internas o propias específicas que no están incluidas formalmente en el modelo. Las propuestas introducidas podrán revisarse para futuras actualizaciones</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Provides complementary values to represent specific internal classifications that are not formally included in the model. The proposals introduced may be reviewed for future updates.</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#allowedPetAreasOnANonStrechtableLeash -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#allowedPetAreasOnANonStrechtableLeash">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAccommodationPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Areas designated by the accommodation where pets are allowed to stay provided they are kept on a leash that cannot be extended.</rdfs:comment>
        <rdfs:comment xml:lang="es">Áreas habilitadas por el alojamiento para que las mascotas puedan permanecer siempre que lleven correa que no pueda extenderse.</rdfs:comment>
        <rdfs:label xml:lang="en">allowed pet areas on a non-stretchable leash</rdfs:label>
        <rdfs:label xml:lang="es">zonas permitidas para mascotas con correa no extensible</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#allowedPetFreeRoamingAreas -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#allowedPetFreeRoamingAreas">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAccommodationPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Areas designated by the accommodation where pets may remain without the need for a muzzle or non-extendable leash.</rdfs:comment>
        <rdfs:comment xml:lang="es">Áreas habilitadas por el alojamiento para que las mascotas puedan permanecer sin la necesidad de llevar bozal o correa no extensible.</rdfs:comment>
        <rdfs:label xml:lang="en">allowed pet free roaming areas</rdfs:label>
        <rdfs:label xml:lang="es">zonas permitidas para mascotas en libertad</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#answer -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#answer">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#FrequentlyAskedQuestion"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Text that provides clarification, a solution, or detailed information in response to a frequently asked  question posed by users.</rdfs:comment>
        <rdfs:comment xml:lang="es">Texto que proporciona una aclaración, solución o información detallada en respuesta a una pregunta frecuente formulada por los usuarios.</rdfs:comment>
        <rdfs:label xml:lang="en">answer</rdfs:label>
        <rdfs:label xml:lang="es">respuesta</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#app -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#app">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#ContactPoint"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Text that allows redirecting the user to a specific software application, designed to facilitate fast and interactive access to information, tools, or services from a smartphone, tablet, or other mobile device.</rdfs:comment>
        <rdfs:comment xml:lang="es">Texto que permite redirigir al usuario a una aplicación informática específica, diseñada para facilitar el acceso rápido e interactivo a información, herramientas o servicios desde un teléfono inteligente, tableta u otro dispositivo móvil.</rdfs:comment>
        <rdfs:label xml:lang="en">app</rdfs:label>
        <rdfs:label xml:lang="es">app</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Facilita la URL para redirigir a un usuario al programa informático de interés en su teléfono inteligente, tableta u otro dispositivo móvil</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Provides the URL to redirect a user to the relevant software application on their smartphone, tablet, or other mobile device</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#audio -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#audio">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Multimedia"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">A URL to a digital file or stream containing recorded sound, such as guided tour narration, ambient audio, or language translations, intended for playback in a tourism context.</rdfs:comment>
        <rdfs:comment xml:lang="es">URL a un archivo digital o retransmisión que contiene sonido grabado, como narraciones de visitas guiadas, audio ambiental o traducciones lingüísticas, destinado a su reproducción en un contexto</rdfs:comment>
        <rdfs:label xml:lang="en">audio</rdfs:label>
        <rdfs:label xml:lang="es">audio</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#autonomousCheckIn -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#autonomousCheckIn">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica la posibilidad de realizar el check-in de forma autónoma.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether check-in can be carried out autonomously.</rdfs:comment>
        <rdfs:label xml:lang="en">autonomous check-in</rdfs:label>
        <rdfs:label xml:lang="es">check-in autónomo</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#autonomousCommunity -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#autonomousCommunity">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">A broad territorial division that groups several provinces or homogeneous geographic areas.</rdfs:comment>
        <rdfs:comment xml:lang="es">División territorial de carácter amplio que agrupa varias provincias o zonas geográficas homogéneas.</rdfs:comment>
        <rdfs:label xml:lang="en">autonomous community</rdfs:label>
        <rdfs:label xml:lang="es">comunidad autónoma</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#averagePricePerPerson -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#averagePricePerPerson">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#FoodAndBeverageService"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#LodgingService"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">The average value of a set of prices or rates charged per person by a service provider.</rdfs:comment>
        <rdfs:comment xml:lang="es">Valor promedio de un conjunto de precios o tarifas de un proveedor de servicios por persona.</rdfs:comment>
        <rdfs:label xml:lang="en">average price per person</rdfs:label>
        <rdfs:label xml:lang="es">precio medio por persona</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#brachycephalicPetsAllowed -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#brachycephalicPetsAllowed">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetTransportPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Posibilidad de transportar animales propensos a las obstrucciones y problemas respiratorios debido a la forma pequeña de su cabeza, hocico y garganta.</rdfs:comment>
        <rdfs:comment xml:lang="en">Possibility of transporting animals prone to obstructions and respiratory problems due to the small size of their head, snout and throat.</rdfs:comment>
        <rdfs:label xml:lang="es">admite mascotas braquicéfalos</rdfs:label>
        <rdfs:label xml:lang="en">brachycephalic pets allowed</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#byMonthDay -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#byMonthDay">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Schedule"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="es">Día(s) recurrente(s) del mes de la programación, por ejemplo, abierto el primer día de cada mes.</rdfs:comment>
        <rdfs:comment xml:lang="en">Recurring month day(s) of the schedule, e.g. open the first day of the month.</rdfs:comment>
        <rdfs:label xml:lang="en">by month day</rdfs:label>
        <rdfs:label xml:lang="es">por día del mes</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Indica el día del mes en que se repite esta</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Indicates the day of the month on which this schedule repeats (1–31). For example, open on the first day of every month</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#byMonthWeek -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#byMonthWeek">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Schedule"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="en">Recurring week(s) of the schedule, e.g. open the third week of the month.</rdfs:comment>
        <rdfs:comment xml:lang="es">Semana(s) recurrente(s) de la programación, por ejemplo, abierto la tercera semana de cada mes.</rdfs:comment>
        <rdfs:label xml:lang="en">by month week</rdfs:label>
        <rdfs:label xml:lang="es">por semana del mes</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Indica la semana del mes en la que se aplica esta programación (1–5). Por ejemplo, abierto la tercera semana de cada mes.a</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Indicates the week of the month in which this schedule applies (1–5). For example, open during the third week of every month</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#checkInTime -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#checkInTime">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">La hora más temprana en la que los huéspedes pueden comenzar el proceso de registro en un alojamiento.</rdfs:comment>
        <rdfs:comment xml:lang="en">The earliest allowable time at which guests may begin the check-in process for an accommodation.</rdfs:comment>
        <rdfs:label xml:lang="en">check-in time</rdfs:label>
        <rdfs:label xml:lang="es">hora de llegada</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#checkOutTime -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#checkOutTime">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">La hora a la que los huéspedes deben completar su salida y desocupar su alojamiento.</rdfs:comment>
        <rdfs:comment xml:lang="en">The time by which guests must complete their departure and vacate their accommodation.</rdfs:comment>
        <rdfs:label xml:lang="en">check-out time</rdfs:label>
        <rdfs:label xml:lang="es">hora de salida</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#civilLiabilityInsuranceRequired -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#civilLiabilityInsuranceRequired">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Necesidad de disponer de un tipo de seguro contra daños por el que el asegurador se obliga a indemnizar a un tercero de los daños y perjuicios causados por un hecho de cuyas consecuencias sea responsable el asegurado.</rdfs:comment>
        <rdfs:comment xml:lang="en">The need for a type of insurance against damages whereby the insurer undertakes to compensate a third party for damages caused by an event for which the insured party is liable.</rdfs:comment>
        <rdfs:label xml:lang="en">civil liability insurance required</rdfs:label>
        <rdfs:label xml:lang="es">requiere seguro de responsabilidad civil</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#conditions -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#conditions">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#AdditionalInformation"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="es">Circunstancias o requisitos específicos que deben cumplirse para que algo suceda o se lleve a cabo de manera adecuada.</rdfs:comment>
        <rdfs:comment xml:lang="en">Specific circumstances or requirements that must be met for something to occur or be carried out properly.</rdfs:comment>
        <rdfs:label xml:lang="es">condiciones</rdfs:label>
        <rdfs:label xml:lang="en">conditions</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#country -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#country">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Country that corresponds to a specific location.</rdfs:comment>
        <rdfs:comment xml:lang="es">País correspondiente a una localización determinada.</rdfs:comment>
        <rdfs:label xml:lang="en">country</rdfs:label>
        <rdfs:label xml:lang="es">país</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Indica el país utilizando el código ISO 3166-1 alfa-2 (dos letras, por ejemplo: ES, FR, PT).</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Indicates the country using the ISO 3166-1 alpha-2 code (two letters, e.g., ES, FR, PT)</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#county -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#county">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">An administrative entity composed of multiple municipalities within a province.</rdfs:comment>
        <rdfs:comment xml:lang="es">Entidad administrativa compuesta por una pluralidad de municipios en el seno de una provincia.</rdfs:comment>
        <rdfs:label xml:lang="es">comarca</rdfs:label>
        <rdfs:label xml:lang="en">county</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#curiosities -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#curiosities">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#AdditionalInformation"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Data, facts, or interesting and little-known aspects that spark interest and the desire to learn more about a topic</rdfs:comment>
        <rdfs:comment xml:lang="es">Datos, hechos o aspectos interesantes y poco conocidos que despiertan el interés y las ganas de aprender más sobre un tema.</rdfs:comment>
        <rdfs:label xml:lang="es">curiosidades</rdfs:label>
        <rdfs:label xml:lang="en">curiosities</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#disabledParking -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#disabledParking">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#ParkingFacility"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si el aparcamiento está adaptado a personas con movilidad reducida.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether the parking facility is adapted for people with reduced mobility.</rdfs:comment>
        <rdfs:label xml:lang="es">aparcamiento para personas con movilidad reducida</rdfs:label>
        <rdfs:label xml:lang="en">disabled parking</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#disallowedDogBreeds -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#disallowedDogBreeds">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Groups into which the canine biological species is subdivided, whose access to an establishment or consumption of a service is restricted.</rdfs:comment>
        <rdfs:comment xml:lang="es">Grupos en los que se subdivide la especie biológica canina cuyo acceso a un establecimiento o al consumo de un servicio está restringido.</rdfs:comment>
        <rdfs:label xml:lang="en">disallowed dog breeds</rdfs:label>
        <rdfs:label xml:lang="es">razas de perros no admitidas</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#discount -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#discount">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Promotion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">An amount expressed as a monetary value or percentage that is deducted from the original price of a product or service before its payment.</rdfs:comment>
        <rdfs:comment xml:lang="es">Cantidad en moneda o porcentaje reducido o rebajado del precio original de un producto o servicio antes de su pago.</rdfs:comment>
        <rdfs:label xml:lang="es">descuento</rdfs:label>
        <rdfs:label xml:lang="en">discount</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Especifica la cantidad en moneda o porcentaje reducido o rebajado del precio original de un producto o servicio antes de su pago</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Specifies the amount in currency or percentage reduced from the original price of a product or service before payment</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#downhillElevation -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#downhillElevation">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Route"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">Diferencia de altura que se pierde al descender desde un punto más alto hasta uno más bajo en un recorrido, ruta o terreno.</rdfs:comment>
        <rdfs:comment xml:lang="en">Difference in height that is lost when descending from a higher point to a lower one along a route, path, or terrain</rdfs:comment>
        <rdfs:label xml:lang="es">desnivel negativo</rdfs:label>
        <rdfs:label xml:lang="en">downhill elevation</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#dramatisedTour -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#dramatisedTour">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Tour"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si la visita guiada está impartida o acompañada por actores o intérpretes que representan personajes relevantes de la historia asociados al itinerario, relatando historias y brindando información sobre el lugar de una manera entretenida y dramática.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether the tour is delivered or accompanied by actors or performers portraying historically relevant characters associated with the itinerary, narrating stories and providing information in an engaging and dramatic manner.</rdfs:comment>
        <rdfs:label xml:lang="en">dramatised tour</rdfs:label>
        <rdfs:label xml:lang="es">tour teatralizado</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#duration -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#duration">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Route"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Schedule"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">The estimated length of time that the described element lasts.</rdfs:comment>
        <rdfs:comment xml:lang="es">Tiempo estimado que dura el elemento descrito.</rdfs:comment>
        <rdfs:label xml:lang="es">duración</rdfs:label>
        <rdfs:label xml:lang="en">duration</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#eligibleQuantity -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#eligibleQuantity">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PriceSpecification"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="es">El número de unidades (por ejemplo, noches de hotel, número de entradas) a las que se aplica la especificación de precio.</rdfs:comment>
        <rdfs:comment xml:lang="en">The number of units (e.g., hotel nights, number of tickets) for which the price specification applies.</rdfs:comment>
        <rdfs:label xml:lang="es">cantidad elegible</rdfs:label>
        <rdfs:label xml:lang="en">eligible quantity</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#email -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#email">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#ContactPoint"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">La dirección de correo electrónico que debe utilizarse a efectos de contacto. Identifica un buzón de correo electrónico al que se envían los mensajes de correo electrónico.</rdfs:comment>
        <rdfs:comment xml:lang="en">The email address to be used for contact purposes. It identifies an email mailbox to which email messages are sent.</rdfs:comment>
        <rdfs:label xml:lang="en">email</rdfs:label>
        <rdfs:label xml:lang="es">email</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#endDateTime -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#endDateTime">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Schedule"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="es">La fecha de finalización con o sin hora de una programación.</rdfs:comment>
        <rdfs:comment xml:lang="en">The end date with or without time of a schedule.</rdfs:comment>
        <rdfs:label xml:lang="en">end datetime</rdfs:label>
        <rdfs:label xml:lang="es">fecha y hora de finalización</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Especifica la fecha de finalización de una programación con o sin hora según la ISO 8601 (YYYY-MM-DD ‘T’ HH:MM:SS).</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Specifies the end date of a schedule, with or without time, according to ISO 8601 (YYYY-MM-DD ‘T’ HH:MM:SS).</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#exceptDate -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#exceptDate">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Schedule"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="es">Fecha(s) específica(s) del calendario (con o sin hora) en la que no se aplica la programación.</rdfs:comment>
        <rdfs:comment xml:lang="en">Specific calendar date(s) (with or without time) on which the schedule does not apply.</rdfs:comment>
        <rdfs:label xml:lang="en">except for date</rdfs:label>
        <rdfs:label xml:lang="es">excepto fecha</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Indica la(s) fecha(s) específica(s) del calendario (con o sin hora) en la que no se aplica la programación según la ISO 8601 (YYYY-MM-DD ‘T’ HH:MM:SS)</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Indicates the specific calendar date(s) (with or without time) on which the schedule does not apply, according to ISO 8601 (YYYY-MM-DD ‘T’ HH:MM:SS).</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#finalPrice -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#finalPrice">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Promotion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="es">Costo total que un cliente paga por un producto o servicio después de aplicar todos los descuentos, bonificaciones u ofertas promocionales.</rdfs:comment>
        <rdfs:comment xml:lang="en">The total cost paid by a customer for a product or service after all discounts, bonuses, or promotional offers have been applied.</rdfs:comment>
        <rdfs:label xml:lang="en">final price</rdfs:label>
        <rdfs:label xml:lang="es">precio final</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#freeLuggage -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#freeLuggage">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportService"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Text specifying whether the transport service includes luggage transfer and under what conditions.</rdfs:comment>
        <rdfs:comment xml:lang="es">Texto que especifica sí el servicio de transporte incluye el traslado de equipaje y en qué condiciones.</rdfs:comment>
        <rdfs:label xml:lang="es">equipaje incluido</rdfs:label>
        <rdfs:label xml:lang="en">free luggage</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#highestAltitude -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#highestAltitude">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Route"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="es">Límite superior al que llega una ruta con respecto a su elevación sobre el nivel del mar.</rdfs:comment>
        <rdfs:comment xml:lang="en">The highest elevation reached by a route above sea level.</rdfs:comment>
        <rdfs:label xml:lang="es">altitud máxima</rdfs:label>
        <rdfs:label xml:lang="en">highest altitude</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#includes -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#includes">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AdventureActivity"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AgrotourismExperience"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#HolidayPackage"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Tour"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="es">Especificación de lo que incluye un servicio turístico.</rdfs:comment>
        <rdfs:comment xml:lang="en">Specification of what a tourism service includes.</rdfs:comment>
        <rdfs:label xml:lang="en">includes</rdfs:label>
        <rdfs:label xml:lang="es">incluye</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#instantMessagingService -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#instantMessagingService">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#ContactPoint"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="es">Canal de contacto que permite la comunicación en tiempo real entre dos o más usuarios a través de internet, mediante el intercambio de mensajes de texto, voz, video y archivos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Contact channel that enables real-time communication between two or more users over the internet through the exchange of text messages, voice, video, and files.</rdfs:comment>
        <rdfs:label xml:lang="en">instant messaging service</rdfs:label>
        <rdfs:label xml:lang="es">servicio de mensajería instantánea</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Facilita la URL para redirigir al usuario al chat del servicio de mensajería instantánea o el número de teléfono con el que el usuario pueda contactar al lugar u organización a través de dicho servicio de mensajería instantánea</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Provides the URL to redirect the user to the chat of an instant messaging service, or the phone number through which the user may contact the place or organization via that service.</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#isAccessibleForFree -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#isAccessibleForFree">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PriceSpecification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica sí el recurso o servicio turístico es de acceso gratuito o no.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether the tourism resource or service is accessible free of charge.</rdfs:comment>
        <rdfs:label xml:lang="en">accessible for free</rdfs:label>
        <rdfs:label xml:lang="es">accesso gratuito</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#isAllinclusive -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#isAllinclusive">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#HolidayPackage"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Tour"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si el costo total incluye todos los servicios adicionales.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether the total cost includes all additional services.</rdfs:comment>
        <rdfs:label xml:lang="en">all inclusive package</rdfs:label>
        <rdfs:label xml:lang="es">todo incluido</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#isIndoorParking -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#isIndoorParking">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#ParkingFacility"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si el aparcamiento está cubierto o no.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether the parking facility is covered or not.</rdfs:comment>
        <rdfs:label xml:lang="es">aparcamiento cubierto</rdfs:label>
        <rdfs:label xml:lang="en">is indoor parking</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#island -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#island">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">Entidad local territorial de una porción de tierra rodeada de agua que goza de autonomía.</rdfs:comment>
        <rdfs:comment xml:lang="en">Local territorial entity of a portion of land surrounded by water that enjoys autonomy</rdfs:comment>
        <rdfs:label xml:lang="es">isla</rdfs:label>
        <rdfs:label xml:lang="en">island</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#keyword -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#keyword">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Description"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">A significant word or phrase that emphasizes the content of a description.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una palabra o frase significativa que enfatiza el contenido de una descripción.</rdfs:comment>
        <rdfs:label xml:lang="en">keyword</rdfs:label>
        <rdfs:label xml:lang="es">palabra clave</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#length -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#length">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Route"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="es">Distancia total del recorrido.</rdfs:comment>
        <rdfs:comment xml:lang="en">The total distance of the route.</rdfs:comment>
        <rdfs:label xml:lang="en">length</rdfs:label>
        <rdfs:label xml:lang="es">longitud total</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#locality -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#locality">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="es">Población correspondiente a una localización determinada.</rdfs:comment>
        <rdfs:comment xml:lang="en">Settlement that corresponds to a specific location.</rdfs:comment>
        <rdfs:label xml:lang="es">localidad</rdfs:label>
        <rdfs:label xml:lang="en">locality</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#logo -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#logo">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Multimedia"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">URL que enlaza al archivo de imagen utilizado para representar visualmente la identidad de una entidad turística, facilitando su reconocimiento y presentación.</rdfs:comment>
        <rdfs:comment xml:lang="en">URL that links to the image file used to visually represent the identity of a tourism entity, facilitating its recognition and presentation.</rdfs:comment>
        <rdfs:label xml:lang="en">logo</rdfs:label>
        <rdfs:label xml:lang="es">logo</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#longDescription -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#longDescription">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Description"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Full text providing a detailed and contextualized explanation of the described entity.</rdfs:comment>
        <rdfs:comment xml:lang="es">Texto completo que proporciona una explicación detallada y contextualizada sobre la entidad descrita.</rdfs:comment>
        <rdfs:label xml:lang="es">descripción larga</rdfs:label>
        <rdfs:label xml:lang="en">long description</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#lowestAltitude -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#lowestAltitude">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Route"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="es">Límite inferior al que llega una ruta con respecto a su elevación sobre el nivel del mar</rdfs:comment>
        <rdfs:comment xml:lang="en">The lowest elevation reached by a route above sea level.</rdfs:comment>
        <rdfs:label xml:lang="es">altitud mínima</rdfs:label>
        <rdfs:label xml:lang="en">minimum altitude</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#mainImage -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#mainImage">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Multimedia"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">URL que enlaza al recurso gráfico principal utilizado para representar visualmente el contenido de manera destacada.</rdfs:comment>
        <rdfs:comment xml:lang="en">URL that links to the main graphic resource used to highlight and visually represent the content in a prominent way.</rdfs:comment>
        <rdfs:label xml:lang="es">imagen principal</rdfs:label>
        <rdfs:label xml:lang="en">main image</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#maxPrice -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#maxPrice">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PriceSpecification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="es">El precio más alto posible para el producto o servicio.</rdfs:comment>
        <rdfs:comment xml:lang="en">The highest possible price for the product or service.</rdfs:comment>
        <rdfs:label xml:lang="en">maximum price</rdfs:label>
        <rdfs:label xml:lang="es">precio máximo</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#maximumAttendeeCapacity -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#maximumAttendeeCapacity">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Event"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Route"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="es">Número total de personas que pueden asistir o participar simultáneamente en un evento, punto de interés o servicio turístico.</rdfs:comment>
        <rdfs:comment xml:lang="en">The total number of individuals permitted to attend or participate simultaneously in an event, point of interest, or tourism service.</rdfs:comment>
        <rdfs:label xml:lang="es">capacidad máxima de asistentes</rdfs:label>
        <rdfs:label xml:lang="en">maximum attendee capacity</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#maximumNonStretchableLeashLength -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#maximumNonStretchableLeashLength">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="es">Longitud máxima que debe cumplir la cuerda con la que se conduce o sujeta el/los animal/es.</rdfs:comment>
        <rdfs:comment xml:lang="en">Maximum length that the rope used to lead or restrain the animal(s) must comply with.</rdfs:comment>
        <rdfs:label xml:lang="es">longitud máxima de la correa no extensible</rdfs:label>
        <rdfs:label xml:lang="en">maximum non-stretchable leash length</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#microchipIdentificationRequired -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#microchipIdentificationRequired">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Necesidad de cumplir con el sistema de identificación establecido reglamentariamente por las autoridades competentes, en el caso español, un dispositivo de identificación por radiofrecuencia pasivo y solo de lectura.</rdfs:comment>
        <rdfs:comment xml:lang="en">Need to comply with the identification system established by regulation by the competent authorities, in the case of Spain, a passive, read-only radio frequency identification device.</rdfs:comment>
        <rdfs:label xml:lang="en">microchip identification required</rdfs:label>
        <rdfs:label xml:lang="es">requiere identificación con microchip</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#minPrice -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#minPrice">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PriceSpecification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="es">El precio más bajo posible para el producto o servicio.</rdfs:comment>
        <rdfs:comment xml:lang="en">The lowest possible price for the product or service.</rdfs:comment>
        <rdfs:label xml:lang="en">minimum price</rdfs:label>
        <rdfs:label xml:lang="es">precio mínimo</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#minimumBookingTime -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#minimumBookingTime">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetTransportPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Minimum advance notice required to book the pet transport service.</rdfs:comment>
        <rdfs:comment xml:lang="es">Tiempo de antelación mínima con el que debe realizarse la reserva del servicio de transporte con mascotas.</rdfs:comment>
        <rdfs:label xml:lang="en">minimum booking time</rdfs:label>
        <rdfs:label xml:lang="es">tiempo mínimo de reserva</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#minimumPetAge -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#minimumPetAge">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="es">Edad mínima que se exige a la mascota para permitir su admisión.</rdfs:comment>
        <rdfs:comment xml:lang="en">Minimum age required for pets to be admitted.</rdfs:comment>
        <rdfs:label xml:lang="es">edad mínima de la mascota</rdfs:label>
        <rdfs:label xml:lang="en">minimum pet age</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#minimumTimeRequiredSinceAntiRabiesVaccination -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#minimumTimeRequiredSinceAntiRabiesVaccination">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="es">Antelación mínima con la que se ha de administrar a un animal la vacuna para inducirle inmunidad contra los agentes patógenos de la rabia.</rdfs:comment>
        <rdfs:comment xml:lang="en">Minimum time in advance that an animal must be given the vaccine to induce immunity against rabies pathogens.</rdfs:comment>
        <rdfs:label xml:lang="en">minimum time required since anti rabies vaccination</rdfs:label>
        <rdfs:label xml:lang="es">tiempo mínimo requerido desde la vacunación antirrábica</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#municipality -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#municipality">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">Entidad local formada por los vecinos de un determinado territorio para gestionar autónomamente sus intereses comunes.</rdfs:comment>
        <rdfs:comment xml:lang="en">Local entity formed by residents of a specific territory to autonomously manage their common interests.</rdfs:comment>
        <rdfs:label xml:lang="en">municipality</rdfs:label>
        <rdfs:label xml:lang="es">municipio</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#muzzleWearRequired -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#muzzleWearRequired">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Animals must wear a muzzle to prevent them from biting.</rdfs:comment>
        <rdfs:comment xml:lang="es">Necesidad de que los animales usen un dispositivo en el hocico para que no muerdan.</rdfs:comment>
        <rdfs:label xml:lang="es">exige uso de bozal</rdfs:label>
        <rdfs:label xml:lang="en">muzzle wear required</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#name -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#name">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Acknowledgement"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Place"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Promotion"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#RulesAndTips"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismEntity"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="es">Denominación oficial o comúnmente aceptada utilizada para identificar una organización, evento, servicio o punto de interés turístico.</rdfs:comment>
        <rdfs:comment xml:lang="en">Official or commonly accepted name used to identify an organisation, event, service or tourism point of interest.</rdfs:comment>
        <rdfs:label xml:lang="en">name</rdfs:label>
        <rdfs:label xml:lang="es">nombre</rdfs:label>
        <estur-annot:presentationOrderCategory>generalInfo</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#nonStretchableLeashRequired -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#nonStretchableLeashRequired">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Animals must be led or restrained with a rope that cannot be extended.</rdfs:comment>
        <rdfs:comment xml:lang="es">Necesidad de que los animales sean conducidos o sujetados con una cuerda que no pueda extenderse.</rdfs:comment>
        <rdfs:label xml:lang="es">exige uso de correa no extensible</rdfs:label>
        <rdfs:label xml:lang="en">non-stretchable leash required</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#notIncluded -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#notIncluded">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AgrotourismExperience"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#HolidayPackage"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Tour"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Additional expenses or services that are not covered by the total cost of a tourism service.</rdfs:comment>
        <rdfs:comment xml:lang="es">Gastos o servicios adicionales que no están cubiertos por el coste total de un servicio turístico.</rdfs:comment>
        <rdfs:label xml:lang="es">no incluido</rdfs:label>
        <rdfs:label xml:lang="en">not included</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#notPetFriendlyAreas -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#notPetFriendlyAreas">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAccommodationPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Areas of the accommodation are not suitable for pets or their stay with them.</rdfs:comment>
        <rdfs:comment xml:lang="es">Áreas del alojamiento no aptas para las mascotas ni su permanencia con ellas.</rdfs:comment>
        <rdfs:label xml:lang="en">not pet friendly areas</rdfs:label>
        <rdfs:label xml:lang="es">zonas no habilitadas para mascotas</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#numberOfAccommodationUnits -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#numberOfAccommodationUnits">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#LodgingService"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="es">Cantidad de espacios o habitaciones individuales en los que un establecimiento alojativo ofrece, como mínimo, camas y servicios de higiene a sus huéspedes.</rdfs:comment>
        <rdfs:comment xml:lang="en">Number of individual spaces or rooms in which an accommodation establishment provides, at least, sleeping and sanitary facilities to its guests.</rdfs:comment>
        <rdfs:label xml:lang="en">number of accommodation units</rdfs:label>
        <rdfs:label xml:lang="es">número de unidades de alojamiento</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#numberOfBeds -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#numberOfBeds">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#LodgingService"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="es">Cantidad de camas del establecimiento alojativo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Number of beds available in the accommodation.</rdfs:comment>
        <rdfs:label xml:lang="en">number of beds</rdfs:label>
        <rdfs:label xml:lang="es">número de camas</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#numberOfPetsAllowedPerEstablishment -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#numberOfPetsAllowedPerEstablishment">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="es">Cantidad máxima de mascotas que admite el establecimiento</rdfs:comment>
        <rdfs:comment xml:lang="en">Maximum number of pets allowed at the establishment.</rdfs:comment>
        <rdfs:label xml:lang="en">number of pets allowed per establishment</rdfs:label>
        <rdfs:label xml:lang="es">número de mascotas permitidas por establecimiento</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#numberOfPetsAllowedPerPerson -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#numberOfPetsAllowedPerPerson">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="es">Cantidad máxima de mascotas por persona aceptadas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Maximum number of pets per person accepted.</rdfs:comment>
        <rdfs:label xml:lang="en">number of pets allowed per person</rdfs:label>
        <rdfs:label xml:lang="es">número de mascotas permitidas por persona</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#numberOfPetsAllowedPerService -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#numberOfPetsAllowedPerService">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="es">Cantidad máxima de mascotas que admite el servicio.</rdfs:comment>
        <rdfs:comment xml:lang="en">Maximum number of pets allowed by the service.</rdfs:comment>
        <rdfs:label xml:lang="en">number of pets allowed per service</rdfs:label>
        <rdfs:label xml:lang="es">número de mascotas permitidas por servicio</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#numberOfPetsAllowedPerTravelContainer -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#numberOfPetsAllowedPerTravelContainer">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetTransportPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="es">Cantidad de animales que se pueden albergar en un mismo recipiente u estructura rígida, siempre y cuando sean de la misma especie y/o camada o estén acostumbrados a cohabitar.</rdfs:comment>
        <rdfs:comment xml:lang="en">Number of animals that can be housed in the same container or rigid structure, provided they are of the same species and/or litter or are accustomed to cohabiting.</rdfs:comment>
        <rdfs:label xml:lang="en">number of pets allowed per travel container</rdfs:label>
        <rdfs:label xml:lang="es">número de mascotas por contenedor de viaje</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#numberedSeats -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#numberedSeats">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Event"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TicketOrEntrance"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si los asientos asociados a una actividad están numerados o no.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether the seats associated with an activity are numbered or not.</rdfs:comment>
        <rdfs:label xml:lang="es">entradas numeradas</rdfs:label>
        <rdfs:label xml:lang="en">numbered seats</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#open24Hours -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#open24Hours">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#OpeningHours"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si un lugar permanece accesible o en funcionamiento durante las 24 horas del día, sin interrupción.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether a place remains accessible or in operation 24 hours a day, without interruption.</rdfs:comment>
        <rdfs:label xml:lang="es">abierto las 24 horas</rdfs:label>
        <rdfs:label xml:lang="en">open 24 hours</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#outdoorEvent -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#outdoorEvent">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si el evento se realiza al aire libre o en un lugar cubierto y/o cerrado.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether the event takes place outdoors or in an indoor and/or enclosed venue.</rdfs:comment>
        <rdfs:label xml:lang="es">evento al aire libre</rdfs:label>
        <rdfs:label xml:lang="en">outdoor event</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#parador -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#parador">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Hotel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si un hotel es un parador o no. Un establecimiento de hostelería, situado en un enclave singular seleccionado por su interés histórico, artístico o cultural, adscrito a la red de Paradores de Turismo de España.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether the hotel is a parador or not. A hospitality establishment located in a unique setting selected for its historical, artistic, or cultural interest, belonging to the Paradores de Turismo de España network.</rdfs:comment>
        <rdfs:label xml:lang="en">parador</rdfs:label>
        <rdfs:label xml:lang="es">parador</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">6</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>generalInfo</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#passportOrAnimalHealthCertificatedRequired -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#passportOrAnimalHealthCertificatedRequired">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Necesidad de disponer de documento que permita identificar claramente al animal y controlar la conformidad de su situación sanitaria.</rdfs:comment>
        <rdfs:comment xml:lang="en">Need for a document that clearly identifies the animal and verifies its health status.</rdfs:comment>
        <rdfs:label xml:lang="en">passport or animal health certificate required</rdfs:label>
        <rdfs:label xml:lang="es">requiere pasaporte o certificado zoosanitario</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#petAdmissionDeposit -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#petAdmissionDeposit">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAccommodationPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Necesidad de abonar una suma dineraria con la que la persona responde ante un eventual incumplimiento de una obligación derivada del alojamiento con su mascota.</rdfs:comment>
        <rdfs:comment xml:lang="en">The requirement to pay a sum of money with which the person is liable in the event of a breach of an obligation arising from the accommodation of their pet.</rdfs:comment>
        <rdfs:label xml:lang="es">depósito de garantía por admisión de la mascota</rdfs:label>
        <rdfs:label xml:lang="en">pet admission deposit</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#petAdmissionFee -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#petAdmissionFee">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="es">Exigencia de pagar una suma de dinero para acceder a un servicio con mascotas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Requirement to pay a sum of money to access a service with pets.</rdfs:comment>
        <rdfs:label xml:lang="en">pet admission fee</rdfs:label>
        <rdfs:label xml:lang="es">suplemento por admisión de la mascota</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#petDeposit -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#petDeposit">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PriceSpecification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Amount of money with which the person is liable in the event of a breach of an obligation arising from any activity that forms part of travelling with a pet.</rdfs:comment>
        <rdfs:comment xml:lang="es">Importe de la suma dineraria con la que la persona responde ante un eventual incumplimiento de una obligación derivada de cualquier actividad que forme parte del viaje con mascota.</rdfs:comment>
        <rdfs:label xml:lang="es">depósito de garantía por mascota</rdfs:label>
        <rdfs:label xml:lang="en">pet deposit</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#petFee -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#petFee">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PriceSpecification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Amount of money paid to access a service with pets.</rdfs:comment>
        <rdfs:comment xml:lang="es">Suma de dinero que se paga para acceder a un servicio con mascotas.</rdfs:comment>
        <rdfs:label xml:lang="en">pet fee</rdfs:label>
        <rdfs:label xml:lang="es">suplemento por mascota</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#petPermanenceInTravelContainerRequired -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#petPermanenceInTravelContainerRequired">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Necesidad de albergar el/los animal/es en recipientes u otras estructuras rígidas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Need to house the animal(s) in containers or other rigid structures.</rdfs:comment>
        <rdfs:label xml:lang="es">exige la permanencia de la mascota en el contenedor de viaje</rdfs:label>
        <rdfs:label xml:lang="en">pet permanence in travel container required</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#petWeightLimitation -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#petWeightLimitation">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="es">Suma del peso de la mascota más el transportín.</rdfs:comment>
        <rdfs:comment xml:lang="en">Total weight of the pet plus the carrier.</rdfs:comment>
        <rdfs:label xml:lang="es">límite de peso de la mascota</rdfs:label>
        <rdfs:label xml:lang="en">pet weight limitation</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#petsInHeatAllowed -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#petsInHeatAllowed">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetTransportPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Posibilidad de transportar animales que se encuentran en la época en la que experimentan apetito sexual.</rdfs:comment>
        <rdfs:comment xml:lang="en">Possibility of transporting animals that are in their sexual appetite season.</rdfs:comment>
        <rdfs:label xml:lang="es">admite mascotas en celo</rdfs:label>
        <rdfs:label xml:lang="en">pets in heat allowed</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#physicalEffort -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#physicalEffort">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Route"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="en">Amount of physical exertion required to complete the route, taking into account extension and unevenness (uphill and downhill), based on an average participant.</rdfs:comment>
        <rdfs:comment xml:lang="es">Cantidad de esfuerzo físico necesario para completar la ruta, teniendo en cuenta la extensión y las irregularidades (subidas y bajadas), basado en un participante medio.</rdfs:comment>
        <rdfs:comment xml:lang="en">Levels of grading of the technical and physical demands of routes, where 1 indicates least difficulty and 5 greatest difficulty.</rdfs:comment>
        <rdfs:comment xml:lang="es">Niveles de graduación de las exigencias técnicas y físicas de rutas, en los que 1 indica menor dificultad y 5 mayor dificultad.</rdfs:comment>
        <rdfs:label xml:lang="es">esfuerzo físico</rdfs:label>
        <rdfs:label xml:lang="en">physical effort</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Asigna un valor entero del 1 al 5 para valorar el esfuerzo físico de la ruta, siendo 1 muy bajo y 5 muy alto</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Assigns an integer value from 1 to 5 to assess the physical effort required by the route, where 1 is very low and 5 is very high</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#position -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#position">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Itinerary"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="en">Number indicating the sequential order of a point of interest within an itinerary.</rdfs:comment>
        <rdfs:comment xml:lang="es">Número que indica el orden secuencial de un punto de interés dentro de un itinerario.</rdfs:comment>
        <rdfs:label xml:lang="es">posición</rdfs:label>
        <rdfs:label xml:lang="en">position</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#postalCode -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#postalCode">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">An alphanumeric code that identifies a specific geographic area that corresponds to a given location.</rdfs:comment>
        <rdfs:comment xml:lang="es">Código alfanumérico que identifica la zona geográfica concreta correspondiente a una localización determinada.</rdfs:comment>
        <rdfs:label xml:lang="es">código postal</rdfs:label>
        <rdfs:label xml:lang="en">postal code</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#price -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#price">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PriceSpecification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Numeric part of the monetary cost expressed in the price specification.</rdfs:comment>
        <rdfs:comment xml:lang="es">Parte numérica del coste monetario expresado en la especificación del precio.</rdfs:comment>
        <rdfs:label xml:lang="es">precio</rdfs:label>
        <rdfs:label xml:lang="en">price</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#priceCurrency -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#priceCurrency">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PriceSpecification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Currency part of the monetary cost expressed in the price specification.</rdfs:comment>
        <rdfs:comment xml:lang="es">Parte del coste monetario expresada en la especificación del precio.</rdfs:comment>
        <rdfs:label xml:lang="es">divisa del precio</rdfs:label>
        <rdfs:label xml:lang="en">price currency</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Especifica la divisa de acuerdo con la ISO 4217 (por ejemplo: EUR, USD, GBP).</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Specifies the currency according to ISO 4217 (e.g., EUR, USD, GBP)</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#province -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#province">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">An intermediate administrative unit between the municipality and the autonomous community that corresponds to a given location.</rdfs:comment>
        <rdfs:comment xml:lang="es">Unidad administrativa intermedia entre el municipio y la comunidad autónoma correspondiente a una localización determinada.</rdfs:comment>
        <rdfs:label xml:lang="en">province</rdfs:label>
        <rdfs:label xml:lang="es">provincia</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#publicAccess -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#publicAccess">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Route"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si un recurso turístico puede ser accedido libremente por el público general, sin necesidad de autorización, reserva o pertenencia a un grupo restringido.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether a tourism resource can be freely accessed by the general public, without the need for authorization, reservation, or membership in a restricted group.</rdfs:comment>
        <rdfs:label xml:lang="es">acceso público</rdfs:label>
        <rdfs:label xml:lang="en">public access</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#publicTransportStopCode -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#publicTransportStopCode">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicTransportStop"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">An officially assigned identifier code for a public transport stop, used in planning systems, signage, and passenger information services</rdfs:comment>
        <rdfs:comment xml:lang="es">Código identificador asignado oficialmente a una parada de transporte público, utilizado en sistemas de planificación, señalización y servicios de información al viajero.</rdfs:comment>
        <rdfs:label xml:lang="es">código de la parada de transporte público</rdfs:label>
        <rdfs:label xml:lang="en">public transport stop code</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#publicTransportStopZone -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#publicTransportStopZone">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicTransportStop"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">An identifier or designation of the fare zone to which a public transport stop belongs.</rdfs:comment>
        <rdfs:comment xml:lang="es">Identificador o denominación de la zona tarifaria a la que pertenece una parada de transporte público.</rdfs:comment>
        <rdfs:label xml:lang="en">public transport stop zone</rdfs:label>
        <rdfs:label xml:lang="es">zona de la parada de transporte público</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#question -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#question">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#FrequentlyAskedQuestion"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Text that expresses a common doubt, concern, or inquiry raised by users in relation to a tourism place or entity.</rdfs:comment>
        <rdfs:comment xml:lang="es">Texto que formula una duda, inquietud o consulta frecuente planteada por los usuarios en relación con un lugar o entidad turística.</rdfs:comment>
        <rdfs:label xml:lang="es">pregunta</rdfs:label>
        <rdfs:label xml:lang="en">question</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#recognizedBy -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#recognizedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Certification"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="es">Nombre de la entidad que concede el reconocimiento.</rdfs:comment>
        <rdfs:comment xml:lang="en">The name of the entity that grants the acknowledgement.</rdfs:comment>
        <rdfs:label xml:lang="en">recognized by</rdfs:label>
        <rdfs:label xml:lang="es">reconocido por</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#refPointOfInterestAsText -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#refPointOfInterestAsText">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#ItineraryElement"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Point of interest within the itinerary, expressed as literal value.</rdfs:comment>
        <rdfs:comment xml:lang="es">Punto de interés dentro del itinerario, expresado como un literal.</rdfs:comment>
        <rdfs:label xml:lang="es">punto de interés de referencia (texto)</rdfs:label>
        <rdfs:label xml:lang="en">reference point of interest (texto)</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Indica puntos de interés dentro del itinerario a través de texto</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Indicates points of interest within the itinerary through text</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#registrationNumber -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#registrationNumber">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourGuide"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">An official code or identifier assigned by a competent authority to a tourism or related facility or to a professional tour guide.</rdfs:comment>
        <rdfs:comment xml:lang="es">Código o identificador oficial asignado por una administración competente a una instalación turística o vinculada o guía turístico.</rdfs:comment>
        <rdfs:label xml:lang="es">número de registro</rdfs:label>
        <rdfs:label xml:lang="en">registration number</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">5</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>generalInfo</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Facilita el código o identificador oficial asignado por la administración competente a la instalación turística o vinculada o el guía turístico.</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Provides the official code or identifier assigned by the competent administration to the tourist facility, related facility, or tourist guide</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#remarks -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#remarks">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#AdditionalInformation"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="es">Anotaciones o comentarios realizados para registrar y destacar información relevante o peculiaridades sobre un tema, evento o situación en particular.</rdfs:comment>
        <rdfs:comment xml:lang="en">Notes or comments made to record and highlight relevant information or particular features about a specific topic, event, or situation.</rdfs:comment>
        <rdfs:label xml:lang="es">observaciones</rdfs:label>
        <rdfs:label xml:lang="en">remarks</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#routeNavigationOrientation -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#routeNavigationOrientation">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Route"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="en">Degree of difficulty in orientation, such as the presence of signs, well-marked trails, single-track trails or the presence of landmarks needed to complete the route.</rdfs:comment>
        <rdfs:comment xml:lang="es">Grado de dificultad en la orientación, como la presencia de señales, senderos bien señalizados, senderos de una sola vía o la presencia de puntos de referencia necesarios para completar la ruta.</rdfs:comment>
        <rdfs:comment xml:lang="en">Levels of grading of the technical and physical demands of routes, where 1 indicates least difficulty and 5 greatest difficulty.</rdfs:comment>
        <rdfs:comment xml:lang="es">Niveles de graduación de las exigencias técnicas y físicas de rutas, en los que 1 indica menor dificultad y 5 mayor dificultad.</rdfs:comment>
        <rdfs:label xml:lang="es">orientación en el itinerario</rdfs:label>
        <rdfs:label xml:lang="en">route navigation orientation</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Asigna un valor entero del 1 al 5 para valorar la dificultad de orientación durante el itinerario de la ruta, siendo 1 muy bajo y 5 muy alto</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Assigns an integer value from 1 to 5 to assess the difficulty of navigation and orientation along the route itinerary, where 1 is very low and 5 is very high</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#saleEndDate -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#saleEndDate">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Event"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TicketOrEntrance"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">Deadline until which the sale or commercialization of an event or service, indicating the moment when it is no longer available.</rdfs:comment>
        <rdfs:comment xml:lang="es">Fecha límite hasta la cual se mantiene activa la venta o comercialización de un evento o servicio, indicando el momento en que deja de estar disponible.</rdfs:comment>
        <rdfs:label xml:lang="es">fecha de fin de la venta</rdfs:label>
        <rdfs:label xml:lang="en">sale end date</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Especifica la fecha de fin de la venta de un evento según la especificación de la ISO 8601 (YYYY-MM-DD ‘T’ HH:MM:SS).</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Specifies the end date of ticket sales for an event according to ISO 8601 (YYYY-MM-DD ‘T’ HH:MM:SS).</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#saleStartDate -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#saleStartDate">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Event"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TicketOrEntrance"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">Date from which the sale or commercialization of an event or service begins, indicating the moment when it becomes available.</rdfs:comment>
        <rdfs:comment xml:lang="es">Fecha a partir de la cual se inicia la venta o comercialización de un evento o servicio, indicando el momento en que queda disponible.</rdfs:comment>
        <rdfs:label xml:lang="es">fecha de inicio de la venta</rdfs:label>
        <rdfs:label xml:lang="en">sale start date</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Especifica la fecha de inicio de la venta de un evento según la especificación de la ISO 8601 (YYYY-MM-DD ‘T’ HH:MM:SS).</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Specifies the start date of ticket sales for an event according to ISO 8601 (YYYY-MM-DD ‘T’ HH:MM:SS).</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#secondaryImage -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#secondaryImage">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Multimedia"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">URL que enlaza a una imagen complementaria asociada a la entidad turística, utilizada para ampliar su representación visual.</rdfs:comment>
        <rdfs:comment xml:lang="en">URL that links to a complementary image associated with the tourism entity, used to enhance its visual representation.</rdfs:comment>
        <rdfs:label xml:lang="es">imagen secundaria</rdfs:label>
        <rdfs:label xml:lang="en">secondary image</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#severityOfTheEnvironment -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#severityOfTheEnvironment">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Route"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="en">Dangers and other difficulties arising from the natural environment, such as temperature, rainfall, risk of falls, ease of rescue or self-rescue, which can be encountered along the way.</rdfs:comment>
        <rdfs:comment xml:lang="en">Levels of grading of the technical and physical demands of routes, where 1 indicates least difficulty and 5 greatest difficulty.</rdfs:comment>
        <rdfs:comment xml:lang="es">Niveles de graduación de las exigencias técnicas y físicas de rutas, en los que 1 indica menor dificultad y 5 mayor dificultad.</rdfs:comment>
        <rdfs:comment xml:lang="es">Peligros y otras dificultades derivadas del entorno natural, como la temperatura, las precipitaciones, el riesgo de caídas, la facilidad de rescate o autorrescate, que pueden encontrarse a lo largo del recorrido.</rdfs:comment>
        <rdfs:label xml:lang="es">Severidad del medio natural</rdfs:label>
        <rdfs:label xml:lang="en">Severity of the environment</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Asigna un valor entero del 1 al 5 para valorar la severidad del medio natural de la ruta, siendo 1 muy bajo y 5 muy alto.</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Assigns an integer value from 1 to 5 to assess the severity of the natural environment of the route, where 1 is very low and 5 is very high</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#shortDescription -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#shortDescription">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Description"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">A clear and concise textual description of the entity, intended to convey its key characteristics.</rdfs:comment>
        <rdfs:comment xml:lang="es">Explicación breve y clara de la entidad, con el objetivo de mostrar sus características principales.</rdfs:comment>
        <rdfs:label xml:lang="es">descripción corta</rdfs:label>
        <rdfs:label xml:lang="en">short description</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Debes crear una descripción de hasta 250 caracteres</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">You should create a description of up to 250 characters</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#startDateTime -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#startDateTime">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Schedule"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="es">La fecha de inicio con o sin hora de una programación.</rdfs:comment>
        <rdfs:comment xml:lang="en">The start date with or without time of a schedule.</rdfs:comment>
        <rdfs:label xml:lang="es">fecha y hora de comienzo</rdfs:label>
        <rdfs:label xml:lang="en">start datetime</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Especifica la fecha de inicio de una programación con o sin hora según la ISO 8601 (YYYY-MM-DD ‘T’ HH:MM:SS).</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Specifies the start date of a schedule, with or without time, according to ISO 8601 (YYYY-MM-DD ‘T’ HH:MM:SS).</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#streetAddress -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#streetAddress">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Text identifying the public road where the location is situated, including the name of the street, avenue, road, square, or other type of road, and optionally a number or additional reference.</rdfs:comment>
        <rdfs:comment xml:lang="es">Texto que identifica la vía pública en la que se encuentra la localización, incluyendo el nombre de la calle, avenida, camino, plaza u otro tipo de vía, y opcionalmente un número o referencia adicional.</rdfs:comment>
        <rdfs:label xml:lang="es">dirección</rdfs:label>
        <rdfs:label xml:lang="en">street address</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#taxesAndFeesIncluded -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#taxesAndFeesIncluded">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PriceSpecification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica sí el precio del producto o servicio incluye impuestos y tasas adicionales.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether the price of the product or service includes taxes and additional fees.</rdfs:comment>
        <rdfs:label xml:lang="es">tasas y cargos incluidos</rdfs:label>
        <rdfs:label xml:lang="en">taxes and fees included</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#telephone -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#telephone">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#ContactPoint"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A telephone number associated with the contact point.</rdfs:comment>
        <rdfs:comment xml:lang="es">Número de teléfono asociado al punto de contacto.</rdfs:comment>
        <rdfs:label xml:lang="en">telephone</rdfs:label>
        <rdfs:label xml:lang="es">teléfono</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#temporaryClosure -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#temporaryClosure">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#OpeningHours"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si un lugar está abierto o cerrado debido a una suspensión temporal de sus operaciones durante un período específico y por razones como mantenimiento, renovación, reestructuración, falta de personal, emergencias, situaciones extraordinarias o vacaciones.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates whether a place is open or not due to a temporary suspension of their operations for a specific period and for reasons such as maintenance, renovation, restructuring, staff shortages, emergencies, extraordinary situations, or holidays</rdfs:comment>
        <rdfs:label xml:lang="es">cierre temporal</rdfs:label>
        <rdfs:label xml:lang="en">temporary closure</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#terrainConditions -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#terrainConditions">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Route"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="es">Aspectos encontrados en la ruta en relación con el terreno y sus condiciones, tales como tipos de terreno, tramos con obstáculos, tramos con piedras sueltas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Aspects found on the route in relation to the ground and its conditions, such as types of terrain, sections with obstacles, sections with loose stones.</rdfs:comment>
        <rdfs:comment xml:lang="en">Levels of grading of the technical and physical demands of routes, where 1 indicates least difficulty and 5 greatest difficulty.</rdfs:comment>
        <rdfs:comment xml:lang="es">Niveles de graduación de las exigencias técnicas y físicas de rutas, en los que 1 indica menor dificultad y 5 mayor dificultad.</rdfs:comment>
        <rdfs:label xml:lang="es">condiciones del terreno</rdfs:label>
        <rdfs:label xml:lang="en">terrainConditions</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Asigna un valor entero del 1 al 5 para valorar la dificultad relativa a las condiciones del terreno de la ruta, siendo 1 muy bajo y 5 muy alto</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Assigns an integer value from 1 to 5 to assess the difficulty related to the terrain conditions of the route, where 1 is very low and 5 is very high</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#text -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#text">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Multimedia"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="es">Contenido textual asociado a un recurso multimedia.</rdfs:comment>
        <rdfs:comment xml:lang="en">Textual content associated with a multimedia resource.</rdfs:comment>
        <rdfs:label xml:lang="en">text</rdfs:label>
        <rdfs:label xml:lang="es">texto</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#timeOfTheDay -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#timeOfTheDay">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AgrotourismExperience"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#DestinationExperience"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Tour"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">A general time period during which a destination experience takes place or is recommended.</rdfs:comment>
        <rdfs:comment xml:lang="es">Franja temporal general en la que se desarrolla o se recomienda una experiencia en destino.</rdfs:comment>
        <rdfs:label xml:lang="es">momento del día</rdfs:label>
        <rdfs:label xml:lang="en">time of the day</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#travelContainerSize -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#travelContainerSize">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetTransportPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Sizes that the container or rigid structure housing the animal(s) must comply with.</rdfs:comment>
        <rdfs:comment xml:lang="es">Tamaños que debe cumplir el recipiente u estructura rígida en la que se alberga el/los animal/es.</rdfs:comment>
        <rdfs:label xml:lang="es">dimensiones del contenedor de viaje</rdfs:label>
        <rdfs:label xml:lang="en">travel container size</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#uphillElevation -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#uphillElevation">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Route"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">Diferencia de altura que se gana al ascender desde un punto más bajo hasta uno más alto en un recorrido, ruta o terreno.</rdfs:comment>
        <rdfs:comment xml:lang="en">Difference in height that is gained when ascending from a lower point to a higher one along a route, path, or terrain.</rdfs:comment>
        <rdfs:label xml:lang="es">desnivel positivo</rdfs:label>
        <rdfs:label xml:lang="en">uphill elevation</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#url -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#url">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Certification"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#ContactPoint"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Multimedia"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#SocialMediaProfile"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">A resolvable Uniform Resource Locator (URL) that points to a web resource providing information about the item.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una dirección URL (Uniform Resource Locator) resoluble que apunta a un recurso web que proporciona información sobre el elemento.</rdfs:comment>
        <rdfs:label xml:lang="en">url</rdfs:label>
        <rdfs:label xml:lang="es">url</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#validFrom -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#validFrom">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Certification"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#OpeningHours"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#RulesAndTips"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="es">Inicio del período de validez de la certificación, horario de apertura, regla o consejo.
Start of the validity period of the certification, opening hours, rule or tip.</rdfs:comment>
        <rdfs:comment xml:lang="en">Start of the validity period of the certification, opening hours, rule or tip.</rdfs:comment>
        <rdfs:label xml:lang="en">valid from</rdfs:label>
        <rdfs:label xml:lang="es">válido desde</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Indica la fecha de inicio del período de validez según la especificación de la ISO 8601 (YYYY-MM-DD)</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Indicates the start date of the validity period according to the ISO 8601 specification (YYYY-MM-DD)</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#validThrough -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#validThrough">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Certification"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#OpeningHours"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#RulesAndTips"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">End of the validity period of the certification, opening hours, rule or tip.</rdfs:comment>
        <rdfs:comment xml:lang="es">Fin del período de validez de la certificación, horario de apertura, regla o consejo.</rdfs:comment>
        <rdfs:label xml:lang="en">valid through</rdfs:label>
        <rdfs:label xml:lang="es">válido hasta</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Indica la fecha de fin del período de validez según la especificación de la ISO 8601 (YYYY-MM-DD)</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Indicates the end date of the validity period according to the ISO 8601 specification (YYYY-MM-DD)</estur-annot:tooltip>
    </owl:DatatypeProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#video -->

    <owl:DatatypeProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#video">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Multimedia"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">URL que enlaza a un recurso audiovisual asociado, permitiendo acceder a un contenido en formato de video que complementa, amplía o ilustra información relacionada con un producto, servicio, actividad o entidad.</rdfs:comment>
        <rdfs:comment xml:lang="en">URL that links to an associated audiovisual resource, allowing access to video content that complements, expands, or illustrates information related to a product, service, activity, or entity</rdfs:comment>
        <rdfs:label xml:lang="en">video</rdfs:label>
        <rdfs:label xml:lang="es">vídeo</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.opengis.net/ont/geosparql#Feature -->

    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Feature"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->

    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
    


    <!-- http://www.w3.org/2008/05/skos#ConceptScheme -->

    <owl:Class rdf:about="http://www.w3.org/2008/05/skos#ConceptScheme">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ATM -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ATM">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FinancialService"/>
        <rdfs:comment xml:lang="en">Machine computer-connected to a bank that allows certain banking operations to be carried out using a card or magnetic book that has a personal password assigned to it.</rdfs:comment>
        <rdfs:comment xml:lang="es">Máquina conectada informáticamente con un banco que permite efectuar ciertas operaciones bancarias mediante una tarjeta o libreta magnética que tienen asignada una clave personal.</rdfs:comment>
        <rdfs:label xml:lang="en">ATM</rdfs:label>
        <rdfs:label xml:lang="es">Cajero automático</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#AccessoriesAndComplements -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#AccessoriesAndComplements">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashionBusiness"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se venden objetos que complementan la indumentaria de una persona, como bolsos, calzado, paraguas, corbatas, sombreros, gafas, guantes, etc.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment in which objects that complement a person&apos;s clothing are sold, such as bags, footwear, umbrellas, ties, hats, glasses, gloves, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">Accessories and complements</rdfs:label>
        <rdfs:label xml:lang="es">Tienda de accesorios y complementos</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#AccommodationCompany -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#AccommodationCompany">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrganisation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasTourismOrRelatedFacility"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Proveedor de, al menos, camas y servicios de higiene</rdfs:comment>
        <rdfs:comment xml:lang="en">Provider of at least sleeping and sanitary facilities</rdfs:comment>
        <rdfs:label xml:lang="en">Accommodation company</rdfs:label>
        <rdfs:label xml:lang="es">Empresa de alojamiento</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#accommodationRateType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#accommodationRating"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#accommodationUnitCategory"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalAccommodationService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalTourismOrRelatedFacilityService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPriceClass"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPriceSpecification"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#PriceSpecification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#autonomousCheckIn"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#checkInTime"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#checkOutTime"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#numberOfAccommodationUnits"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#numberOfBeds"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Establecimiento que ofrece alojamiento turístico.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment providing tourist accommodation.</rdfs:comment>
        <rdfs:label xml:lang="en">Accommodation establishment</rdfs:label>
        <rdfs:label xml:lang="es">Establecimiento alojativo</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Acknowledgement -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Acknowledgement">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#url"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#name"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#recognizedBy"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Achievements or distinctions awarded to people, companies or products for meeting certain standards or specific criteria. These recognitions may include certifications, awards, or other types of honors that recognize quality, performance, compliance, or excellence in a particular field.</rdfs:comment>
        <rdfs:comment xml:lang="es">Logros o distinciones otorgadas a personas, empresas o productos por cumplir con ciertos estándares o criterios específicos. Estos reconocimientos pueden incluir certificaciones, premios u otros tipos de distinciones que reconocen la calidad, el rendimiento, el cumplimiento de normas o la excelencia en un determinado campo.</rdfs:comment>
        <rdfs:label xml:lang="en">Acknowledgement</rdfs:label>
        <rdfs:label xml:lang="es">Reconocimiento</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#AdditionalInformation -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#AdditionalInformation">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#frequentlyAskedQuestion"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#FrequentlyAskedQuestion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#petAdmissionPolicy"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#PetAdmissionPolicy"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#accessTip"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#conditions"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#curiosities"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#remarks"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Additional details, data or explanations that complement or expand the main information provided. It is extra information that can provide clarification, context, or specific details on a given topic.</rdfs:comment>
        <rdfs:comment xml:lang="es">Detalles, datos o explicaciones adicionales que complementan o amplían la información principal proporcionada. Es información extra que puede proporcionar aclaraciones, contexto o detalles específicos sobre un tema determinado.</rdfs:comment>
        <rdfs:label xml:lang="en">Additional information</rdfs:label>
        <rdfs:label xml:lang="es">Información adicional</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#AdventureActivity -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#AdventureActivity">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#relatedTourismOrRelatedFacility"/>
                <owl:someValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#AdventureActivityCentre"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPriceClass"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offeredBy"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#ComplementaryActivitiesCompany"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#includes"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Servicio turístico basado en la realización de una actividad recreativa o deportiva, generalmente asociada a un cierto grado de desafío físico, técnico o de riesgo percibido.</rdfs:comment>
        <rdfs:comment xml:lang="en">Tourism service based on the performance of a recreational or sporting activity, generally associated with a certain degree of physical, technical, or perceived risk.</rdfs:comment>
        <rdfs:label xml:lang="es">Actividad de aventura</rdfs:label>
        <rdfs:label xml:lang="en">Adventure activity</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#AdventureActivityCentre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#AdventureActivityCentre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#adventureActivityType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Center oriented towards sports or practices that involve, in addition to physical activity, intense recreational activity in the natural environment.</rdfs:comment>
        <rdfs:comment xml:lang="es">Centro orientado a los deportes o prácticas que conllevan, además de una actividad física, una intensa actividad recreativa en el medio natural.</rdfs:comment>
        <rdfs:label xml:lang="en">Adventure activity centre</rdfs:label>
        <rdfs:label xml:lang="es">Centro de actividades de aventura</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Advice -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Advice">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RulesAndTips"/>
        <rdfs:comment xml:lang="en">Communication to the user of advice and good practices.</rdfs:comment>
        <rdfs:comment xml:lang="es">Comunicación al usuario de consejos y buenas prácticas.</rdfs:comment>
        <rdfs:label xml:lang="en">Advice</rdfs:label>
        <rdfs:label xml:lang="es">Recomendación</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#AgrotourismExperience -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#AgrotourismExperience">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#agrotourismExperienceRelatedProduct"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#agrotourismExperienceType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPriceClass"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offeredBy"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#ComplementaryActivitiesCompany"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#refPointOfInterest"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Place"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#includes"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#notIncluded"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Experiences resulting from the provision of tourism services on primary sector exploitations that are compatible with the main production and capable of attracting visitors to whom they can convey satisfying sensations</rdfs:comment>
        <rdfs:comment xml:lang="es">Experiencias resultantes de la prestación de servicios turísticos en explotaciones del sector primario compatibles con la producción principal y capaces de atraer visitantes a los que transmitirles sensaciones satisfactorias.</rdfs:comment>
        <rdfs:label xml:lang="en">Agrotourism experience</rdfs:label>
        <rdfs:label xml:lang="es">Experiencia agroturística</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#AgrotourismFacility -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#AgrotourismFacility">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalTourismOrRelatedFacilityService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offers"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#AgrotourismExperience"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPriceClass"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Explotaciones del sector primario que prestan servicios turísticos resultantes en experiencias agroturísticas capaces de atraer visitantes y compatibles con la producción principal de la explotación.</rdfs:comment>
        <rdfs:comment xml:lang="en">Primary sector exploitation providing tourist services resulting in agrotourism experiences capable of attracting visitors and compatible with the main production of the exploitation.</rdfs:comment>
        <rdfs:label xml:lang="en">Agrotourism facility</rdfs:label>
        <rdfs:label xml:lang="es">Instalación agroturística</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Airport -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Airport">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#transportInfrastructureContains"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A facility where air transportation originates stops and / or terminates and where passengers and/or cargo can be taken on or off and/or maintenance re-stocking or re-fueling takes place.</rdfs:comment>
        <rdfs:comment xml:lang="es">Instalación en la que se inicia, interrumpe o finaliza el transporte aéreo y en la que se puede embarcar o desembarcar pasajeros y/o carga, y/o se realizan tareas de mantenimiento, reabastecimiento o repostaje.</rdfs:comment>
        <rdfs:label xml:lang="es">Aeropuerto</rdfs:label>
        <rdfs:label xml:lang="en">Airport</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Alcazar -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Alcazar">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">A fortified castle located in a strategic position, especially when enclosed by defensive walls.</rdfs:comment>
        <rdfs:comment xml:lang="es">Castillo fortificado situado en un lugar estratégico, especialmente cuando está amurallado.</rdfs:comment>
        <rdfs:label xml:lang="en">Alcazar</rdfs:label>
        <rdfs:label xml:lang="es">Alcázar</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Amphitheatre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Amphitheatre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">An oval or circular structure equipped with tiered seating surrounding a central sandy area, where public spectacles were held in ancient Rome.</rdfs:comment>
        <rdfs:comment xml:lang="es">Construcción oval o circular provista de un graderío alrededor de una zona arenosa central, en la que en la antigua Roma se celebraban espectáculos públicos.</rdfs:comment>
        <rdfs:label xml:lang="en">Amphitheater</rdfs:label>
        <rdfs:label xml:lang="es">Anfiteatro</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#AmusementPark -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#AmusementPark">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="en">A venue that hosts a wide variety of attractions and events for fun and entertainment.</rdfs:comment>
        <rdfs:comment xml:lang="es">Recinto que acoge una gran variedad de atracciones y acontecimientos destinados a la diversión y al entretenimiento.</rdfs:comment>
        <rdfs:label xml:lang="en">Amusement park</rdfs:label>
        <rdfs:label xml:lang="es">Parque de atracciones</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Aparthotel -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Aparthotel">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
        <rdfs:comment xml:lang="en"> Apartment hotel where accommodation is provided in studios or apartments.</rdfs:comment>
        <rdfs:comment xml:lang="es">Apartotel donde se ofrece alojamiento en estudios o apartamentos.</rdfs:comment>
        <rdfs:label xml:lang="es">Apartahotel</rdfs:label>
        <rdfs:label xml:lang="en">Aparthotel</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Aquarium -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Aquarium">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="en">Enclosure intended for the exhibition of live aquatic animals.</rdfs:comment>
        <rdfs:comment xml:lang="es">Recinto destinado a la exhibición de animales acuáticos vivos.</rdfs:comment>
        <rdfs:label xml:lang="es">Acuario</rdfs:label>
        <rdfs:label xml:lang="en">Aquarium</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Aqueduct -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Aqueduct">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en"> A bridge-like structure supported by one or more rows of arches, designed to carry water across a deep natural depression.</rdfs:comment>
        <rdfs:comment xml:lang="es">Construcción en forma de puente soportado por una o más filas de arcos sobre la cual se conduce agua de un lado a otro de una fuerte depresión de terreno.</rdfs:comment>
        <rdfs:label xml:lang="es">Acueducto</rdfs:label>
        <rdfs:label xml:lang="en">Aqueduct</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ArabicBath -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ArabicBath">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">Arab baths, also known as hammam, are public bathing spaces that combine body cleansing with relaxation and well-being.</rdfs:comment>
        <rdfs:comment xml:lang="es">Los baños árabes, también conocidos como hammam, son espacios públicos de baño que combinan la limpieza del cuerpo con la relajación y el bienestar.</rdfs:comment>
        <rdfs:label xml:lang="en">Arabic bath</rdfs:label>
        <rdfs:label xml:lang="es">Baños árabes</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Arcade -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Arcade">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="es">Lugar donde se encuentran un conjunto de máquinas o juegos, en los que a cambio de una determinada cantidad de dinero se obtiene un tiempo de juego.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place where a set of machines or games are found, in which in exchange for a certain amount of money you get playing time.</rdfs:comment>
        <rdfs:label xml:lang="en">Arcade</rdfs:label>
        <rdfs:label xml:lang="es">Salón recreativo</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Arch -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Arch">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">A structural element with a curved or polygonal profile.</rdfs:comment>
        <rdfs:comment xml:lang="es">Elemento constructivo de directriz en forma curvada o poligonal.</rdfs:comment>
        <rdfs:label xml:lang="en">Arch</rdfs:label>
        <rdfs:label xml:lang="es">Arco</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ArcheologicalSite -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ArcheologicalSite">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">A place where archaeological remains are found.</rdfs:comment>
        <rdfs:comment xml:lang="es">Lugar donde se hallan restos arqueológicos.</rdfs:comment>
        <rdfs:label xml:lang="en">Archaelogical site</rdfs:label>
        <rdfs:label xml:lang="es">Yacimiento arqueológico</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ArtGallery -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ArtGallery">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="es">Establecimiento para exposición y venta de obras de arte.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment for exhibition and sale of works of art.</rdfs:comment>
        <rdfs:label xml:lang="en">Art gallery</rdfs:label>
        <rdfs:label xml:lang="es">Galería de arte</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Auditorium -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Auditorium">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#EventAttendanceFacility"/>
        <rdfs:comment xml:lang="en">Room for concerts, recitals, conferences, colloquiums, public readings, etc.</rdfs:comment>
        <rdfs:comment xml:lang="es">Sala destinada a conciertos, recitales, conferencias, coloquios, lecturas públicas, etc.</rdfs:comment>
        <rdfs:label xml:lang="es">Auditorio</rdfs:label>
        <rdfs:label xml:lang="en">Auditorium</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BakeryAndPastry -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BakeryAndPastry">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#GroceriesService"/>
        <rdfs:comment xml:lang="es">Establecimiento donde se hacen y/o se venden panes, pasteles, pastas u otros dulces.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment where breads, cakes, pastas or other sweets are made and/or sold.</rdfs:comment>
        <rdfs:label xml:lang="en">Bakery and pastry</rdfs:label>
        <rdfs:label xml:lang="es">Panadería y pastelería</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BankOffice -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BankOffice">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FinancialService"/>
        <rdfs:comment xml:lang="es">Lugar donde una institución financiera ofrece asistencia personal y automatizada a los clientes.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place where a financial institution offers personal and automated assistance to customers</rdfs:comment>
        <rdfs:label xml:lang="en">Bank office</rdfs:label>
        <rdfs:label xml:lang="es">Oficina bancaria</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Bar -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Bar">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
        <rdfs:comment xml:lang="es">Establecimiento equipado con una barra en la que se venden bebidas alcohólicas o no alcohólicas y en el que, en ocasiones, se sirven comidas ligeras, dependiendo de la especialización.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment equipped with a counter selling alcoholic or non-alcoholic beverages, and where light food is sometimes served depending on the specialization.</rdfs:comment>
        <rdfs:label xml:lang="en">Bar</rdfs:label>
        <rdfs:label xml:lang="es">Bar</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Basilica -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Basilica">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">A church distinguished by its antiquity, magnificence, or the significance of the rites celebrated within it.</rdfs:comment>
        <rdfs:comment xml:lang="es">Iglesia notable por su antigüedad o magnificencia o por los cultos que en ella se celebran.</rdfs:comment>
        <rdfs:label xml:lang="en">Basilica</rdfs:label>
        <rdfs:label xml:lang="es">Basílica</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BasketballCourt -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BasketballCourt">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="en">Flat surface, indoor or outdoor, with a hoop at each end suspended about three meters high for practicing this sport.</rdfs:comment>
        <rdfs:comment xml:lang="es">Superficie plana, interior o exterior, con un aro en cada extremo suspendido a unos tres metros de altura para la práctica de este deporte.</rdfs:comment>
        <rdfs:label xml:lang="en">Basketball court</rdfs:label>
        <rdfs:label xml:lang="es">Cancha de baloncesto</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Bazaar -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Bazaar">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashionBusiness"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se venden gran diversidad de productos, como ropa, relojes, juguetes, artículos para la casa y objetos de regalo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment where a wide variety of products are sold, such as clothing, watches, toys, household items and gift items.</rdfs:comment>
        <rdfs:label xml:lang="en">Bazaar</rdfs:label>
        <rdfs:label xml:lang="es">Bazar</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Beach -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Beach">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#beachType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasBeachService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#naturalResourceContains"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Natural or artificial area, formed by sand, gravel, pebble, rock or another material, that facilitates access to the water and the bathing area where leisure activities are carried out and where services are provided.</rdfs:comment>
        <rdfs:comment xml:lang="en">Área natural o artificial, formada por arena, grava, guijarros, rocas u otro material, que facilita el acceso al agua y a la zona de baño donde se realizan actividades de ocio y se prestan servicios.</rdfs:comment>
        <rdfs:label xml:lang="en">Beach</rdfs:label>
        <rdfs:label xml:lang="es">Playa</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BeachBar -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BeachBar">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
        <rdfs:comment xml:lang="es">Pequeño establecimiento a pie de playa, que ofrece comidas y bebidas y que posee una terraza o área de mesas al aire libre.</rdfs:comment>
        <rdfs:comment xml:lang="en">Small establishment on the beach, which offers food and drinks and has a terrace or outdoor table area.</rdfs:comment>
        <rdfs:label xml:lang="en">Beach bar</rdfs:label>
        <rdfs:label xml:lang="es">Chiringuito</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BeachClub -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BeachClub">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PartyAndEntertainmentFacility"/>
        <rdfs:comment xml:lang="en">Leisure and entertainment venue in coastal areas with facilities and services similar to those of a hotel, but without the lodging option.</rdfs:comment>
        <rdfs:comment xml:lang="es">Lugar de ocio y entretenimiento en las zonas costeras con instalaciones y servicios semejantes a los de un hotel, pero sin la opción de hospedaje.</rdfs:comment>
        <rdfs:label xml:lang="en">Beach club</rdfs:label>
        <rdfs:label xml:lang="es">Club de playa</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BeautyCentre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BeautyCentre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HealthAndWellnessFacility"/>
        <rdfs:comment xml:lang="es">Establecimiento orientado a la belleza y cuidado del cuerpo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment aimed at beauty and body care.</rdfs:comment>
        <rdfs:label xml:lang="en">Beauty centre</rdfs:label>
        <rdfs:label xml:lang="es">Centro estético</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BellTower -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BellTower">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">A tall tower, whether freestanding, attached, or integrated ninto a building, where bells are housed.</rdfs:comment>
        <rdfs:comment xml:lang="es">Torre elevada, exenta, adosada o integrada en un edificio, donde se colocan las campanas.</rdfs:comment>
        <rdfs:label xml:lang="en">Bell tower</rdfs:label>
        <rdfs:label xml:lang="es">Campanario</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BicycleSharingSystem -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BicycleSharingSystem">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPriceSpecification"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#PriceSpecification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Service that makes a series of bicycles available to users to be used temporarily as a means of transportation.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicio que pone a disposición de los usuarios una serie de bicicletas para que sean utilizadas temporalmente como medio de transporte.</rdfs:comment>
        <rdfs:label xml:lang="en">Bicycle sharing system</rdfs:label>
        <rdfs:label xml:lang="es">Sistema de bicicletas compartidas</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BikeLane -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BikeLane">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:comment xml:lang="en">Cycle route that runs adjacent to the road in one or two directions.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vía ciclista que discurre adosada a la calzada en uno o en doble sentido.</rdfs:comment>
        <rdfs:label xml:lang="en">Bike lane</rdfs:label>
        <rdfs:label xml:lang="es">Carril bici</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Bingo -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Bingo">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PartyAndEntertainmentFacility"/>
        <rdfs:comment xml:lang="en">An establishment specifically designed for playing bingo games and offering the chance to win prizes.</rdfs:comment>
        <rdfs:comment xml:lang="es">Establecimiento diseñado específicamente para la realización de juegos de bingo y tener la oportunidad de ganar premios.</rdfs:comment>
        <rdfs:label xml:lang="en">Bingo</rdfs:label>
        <rdfs:label xml:lang="es">Bingo</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BookingChannel -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BookingChannel">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#ContactPoint"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#onSite"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Means or platforms that a place, event, or organisation offers for the purpose of making a booking.</rdfs:comment>
        <rdfs:comment xml:lang="es">Medios o plataformas que pone a disposición un lugar, evento u organización para realizar una reserva.</rdfs:comment>
        <rdfs:label xml:lang="en">Booking channel</rdfs:label>
        <rdfs:label xml:lang="es">Canal de reserva</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Bookshop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Bookshop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashionBusiness"/>
        <rdfs:comment xml:lang="en">Shop where books are sold</rdfs:comment>
        <rdfs:comment xml:lang="es">Tienda donde se venden libros.</rdfs:comment>
        <rdfs:label xml:lang="en">Bookshop</rdfs:label>
        <rdfs:label xml:lang="es">Librería</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BowlingAlley -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BowlingAlley">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="en">A recreational facility equipped with lanes for bowling, often featuring catering and complementary entertainment services.</rdfs:comment>
        <rdfs:comment xml:lang="es">Instalación recreativa equipada con pistas para la práctica de bolos, que suele integrar servicios de restauración y entretenimiento complementario.</rdfs:comment>
        <rdfs:label xml:lang="es">Bolera</rdfs:label>
        <rdfs:label xml:lang="en">Bowling alley</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Brewery -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Brewery">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se sirve cerveza como especialidad.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment in which beer is served as specialty.</rdfs:comment>
        <rdfs:label xml:lang="en">Brewery</rdfs:label>
        <rdfs:label xml:lang="es">Cervecería</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Bridge -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Bridge">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">A structure made of stone, brick, wood, iron, concrete, or other materials, built over rivers, moats, or other areas to connect two sides</rdfs:comment>
        <rdfs:comment xml:lang="es">Construcción de piedra, ladrillo, madera, hierro, hormigón, etc., que se construye y forma sobre los ríos, fosos y otros sitios, para comunicar dos lados.</rdfs:comment>
        <rdfs:label xml:lang="en">Bridge</rdfs:label>
        <rdfs:label xml:lang="es">Puente</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BullRing -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BullRing">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#EventAttendanceFacility"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">A generally circular structure with tiered seating, intended for bullfighting but also used for other types of events.</rdfs:comment>
        <rdfs:comment xml:lang="es">Construcción generalmente circular y con graderías, destinada a la lidia de toros, aunque también puede ser utilizada para otros tipos de eventos.</rdfs:comment>
        <rdfs:label xml:lang="en">Bullring</rdfs:label>
        <rdfs:label xml:lang="es">Plaza de toros</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BusOperator -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BusOperator">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PassengerTransportCompany"/>
        <rdfs:comment xml:lang="en">Company specialized in providing passenger transport services using coaches on pre-established routes.</rdfs:comment>
        <rdfs:comment xml:lang="es">Empresa especializada en la prestación de servicios de transporte de pasajeros utilizando autocares en rutas preestablecidas.</rdfs:comment>
        <rdfs:label xml:lang="en">Bus operator</rdfs:label>
        <rdfs:label xml:lang="es">Operador de autocares</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#BusStation -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#BusStation">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#transportInfrastructureContains"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Facility for the arrival and departure of buses.</rdfs:comment>
        <rdfs:comment xml:lang="es">Instalación destinada a la llegada y salida de autobuses.</rdfs:comment>
        <rdfs:label xml:lang="en">Bus station</rdfs:label>
        <rdfs:label xml:lang="es">Estación de autobuses</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CafeOrCoffeeShop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CafeOrCoffeeShop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
        <rdfs:comment xml:lang="es">Establecimiento donde se sirven y/o venden bebidas frías y calientes, pasteles, a veces sándwiches, comidas ligeras y café en grano.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment where hot and cold beverages, cakes, sometimes sandwiches, light meals, and coffee beans are served and/or sold.</rdfs:comment>
        <rdfs:label xml:lang="en">Cafe or coffee shop</rdfs:label>
        <rdfs:label xml:lang="es">Cafetería</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CallShop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CallShop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MiscellaneousBusiness"/>
        <rdfs:comment xml:lang="es">Local que ofrece a sus clientes servicios de telefonía y conexión a internet principalmente.</rdfs:comment>
        <rdfs:comment xml:lang="en">Local that offers its clients telephone services and internet connection mainly.</rdfs:comment>
        <rdfs:label xml:lang="en">Call shop</rdfs:label>
        <rdfs:label xml:lang="es">Locutorio</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Camping -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Camping">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
        <rdfs:comment xml:lang="es">Tipo de establecimiento situado al aire libre que posee las instalaciones necesarias para atender la demanda y las necesidades alojativas y servicios para albergar a turistas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Type of establishment located outdoors that has the necessary facilities to meet the demand and accommodation needs and services to accommodate tourists.</rdfs:comment>
        <rdfs:label xml:lang="en">Camping</rdfs:label>
        <rdfs:label xml:lang="es">Camping</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Campsite -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Campsite">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#EducationalFacility"/>
        <rdfs:comment xml:lang="es">Instalación eventual, en terreno abierto, donde se practican actividades de convivencia al aire libre, orientada a fines educativos y de formación.</rdfs:comment>
        <rdfs:comment xml:lang="en">Possible installation, in open terrain, where outdoor coexistence activities are practiced, aimed at educational and training purposes.</rdfs:comment>
        <rdfs:label xml:lang="es">Campamento</rdfs:label>
        <rdfs:label xml:lang="en">Campsite</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Canal -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Canal">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="en">Artificial channel through which water is conducted to discharge it or for other uses</rdfs:comment>
        <rdfs:comment xml:lang="es">Cauce artificial por donde se conduce el agua para darle salida o para otros usos</rdfs:comment>
        <rdfs:label xml:lang="en">Canal</rdfs:label>
        <rdfs:label xml:lang="es">Canal</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CaravanArea -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CaravanArea">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:comment xml:lang="es">Espacio específicamente designado para el estacionamiento y pernocta de autocaravanas y campers, que ofrece servicios adaptados a este tipo de vehículos</rdfs:comment>
        <rdfs:comment xml:lang="en">Space specifically designated for parking and overnight stays for motorhomes and campers, which offers services adapted to this type of vehicle.</rdfs:comment>
        <rdfs:label xml:lang="en">Caravan area</rdfs:label>
        <rdfs:label xml:lang="es">Área de autocaravanas</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Casino -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Casino">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PartyAndEntertainmentFacility"/>
        <rdfs:comment xml:lang="en">An establishment dedicated to gambling activities, where shows, concerts, dances, and other events may also be offered.</rdfs:comment>
        <rdfs:comment xml:lang="es">Establecimiento destinado a la práctica de juegos de azar, donde en ocasiones también se ofrecen espectáculos, conciertos, bailes u otras actividades.</rdfs:comment>
        <rdfs:label xml:lang="en">Casino</rdfs:label>
        <rdfs:label xml:lang="es">Casino</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Castle -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Castle">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">A building or group of buildings surrounded by walls, moats, and other defensive works, typically constructed on elevated ground and strategically located for warfare.</rdfs:comment>
        <rdfs:comment xml:lang="es">Edificio o conjunto de edificios rodeados de murallas, fosos y otras obras de fortificación, construido generalmente en un lugar elevado y estratégicamente situado para la guerra.</rdfs:comment>
        <rdfs:label xml:lang="es">Castillo</rdfs:label>
        <rdfs:label xml:lang="en">Castle</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Catacomb -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Catacomb">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="es">Galerías subterráneas que algunas civilizaciones mediterráneas antiguas construyeron y utilizaron como lugar de enterramiento.</rdfs:comment>
        <rdfs:comment xml:lang="en">Underground galleries built and used by certain ancient Mediterranean civilizations as burial places.</rdfs:comment>
        <rdfs:label xml:lang="en">Catacomb</rdfs:label>
        <rdfs:label xml:lang="es">Catacumba</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CateringService -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CateringService">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
        <rdfs:comment xml:lang="en">Food and beverage services for events, whether large or small, formal or informal.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicio de provisión de alimentos y bebidas para eventos, ya sean grandes o pequeños, formales o informales.</rdfs:comment>
        <rdfs:label xml:lang="en">Catering service</rdfs:label>
        <rdfs:label xml:lang="es">Servicio de catering</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Cathedral -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Cathedral">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="es">Iglesia principal en que el obispo, con su cabildo, tiene su sede o cátedra.</rdfs:comment>
        <rdfs:comment xml:lang="en">The principal church where the bishop, together with the cathedral chapter, has his seat.</rdfs:comment>
        <rdfs:label xml:lang="es">Catedral</rdfs:label>
        <rdfs:label xml:lang="en">Cathedral</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Cave -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Cave">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="es">Cavidad natural del terreno causada por algún tipo de erosión de corrientes de agua, hielo o lava.</rdfs:comment>
        <rdfs:comment xml:lang="en">Natural cavity in the ground caused by some type of erosion from water currents, ice or lava.</rdfs:comment>
        <rdfs:label xml:lang="en">Cave</rdfs:label>
        <rdfs:label xml:lang="es">Cueva o caverna</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Cemetery -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Cemetery">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">An enclosed area generally designated for the burial or interment of deceased persons.</rdfs:comment>
        <rdfs:comment xml:lang="es">Recinto generalmente delimitado destinado al enterramiento o sepultura de personas fallecidas.</rdfs:comment>
        <rdfs:label xml:lang="es">Cementerio</rdfs:label>
        <rdfs:label xml:lang="en">Cemetery</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Certification -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Certification">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Acknowledgement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#certificationType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasDescription"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Description"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#validFrom"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#validThrough"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Certificados que indican el cumplimiento de normas, requisitos, características o exigencias</rdfs:comment>
        <rdfs:comment xml:lang="en">Certificates that indicate compliance with standards, requirements, characteristics or demands</rdfs:comment>
        <rdfs:label xml:lang="es">Certificación</rdfs:label>
        <rdfs:label xml:lang="en">Certification</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Chapel -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Chapel">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">A building adjacent to a church, or forming part of it, containing an altar and dedicated to a particular devotion.</rdfs:comment>
        <rdfs:comment xml:lang="es">Edificio contiguo a una iglesia o parte integrante de ella, con altar y advocación particular.</rdfs:comment>
        <rdfs:label xml:lang="es">Capilla</rdfs:label>
        <rdfs:label xml:lang="en">Chapel</rdfs:label>
        <rdfs:label xml:lang="es">Ermita</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ChillOut -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ChillOut">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PartyAndEntertainmentFacility"/>
        <rdfs:comment xml:lang="en">A place where drinks are served and calm and relaxing electronic music is listened to.</rdfs:comment>
        <rdfs:comment xml:lang="es">Local en el que se despachan bebidas y se escucha música electrónica tranquila y relajante.</rdfs:comment>
        <rdfs:label xml:lang="en">Chill out</rdfs:label>
        <rdfs:label xml:lang="es">Chill out</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ChocolateShop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ChocolateShop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se sirve chocolate a la taza, bebidas y productos de pastelería.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment that serves hot chocolate, drinks and pastries.</rdfs:comment>
        <rdfs:label xml:lang="en">Chocolate shop</rdfs:label>
        <rdfs:label xml:lang="es">Chocolatería</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Church -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Church">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">A Christian place of worship.</rdfs:comment>
        <rdfs:comment xml:lang="es">Templo cristiano.</rdfs:comment>
        <rdfs:label xml:lang="en">Church</rdfs:label>
        <rdfs:label xml:lang="es">Iglesia</rdfs:label>
        <rdfs:label xml:lang="en">Parish</rdfs:label>
        <rdfs:label xml:lang="es">Parroquia</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ChurroShop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ChurroShop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se elaboran y se comercializan churros y porras, de forma artesanal, así como chocolate a la taza.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment where artisanal churros and porras are made and sold, as well as hot chocolate.</rdfs:comment>
        <rdfs:label xml:lang="es">Churrería</rdfs:label>
        <rdfs:label xml:lang="en">Churro shop</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CiderBar -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CiderBar">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se vende y se consume sidra como especialidad.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment in which cider is sold and consumed as a specialty.</rdfs:comment>
        <rdfs:label xml:lang="en">Cider bar</rdfs:label>
        <rdfs:label xml:lang="es">Sidrería</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CivilProtection -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CivilProtection">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:comment xml:lang="en">Public service that protects people and property, guaranteeing an adequate response to different types of emergencies and catastrophes</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicio público que protege a las personas y bienes garantizando una respuesta adecuada ante los distintos tipos de emergencias y catástrofes.</rdfs:comment>
        <rdfs:label xml:lang="en">Civil protection</rdfs:label>
        <rdfs:label xml:lang="es">Protección civil</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ClimbingWall -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ClimbingWall">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Instalación deportiva consistente en una pared rocosa para el entrenamiento de la escalada.</rdfs:comment>
        <rdfs:comment xml:lang="en">Sports facility consisting of a rock wall for climbing training.</rdfs:comment>
        <rdfs:label xml:lang="en">Climbing wall</rdfs:label>
        <rdfs:label xml:lang="es">Rocódromo</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Cloister -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Cloister">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">A gallery that encloses the main courtyard of a church or monastery.</rdfs:comment>
        <rdfs:comment xml:lang="es">Galería que cerca el patio principal de una iglesia o convento.</rdfs:comment>
        <rdfs:label xml:lang="es">Claustro</rdfs:label>
        <rdfs:label xml:lang="en">Cloister</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Clothing -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Clothing">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashionBusiness"/>
        <rdfs:comment xml:lang="en">A retail establishment dedicated to the sale of clothing, footwear, and accessories that follow current design and market trends.</rdfs:comment>
        <rdfs:comment xml:lang="es">Establecimiento dedicado a la venta minorista de prendas devestir, calzado y accesorios que siguen las tendencias actuales del diseño y el mercado.</rdfs:comment>
        <rdfs:label xml:lang="en">Clothing</rdfs:label>
        <rdfs:label xml:lang="es">Tienda de moda</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CocktailBar -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CocktailBar">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
        <rdfs:comment xml:lang="es">Establecimiento dedicado a la elaboración y al servicio de cócteles, entendidos como resultantes de la combinación de distintas bebidas y otros ingredientes, generalmente de carácter alcohólico.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment dedicated to the preparation and service of cocktails, understood as beverages resulting from the combination of different drinks and other ingredients, generally of an alcoholic nature.</rdfs:comment>
        <rdfs:label xml:lang="en">Cocktail bar</rdfs:label>
        <rdfs:label xml:lang="es">Coctelería</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ComplementaryActivitiesCompany -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ComplementaryActivitiesCompany">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrganisation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasTourismOrRelatedFacility"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offers"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AdventureActivity"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AgrotourismExperience"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TicketOrEntrance"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Tour"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Organización turística dedicada a la prestación de actividades o servicios que satisfacen necesidades vinculadas a una o varias tipologías turísticas concretas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Tourism organisation dedicated to providing activities or services that meet needs related to one or more specific types of tourism.</rdfs:comment>
        <rdfs:label xml:lang="en">Complementary activities company</rdfs:label>
        <rdfs:label xml:lang="es">Empresa de actividades complementarias</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CongressCentre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CongressCentre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#EventAttendanceFacility"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="es">Espacio preparado para la acogida y celebración de congresos, convenciones, ferias, incentivos y cualquier otro acontecimiento similar.</rdfs:comment>
        <rdfs:comment xml:lang="en">Space prepared for hosting and holding conferences, conventions, fairs, incentives and any other similar event.</rdfs:comment>
        <rdfs:label xml:lang="en">Congress centre</rdfs:label>
        <rdfs:label xml:lang="es">Palacio de congresos y exposiciones</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ContactPoint -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ContactPoint">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#app"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#email"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#instantMessagingService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#telephone"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#url"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A designated means of communication (e.g., phone number, email, website) through which a person or organisation can be reached for inquiries or support.</rdfs:comment>
        <rdfs:comment xml:lang="es">Medio de comunicación designado (por ejemplo, número de teléfono, correo electrónico, URL) a través del cual se puede contactar con una persona u organización para realizar consultas o solicitar asistencia.</rdfs:comment>
        <rdfs:label xml:lang="en">Contact point</rdfs:label>
        <rdfs:label xml:lang="es">Punto de contacto</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Convent -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Convent">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">A residence where members of a religious order live under the rules of their institute.</rdfs:comment>
        <rdfs:comment xml:lang="es">Casa en que viven religiosos o religiosas bajo las reglas de su instituto.</rdfs:comment>
        <rdfs:label xml:lang="en">Convent</rdfs:label>
        <rdfs:label xml:lang="es">Convento</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ConventionCentre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ConventionCentre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#EventAttendanceFacility"/>
        <rdfs:comment xml:lang="en">A facility designed for hosting conventions, congresses, conferences, professional meetings, and other corporate or institutional events, equipped with versatile spaces such as modular rooms, auditoriums, and support areas, as well as the technical infrastructure and services required for the organisation and management of large-scale events.</rdfs:comment>
        <rdfs:comment xml:lang="es">Instalación destinada a la celebración de congresos, convenciones, conferencias, reuniones profesionales y otros eventos de carácter corporativo o institucional, dotada de espacios versátiles como salas modulares, auditorios y áreas de apoyo, así como de infraestructuras técnicas y servicios necesarios para la organización y gestión de eventos a gran escala.</rdfs:comment>
        <rdfs:label xml:lang="es">Centro de convenciones</rdfs:label>
        <rdfs:label xml:lang="en">Convention centre</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Cove -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Cove">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="en">A small, rounded inlet forming part of a bay, smaller than a beach and characterized by calmer waters.</rdfs:comment>
        <rdfs:comment xml:lang="es">Tramo de bahía de forma redondeada, de dimensiones más pequeñas a las de la playa y donde sus aguas son más tranquilas</rdfs:comment>
        <rdfs:label xml:lang="es">Cala</rdfs:label>
        <rdfs:label xml:lang="en">Cove</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#CultureCentre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#CultureCentre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="es">Recinto en los que se organizan actividades de carácter cultural: conferencias, exposiciones, tertulias, etc.</rdfs:comment>
        <rdfs:comment xml:lang="en">Venue where cultural activities are organized: conferences, exhibitions, gatherings, etc.</rdfs:comment>
        <rdfs:label xml:lang="es">Centro cultural</rdfs:label>
        <rdfs:label xml:lang="en">Culture centre</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#DailyOpeningHours -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#DailyOpeningHours">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#dayOfTheWeek"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Horario de apertura correspondiente a un día concreto de la semana, definido mediante uno o varios intervalos horarios con horas de apertura y cierre.</rdfs:comment>
        <rdfs:comment xml:lang="en">Opening hours corresponding to a specific day of the week, defined by one or more time intervals with opening and closing times.</rdfs:comment>
        <rdfs:label xml:lang="en">Daily opening hours</rdfs:label>
        <rdfs:label xml:lang="es">Horario de apertura diario</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Description -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Description">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#author"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismDestination"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#relatedTourismDestination"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismDestination"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#keyword"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#shortDescription"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#longDescription"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Proporciona información concisa y resumida sobre un elemento específico, como un producto, servicio o entidad. Este bloque suele contener detalles clave y destacados que describen las características principales, funciones, beneficios o aspectos destacados del elemento en cuestión.</rdfs:comment>
        <rdfs:comment xml:lang="en">Provides concise, summarized information about a specific item, such as a product, service, or entity. This block usually contains key details and highlights that describe the main features, functions, benefits or highlights of the item in question.</rdfs:comment>
        <rdfs:label xml:lang="es">Descripción</rdfs:label>
        <rdfs:label xml:lang="en">Description</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Desert -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Desert">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#naturalResourceContains"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Sandy or rocky territory, which due to the almost total lack of rain lacks or has very little vegetation</rdfs:comment>
        <rdfs:comment xml:lang="es">Territorio arenoso o pedregoso, que por la falta casi total de lluvias carece de vegetación o la tiene muy escasa.</rdfs:comment>
        <rdfs:label xml:lang="en">Desert</rdfs:label>
        <rdfs:label xml:lang="es">Desierto</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#DestinationExperience -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#DestinationExperience">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offeredBy"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismDestination"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasLocation"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#itinerary"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#Itinerary"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#timeOfTheDay"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#endDateTime"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#startDateTime"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Price-free experiences that the destination proposes so that the tourist integrates into the way of life of its inhabitants, their culture and their authenticity, to motivate the completion of the trip or so that they take away a memory that survives after it and can be transmitted to others. It allows establishing an emotional relationship between the tourist and the inhabitants of the destination.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vivencias libres de precio que el destino propone para que el turista se integre en la forma de vivir de sus habitantes, su cultura y su autenticidad, para motivar la realización del viaje o bien para que se lleve un recuerdo que perviva después del mismo y pueda ser transmitido a los demás. Permite establecer una relación emocional entre el turista y los habitantes del destino.</rdfs:comment>
        <rdfs:label xml:lang="en">Destination experience</rdfs:label>
        <rdfs:label xml:lang="es">Experiencia en destino</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#DestinationManagementCompany -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#DestinationManagementCompany">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismIntermediary"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalDMCService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Company specialized in the organization and management of tourist services for foreign visitors in a specific destination.</rdfs:comment>
        <rdfs:comment xml:lang="es">Empresa especializada en la organización y gestión de servicios turísticos para visitantes extranjeros en un destino específico.</rdfs:comment>
        <rdfs:label xml:lang="en">Destination management company</rdfs:label>
        <rdfs:label xml:lang="es">Operador receptivo</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#DiveSite -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#DiveSite">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="en">Specific area of a natural environment, generally marine or underwater, that meets physical, biological, or scenic conditions of interest for the practice of diving.</rdfs:comment>
        <rdfs:comment xml:lang="es">Zona específica de un entorno natural, generalmente marino o subacuático, que reúne condiciones físicas, biológicas o paisajísticas de interés para la práctica del buceo.</rdfs:comment>
        <rdfs:label xml:lang="en">Dive site</rdfs:label>
        <rdfs:label xml:lang="es">Punto de inmersión</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#DryCleaningOrLaundry -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#DryCleaningOrLaundry">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MiscellaneousBusiness"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se tiñen, se planchan o se limpian en seco o mediante otro procedimiento tejidos y prendas de vestir.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment in which fabrics and clothing are dyed, ironed, dry cleaned or otherwise cleaned.</rdfs:comment>
        <rdfs:label xml:lang="en">Dry cleaning or laundry</rdfs:label>
        <rdfs:label xml:lang="es">Tintorería o lavandería</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EVChargingStation -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EVChargingStation">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:comment xml:lang="es">Lugar que provee electricidad para la recarga rápida de las baterías de los vehículos eléctricos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place that provides electricity for the rapid recharging of electric vehicle batteries.</rdfs:comment>
        <rdfs:label xml:lang="en">Electric vehicle charging station</rdfs:label>
        <rdfs:label xml:lang="es">Estación de carga de vehículos eléctricos</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EducationalCentre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EducationalCentre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#EducationalFacility"/>
        <rdfs:comment xml:lang="es">Establecimiento destinado a la enseñanza.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment intended for teaching.</rdfs:comment>
        <rdfs:label xml:lang="es">Centro educativo</rdfs:label>
        <rdfs:label xml:lang="en">Educational centre</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EducationalFacility -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EducationalFacility">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalEducationalFacilityService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalTourismOrRelatedFacilityService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Espacios dedicados al aprendizaje y desarrollo de habilidades donde los participantes, generalmente niños o jóvenes, participan en actividades educativas, recreativas y sociales fuera del entorno escolar tradicional y con un enfoque generalmente temático.</rdfs:comment>
        <rdfs:comment xml:lang="en">Spaces dedicated to learning and skill development where participants, generally children or young people, participate in educational, recreational and social activities outside the traditional school environment and with a generally thematic focus.</rdfs:comment>
        <rdfs:label xml:lang="en">Educational facility</rdfs:label>
        <rdfs:label xml:lang="es">Instalación educativa</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EmbassyAndConsulate -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EmbassyAndConsulate">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:comment xml:lang="es">Representación de la administración pública de un país en otro.</rdfs:comment>
        <rdfs:comment xml:lang="en">Representation of the public administration of a country in another</rdfs:comment>
        <rdfs:label xml:lang="es">Embajada y consulado</rdfs:label>
        <rdfs:label xml:lang="en">Embassy and consulate</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EngineCircuit -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EngineCircuit">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="en"> An area equipped with one or more tracks designed for holding races.</rdfs:comment>
        <rdfs:comment xml:lang="es">Espacio provisto de una o varias pistas preparadas para disputar carreras.</rdfs:comment>
        <rdfs:label xml:lang="es">Circuito de motor</rdfs:label>
        <rdfs:label xml:lang="en">Engine circuit</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EquestrianClub -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EquestrianClub">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="en">Facilities that house horses for recreational, sporting or tourist purposes, including sports stables, rental stables and other establishments for equestrian practice.</rdfs:comment>
        <rdfs:comment xml:lang="es">Instalaciones que albergan caballos con fines recreativos deportivos o turísticos incluyendo las cuadras deportivas, las cuadras en alquiler y otros establecimientos para la práctica ecuestre.</rdfs:comment>
        <rdfs:label xml:lang="es">Club hípico</rdfs:label>
        <rdfs:label xml:lang="en">Equestrian club</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EscapeRoom -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EscapeRoom">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="en">An interactive leisure experience based on solving puzzles and locating key items, with the objective of completing a mission or exiting a premises within a set time limit.</rdfs:comment>
        <rdfs:comment xml:lang="es">Experiencia de ocio interactivo basada en la resolución de enigmas y la localización de objetos clave, con el fin de completar una misión o abandonar un recinto en un tiempo determinado.</rdfs:comment>
        <rdfs:label xml:lang="en">Escape room</rdfs:label>
        <rdfs:label xml:lang="es">Escape room</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Event -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Event">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#availableLanguage"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#eventType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAcknowledgement"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Acknowledgement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalEventService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasContactPoint"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#ContactPoint"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPriceSpecification"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#PriceSpecification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasSubEvent"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Event"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasSuperEvent"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Event"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#nearTo"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Place"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#refPointOfInterest"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Place"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#relatedTo"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#touristType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#travelUnit"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#venue"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Place"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasContactPoint"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#ContactPoint"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#eventSchedule"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#Schedule"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasContactPoint"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#BookingChannel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasLocation"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#Location"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasSuperEvent"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#Event"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offeredBy"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismDestination"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrganisation"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#saleEndDate"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#saleStartDate"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#startDateTime"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#maximumAttendeeCapacity"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#numberedSeats"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#outdoorEvent"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Experience which takes place at a specific time and location.</rdfs:comment>
        <rdfs:comment xml:lang="es">Experiencia que tiene lugar en un momento y lugar específicos.</rdfs:comment>
        <rdfs:label xml:lang="en">Event</rdfs:label>
        <rdfs:label xml:lang="es">Evento</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EventAttendanceFacility -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EventAttendanceFacility">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalEventAttendanceFacilityService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalTourismOrRelatedFacilityService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Espacios diseñados y equipados para albergar la celebración de diversas actividades y acontecimientos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Spaces designed and equipped to host various activities and events.</rdfs:comment>
        <rdfs:label xml:lang="en">Event attendance facility</rdfs:label>
        <rdfs:label xml:lang="es">Instalación para eventos</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#EventOrganisationCompany -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#EventOrganisationCompany">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrganisation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasTourismOrRelatedFacility"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Company that is mainly responsible for the design, planning, coordination, as well as the production and execution of an event.</rdfs:comment>
        <rdfs:comment xml:lang="es">Empresa que se encarga principalmente del diseño, la planificación, la coordinación, así como la producción y ejecución de un evento.</rdfs:comment>
        <rdfs:label xml:lang="es">Empresa de organización de eventos</rdfs:label>
        <rdfs:label xml:lang="en">Event organisation company</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ExchangeBureau -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ExchangeBureau">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FinancialService"/>
        <rdfs:comment xml:lang="es">Organización o centro que permite a los clientes cambiar una divisa por otra.</rdfs:comment>
        <rdfs:comment xml:lang="en">Organization or facility that allows customers to exchange one currency for another</rdfs:comment>
        <rdfs:label xml:lang="es">Casa de cambio</rdfs:label>
        <rdfs:label xml:lang="en">Exchange bureau</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ExhibitionHall -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ExhibitionHall">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="es">Espacio de fomento, promoción y difusión de las artes plásticas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Space for the promotion, promotion and dissemination of the plastic arts.</rdfs:comment>
        <rdfs:label xml:lang="en">Exhibition hall</rdfs:label>
        <rdfs:label xml:lang="es">Sala de exposiciones</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Fairground -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Fairground">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#EventAttendanceFacility"/>
        <rdfs:comment xml:lang="en">A facility intended for hosting fairs, exhibitions, and other temporary events open to the public, composed of large and modular spaces, indoor or outdoor, adapted for the exhibition and promotion of products and services.</rdfs:comment>
        <rdfs:comment xml:lang="es">Instalación destinada a la celebración de ferias, exposiciones y otros eventos temporales abiertos al público, formada por espacios amplios y modulares, cubiertos o al aire libre, adaptados para la exhibición y promoción de productos y servicios.</rdfs:comment>
        <rdfs:label xml:lang="en">Fairground</rdfs:label>
        <rdfs:label xml:lang="es">Recinto ferial</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#FarmSchool -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#FarmSchool">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AgrotourismFacility"/>
        <rdfs:comment xml:lang="en">Educational and learning space where activities related to nature, the rural world and respect for the environment are carried out.</rdfs:comment>
        <rdfs:comment xml:lang="es">Espacio educativo y de aprendizaje donde se realizan actividades relacionadas con la naturaleza, el mundo rural y el respeto al medio ambiente.</rdfs:comment>
        <rdfs:label xml:lang="en">Farm school</rdfs:label>
        <rdfs:label xml:lang="es">Granja escuela</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#FerryOperator -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#FerryOperator">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PassengerTransportCompany"/>
        <rdfs:comment xml:lang="en">Company dedicated to operating maritime transportation services for passengers and vehicles through ferries and specific maritime routes.</rdfs:comment>
        <rdfs:comment xml:lang="es">Compañía que se dedica a operar servicios de transporte marítimo de pasajeros y vehículos a través de ferris y rutas marítimas específicas.</rdfs:comment>
        <rdfs:label xml:lang="en">Ferry operator</rdfs:label>
        <rdfs:label xml:lang="es">Operador de ferris</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#FinancialService -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#FinancialService">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LocalBusiness"/>
        <rdfs:comment xml:lang="es">Actividad o función relacionada con la gestión, el manejo o la intermediación de dinero y recursos financieros.</rdfs:comment>
        <rdfs:comment xml:lang="en">Activity or function related to the management, handling or intermediation of money and financial resources.</rdfs:comment>
        <rdfs:label xml:lang="en">Financial service</rdfs:label>
        <rdfs:label xml:lang="es">Servicio financiero</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#FireStation -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#FireStation">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
        <rdfs:comment xml:lang="en">Competent body for the prevention, preparation and attention of fires and other emergencies</rdfs:comment>
        <rdfs:comment xml:lang="es">Órgano competente para la prevención, preparación y atención de incendios y otras emergencias</rdfs:comment>
        <rdfs:label xml:lang="es">Estación de bomberos</rdfs:label>
        <rdfs:label xml:lang="en">Fire station</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#FoodAndBeverageService -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#FoodAndBeverageService">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offeredBy"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#RestaurantCompany"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en"> A tourism service that encompasses the preparation, provision, and consumption of food and beverages offered to customers by food and beverage establishments, either for on-site consumption or takeaway.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicio turístico que comprende la preparación, elaboración, suministro y consumo de alimentos y bebidas ofrecidos a los clientes por establecimientos de restauración, ya sea para su consumo en el propio establecimiento o para llevar.</rdfs:comment>
        <rdfs:label xml:lang="en">Food and beverage service</rdfs:label>
        <rdfs:label xml:lang="es">Servicio de comidas y bebidas</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#FoodEstablishment -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalFoodEstablishmentService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalTourismOrRelatedFacilityService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#menuOptions"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersGastronomicResource"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#GastronomicResource"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#servesCuisine"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPriceClass"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasPriceSpecification"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#PriceSpecification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#averagePricePerPerson"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Businesses dedicated to the production of foods and beverages prepared for consumption.</rdfs:comment>
        <rdfs:comment xml:lang="es">Negocios dedicados a la elaboración de comidas y bebidas preparadas para su consumo.</rdfs:comment>
        <rdfs:label xml:lang="es">Establecimiento de restauración</rdfs:label>
        <rdfs:label xml:lang="en">Food establishment</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#FoodStall -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#FoodStall">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
        <rdfs:comment xml:lang="es">Puesto sin sitio para sentarse donde los clientes pueden comprar aperitivos ligeros y bebidas, así como comidas preparadas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Stall without place for sitting from which customers can purchase light snacks and beverages, as well as fully prepared meals.</rdfs:comment>
        <rdfs:label xml:lang="en">Food stall</rdfs:label>
        <rdfs:label xml:lang="es">Puesto de comida</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#FootballField -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#FootballField">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="en">A sports venue designed and equipped for football, featuring a regulation-sized pitch and perimeter areas for spectators.</rdfs:comment>
        <rdfs:comment xml:lang="es">Recinto deportivo diseñado y equipado para la práctica del fútbol, que cuenta con un terreno de juego de dimensiones reglamentarias y zonas perimetrales para el público.</rdfs:comment>
        <rdfs:label xml:lang="es">Campo de fútbol</rdfs:label>
        <rdfs:label xml:lang="en">Football field</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Forest -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Forest">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#naturalResourceContains"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Ecosistema donde la vegetación predominante la constituyen los árboles y arbustos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Ecosystem where the predominant vegetation is trees and shrubs.</rdfs:comment>
        <rdfs:label xml:lang="es">Bosque</rdfs:label>
        <rdfs:label xml:lang="en">Forest</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#FrequentlyAskedQuestion -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#FrequentlyAskedQuestion">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#answer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#question"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A structured set of question-and-answer pairs that collect and clarify the most common inquiries raised by users.</rdfs:comment>
        <rdfs:comment xml:lang="es">Conjunto estructurado de pares de pregunta y respuesta que recopilan y aclaran las dudas más habituales planteadas por los usuarios.</rdfs:comment>
        <rdfs:label xml:lang="en">Frequently Asked Question</rdfs:label>
        <rdfs:label xml:lang="es">Pregunta frecuente</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Garden -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Garden">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">A landscaped area where plant species are cultivated, which may also include elements such as fountains, sculptures, or recreational spaces.</rdfs:comment>
        <rdfs:comment xml:lang="es">Terreno donde se cultivan especies vegetales, con posible añadidura de otros elementos como fuentes, esculturas o zonas de ocio.</rdfs:comment>
        <rdfs:label xml:lang="en">Garden</rdfs:label>
        <rdfs:label xml:lang="es">Jardín</rdfs:label>
        <rdfs:label xml:lang="es">Parque urbano</rdfs:label>
        <rdfs:label xml:lang="en">Urban park</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#GasStation -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#GasStation">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"/>
        <rdfs:comment xml:lang="es">Establecimiento o puesto de venta en el que se vende y suministra a vehículos automóviles gasolina u otros combustibles.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment or sales stand in which gasoline or other fuels are sold and supplied to automobile vehicles.</rdfs:comment>
        <rdfs:label xml:lang="en">Gas station</rdfs:label>
        <rdfs:label xml:lang="es">Gasolinera</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#GastronomicMarket -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#GastronomicMarket">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
        <rdfs:comment xml:lang="es">Lugar donde se reúnen diferentes puestos de comida y bebida en un espacio común donde consumir productos y elaboraciones de carácter gourmet.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place where different food and drink stalls meet in a common space where you can consume gourmet products and preparations.</rdfs:comment>
        <rdfs:label xml:lang="en">Gastronomic market</rdfs:label>
        <rdfs:label xml:lang="es">Mercado gastronómico</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#GastronomicResource -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#GastronomicResource">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismResource"/>
        <rdfs:comment xml:lang="en">Element related to gastronomy that holds tourism value due to its ability to represent culinary traditions, products, techniques, or food-related expressions, and to contribute to the identity and attractiveness of a destination</rdfs:comment>
        <rdfs:comment xml:lang="es">Elemento vinculado a la gastronomía que posee valor turístico por su capacidad para representar tradiciones culinarias, productos, técnicas o manifestaciones alimentarias, y contribuir a la identidad y atractivo de un destino.</rdfs:comment>
        <rdfs:label xml:lang="en">Gastronomic resource</rdfs:label>
        <rdfs:label xml:lang="es">Recurso gastronómico</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#GeneralStore -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#GeneralStore">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#GroceriesService"/>
        <rdfs:comment xml:lang="es">Establecimiento o tienda comercial que vende diversos productos alimenticios.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment or commercial store that sells various food products.</rdfs:comment>
        <rdfs:label xml:lang="en">General store</rdfs:label>
        <rdfs:label xml:lang="es">Tienda de ultramarinos</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Geyser -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Geyser">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="en">A special type of hot spring that periodically ejects a column of hot water and steam into the air.</rdfs:comment>
        <rdfs:comment xml:lang="es">Tipo especial de fuente termal que emite periódicamente una columna de agua caliente y vapor al aire.</rdfs:comment>
        <rdfs:label xml:lang="en">Geyser</rdfs:label>
        <rdfs:label xml:lang="es">Géiser</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Glamping -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Glamping">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
        <rdfs:comment xml:lang="en">A form of camping that combines the experience of staying outdoors with the comforts and amenities characteristic of high-end hotel establishments.</rdfs:comment>
        <rdfs:comment xml:lang="es">Modalidad de acampada que combina la experiencia de acampar al aire libre con las comodidades y prestaciones propias de establecimientos hoteleros de alta categoría.</rdfs:comment>
        <rdfs:label xml:lang="en">Glamping</rdfs:label>
        <rdfs:label xml:lang="es">Glamping</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#GolfCourse -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#GolfCourse">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="en">Large outdoor natural grass area where golf is practiced.</rdfs:comment>
        <rdfs:comment xml:lang="es">Área amplia de hierba natural al aire libre donde se practica el golf.</rdfs:comment>
        <rdfs:label xml:lang="es">Campo de golf</rdfs:label>
        <rdfs:label xml:lang="en">Golf course</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#GroceriesService -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#GroceriesService">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LocalBusiness"/>
        <rdfs:comment xml:lang="es">Espacios físicos que proporcionan a los consumidores un lugar accesible y conveniente donde se ofrecen productos alimenticios para su compra y consumo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Physical spaces that provide consumers with an accessible and convenient place where food products are offered for purchase and consumption.</rdfs:comment>
        <rdfs:label xml:lang="en">Groceries service</rdfs:label>
        <rdfs:label xml:lang="es">Servicio de alimentación</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#GuestHouse -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#GuestHouse">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
        <rdfs:comment xml:lang="es">Establecimiento que ofrece alojamiento y comidas principalmente para los huéspedes alojados.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment offering accommodation where meals are available mainly for accommodated guests.</rdfs:comment>
        <rdfs:label xml:lang="en">Guest house</rdfs:label>
        <rdfs:label xml:lang="es">Pensión</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Gym -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Gym">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Local dotado de las instalaciones y los aparatos adecuados para hacer gimnasia y practicar ciertos deportes.</rdfs:comment>
        <rdfs:comment xml:lang="en">Local equipped with the appropriate facilities and equipment to do gymnastics and practice certain sports.</rdfs:comment>
        <rdfs:label xml:lang="es">Gimnasio</rdfs:label>
        <rdfs:label xml:lang="en">Gym</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Hairdressing -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Hairdressing">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MiscellaneousBusiness"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se peina, se corta, se arregla y se cuida el cabello.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment where hair is combed, cut, groomed and cared for.</rdfs:comment>
        <rdfs:label xml:lang="en">Hairdressing</rdfs:label>
        <rdfs:label xml:lang="es">Peluquería</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Handicrafts -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Handicrafts">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AgrotourismFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#handicraftsType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Shop dedicated to the sale of objects or artifacts, done manually or with the use of traditional or rudimentary means, with skill, dexterity, quality and creativity.</rdfs:comment>
        <rdfs:comment xml:lang="es">Tienda que se dedica a la venta de objetos o artefactos, realizados manualmente o con medios tradicionales o rudimentarios, con habilidad, destreza, calidad y creatividad.</rdfs:comment>
        <rdfs:label xml:lang="en">Handicrafts</rdfs:label>
        <rdfs:label xml:lang="es">Tienda de artesanías</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#HealthAndWellnessFacility -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#HealthAndWellnessFacility">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalTourismOrRelatedFacilityService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Espacio destinado a la prestación de servicios orientados a la salud, el bienestar físico y mental y la relajación, mediante tratamientos, terapias o actividades especializadas</rdfs:comment>
        <rdfs:comment xml:lang="en">Facility intended for the provision of services aimed at health, physical and mental well-being, and relaxation, through specialized treatments, therapies, or activities.</rdfs:comment>
        <rdfs:label xml:lang="en">Health and wellness facility</rdfs:label>
        <rdfs:label xml:lang="es">Instalación de salud y bienestar</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#HealthResort -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#HealthResort">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HealthAndWellnessFacility"/>
        <rdfs:comment xml:lang="en">A health and wellness establishment that utilizes thermal or mineral waters for therapeutic, preventive, relaxation, and leisure purposes.</rdfs:comment>
        <rdfs:comment xml:lang="es">Establecimiento de salud y bienestar que utiliza aguas termales o minerales con fines terapéuticos, preventivos, de relajación y de ocio.</rdfs:comment>
        <rdfs:label xml:lang="es">Balneario</rdfs:label>
        <rdfs:label xml:lang="en">Health resort</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Place"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalHistoricalOrCulturalResourceService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalTourismResourceService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#paymentMethod"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#touristType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#travelUnit"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#additionalClassification"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#maximumAttendeeCapacity"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#publicAccess"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Lugares, sitios y estructuras que tienen un valor significativo para los turistas desde el punto de vista histórico, arqueológico, arquitectónico o cultural.</rdfs:comment>
        <rdfs:comment xml:lang="en">Places, sites and structures that have significant value to tourists from a historical, archaeological, architectural or cultural point of view</rdfs:comment>
        <rdfs:label xml:lang="en">Historical or cultural resource</rdfs:label>
        <rdfs:label xml:lang="es">Recurso histórico o cultural</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#HolidayPackage -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#HolidayPackage">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#offeredBy"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismIntermediary"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#itinerary"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://ontologia.segittur.es/turismo/def/core#Itinerary"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#includes"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#isAllinclusive"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#notIncluded"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Experience that is marketed only through travel agencies that contains two or more tourist services (accommodation, maintenance or transportation) for which the client pays a price.</rdfs:comment>
        <rdfs:comment xml:lang="es">Experiencia que se comercializa únicamente por medio de las agencias de viajes que contiene dos o más servicios de carácter turístico (alojamiento, manutención o transporte) por el que el cliente abona un precio.</rdfs:comment>
        <rdfs:label xml:lang="en">Holiday package</rdfs:label>
        <rdfs:label xml:lang="es">Paquete turístico</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Hostal -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Hostal">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
        <rdfs:comment xml:lang="es">Establecimiento de alojamiento turístico que proporciona servicios básicos de hospedaje, con una categoría y nivel de servicios inferiores a los de un hotel.</rdfs:comment>
        <rdfs:comment xml:lang="en">HA tourist accommodation establishment that provides basic lodging services, with a category and level of amenities lower than those of a hotel.</rdfs:comment>
        <rdfs:label xml:lang="en">Hostal</rdfs:label>
        <rdfs:label xml:lang="es">Hostal</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Hostel -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Hostel">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
        <rdfs:comment xml:lang="es">Establecimiento hotelero para estancias cortas, generalmente situado en un lugar de paso o estratégico.</rdfs:comment>
        <rdfs:comment xml:lang="en">Hotel establishment for short stays, generally located in a transit or strategic location.</rdfs:comment>
        <rdfs:label xml:lang="es">Albergue</rdfs:label>
        <rdfs:label xml:lang="en">Hostel</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Hotel -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Hotel">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#parador"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Commercial establishment providing at least reception, accommodation and guest services, recognized or registered as such in the applicable legislation. It might also offer food and beverage services and/or other ancillary services.</rdfs:comment>
        <rdfs:comment xml:lang="es">Establecimiento comercial que ofrece, como mínimo, servicios de recepción, alojamiento y atención al huésped, reconocido o registrado como tal en la legislación aplicable. También puede ofrecer servicios de restauración y/u otros servicios auxiliares.</rdfs:comment>
        <rdfs:label xml:lang="en">Hotel</rdfs:label>
        <rdfs:label xml:lang="es">Hotel</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#IceCreamShop -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#IceCreamShop">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se comercializan y se sirven helados.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment in which ice cream is sold and served.</rdfs:comment>
        <rdfs:label xml:lang="es">Heladería</rdfs:label>
        <rdfs:label xml:lang="en">Ice cream shop</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Inn -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Inn">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#FoodEstablishment"/>
        <rdfs:comment xml:lang="es">Establecimiento en el que se preparan y sirven comidas y que está decorado de forma tradicional y rústica.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment in which meals are prepared and served and which is decorated in a traditional and rustic way.</rdfs:comment>
        <rdfs:label xml:lang="es">Mesón</rdfs:label>
        <rdfs:label xml:lang="es">Venta</rdfs:label>
        <rdfs:label xml:lang="en">inn</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#InterpretationCentre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#InterpretationCentre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#EducationalFacility"/>
        <rdfs:comment xml:lang="es">Espacio que revela el significado y la relación del patrimonio con el visitante que llega hasta el sitio turístico que lo contiene.</rdfs:comment>
        <rdfs:comment xml:lang="en">Space that reveals the meaning and relationship of heritage with the visitor who arrives at the tourist site that contains it.</rdfs:comment>
        <rdfs:label xml:lang="es">Centro de interpretación</rdfs:label>
        <rdfs:label xml:lang="en">Interpretation centre</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Itinerary -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Itinerary">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasItineraryElement"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#ItineraryElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#position"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A collection of points of interest involved in a route or tourism service.</rdfs:comment>
        <rdfs:comment xml:lang="es">Colección de puntos de interés de referencia asociados a la realización de una ruta o servicio turístico.</rdfs:comment>
        <rdfs:label xml:lang="es">Itinerario</rdfs:label>
        <rdfs:label xml:lang="en">Itinerary</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#ItineraryElement -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#ItineraryElement">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#refPointOfInterest"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Event"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Place"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#refPointOfInterestAsText"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A point of interest with, optionally, the position or numerical order it occupies in the sequence of an itinerary.</rdfs:comment>
        <rdfs:comment xml:lang="es">Un punto de interés de referencia con, opcionalmente, la posición u orden numérico que ocupa en la secuencia de un itinerario.</rdfs:comment>
        <rdfs:label xml:lang="es">Elemento de un itinerario</rdfs:label>
        <rdfs:label xml:lang="en">Itinerary element</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#JewelryAndWatches -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#JewelryAndWatches">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashionBusiness"/>
        <rdfs:comment xml:lang="es">Establecimiento donde se venden joyas y relojes</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment where jewelry and watches are sold</rdfs:comment>
        <rdfs:label xml:lang="en">Jewelry and watches</rdfs:label>
        <rdfs:label xml:lang="es">Joyería y relojería</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Karaoke -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Karaoke">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PartyAndEntertainmentFacility"/>
        <rdfs:comment xml:lang="es">Local público con instalaciones para karaoke, equipo que se usa para interpretar canciones sobre un fondo musical grabado, mientras se sigue la letra que aparece en una pantalla.</rdfs:comment>
        <rdfs:comment xml:lang="en">Public venue with karaoke facilities, equipment used to perform songs over a recorded musical background, while following the lyrics that appear on a screen.</rdfs:comment>
        <rdfs:label xml:lang="en">Karaoke</rdfs:label>
        <rdfs:label xml:lang="es">Karaoke</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#KartsCircuit -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#KartsCircuit">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#SportFacility"/>
        <rdfs:comment xml:lang="es">Espacio provisto de una o varias pistas preparadas para disputar carreras con estos vehículos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Space provided with one or more tracks prepared to compete in races with these vehicles.</rdfs:comment>
        <rdfs:label xml:lang="es">Circuito de karts</rdfs:label>
        <rdfs:label xml:lang="en">Karts circuit</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Kiosk -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Kiosk">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#RetailAndFashionBusiness"/>
        <rdfs:comment xml:lang="es">Local comercial de pequeño tamaño destinado a la venta de periódicos, revistas, golosinas y otros artículos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Small commercial premises for the sale of newspapers, magazines, candy and other items.</rdfs:comment>
        <rdfs:label xml:lang="en">Kiosk</rdfs:label>
        <rdfs:label xml:lang="es">Quiosco</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Label -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Label">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Acknowledgement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasDescription"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#Description"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#labelType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Aquellos reconocimientos que el propio establecimiento se otorga, o que son obtenidos a través de una membresía.</rdfs:comment>
        <rdfs:comment xml:lang="en">Those recognitions that the establishment itself grants, or that are obtained through a membership.</rdfs:comment>
        <rdfs:label xml:lang="es">Distintivo</rdfs:label>
        <rdfs:label xml:lang="en">Label</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Lake -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Lake">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasLakeService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Gran masa permanente de agua depositada en depresiones del terreno.</rdfs:comment>
        <rdfs:comment xml:lang="en">Large permanent mass of water deposited in depressions in the ground.</rdfs:comment>
        <rdfs:label xml:lang="es">Lago</rdfs:label>
        <rdfs:label xml:lang="en">Lake</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalLeisureAndCultureFacilityService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalTourismOrRelatedFacilityService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Espacios destinados a actividades recreativas, artísticas y culturales que ofrecen oportunidades para el entretenimiento, la diversión y la apreciación de diversas formas de expresión artística y cultural.</rdfs:comment>
        <rdfs:comment xml:lang="en">Spaces for recreational, artistic and cultural activities that offer opportunities for entertainment, fun and appreciation of various forms of artistic and cultural expression.</rdfs:comment>
        <rdfs:label xml:lang="es">Instalación de cultura y ocio</rdfs:label>
        <rdfs:label xml:lang="en">Leisure and culture facility</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Library -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Library">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="en">A place dedicated to the acquisition, preservation, study, and display of books and documents.</rdfs:comment>
        <rdfs:comment xml:lang="es">Lugar cuya finalidad consiste en la adquisición, conservación, estudio y exposición de libros y documentos.</rdfs:comment>
        <rdfs:label xml:lang="es">Biblioteca</rdfs:label>
        <rdfs:label xml:lang="en">Library</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#LocalBusiness -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#LocalBusiness">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
        <rdfs:comment xml:lang="en">Company or commercial establishment that operates in a specific physical location that provides products or services.</rdfs:comment>
        <rdfs:comment xml:lang="es">Empresa o establecimiento comercial que opera en una ubicación física específica que proporciona productos o servicios.</rdfs:comment>
        <rdfs:label xml:lang="en">Local business</rdfs:label>
        <rdfs:label xml:lang="es">Negocio local</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Location -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Location">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#autonomousCommunity"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#country"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#locality"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#postalCode"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#province"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#streetAddress"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#county"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Proporciona información sobre la ubicación física de un lugar.</rdfs:comment>
        <rdfs:comment xml:lang="en">Provides information about the physical location of a place.</rdfs:comment>
        <rdfs:label xml:lang="es">Localización</rdfs:label>
        <rdfs:label xml:lang="en">Location</rdfs:label>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Lodge -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Lodge">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
        <rdfs:comment xml:lang="es">Establecimiento hotelero formado por varias unidades independientes alojativas (bungalows, cabañas, villas) edificadas en entornos naturales y construidos con materiales propios del lugar, normalmente madera, cuyo fin es acercar al cliente a la naturaleza.</rdfs:comment>
        <rdfs:comment xml:lang="en">Hotel establishment made up of several independent accommodation units (bungalows, cabins, villas) built in natural environments and built with local materials, usually wood, whose purpose is to bring the client closer to nature.</rdfs:comment>
        <rdfs:label xml:lang="en">Lodge</rdfs:label>
        <rdfs:label xml:lang="es">Lodge</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#LodgingService -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#LodgingService">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:comment xml:lang="en">A proposal of a tourism organisation to sell a specific set of products (accommodation) or services under specific conditions or rates, for a certain price.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una propuesta de una organización turística para vender un conjunto específico de productos (hospedaje) o servicios en condiciones o tarifas específicas, por un precio determinado.</rdfs:comment>
        <rdfs:label xml:lang="en">Lodging service</rdfs:label>
        <rdfs:label xml:lang="es">Servicio de hospedaje</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#LuggageStorage -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#LuggageStorage">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#MiscellaneousBusiness"/>
        <rdfs:comment xml:lang="es">Lugares reservados para guardar el equipaje de forma segura y para espacios de tiempo cortos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Reserved places to store luggage safely and for short periods of time.</rdfs:comment>
        <rdfs:label xml:lang="es">Consigna de equipaje</rdfs:label>
        <rdfs:label xml:lang="en">Lugagge storage</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#MassageCentre -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#MassageCentre">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HealthAndWellnessFacility"/>
        <rdfs:comment xml:lang="en">Business that provides relaxation, health and body well-being services through therapeutic and anti-stress massages.</rdfs:comment>
        <rdfs:comment xml:lang="es">Negocio que brinda los servicios de relax, salud y bienestar corporal por medio de masajes terapéuticos y anti estrés.</rdfs:comment>
        <rdfs:label xml:lang="es">Centro de masajes</rdfs:label>
        <rdfs:label xml:lang="en">Massage centre</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#MedicalBusiness -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#MedicalBusiness">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LocalBusiness"/>
        <rdfs:comment xml:lang="es">Atención y cuidado de la salud proporcionados por profesionales de la salud para mantener, promover y restablecer la salud de las personas, prevenir enfermedades y lesiones, y brindar diagnóstico, tratamiento y seguimiento médico.</rdfs:comment>
        <rdfs:comment xml:lang="en">Health care and care provided by health professionals to maintain, promote and restore people&apos;s health, prevent illness and injury, and provide diagnosis, treatment and medical follow-up.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical business</rdfs:label>
        <rdfs:label xml:lang="es">Negocio médico</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Minaret -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Minaret">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">A tower of a mosque from which the muezzin calls Muslims to prayer.</rdfs:comment>
        <rdfs:comment xml:lang="es">Torre de las mezquitas desde cuya altura convoca el almuédano a los musulmanes en las horas de oración.</rdfs:comment>
        <rdfs:label xml:lang="en">Minaret</rdfs:label>
        <rdfs:label xml:lang="es">Minarete</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#MiscellaneousBusiness -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#MiscellaneousBusiness">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LocalBusiness"/>
        <rdfs:comment xml:lang="es">Espacios físicos donde se ofrecen una variedad de servicios para satisfacer las necesidades de los clientes.</rdfs:comment>
        <rdfs:comment xml:lang="en">Physical spaces where a variety of services are offered to satisfy customer needs.</rdfs:comment>
        <rdfs:label xml:lang="en">Miscellaneous business</rdfs:label>
        <rdfs:label xml:lang="es">Negocios varios</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Monastery -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Monastery">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">A residence, typically located outside urban areas, where monks live together in community</rdfs:comment>
        <rdfs:comment xml:lang="es">Casa, ordinariamente fuera de poblado, donde viven monjes en comunidad.</rdfs:comment>
        <rdfs:label xml:lang="es">Monasterio</rdfs:label>
        <rdfs:label xml:lang="en">Monastery</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Monument -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Monument">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">An architectural or sculptural structure, generally of large dimensions, erected to commemorate a person or a memorable event.</rdfs:comment>
        <rdfs:comment xml:lang="es">Construcción arquitectónica o escultórica, generalmente de grandes dimensiones, que se erige en recuerdo de una persona o hecho memorable.</rdfs:comment>
        <rdfs:label xml:lang="en">Monument</rdfs:label>
        <rdfs:label xml:lang="es">Monumento</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Mosque -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Mosque">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:comment xml:lang="en">A Muslim place of worship.</rdfs:comment>
        <rdfs:comment xml:lang="es">Templo musulmán.</rdfs:comment>
        <rdfs:label xml:lang="es">Mezquita</rdfs:label>
        <rdfs:label xml:lang="en">Mosque</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Motel -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Motel">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
        <rdfs:comment xml:lang="en">Modest type of tourist accommodation characterized by being located close to roads and offering accommodation and parking for short-term stays.</rdfs:comment>
        <rdfs:comment xml:lang="es">Tipo de alojamiento turístico modesto que se caracteriza por estar situado próximo a carreteras y ofrecer alojamiento y aparcamiento para estancias de corta duración.</rdfs:comment>
        <rdfs:label xml:lang="en">Motel</rdfs:label>
        <rdfs:label xml:lang="es">Motel</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Mountain -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Mountain">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#naturalResourceContains"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Gran elevación natural del terreno.</rdfs:comment>
        <rdfs:comment xml:lang="en">Great natural elevation of the land</rdfs:comment>
        <rdfs:label xml:lang="es">Montaña</rdfs:label>
        <rdfs:label xml:lang="en">Mountain</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#MovieTheater -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#MovieTheater">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:comment xml:lang="es">Establecimiento destinado a la proyección de películas cinematográficas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Establishment intended for the projection of cinematographic films.</rdfs:comment>
        <rdfs:label xml:lang="es">Cine</rdfs:label>
        <rdfs:label xml:lang="en">Movie theater</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Multimedia -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Multimedia">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#author"/>
                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismDestination"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#audio"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#secondaryImage"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#text"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#video"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#mainImage"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#logo"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#url"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A digital file containing audio, video, or image content.</rdfs:comment>
        <rdfs:comment xml:lang="es">Archivo digital que contiene audio, vídeo o imágenes.</rdfs:comment>
        <rdfs:label xml:lang="en">Multimedia</rdfs:label>
        <rdfs:label xml:lang="es">Multimedia</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#Museum -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#Museum">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#museumType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Institución legalmente reconocida como tal, abierta al público, que adquiere, conserva, investiga, difunde y expone el patrimonio material e inmaterial de la humanidad y su entorno con fines educativos, de estudio y de disfrute.</rdfs:comment>
        <rdfs:comment xml:lang="en">Institution legally recognized as such, open to the public, which acquires, conserves, researches, communicates and exhibits the tangible and intangible heritage of humanity and its environment for the purposes of education, study and enjoyment.</rdfs:comment>
        <rdfs:label xml:lang="es">Museo</rdfs:label>
        <rdfs:label xml:lang="en">Museum</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#MusicVenue -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#MusicVenue">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#EventAttendanceFacility"/>
        <rdfs:comment xml:lang="es">Local dedicado a interpretaciones de música en vivo</rdfs:comment>
        <rdfs:comment xml:lang="en">Venue dedicated to live music performances</rdfs:comment>
        <rdfs:label xml:lang="en">Music venue</rdfs:label>
        <rdfs:label xml:lang="es">Sala de conciertos</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#NaturalPark -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalPark">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#naturalResourceContains"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#PublicService"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Espacio natural legalmente protegido que, por su belleza o por la singularidad de su fauna y flora, posee valor ecológico y cultural.</rdfs:comment>
        <rdfs:comment xml:lang="en">Legally protected natural space that, due to its beauty or the uniqueness of its fauna and flora, has ecological and cultural value</rdfs:comment>
        <rdfs:label xml:lang="en">Natural park</rdfs:label>
        <rdfs:label xml:lang="es">Parque natural</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#NaturalResource -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalResource">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#Place"/>
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#hasAdditionalTourismResourceService"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#paymentMethod"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#touristType"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#travelUnit"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#additionalClassification"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#maximumAttendeeCapacity"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#publicAccess"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Lugar, paisaje o fenómeno de la naturaleza que posee un valor especial y atractivo para los turistas. Son apreciados por su belleza escénica, biodiversidad, características geológicas únicas o experiencias al aire libre que ofrecen a los visitantes.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place, landscape or natural phenomenon that has a special and attractive value for tourists. They are appreciated for their scenic beauty, biodiversity, unique geological features or outdoor experiences they offer to visitors.</rdfs:comment>
        <rdfs:label xml:lang="en">Natural resource</rdfs:label>
        <rdfs:label xml:lang="es">Recurso natural</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#NaturalViewPoint -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#NaturalViewPoint">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#NaturalResource"/>
        <rdfs:comment xml:lang="es">Lugar o punto elevado desde el cual puede contemplarse con facilidad un paisaje.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place or elevated point from which a landscape can be easily seen</rdfs:comment>
        <rdfs:label xml:lang="es">Mirador natural</rdfs:label>
        <rdfs:label xml:lang="en">Natural viewpoint</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#NightClub -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#NightClub">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#PartyAndEntertainmentFacility"/>
        <rdfs:comment xml:lang="en"> A late-night entertainment establishment for dancing and socializing, featuring recorded music (usually by a DJ), light shows, and a bar service.</rdfs:comment>
        <rdfs:comment xml:lang="es">Establecimiento de ocio nocturno diseñado para el baile y la socialización, caracterizado por contar con música (generalmente de un DJ), juegos de luces y servicio de bebidas.</rdfs:comment>
        <rdfs:label xml:lang="es">Discoteca</rdfs:label>
        <rdfs:label xml:lang="en">Night club</rdfs:label>
        <estur-annot:visibleResource rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</estur-annot:visibleResource>
    </owl:Class>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#OldTown -->

    <owl:Class rdf:about="https://ontologia.segittur.es/turismo/def/core#OldTown">
        <rdfs:subClassOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontologia.segittur.es/turismo/def/core#historicalOrCulturalResourceContains"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource"/>
                            <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrRelatedFacility"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es"> Área urbana que constituye el núcleo histórico de una localidad, caracterizada por edificaciones y espacios de valor histórico, cultural o arquitectónico, y considerada un recurso de interés turístico.</rdfs:comment>
        <rdfs:comment xml:lang="en">Urban area that constitutes the historical core of a locality, characterized by buildings and spaces of historical, cultural, or architectural value, and considered a tourism resource.</rdfs:comment>
        <rdfs:label xml:lang="es">Casco antiguo</rdfs:label>
        <rdfs:label xml:lang="en">Old town</rdfs:label>
