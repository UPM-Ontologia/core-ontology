        <rdfs:label xml:lang="es">tipo de estación</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#targetAudience -->

