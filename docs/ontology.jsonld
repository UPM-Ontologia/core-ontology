}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#TouristInformationOffice",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Instalación física donde se prestan servicios de información turística, ya sea in situ o en línea, con el objetivo de satisfacer y mejorar las expectativas de los turistas una vez que se encuentran en el destino."
  }, {
    "@language" : "en",
    "@value" : "Physical facility where tourist information services are provided either onsite or online with the aim of meeting and improving the tourists' expectations once they are at the destination."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Oficina de turismo"
  }, {
    "@language" : "en",
    "@value" : "Tourist information office"
  } ],
