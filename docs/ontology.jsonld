  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An area made up of individual stalls that offer products of various kinds with a predominance of fresh products: meat, fruits, vegetables, fish, etc."
  }, {
    "@language" : "es",
    "@value" : "Recinto formado por puestos individuales que ofrecen productos de diversa índole con predominancia de los productos frescos: carne, frutas, verduras, pescado, etc."
  } ],
