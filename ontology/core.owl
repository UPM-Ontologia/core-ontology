    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#priceSchedule">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#PriceSpecification"/>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#Schedule"/>
        <rdfs:comment xml:lang="es">Asocia una especificación del precio a una programación.</rdfs:comment>
        <rdfs:comment xml:lang="en">Association of a price specification with a schedule.</rdfs:comment>
        <rdfs:label xml:lang="en">price schedule</rdfs:label>
        <rdfs:label xml:lang="es">programación del precio</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">6</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>contact</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#refPointOfInterest -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#refPointOfInterest">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#ItineraryElement"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Event"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Place"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Lugar relevante o destacado que sirve como punto de localización, contextualización o atracción relacionada con la experiencia, servicio o ruta descrito.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relevant or notable place that serves as a point of location, context, or attraction related to the described experience, service, or route.</rdfs:comment>
        <rdfs:label xml:lang="es">punto de interés de referencia</rdfs:label>
        <rdfs:label xml:lang="en">reference point of interest</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Indica lugares relevantes o destacados que sirvan como punto de localización, contextualización o atracción relacionada con la experiencia, servicio o ruta descrito.</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Indicates relevant or outstanding places that serve as a point of location, context, or attraction related to the described experience, service, or route.</estur-annot:tooltip>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#relatedEvent -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#relatedEvent">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#Event"/>
        <rdfs:comment xml:lang="en">Event that is related to a tourism service and is connected to its execution, content, or purpose.</rdfs:comment>
        <rdfs:comment xml:lang="es">Evento que está vinculado a un servicio turístico y guarda relación con su realización, contenido o propósito.</rdfs:comment>
        <rdfs:label xml:lang="es">evento relacionado</rdfs:label>
        <rdfs:label xml:lang="en">related event</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#relatedTo -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#relatedTo">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Event"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Place"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismOrganisation"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismEntity"/>
        <rdfs:comment xml:lang="es">Asociación genérica de lugares, eventos, organizaciones y servicios turísticos con otras entidades turísticas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Generic association of places, events, organisations and tourism services with other tourism entities.</rdfs:comment>
        <rdfs:label xml:lang="es">relacionado con</rdfs:label>
        <rdfs:label xml:lang="en">related to</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">7</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>acknowledgement</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


