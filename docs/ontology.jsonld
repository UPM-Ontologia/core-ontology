  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#Winery",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A complex of facilities dedicated to the production, ageing, and marketing of wine. In many cases, wineries feature complementary facilities for tourism activities, such as tasting rooms, retail shops, and event venues."
  }, {
    "@language" : "es",
    "@value" : "Conjunto de instalaciones donde se elabora, cría y comercializa el vino. En ocasiones, las bodegas cuentan con instalaciones complementarias destinadas a la actividad turística (espacios de degustación, tienda, espacios para la realización de eventos, etc.)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Bodega"
  }, {
    "@language" : "en",
    "@value" : "Winery"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#AgrotourismFacility"
  }, {
    "@id" : "_:genid1036"
  } ],
  "https://ontologia.segittur.es/turismo/def/annot#visibleResource" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#WinterSportsResort",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A tourist center dedicated to skiing and other snow and mountain sports, comprising a coordinated system of mechanical ski lifts, slopes, and complementary facilities."
  }, {
    "@language" : "es",
    "@value" : "Centro turístico dedicado a la práctica del esquí y demás deportes de nieve y montaña, que forma un conjunto coordinado de medios de remonte mecánicos, pistas e instalaciones complementarias."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Estación de deportes de invierno"
  }, {
    "@language" : "en",
    "@value" : "Winter sports resort"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#SportFacility"
  } ],
  "https://ontologia.segittur.es/turismo/def/annot#visibleResource" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#YatchingHarbour",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Instalación de amarre que ofrece refugio contra las inclemencias meteorológicas y proporciona un embarcadero y las instalaciones terrestres y acuáticas adecuadas para las embarcaciones y sus tripulaciones."
  }, {
    "@language" : "en",
    "@value" : "Mooring facility giving shelter against bad weather conditions and providing a landing stage and the appropriate land and water based facilities for craft and their crew"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Puerto deportivo"
  }, {
    "@language" : "en",
    "@value" : "Yachting harbour"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#SportFacility"
  } ],
  "https://ontologia.segittur.es/turismo/def/annot#visibleResource" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#YogaCentre",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A dedicated space for the practice and teaching of physical, mental, and spiritual disciplines aimed at holistic wellness and personal balance."
  }, {
    "@language" : "es",
    "@value" : "Espacio dedicado a la práctica y enseñanza de disciplinas físicas, mentales y espirituales orientadas al bienestar integral y el equilibrio personal."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Centro de yoga"
  }, {
    "@language" : "en",
    "@value" : "Yoga centre"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#HealthAndWellnessFacility"
  } ],
  "https://ontologia.segittur.es/turismo/def/annot#visibleResource" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#Zoo",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A facility dedicated to the conservation, care, and occasionally the breeding of diverse animal species for public exhibition and scientific study."
  }, {
    "@language" : "es",
    "@value" : "Lugar en que se conservan, cuidan y en ocasiones se crían diversas especies animales para que sean contempladas por el público y para su estudio."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Zoo"
  }, {
    "@language" : "es",
    "@value" : "Zoológico"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"
  } ],
