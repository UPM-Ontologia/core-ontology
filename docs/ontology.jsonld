  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Establecimiento dedicado a la prestación de tratamientos de spa o paquetes de tratamientos de bienestar en un espacio apartado con un ambiente relajante, para la promoción de la salud y el bienestar."
  }, {
    "@language" : "en",
    "@value" : "Establishment dedicated to the provision of wellness spa treatments or treatment packages within a secluded space with a relaxing ambience, for the promotion of health and well-being."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Spa"
  }, {
    "@language" : "en",
    "@value" : "Wellness spa"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#HealthAndWellnessFacility"
