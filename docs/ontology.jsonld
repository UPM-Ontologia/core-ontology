    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-LabelType.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/LakeService",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Complementary or additional services that may be offered at a lake alongside its main service or activity in order to enhance or improve the user experience."
  }, {
    "@language" : "es",
    "@value" : "Servicios complementarios o adicionales que pueden ofrecerse en un lago junto a su servicio o actividad principal para ampliar o mejorar la experiencia del usuario."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-LakeService.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/LocomotionMode",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Formas particulares de emprender una ruta o cualquier tipo de actividad organizada."
  }, {
    "@language" : "en",
    "@value" : "Specific modes used to undertake a route or any type of organized activity."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-LocomotionMode.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/MenuOptions",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Alternativas o elecciones que están disponibles en un establecimiento de restauración en relación a los tipos de alimentos que se ofrecen. Estas opciones pueden adaptarse a las preferencias y necesidades dietéticas de los comensales, incluyendo alergias alimentarias, restricciones dietéticas, preferencias vegetarianas o veganas, entre otros."
  }, {
    "@language" : "en",
    "@value" : "Options or choices available in a food establishment regarding the types of food offered. These options may be adapted to diners’ preferences and dietary needs, including food allergies, dietary restrictions, vegetarian or vegan preferences, among others."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-MenuOptions.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/MonthOfTheYear",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "One of the twelve named periods (January through December) that constitute a standard yearly cycle, used to define recurring schedules."
  }, {
    "@language" : "es",
    "@value" : "Uno de los doce periodos nombrados (de enero a diciembre) que constituyen un ciclo anual estándar, utilizado para definir programaciones recurrentes."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-MonthOfTheYear.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/MuseumType",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Categories or classifications used to differentiate museums according to their theme, focus, or collections. Each museum type focuses on a specific field of art, history, science, or other areas of interest."
  }, {
    "@language" : "es",
    "@value" : "Categorías o clasificaciones que se utilizan para diferenciar los museos según su temática, enfoque o colecciones. Cada tipo de museo se centra en un ámbito específico del arte, la historia, la ciencia u otros campos de interés."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-MuseumType.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/PaymentMethod",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Method used by the customer to pay for the service."
  }, {
    "@language" : "es",
    "@value" : "Método utilizado por el cliente para pagar el servicio."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-PaymentMethod.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/PriceClass",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A range of prices at which products or services are offered, allowing them to be classified into different segments within a given market or industry."
  }, {
    "@language" : "es",
    "@value" : "Rango de precios en el que se ofrecen productos o servicios que permiten clasificarlos en diferentes segmentos dentro de un determinado mercado o industria."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-PriceClass.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/RiverService",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Complementary or additional services that may be offered at a river alongside its main service or activity in order to enhance or improve the user experience."
  }, {
    "@language" : "es",
    "@value" : "Servicios complementarios o adicionales que pueden ofrecerse en un río junto a su servicio o actividad principal para ampliar o mejorar la experiencia del usuario."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-RiverService.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/SocialMediaPlatform",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A selection of leading digital platforms designed for social interaction."
  }, {
    "@language" : "es",
    "@value" : "Selección de plataformas digitales de referencia diseñadas para la interacción social."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-SocialMediaPlatform.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/Species",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Biological species of pets whose entry is permitted."
  }, {
    "@language" : "es",
    "@value" : "Especies biológicas de mascotas cuyo ingreso es permitido."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Especie"
  }, {
    "@language" : "en",
    "@value" : "Species"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-Species.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/SportsCentrePremise",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Espacios, equipamientos y estructuras físicas que están disponibles para la práctica de diferentes actividades deportivas y recreativas en un polideportivo."
  }, {
    "@language" : "en",
    "@value" : "Spaces, equipment and physical structures that are available for practising different sports and recreational activities in a sports centre."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-SportsCentrePremise.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/StationType",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "En el contexto del transporte público, el tipo de estación se refiere al medio de transporte público que opera en dicha estación."
  }, {
    "@language" : "en",
    "@value" : "In the context of public transport, the station type refers to the mode of public transport operating at that station."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-StationType.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/Tag",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Conjunto de etiquetas utilizadas para clasificar y describir de forma transversal características, temáticas, atributos o enfoques experienciales asociados a un elemento."
  }, {
    "@language" : "en",
    "@value" : "Set of tags used to classify and describe, in a transversal manner, characteristics, themes, attributes or experiential approaches associated with an item."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Etiqueta"
  }, {
    "@language" : "en",
    "@value" : "Tag"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-Tag.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/TargetAudience",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A specific group of people targeted by a price or special offer, based on their age."
  }, {
    "@language" : "es",
    "@value" : "Grupo específico de personas al que va dirigido un precio o una propuesta especial, según la edad."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Público objetivo"
  }, {
    "@language" : "en",
    "@value" : "Target audience"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-TargetAudience.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/TimeOfTheYear",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A seasonal period during which a destination experience, agrotourism experience, or route is recommended, or during which it has greater relevance, intensity, or appeal."
  }, {
    "@language" : "es",
    "@value" : "Periodo estacional en el que se recomienda realizar la experiencia en destino, experiencia agroturística o ruta, o en el que esta tiene mayor relevancia, intensidad o atractivo."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Temporada del año"
  }, {
    "@language" : "en",
    "@value" : "Time of the year"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-TimeOfTheYear.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/TourSpecialty",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Enfoque particular o características únicas que distinguen al servicio de visita guiada."
  }, {
    "@language" : "en",
    "@value" : "Particular focus or unique features that distinguish the tour service."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-TourSpecialty.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/TouristType",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Clasificación para eventos, propuestas especiales, destinos y organizaciones turísticas, instalaciones turísticas o vinculadas, recursos y servicios turísticos en función de sus turistas objetivo con relación a sus motivaciones principales de viaje."
  }, {
    "@language" : "en",
    "@value" : "Classification for events, special offers, destinations and tourism organisations, tourism or related facilities, tourism resources and services based on their target tourists in relation to their main travel motivations."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-TouristType.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/TrailType",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Clasificación de las vías de una ruta, organizada o no, en función del tipo de itinerario y el entorno en el que se emplaza."
  }, {
    "@language" : "en",
    "@value" : "Classification of the paths used along a route, whether organized or not, based on the type of itinerary and the environment in which they are located."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-TrailType.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/TravelContainerType",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Tipos de habitáculos portátiles utilizados para transportar o albergar a mascotas."
  }, {
    "@language" : "en",
    "@value" : "Types of portable enclosures used to transport or house pets."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Tipo de contenedor de viaje"
  }, {
    "@language" : "en",
    "@value" : "Travel container type"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-TravelContainerType.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/TravelUnit",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Clasificación de eventos, propuestas especiales, destinos y organizaciones turísticas, instalaciones turísticas o relacionadas, recursos y servicios turísticos en función de sus turistas objetivo con relación a la composición del grupo con el que viajan y comparten los gastos asociados."
  }, {
    "@language" : "en",
    "@value" : "Classification for events, special offers, tourism destinations and organisations, tourism or related facilities, tourism resources and services based on their target tourists in relation to the composition of the party with whom they travel and share the associated expenses."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-TravelUnit.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/VehicleExperienceType",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A list of vehicle types through which specific experiences can be carried out."
  }, {
    "@language" : "es",
    "@value" : "Listado de vehículos con los cuales se pueden realizar determinadas experiencias."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Tipo de experiencia en vehículo"
  }, {
    "@language" : "en",
    "@value" : "Vehicle experience type"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-VehicleExperienceType.ttl"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/kos/VehicleType",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2008/05/skos#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Categories or classifications of vehicles based on their design, size, purpose, and characteristics."
  }, {
    "@language" : "es",
    "@value" : "Categorías o clasificaciones de vehículos según su diseño, tamaño, propósito y características."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/kos/skos-VehicleType.ttl"
  } ]
} ]