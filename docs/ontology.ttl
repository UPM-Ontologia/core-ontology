                        ] ;
             rdfs:label "estilo de jardín"@es ,
                        "garden style"@en .


###  https://ontologia.segittur.es/turismo/def/core#gender
:gender rdf:type owl:ObjectProperty ;
        rdfs:domain :Person ;
        rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                            owl:hasValue <https://ontologia.segittur.es/turismo/kos/Gender>
                                          ]
                                        ) ;
                     rdf:type owl:Class
                   ] ;
        rdfs:label "gender"@en ,
                   "género"@es .


###  https://ontologia.segittur.es/turismo/def/core#group
:group rdf:type owl:ObjectProperty ;
       rdfs:domain :TravelUnit ;
       rdfs:range :Group ;
       rdfs:label "group"@en ,
                  "grupo"@es .


###  https://ontologia.segittur.es/turismo/def/core#hasAcknowledgement
:hasAcknowledgement rdf:type owl:ObjectProperty ;
                    rdfs:domain [ rdf:type owl:Class ;
                                  owl:unionOf ( :Organisation
                                                :TourismResource
                                                :TourismService
                                              )
                                ] ;
                    rdfs:range :Acknowledgement ;
                    rdfs:label "has Acknowledgement"@en ,
                               "tiene reconocimiento"@es .


###  https://ontologia.segittur.es/turismo/def/core#hasAdditionalInformation
:hasAdditionalInformation rdf:type owl:ObjectProperty ;
                          rdfs:domain [ rdf:type owl:Class ;
                                        owl:unionOf ( :Organisation
                                                      :TourismResource
                                                      :TourismService
                                                    )
                                      ] ;
                          rdfs:range :AdditionalInformation ;
                          rdfs:label "tiene información adicional"@es ,
                                     "hasAdditionalInformation" .


###  https://ontologia.segittur.es/turismo/def/core#hasBookingChannel
:hasBookingChannel rdf:type owl:ObjectProperty ;
                   rdfs:domain [ rdf:type owl:Class ;
                                 owl:unionOf ( :Organisation
                                               :TourismResource
                                               :TourismService
                                             )
                               ] ;
                   rdfs:range :BookingChannel ;
                   rdfs:label "has booking channel"@en ,
                              "tiene canal de reservas"@es .


