    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme"/>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#accommodationRateType -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#accommodationRateType">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#LodgingService"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/AccommodationRateType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Rates applicable specifically to accommodation establishments and lodging services.</rdfs:comment>
        <rdfs:comment xml:lang="es">Tarifas aplicables específicamente a establecimientos alojativos y servicios de hospedaje.</rdfs:comment>
        <rdfs:label xml:lang="en">accommodation rate type</rdfs:label>
        <rdfs:label xml:lang="es">tipo de tarifa de alojamiento</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#accommodationRating -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#accommodationRating">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/AccommodationRatingSystem"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Grading or classification scheme system providing an assessment of the facilities, services or both provided by tourist accommodation. Typically within five categories, often indicated by one to five symbols.</rdfs:comment>
        <rdfs:comment xml:lang="es">Sistema de clasificación o categorización que evalúa las instalaciones, los servicios o ambos aspectos de los alojamientos turísticos. Normalmente se divide en cinco categorías, que suelen indicarse con uno a cinco símbolos.</rdfs:comment>
        <rdfs:label xml:lang="en">accommodation rating</rdfs:label>
        <rdfs:label xml:lang="es">clasificación del alojamiento</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#accommodationUnitCategory -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#accommodationUnitCategory">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AccommodationEstablishment"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#LodgingService"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/AccommodationUnitCategory"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Tipo de unidad de alojamiento que se ofrece a los huéspedes y en la que se les proporcionan, como mínimo, camas y servicios de higiene.</rdfs:comment>
        <rdfs:comment xml:lang="en">Type of accommodation unit offered to guests, in which they are provided with, at least, sleeping and sanitary facilities.</rdfs:comment>
        <rdfs:label xml:lang="en">accommodation unit category</rdfs:label>
        <rdfs:label xml:lang="es">tipo de unidad de alojamiento</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#adventureActivityType -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#adventureActivityType">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AdventureActivity"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#AdventureActivityCentre"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/AdventureActivityType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Actividades físicas, deportivas o recreativas ofrecidas por el centro.</rdfs:comment>
        <rdfs:comment xml:lang="en">Physical, sports, or recreational activities offered by the facility.</rdfs:comment>
        <rdfs:label xml:lang="en">adventure activity type</rdfs:label>
        <rdfs:label xml:lang="es">tipo de actividad de aventura</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#adversityType -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#adversityType">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#RulesAndTips"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/AdversityType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">A situation or event characterized by significant misfortune, lasting over a period of time and involving a varying degree of severity.</rdfs:comment>
        <rdfs:comment xml:lang="es">Situación o suceso con un fuerte componente de infortunio, una cierta duración en el tiempo y con un mayor o menor grado de gravedad.</rdfs:comment>
        <rdfs:label xml:lang="en">adversity type</rdfs:label>
        <rdfs:label xml:lang="es">tipo de adversidad</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#agrotourismExperienceRelatedProduct -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#agrotourismExperienceRelatedProduct">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#AgrotourismExperience"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/AgrotourismExperienceRelatedProduct"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">An agri-food product linked to an agrotourism experience.</rdfs:comment>
        <rdfs:comment xml:lang="es">Producto agroalimentario vinculado con una experiencia agroturística.</rdfs:comment>
        <rdfs:label xml:lang="en">agrotourism experience related product</rdfs:label>
        <rdfs:label xml:lang="es">producto relacionado con experiencia agriturística</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#agrotourismExperienceType -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#agrotourismExperienceType">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#AgrotourismExperience"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/AgrotourismExperienceType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Naturaleza o temática de la experiencia agroturística ofrecida, en función de las actividades desarrolladas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Nature or theme of the agrotourism experience offered, based on the activities carried out. </rdfs:comment>
        <rdfs:label xml:lang="en">agrotourism experience type</rdfs:label>
        <rdfs:label xml:lang="es">tipo de experiencia agroturística</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#author -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#author">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Description"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Multimedia"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismDestination"/>
        <rdfs:comment xml:lang="es">Destino turístico responsable de generar el contenido multimedia de una entidad turística.</rdfs:comment>
        <rdfs:comment xml:lang="en">Tourism destination responsible for generating multimedia content for a tourism entity.</rdfs:comment>
        <rdfs:label xml:lang="en">author</rdfs:label>
        <rdfs:label xml:lang="es">autor</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#availableLanguage -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#availableLanguage">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Event"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismService"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://id.loc.gov/vocabulary/iso639-2"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Idioma o conjunto de idiomas en los que un artículo, contenido o recurso puede ser utilizado, presentado o comunicado, ya sea de forma hablada, escrita o mediante otros medios de expresión.</rdfs:comment>
        <rdfs:comment xml:lang="en">Language or set of languages in which an article, content, or resource can be used, presented, or communicated, whether in spoken, written, or other forms of expression.</rdfs:comment>
        <rdfs:label xml:lang="en">available language</rdfs:label>
        <rdfs:label xml:lang="es">idioma disponible</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#beachType -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#beachType">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Beach"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/BeachType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Diferentes categorías o clasificaciones que se utilizan para describir y diferenciar las playas según sus características físicas y ambientales.</rdfs:comment>
        <rdfs:comment xml:lang="en">Different categories or classifications used to describe and distinguish beaches according to their physical and environmental characteristics.</rdfs:comment>
        <rdfs:label xml:lang="en">beach type</rdfs:label>
        <rdfs:label xml:lang="es">tipo de playa</rdfs:label>
        <estur-annot:presentationOrderCategory>other</estur-annot:presentationOrderCategory>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#byDay -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#byDay">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Schedule"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/DayOfTheWeek"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Indica los días específicos de la semana en los que la programación de un evento, servicio o propuesta especial se realiza de forma recurrente (por ejemplo, lunes y martes)</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates the specific days of the week on which the schedule for an event, service, or special offer takes place on a recurring basis (for example, Monday and Tuesday).</rdfs:comment>
        <rdfs:label xml:lang="en">by day</rdfs:label>
        <rdfs:label xml:lang="es">por día</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">10</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>contact</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Indica los días recurrentes de la programación. Por ejemplo, abierto los lunes y martes</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Indicates the recurring days of the schedule. For example, open on Mondays and Tuesdays.</estur-annot:tooltip>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#byMonth -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#byMonth">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Schedule"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/MonthOfTheYear"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Indica el mes o los meses específicos del calendario en los que la programación de un evento, servicio o propuesta especial se realiza de forma recurrente.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates the specific month or months of the calendar in which the scheduling of an event, service, or special offer takes place on a recurring basis.</rdfs:comment>
        <rdfs:label xml:lang="en">by month</rdfs:label>
        <rdfs:label xml:lang="es">por mes</rdfs:label>
        <estur-annot:orderInCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">11</estur-annot:orderInCategory>
        <estur-annot:presentationOrderCategory>contact</estur-annot:presentationOrderCategory>
        <estur-annot:tooltip xml:lang="es">Indica el/los mes(es) recurrente(s) del calendario de la programación</estur-annot:tooltip>
        <estur-annot:tooltip xml:lang="en">Indicates the recurring month(s) of the schedule</estur-annot:tooltip>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#certificationType -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#certificationType">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#Certification"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
