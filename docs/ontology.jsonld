    "@language" : "en",
    "@value" : "A facility intended for hosting fairs, exhibitions, and other temporary events open to the public, composed of large and modular spaces, indoor or outdoor, adapted for the exhibition and promotion of products and services."
  }, {
    "@language" : "es",
    "@value" : "Instalación destinada a la celebración de ferias, exposiciones y otros eventos temporales abiertos al público, formada por espacios amplios y modulares, cubiertos o al aire libre, adaptados para la exhibición y promoción de productos y servicios."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Fairground"
  }, {
    "@language" : "es",
    "@value" : "Recinto ferial"
