}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#routeNavigationOrientation",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Degree of difficulty in orientation, such as the presence of signs, well-marked trails, single-track trails or the presence of landmarks needed to complete the route."
  }, {
    "@language" : "es",
    "@value" : "Grado de dificultad en la orientación, como la presencia de señales, senderos bien señalizados, senderos de una sola vía o la presencia de puntos de referencia necesarios para completar la ruta."
  }, {
    "@language" : "en",
    "@value" : "Levels of grading of the technical and physical demands of routes, where 1 indicates least difficulty and 5 greatest difficulty."
  }, {
    "@language" : "es",
    "@value" : "Niveles de graduación de las exigencias técnicas y físicas de rutas, en los que 1 indica menor dificultad y 5 mayor dificultad."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#Route"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "orientación en el itinerario"
  }, {
    "@language" : "en",
    "@value" : "route navigation orientation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#int"
  } ],
  "https://ontologia.segittur.es/turismo/def/annot#presentationOrderCategory" : [ {
    "@value" : "other"
  } ],
  "https://ontologia.segittur.es/turismo/def/annot#tooltip" : [ {
    "@language" : "es",
    "@value" : "Asigna un valor entero del 1 al 5 para valorar la dificultad de orientación durante el itinerario de la ruta, siendo 1 muy bajo y 5 muy alto"
  }, {
    "@language" : "en",
    "@value" : "Assigns an integer value from 1 to 5 to assess the difficulty of navigation and orientation along the route itinerary, where 1 is very low and 5 is very high"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#saleEndDate",
