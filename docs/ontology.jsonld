    "@value" : "true"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#Terroir",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Areas of land where an indeterminate number of vineyards are located which, due to their location and microclimatic conditions, geological composition or terrain, share similar conditions and therefore produce grapes with distinctive characteristics that give rise to very unique wines, generally known as vinos de pago"
  }, {
    "@language" : "es",
    "@value" : "Extensiones de terreno en las que se localizan un número indeterminado de viñas que -por razón de su situación y condiciones micro-climáticas, por su composición geológica o por su orografía- comparten condiciones similares y producen por ello uvas con características diferenciadas que dan lugar a unos vinos muy singulares, generalmente conocidos como vinos de pago"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Pago"
  }, {
    "@language" : "en",
    "@value" : "Terroir"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#AgrotourismFacility"
  }, {
    "@id" : "_:genid908"
  } ],
  "https://ontologia.segittur.es/turismo/def/annot#visibleResource" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#Thalasso",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Instalación especializada en el uso terapéutico del agua de mar y del entorno marino con fines de bienestar y salud."
  }, {
    "@language" : "en",
    "@value" : "TA facility specialized in the therapeutic use of seawater and the marine environment for wellbeing and health purposes."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
