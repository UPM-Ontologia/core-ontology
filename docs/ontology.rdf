    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme"/>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#accessType -->


    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#accessType">
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#TourismResource"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://ontologia.segittur.es/turismo/kos/AccessType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:label xml:lang="en">access type</rdfs:label>
        <rdfs:label xml:lang="es">tipo de acceso</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://ontologia.segittur.es/turismo/def/core#accommodationCapacity -->


    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#accommodationCapacity">
