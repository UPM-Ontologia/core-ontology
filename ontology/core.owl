                <owl:allValuesFrom rdf:resource="https://ontologia.segittur.es/turismo/def/core#DailyOpeningHours"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
