    <!-- https://ontologia.segittur.es/turismo/def/core#OnlineTravelAgencyOffersServiceOrTicket -->

    <owl:ObjectProperty rdf:about="https://ontologia.segittur.es/turismo/def/core#OnlineTravelAgencyOffersServiceOrTicket">
        <rdfs:subPropertyOf rdf:resource="https://ontologia.segittur.es/turismo/def/core#offersServiceOrTicket"/>
        <rdfs:domain rdf:resource="https://ontologia.segittur.es/turismo/def/core#OTA"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Event"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Facility"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#SingularExperience"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Tour"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#TourismResource"/>
                    <rdf:Description rdf:about="https://ontologia.segittur.es/turismo/def/core#Vehicle"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:label xml:lang="es">agencia de viajes online ofrece servicio o ticket</rdfs:label>
        <rdfs:label xml:lang="en">online travel agency offers service or ticket</rdfs:label>
    </owl:ObjectProperty>
    


