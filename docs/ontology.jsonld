}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#severityOfTheEnvironment",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Dangers and other difficulties arising from the natural environment, such as temperature, rainfall, risk of falls, ease of rescue or self-rescue, which can be encountered along the way."
  }, {
    "@language" : "en",
    "@value" : "Levels of grading of the technical and physical demands of routes, where 1 indicates least difficulty and 5 greatest difficulty."
  }, {
    "@language" : "es",
    "@value" : "Niveles de graduación de las exigencias técnicas y físicas de rutas, en los que 1 indica menor dificultad y 5 mayor dificultad."
  }, {
    "@language" : "es",
    "@value" : "Peligros y otras dificultades derivadas del entorno natural, como la temperatura, las precipitaciones, el riesgo de caídas, la facilidad de rescate o autorrescate, que pueden encontrarse a lo largo del recorrido."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#Route"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Severidad del medio natural"
  }, {
    "@language" : "en",
    "@value" : "Severity of the environment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#int"
  } ],
  "https://ontologia.segittur.es/turismo/def/annot#presentationOrderCategory" : [ {
    "@value" : "other"
  } ],
  "https://ontologia.segittur.es/turismo/def/annot#tooltip" : [ {
    "@language" : "es",
    "@value" : "Asigna un valor entero del 1 al 5 para valorar la severidad del medio natural de la ruta, siendo 1 muy bajo y 5 muy alto."
  }, {
    "@language" : "en",
    "@value" : "Assigns an integer value from 1 to 5 to assess the severity of the natural environment of the route, where 1 is very low and 5 is very high"
  } ]
}, {
