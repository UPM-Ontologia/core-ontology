    "@language" : "es",
    "@value" : "Concepto general que agrupa los elementos públicos y privados con capacidad de intervenir en el ciclo de viaje del turista."
  }, {
    "@value" : "General concept that groups public and private elements capable of intervening in the tourist's travel cycle."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Entidad turística"
  }, {
    "@language" : "en",
    "@value" : "Tourism entity"
  } ],
