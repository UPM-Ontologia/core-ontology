:eventSession rdf:type owl:ObjectProperty ;
              rdfs:domain :Event ;
              rdfs:range :EventSession ;
              rdfs:label "event session"@en ,
                         "sesión del evento"@es .


###  https://ontologia.segittur.es/turismo/def/core#eventType
:eventType rdf:type owl:ObjectProperty ;
